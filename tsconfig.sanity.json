{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "isolatedModules": true,
    "jsx": "preserve",
    "noEmit": true
  },
  "include": [
    "sanity-types.d.ts",
    "sanity.config.ts",
    "sanity.cli.ts",
    "src/**/deskStructure.ts",
    "src/**/structure.ts",
    "src/**/schemas/**/*.ts",
    "src/**/schemas/**/*.tsx",
    "src/**/sanity/**/*.ts",
    "src/**/sanity/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
