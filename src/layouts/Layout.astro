---
interface Props {
	title?: string;
	description?: string;
    canonicalPath?: string;
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    twitterCardType?: string;
    noindex?: boolean;
    type?: string;
    jsonLd?: any[];
}

const {
    title,
    description,
    canonicalPath,
    ogTitle,
    ogDescription,
    ogImage,
    twitterCardType,
    noindex = false,
    type = 'website',
    jsonLd = []
} = Astro.props;
import { getSiteSettings } from '../sanity/queries';
import { buildCanonicalUrl, formatTitle, formatDescription } from '../lib/seo';
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import TawkChat from '../components/integrations/TawkChat.astro';
import PersistentAIBottomBar from '../components/ai/PersistentAIBottomBar.astro';
import RightSalesWidget from '../components/sales/RightSalesWidget.astro';

const siteSettings = await getSiteSettings();
const site = siteSettings || { title: 'TheEduAssist', name: 'TheEduAssist' };

const formattedTitle = formatTitle(title);
const formattedDescription = formatDescription(description);
const canonicalUrl = canonicalPath ? buildCanonicalUrl(canonicalPath) : buildCanonicalUrl(Astro.url.pathname);
const finalOgTitle = ogTitle || formattedTitle;
const finalOgDescription = ogDescription || formattedDescription;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://www.theeduassist.com';
const isMainDomain = siteUrl === 'https://www.theeduassist.com';
// Only noindex if explicitly requested, or if a site URL is set and it's NOT the main domain (e.g. preview)
// If PUBLIC_SITE_URL is missing or empty, it defaults to indexable via the fallback.
const shouldNoIndex = noindex === true || (import.meta.env.PUBLIC_SITE_URL && import.meta.env.PUBLIC_SITE_URL.trim() !== '' && !isMainDomain);
---

<!doctype html>
<html lang="en">
	<head>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png">
<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="manifest" href="/site.webmanifest">
<meta name="theme-color" content="#27496D">
		<meta charset="UTF-8" />
		<meta name="description" content={formattedDescription} />
		<meta name="google-site-verification" content="8bSmU6Y72pExQFv2ecIfZt5Rs8KO6U6ADLJJXI37_0Y" />

		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-39NHQ9YM9P"></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  gtag('config', 'G-39NHQ9YM9P');
		</script>
		<meta name="viewport" content="width=device-width" />
										<meta name="generator" content={Astro.generator} />
		<title>{formattedTitle}</title>
        <link rel="canonical" href={canonicalUrl} />
        <meta property="og:title" content={finalOgTitle} />
        <meta property="og:description" content={finalOgDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:type" content={type} />
        <meta property="og:site_name" content={site.name} />
        <meta property="og:image" content={ogImage || `${siteUrl}/og/theeduassist-og-image.png`} />

        <meta name="twitter:card" content={twitterCardType || 'summary_large_image'} />
        <meta name="twitter:title" content={finalOgTitle} />
        <meta name="twitter:description" content={finalOgDescription} />
        <meta name="twitter:image" content={ogImage || `${siteUrl}/og/theeduassist-og-image.png`} />

        {shouldNoIndex && <meta name="robots" content="noindex, nofollow" />}
        {!shouldNoIndex && <meta name="robots" content="index, follow" />}

        {jsonLd && jsonLd.length > 0 && jsonLd.map((schema) => (
            <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        ))}
	</head>
		<body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-screen flex flex-col">
        <Header />
        <main class="flex-grow">
		    <slot />
        </main>
        <Footer />
        <RightSalesWidget />
        <TawkChat />
        <PersistentAIBottomBar />
	</body>
</html>
