---
interface Model {
  title: string;
  description: string;
  features: string[];
}

interface Props {
  title?: string;
  description?: string;
  models: Model[];
}

const {
  title = "Support Models",
  description = "Flexible ways to partner with us.",
  models
} = Astro.props;
---

<section class="py-16 bg-white border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">{title}</h2>
      <p class="text-lg text-slate-600">{description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {models.map((model) => (
        <div class="bg-slate-50 rounded-xl border border-slate-200 p-8 shadow-sm flex flex-col">
          <h3 class="text-xl font-bold text-brand-navy mb-3">{model.title}</h3>
          <p class="text-slate-600 mb-6">{model.description}</p>
          <ul class="space-y-3 mt-auto">
            {model.features.map(feature => (
              <li class="flex items-start text-sm text-slate-700">
                <span class="text-brand-accent mr-2 font-bold">•</span>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
