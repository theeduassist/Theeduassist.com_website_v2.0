---
import { FileText } from "lucide-react";

interface Props {
  title?: string;
  description?: string;
  inputs: string[];
}

const {
  title = "What You Provide",
  description = "To get started, we typically need:",
  inputs
} = Astro.props;
---

<section class="py-16 bg-white border-b border-slate-200">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center gap-8 bg-brand-navy text-white p-8 md:p-12 rounded-2xl">
      <div class="md:w-1/3 text-center md:text-left">
        <FileText class="w-16 h-16 text-brand-accent mx-auto md:mx-0 mb-4" />
        <h2 class="text-2xl font-bold mb-2">{title}</h2>
        <p class="text-slate-300">{description}</p>
      </div>
      <div class="md:w-2/3 w-full">
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {inputs.map(input => (
            <li class="flex items-start gap-3 bg-white/10 p-4 rounded-lg">
              <span class="w-2 h-2 mt-2 bg-brand-accent rounded-full shrink-0"></span>
              <span class="text-slate-100">{input}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
