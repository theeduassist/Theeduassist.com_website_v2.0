---
import { AlertCircle } from "lucide-react";

interface Props {
  title?: string;
  description?: string;
  limitations: string[];
}

const {
  title = "Service Boundaries & Limitations",
  description = "To ensure clear expectations and successful outcomes, please note the following:",
  limitations
} = Astro.props;
---

<section class="py-12 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-amber-50/50 border border-amber-200/60 rounded-xl p-8">
      <div class="flex items-start gap-4 mb-6">
        <AlertCircle class="w-6 h-6 text-amber-600 shrink-0 mt-1" />
        <div>
          <h2 class="text-xl font-bold text-slate-800 mb-2">{title}</h2>
          <p class="text-slate-600">{description}</p>
        </div>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 pl-10 text-slate-700 text-sm">
        {limitations.map(limitation => (
          <li class="flex items-start">
            <span class="text-amber-500 mr-2 mt-0.5">•</span>
            <span>{limitation}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
