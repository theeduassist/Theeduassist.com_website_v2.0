---
import { getLiveServices } from "../../data/serviceArchitecture";
import { ArrowRight, MonitorPlay, RefreshCw, Database, Cpu, LifeBuoy } from "lucide-react";

// Map string icons to components
const iconMap: Record<string, any> = {
  "MonitorPlay": MonitorPlay,
  "RefreshCw": RefreshCw,
  "Database": Database,
  "Cpu": Cpu,
  "LifeBuoy": LifeBuoy
};

const liveServices = getLiveServices().filter(s => s.hubVisibility);
---

<section class="py-24 bg-white" id="all-services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Verified Live Services</h2>
      <p class="text-lg text-slate-600">
        Explore our currently available e-learning and technology services.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {liveServices.map(service => {
        const IconComponent = iconMap[service.icon] || MonitorPlay;

        return (
          <div class="flex flex-col h-full bg-white border border-slate-200 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 group hover:-translate-y-1">
            <div class="p-8 flex-grow">
              <div class="w-14 h-14 rounded-xl bg-brand-softBg text-brand-primary flex items-center justify-center mb-6 group-hover:bg-brand-primary group-hover:text-white transition-colors duration-300">
                <IconComponent class="w-7 h-7" />
              </div>

              <h3 class="text-xl font-bold text-brand-navy mb-3">
                {service.title}
              </h3>

              <p class="text-slate-600 mb-6 leading-relaxed text-sm">
                {service.shortDescription}
              </p>

              <div class="space-y-2 mb-8">
                <div class="flex gap-2 items-start text-sm">
                  <span class="font-bold text-brand-navy shrink-0">Problem:</span>
                  <span class="text-slate-600">{service.problemSolved}</span>
                </div>
                <div class="flex gap-2 items-start text-sm">
                  <span class="font-bold text-brand-navy shrink-0">For:</span>
                  <span class="text-slate-600">{service.audience.join(" & ")}</span>
                </div>
              </div>
            </div>

            <div class="p-6 border-t border-slate-100 bg-slate-50 mt-auto">
              <a
                href={service.slug}
                class="flex items-center justify-between text-brand-primary font-bold hover:text-brand-accent transition-colors focus-ring"
              >
                <span>View Service Details</span>
                <ArrowRight class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" />
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
