---
import { Check, User, Users, Briefcase } from "lucide-react";

interface Responsibility {
  task: string;
  owner: "client" | "theeduassist" | "shared";
}

interface Props {
  title?: string;
  description?: string;
  responsibilities: Responsibility[];
}

const {
  title = "Responsibility Model",
  description = "Clear boundaries and shared goals.",
  responsibilities
} = Astro.props;

const clientTasks = responsibilities.filter(r => r.owner === "client");
const agencyTasks = responsibilities.filter(r => r.owner === "theeduassist");
const sharedTasks = responsibilities.filter(r => r.owner === "shared");
---

<section class="py-16 bg-slate-50 border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">{title}</h2>
      <p class="text-lg text-slate-600">{description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Client Owns -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="bg-slate-100 p-4 border-b border-slate-200 flex items-center gap-3">
          <User class="w-5 h-5 text-slate-600" />
          <h3 class="font-bold text-slate-800">You Own</h3>
        </div>
        <div class="p-6">
          <ul class="space-y-4">
            {clientTasks.map(t => (
               <li class="flex items-start text-slate-700">
                 <Check class="w-5 h-5 text-slate-400 mr-3 shrink-0 mt-0.5" />
                 <span>{t.task}</span>
               </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Shared -->
      <div class="bg-white rounded-xl border-2 border-brand-primary/20 shadow-sm overflow-hidden relative transform md:-translate-y-2">
        <div class="absolute top-0 left-0 right-0 h-1 bg-brand-primary"></div>
        <div class="bg-brand-softBg p-4 border-b border-brand-border/50 flex items-center gap-3">
          <Users class="w-5 h-5 text-brand-primary" />
          <h3 class="font-bold text-brand-navy">Shared Responsibilities</h3>
        </div>
        <div class="p-6">
          <ul class="space-y-4">
             {sharedTasks.map(t => (
               <li class="flex items-start text-slate-700">
                 <Check class="w-5 h-5 text-brand-accent mr-3 shrink-0 mt-0.5" />
                 <span class="font-medium">{t.task}</span>
               </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Agency Owns -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="bg-slate-100 p-4 border-b border-slate-200 flex items-center gap-3">
          <Briefcase class="w-5 h-5 text-slate-600" />
          <h3 class="font-bold text-slate-800">We Support</h3>
        </div>
        <div class="p-6">
           <ul class="space-y-4">
            {agencyTasks.map(t => (
               <li class="flex items-start text-slate-700">
                 <Check class="w-5 h-5 text-slate-400 mr-3 shrink-0 mt-0.5" />
                 <span>{t.task}</span>
               </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
