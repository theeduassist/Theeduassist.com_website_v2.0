---
import { ArrowRight, CheckCircle2 } from "lucide-react";

interface Stage {
  title: string;
  items: string[];
}

interface Props {
  title?: string;
  description?: string;
  stages: Stage[];
}

const {
  title = "Migration Process",
  description = "How we move your content.",
  stages
} = Astro.props;
---

<section class="py-20 bg-white border-b border-slate-200">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">{title}</h2>
      <p class="text-lg text-slate-600">{description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {stages.map((stage, index) => (
        <div class="relative bg-slate-50 rounded-xl p-6 border border-slate-200 shadow-sm flex flex-col h-full">
            {index < stages.length - 1 && (
                <div class="hidden lg:block absolute top-1/2 -right-6 transform -translate-y-1/2 z-10 text-slate-400">
                    <ArrowRight class="w-6 h-6" />
                </div>
            )}
            <div class="flex items-center gap-3 mb-4">
                <span class="flex-shrink-0 w-8 h-8 bg-brand-primary text-white rounded-full flex items-center justify-center text-sm font-bold">
                  {index + 1}
                </span>
                <h3 class="font-bold text-brand-navy text-lg">{stage.title}</h3>
            </div>
            <ul class="space-y-3 flex-grow">
              {stage.items.map(item => (
                <li class="flex items-start text-sm text-slate-700">
                  <CheckCircle2 class="w-4 h-4 text-brand-accent mr-2 shrink-0 mt-0.5" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
        </div>
      ))}
    </div>
  </div>
</section>
