---
import { serviceArchitecture } from "../../data/serviceArchitecture";
import { ArrowRight } from "lucide-react";

// Get live services for the navigator
const availableServices = serviceArchitecture.filter(s => s.status === 'live' && s.hubVisibility);

// Include Kajabi manually since it's outside the core architecture but solves a problem
const problems = [
  ...availableServices.map(s => ({
    problem: s.problemSolved,
    link: s.slug,
    linkText: s.title
  })),
  {
    problem: "We need help with Kajabi.",
    link: "/kajabi-services/",
    linkText: "Kajabi Services"
  },
  {
    problem: "Our knowledge and content are not organized.",
    link: "/contact/",
    linkText: "Discuss Strategy"
  }
];
---

<section class="py-16 bg-white border-b border-slate-200">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">Choose by Problem</h2>
      <p class="text-slate-600">Select the challenge that best describes your situation.</p>
    </div>

    <div class="space-y-3">
      {problems.map((item) => (
        <a
          href={item.link}
          class="flex flex-col sm:flex-row sm:items-center justify-between p-5 rounded-xl border border-slate-200 hover:border-brand-primary hover:shadow-md transition-all group bg-slate-50 hover:bg-white focus-ring"
        >
          <span class="font-medium text-brand-navy group-hover:text-brand-primary transition-colors text-lg">
            "{item.problem}"
          </span>
          <span class="flex items-center text-brand-accent text-sm font-semibold uppercase tracking-wider shrink-0 mt-3 sm:mt-0 sm:ml-4">
            {item.linkText}
            <ArrowRight class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" />
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
