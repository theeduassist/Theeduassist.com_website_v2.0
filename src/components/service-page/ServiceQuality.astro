---
import { ShieldCheck } from "lucide-react";

interface Props {
  title?: string;
  description?: string;
  points: string[];
}

const {
  title = "Quality and Review",
  description = "How we ensure the learning experience is effective and accurate.",
  points
} = Astro.props;
---

<section class="py-16 bg-slate-50 border-b border-slate-200">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <div class="inline-flex items-center justify-center p-3 bg-brand-primary/10 text-brand-primary rounded-full mb-4">
        <ShieldCheck class="w-8 h-8" />
      </div>
      <h2 class="text-3xl font-bold text-brand-navy mb-4">{title}</h2>
      <p class="text-lg text-slate-600">{description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {points.map((point) => (
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-start gap-4">
           <div class="w-2 h-2 mt-2 bg-brand-accent rounded-full shrink-0"></div>
           <p class="text-slate-700 leading-relaxed">{point}</p>
        </div>
      ))}
    </div>
  </div>
</section>
