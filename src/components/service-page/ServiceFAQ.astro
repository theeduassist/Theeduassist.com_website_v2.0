---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  title?: string;
  description?: string;
}

const {
  faqs,
  title = "Frequently Asked Questions",
  description = "Common questions about this service."
} = Astro.props;

// We use native HTML details/summary instead of JS hydration
---

<section class="py-20 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">{title}</h2>
      <p class="text-lg text-slate-600">{description}</p>
    </div>

    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="group border border-slate-200 rounded-lg bg-slate-50 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex justify-between items-center cursor-pointer p-6 font-semibold text-brand-navy focus-ring hover:bg-slate-100 transition-colors">
            <span class="pr-6">{faq.question}</span>
            <span class="relative shrink-0 ml-1.5 h-5 w-5">
              <svg class="absolute inset-0 w-5 h-5 opacity-100 group-open:opacity-0 transition-opacity" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              <svg class="absolute inset-0 w-5 h-5 opacity-0 group-open:opacity-100 transition-opacity" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
              </svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-slate-600 leading-relaxed bg-white border-t border-slate-100">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
