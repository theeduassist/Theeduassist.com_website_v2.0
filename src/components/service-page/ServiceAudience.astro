---
interface AudienceMember {
  role: string;
  description: string;
}

interface Props {
  title?: string;
  description?: string;
  audience: AudienceMember[];
}

const {
  title = "Who This Service is For",
  description,
  audience
} = Astro.props;
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">{title}</h2>
      {description && <p class="text-lg text-slate-600">{description}</p>}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {audience.map((item) => (
        <div class="p-6 bg-slate-50 border border-slate-200 rounded-xl">
          <h3 class="font-bold text-brand-primary mb-2">{item.role}</h3>
          <p class="text-slate-600 text-sm leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
