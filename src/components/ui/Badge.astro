---
import { cn } from '../../lib/utils/cn';
import { cva, type VariantProps } from 'class-variance-authority';

const badgeVariants = cva(
  "inline-flex items-center rounded px-3 py-1 text-sm font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2",
  {
    variants: {
      variant: {
        outline: "bg-slate-50 border border-slate-200 text-slate-700",
        filled: "bg-blue-100 text-blue-800 border-transparent",
        pill: "bg-white border border-blue-100 rounded-full text-blue-800 shadow-sm px-4",
      },
    },
    defaultVariants: {
      variant: "outline",
    },
  }
);

// We define our own interface that extends cva variants, ensuring compatibility
// and fallback defaults if needed.
interface Props {
  className?: string;
  variant?: 'outline' | 'filled' | 'pill';
}

const { className, variant = 'outline' } = Astro.props;

// Use the variant if valid, else fall back to outline
const safeVariant = ['outline', 'filled', 'pill'].includes(variant as string) ? variant : 'outline';
---

<span class={cn(badgeVariants({ variant: safeVariant as any }), className)}>
  <slot />
</span>
