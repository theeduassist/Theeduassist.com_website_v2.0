---
// src/components/lms/LMSPlatformAgnostic.astro

const platforms = [
  "Kajabi",
  "Moodle-style LMS platforms",
  "WordPress LMS setups",
  "Thinkific / Teachable-style platforms",
  "Custom course websites",
  "Corporate training portals",
  "Membership platforms",
  "Internal learning libraries"
];
---

<section class="py-24 bg-white border-y border-slate-100">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <h2 class="text-3xl font-bold mb-6 text-[#27496D]">Platform-Agnostic Support for Cleaner Learning Systems</h2>
    <p class="text-lg text-slate-600 mb-12 leading-relaxed">
      TheEduAssist is not tied to one LMS. We help you plan and organize the learning experience around your content, audience, and business goals, then support setup or migration into the platform that fits your needs.
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      {platforms.map((platform) => (
        <span class="inline-block px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 font-medium rounded-full shadow-sm text-sm hover:bg-slate-100 hover:border-slate-300 transition-colors">
          {platform}
        </span>
      ))}
    </div>

  </div>
</section>
