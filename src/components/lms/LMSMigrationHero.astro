---
// src/components/lms/LMSMigrationHero.astro
---
<section class="bg-[#F8FAFC] py-20 lg:py-28 overflow-hidden relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">

      {/* Text Content */}
      <div class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#27496D] tracking-tight leading-tight mb-6">
          Move Your Learning Content Into a Cleaner LMS Experience
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 mb-8 leading-relaxed">
          TheEduAssist helps businesses, educators, training companies, online academies, and course creators migrate scattered content from WordPress, Google Drive, PDFs, videos, old LMS platforms, and messy file systems into structured, learner-friendly online learning systems.
        </p>

        <div class="flex flex-wrap gap-4 mb-10">
          <a href="/book-free-audit/" class="inline-flex justify-center items-center px-8 py-3.5 border border-transparent text-base font-semibold rounded-lg text-white bg-[#77BA55] hover:bg-[#65a347] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[#77BA55] shadow-sm">
            Get 24-48 Hour Review
          </a>
          <a href="#migration-process" class="inline-flex justify-center items-center px-8 py-3.5 border border-slate-300 text-base font-semibold rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-slate-500 shadow-sm">
            See Migration Process
          </a>
        </div>

        {/* Trust Chips */}
        <div class="flex flex-wrap gap-2">
          {['LMS Migration', 'Content Cleanup', 'Course Restructure', 'Learner Experience', 'Platform Setup', 'Launch Support', 'Ongoing Maintenance'].map((chip) => (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-white text-slate-600 border border-slate-200 shadow-sm">
              <svg class="mr-1.5 h-4 w-4 text-[#77BA55]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {chip}
            </span>
          ))}
        </div>
      </div>

      {/* Hero Visual - LMS Migration Pathway Infographic */}
      <div class="relative lg:ml-auto w-full max-w-lg lg:max-w-none mx-auto">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 sm:p-8 relative overflow-hidden">

          <div class="absolute top-0 right-0 -mt-16 -mr-16 w-32 h-32 bg-[#EFF6FF] rounded-full blur-2xl opacity-50 pointer-events-none"></div>
          <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-32 h-32 bg-[#F3FAF0] rounded-full blur-2xl opacity-50 pointer-events-none"></div>

          <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6">

            {/* Left: Scattered Content */}
            <div class="flex-1 w-full space-y-3">
              <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider text-center mb-4">Scattered Content</div>
              <div class="flex flex-wrap justify-center gap-2">
                 {['PDFs', 'Slides', 'Videos', 'WordPress', 'Google Drive', 'Old LMS', 'Training Files'].map(item => (
                    <div class="bg-slate-50 border border-slate-200 text-slate-600 text-xs py-1.5 px-3 rounded-md shadow-sm transform transition-transform hover:-translate-y-0.5">
                      {item}
                    </div>
                 ))}
              </div>
            </div>

            {/* Center: System */}
            <div class="flex flex-col items-center justify-center relative px-2">
                <div class="hidden md:block absolute w-full h-0.5 bg-gradient-to-r from-slate-200 via-[#77BA55] to-slate-200 top-1/2 left-0 -z-10"></div>
                <div class="md:hidden absolute h-full w-0.5 bg-gradient-to-b from-slate-200 via-[#77BA55] to-slate-200 left-1/2 top-0 -z-10"></div>

                <div class="w-16 h-16 bg-[#27496D] rounded-xl flex items-center justify-center shadow-lg border-4 border-white z-10 my-4 md:my-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                  </svg>
                </div>
                <div class="text-[10px] font-bold text-[#27496D] uppercase tracking-widest text-center mt-2 whitespace-nowrap bg-white px-2">TheEduAssist</div>
            </div>

            {/* Right: Clean Experience */}
            <div class="flex-1 w-full space-y-3">
              <div class="text-xs font-semibold text-[#77BA55] uppercase tracking-wider text-center mb-4">Clean Experience</div>
              <div class="grid grid-cols-2 gap-2">
                {['Modules', 'Lessons', 'Resources', 'Assessments', 'Learner Journey', 'Student Access', 'Reporting Ready'].map(item => (
                   <div class="bg-[#EFF6FF] border border-blue-100 text-[#27496D] text-xs py-1.5 px-2 rounded-md shadow-sm text-center font-medium transform transition-transform hover:-translate-y-0.5">
                     {item}
                   </div>
                ))}
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>
