---
// src/components/lms/LMSContentStandards.astro
import Card from "../ui/Card.astro";

const standards = [
  "Native LMS content",
  "Video lessons",
  "PDFs and downloads",
  "Quizzes and assessments",
  "SCORM-ready content if available",
  "xAPI-ready content if relevant",
  "Certificates and completion paths where supported"
];
---

<section class="py-24 bg-[#F8FAFC]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row gap-12 items-start">

      <div class="lg:w-1/3 sticky top-24">
        <h2 class="text-3xl font-bold mb-6 text-[#27496D]">Content Structure Matters Before Migration</h2>
        <div class="space-y-4 text-slate-600">
          <p>
            Before moving content, TheEduAssist helps check what format the content is in and how it should be delivered.
          </p>
          <p>
            Some LMS environments may use structured packages or standards such as SCORM, while others rely on modules, lessons, videos, downloads, quizzes, and platform-native content.
          </p>
          <div class="mt-6 p-5 bg-[#EFF6FF] rounded-xl border border-blue-100">
            <p class="text-sm font-medium text-[#27496D]">
              We can help assess whether your content needs native lessons, downloadable resources, SCORM-style packages, or another structure depending on your LMS.
            </p>
          </div>
        </div>
      </div>

      <div class="lg:w-2/3 w-full">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {standards.map((standard) => (
             <Card class="bg-white hover:border-blue-200 transition-colors p-5 flex items-center">
                <div class="w-10 h-10 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center mr-4 border border-blue-100 flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                  </svg>
                </div>
                <span class="text-slate-700 font-medium">{standard}</span>
             </Card>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
