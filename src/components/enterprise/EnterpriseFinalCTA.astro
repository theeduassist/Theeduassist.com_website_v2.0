---
import { ArrowRight } from "lucide-react";
---
<section class="py-20 bg-brand-navy text-center px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Planning an Enterprise Learning Initiative?</h2>
    <p class="text-xl text-slate-300 mb-10 leading-relaxed">
      Share your audiences, learning goals, existing content, platform and project requirements through the enterprise project brief.
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/enterprise-solutions/project-brief/" class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-lg font-bold rounded-md text-brand-navy bg-brand-green hover:bg-green-500 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-green focus:ring-offset-brand-navy" data-analytics-event="enterprise_cta_click" data-cta-name="Submit an Enterprise Project Brief" data-cta-location="enterprise_hub_footer" data-destination-type="project-brief">
        Submit an Enterprise Project Brief
        <ArrowRight className="ml-2 -mr-1 w-5 h-5" />
      </a>
      <a href="/contact/" class="inline-flex justify-center items-center px-8 py-4 border border-slate-500 text-lg font-bold rounded-md text-white hover:bg-slate-800 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-500 focus:ring-offset-brand-navy" data-analytics-event="enterprise_cta_click" data-cta-name="Contact Our Team" data-cta-location="enterprise_hub_footer" data-destination-type="contact">
        Contact Our Team
      </a>
    </div>
    <div class="mt-8">
       <a href="/trust-centre/" class="text-slate-400 hover:text-white font-medium transition-colors underline underline-offset-4 decoration-slate-600">
         Review Our Delivery and Trust Information
       </a>
    </div>
  </div>
</section>
