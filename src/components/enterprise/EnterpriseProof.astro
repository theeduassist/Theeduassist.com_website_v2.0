---
import { ArrowRight } from "lucide-react";
---
<section class="py-16 bg-white border-y border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold text-brand-navy">Verified Proof</h2>
        <p class="mt-4 text-lg text-slate-600">See how TheEduAssist has delivered structured learning systems for diverse organizational needs.</p>
      </div>
      <a href="/case-studies/" class="inline-flex items-center text-brand-navy font-semibold hover:text-brand-green transition-colors">
        View All Case Studies <ArrowRight className="ml-2 w-5 h-5" />
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Case Study 1 -->
      <a href="/case-studies/sqa-aligned-vocational-training/" class="group block bg-slate-50 rounded-xl overflow-hidden border border-slate-200 hover:shadow-md transition-all">
         <div class="p-6">
            <span class="text-xs font-semibold uppercase tracking-wider text-brand-green mb-2 block">Internal Academies</span>
            <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-green transition-colors">SQA-Aligned Vocational Training</h3>
            <p class="text-slate-600 mb-4 line-clamp-3">Supporting structured vocational learning, instructional design, digital course development and LMS-ready learning.</p>
            <span class="inline-flex items-center text-sm font-semibold text-brand-navy">Read Case Study <ArrowRight className="ml-1 w-4 h-4" /></span>
         </div>
      </a>

      <!-- Case Study 2 -->
      <a href="/case-studies/business-analytics-corporate-training/" class="group block bg-slate-50 rounded-xl overflow-hidden border border-slate-200 hover:shadow-md transition-all">
         <div class="p-6">
            <span class="text-xs font-semibold uppercase tracking-wider text-brand-green mb-2 block">Workforce Learning</span>
            <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-green transition-colors">Business Analytics for Corporate Teams</h3>
            <p class="text-slate-600 mb-4 line-clamp-3">Supporting workforce learning, corporate training across varied learner experience levels, practical activities and structured digital delivery.</p>
            <span class="inline-flex items-center text-sm font-semibold text-brand-navy">Read Case Study <ArrowRight className="ml-1 w-4 h-4" /></span>
         </div>
      </a>

      <!-- Case Study 3 -->
      <a href="/case-studies/language-courses-book-publisher/" class="group block bg-slate-50 rounded-xl overflow-hidden border border-slate-200 hover:shadow-md transition-all">
         <div class="p-6">
            <span class="text-xs font-semibold uppercase tracking-wider text-brand-green mb-2 block">Content Modernization</span>
            <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-green transition-colors">Language Courses for Book Publisher</h3>
            <p class="text-slate-600 mb-4 line-clamp-3">Supporting content modernization, curriculum mapping, language learning and digital course development from legacy materials.</p>
            <span class="inline-flex items-center text-sm font-semibold text-brand-navy">Read Case Study <ArrowRight className="ml-1 w-4 h-4" /></span>
         </div>
      </a>
    </div>
  </div>
</section>
