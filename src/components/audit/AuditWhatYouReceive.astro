---
import SectionHeader from '../ui/SectionHeader.astro';

const outcomes = [
  "A clearer view of what is working",
  "A list of weak or confusing areas",
  "Suggested next steps for your Kajabi setup",
  "Recommended service path if support is needed",
  "Better understanding of your course, funnel, or migration priorities",
  "No pressure and no fake promises"
];
---

<section class="py-16 md:py-24 bg-[#27496D] text-white overflow-hidden relative">
  {/* Abstract Background Element */}
  <div class="absolute top-0 right-0 w-64 h-64 bg-white opacity-5 rounded-full blur-3xl -z-0 transform translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#77BA55] opacity-10 rounded-full blur-3xl -z-0 transform -translate-x-1/3 translate-y-1/3"></div>

  <div class="container mx-auto px-4 md:px-6 max-w-4xl relative z-10">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">What you will leave with</h2>
      <p class="text-blue-100 text-lg">Clear direction for your next move, whether you build it yourself or hire help.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
      {outcomes.map((item) => (
        <div class="flex items-start">
          <div class="w-8 h-8 rounded-full bg-[#77BA55]/20 flex items-center justify-center mr-4 shrink-0 border border-[#77BA55]/30">
            <svg class="w-5 h-5 text-[#77BA55]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-white text-lg font-medium pt-1">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>
