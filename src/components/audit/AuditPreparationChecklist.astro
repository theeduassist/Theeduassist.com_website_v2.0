---
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';

const preparationItems = [
  "Your Kajabi website link if available",
  "Any landing page or offer page",
  "Course outline or module list",
  "Current funnel or checkout link",
  "Email sequence notes",
  "Old WordPress/LMS/content folder if migration is needed",
  "Main improvement area you want solved first"
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="container mx-auto px-4 md:px-6 max-w-4xl">

    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8 md:p-12 shadow-sm">
      <SectionHeader
        title="What to prepare before the audit"
        subtitle="To get the most out of our 30 minutes, gather these items if you have them."
        centered={true}
      />

      <div class="mt-8 bg-white border border-slate-100 rounded-xl p-6 shadow-sm">
        <ul class="space-y-4">
          {preparationItems.map((item) => (
            <li class="flex items-start">
              <div class="w-6 h-6 rounded-full bg-[#EFF6FF] text-[#27496D] flex items-center justify-center mr-4 shrink-0 mt-0.5">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-slate-700 text-lg">{item}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 p-4 bg-blue-50 border border-blue-100 rounded-lg flex items-start">
           <svg class="w-5 h-5 text-blue-600 mr-3 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
           </svg>
           <p class="text-sm text-blue-800">Don't have everything ready? That's okay. Bring what you have, even if it's just raw notes or an idea.</p>
        </div>
      </div>

    </div>

  </div>
</section>
