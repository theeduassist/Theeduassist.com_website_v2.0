---
import Button from '../ui/Button.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  primaryCtaLabel?: string;
  primaryCtaLink?: string;
  secondaryCtaLabel?: string;
  secondaryCtaLink?: string;
  trustChips?: string[];
}

const {
  title = "Get a 24–48 Hour Course/LMS Review",
  subtitle = "Send us your course, Kajabi, LMS, or content challenge. We’ll review it and reply within 24–48 hours with the best service path, estimated scope, and next step.",
  primaryCtaLabel = "Submit Project Details",
  primaryCtaLink = "/book-free-audit/",
  secondaryCtaLabel = "Learn More",
  secondaryCtaLink = "/services/",
  trustChips = []
} = Astro.props;
---

<section class="py-20 md:py-28 bg-[#27496D] text-white text-center px-4 relative overflow-hidden">
  <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-blue-500 to-transparent"></div>
  <div class="max-w-5xl mx-auto relative z-10">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">{title}</h1>
    <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto mb-10">{subtitle}</p>

    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mb-12">
      <Button href={primaryCtaLink} variant="primary" size="lg" class="bg-[#77BA55] border-[#77BA55] hover:bg-green-600">{primaryCtaLabel}</Button>
      <Button href={secondaryCtaLink} variant="outline" size="lg" class="bg-white/5 text-white border-white/20 hover:bg-white/10">{secondaryCtaLabel}</Button>
    </div>

    <!-- Audit Pathway Infographic -->
    <div class="hidden md:flex items-center justify-center gap-4 mb-12 text-sm font-medium">
      <div class="flex flex-col items-center bg-white/10 border border-white/20 p-4 rounded-lg w-40">
        <svg class="h-8 w-8 text-blue-300 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        Your Content / Platform
      </div>
      <svg class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      <div class="flex flex-col items-center bg-white/10 border border-white/20 p-4 rounded-lg w-40">
        <svg class="h-8 w-8 text-blue-300 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        Audit Questions
      </div>
      <svg class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      <div class="flex flex-col items-center bg-white/10 border border-white/20 p-4 rounded-lg w-40">
        <svg class="h-8 w-8 text-blue-300 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        TheEduAssist Review
      </div>
      <svg class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      <div class="flex flex-col items-center bg-[#77BA55]/20 border border-[#77BA55]/40 p-4 rounded-lg w-40">
        <svg class="h-8 w-8 text-[#77BA55] mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        Recommended Next Step
      </div>
    </div>

    <div class="flex flex-wrap justify-center gap-2">
      {trustChips.map((chip) => (
        <span class="px-3 py-1 bg-white/10 border border-white/20 rounded-full text-xs font-medium text-blue-100">
          {chip}
        </span>
      ))}
    </div>
  </div>
</section>
