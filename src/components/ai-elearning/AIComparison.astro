---
// src/components/ai-elearning/AIComparison.astro
import SectionHeader from '../ui/SectionHeader.astro';
---

<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader
      title="AI Alone vs TheEduAssist AI-Powered Support"
      description="The difference between generating raw text and producing a structured, platform-ready learning system."
    />

    <div class="mt-12 overflow-x-auto pb-8">
      <div class="min-w-[800px] bg-white rounded-2xl shadow-sm border border-brand-border/60 overflow-hidden">

        <!-- Header Row -->
        <div class="grid grid-cols-4 bg-slate-50 border-b border-brand-border/60">
            <div class="p-6 font-bold text-slate-500 uppercase tracking-wider text-sm flex items-center">Features</div>
            <div class="p-6 font-bold text-slate-700 text-center border-l border-brand-border/60">DIY AI Prompting</div>
            <div class="p-6 font-bold text-slate-700 text-center border-l border-brand-border/60">Generic AI Content Writer</div>
            <div class="p-6 font-bold text-brand-navy text-center border-l border-brand-accent/30 bg-brand-softGreen/30 relative">
                <div class="absolute top-0 left-0 right-0 h-1 bg-brand-accent"></div>
                TheEduAssist AI-Powered E-Learning Support
            </div>
        </div>

        <!-- Data Rows -->
        {[
            { label: "Course strategy", diy: false, generic: false, us: true },
            { label: "Curriculum structure", diy: false, generic: true, us: true },
            { label: "Learner journey", diy: false, generic: false, us: true },
            { label: "Content conversion", diy: true, generic: true, us: true },
            { label: "Human review", diy: true, generic: false, us: true },
            { label: "Worksheets/quizzes", diy: true, generic: true, us: true },
            { label: "Kajabi/LMS readiness", diy: false, generic: false, us: true },
            { label: "Launch assets", diy: false, generic: false, us: true },
            { label: "Ongoing improvement", diy: false, generic: false, us: true }
        ].map((row, i) => (
            <div class={`grid grid-cols-4 border-b border-brand-border/30 ${i % 2 === 0 ? 'bg-white' : 'bg-slate-50/50'}`}>
                <div class="p-4 font-medium text-slate-700 flex items-center">{row.label}</div>

                <div class="p-4 flex items-center justify-center border-l border-brand-border/30">
                    {row.diy ?
                        <svg class="w-6 h-6 text-brand-textMuted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> :
                        <svg class="w-6 h-6 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    }
                </div>

                <div class="p-4 flex items-center justify-center border-l border-brand-border/30">
                    {row.generic ?
                        <svg class="w-6 h-6 text-brand-textMuted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> :
                        <svg class="w-6 h-6 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    }
                </div>

                <div class="p-4 flex items-center justify-center border-l border-brand-accent/30 bg-brand-softGreen/10">
                    {row.us ?
                        <svg class="w-6 h-6 text-brand-accent drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg> :
                        <svg class="w-6 h-6 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    }
                </div>
            </div>
        ))}
      </div>
    </div>
  </div>
</section>
