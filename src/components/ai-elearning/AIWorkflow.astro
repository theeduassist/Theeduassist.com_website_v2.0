---
// src/components/ai-elearning/AIWorkflow.astro
import SectionHeader from '../ui/SectionHeader.astro';

const steps = [
  {
    number: "1",
    title: "Audit",
    description: "We review your content, audience, goals, platform, and learning outcome.",
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
  },
  {
    number: "2",
    title: "Prompt & Extract",
    description: "We use structured AI prompts to extract key ideas, summarize content, and identify possible lesson flows.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  },
  {
    number: "3",
    title: "Organize",
    description: "We build the course map, modules, lessons, learning outcomes, and student journey.",
    icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
  },
  {
    number: "4",
    title: "Review",
    description: "Human review checks accuracy, tone, flow, clarity, learner needs, and missing gaps.",
    icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
  },
  {
    number: "5",
    title: "Convert",
    description: "We create scripts, worksheets, quizzes, summaries, support content, and launch assets.",
    icon: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
  },
  {
    number: "6",
    title: "Prepare",
    description: "We format assets for Kajabi, LMS, or your chosen learning platform.",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
  },
  {
    number: "7",
    title: "Launch & Improve",
    description: "We support updates, student onboarding, and improvement after delivery.",
    icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
  }
];
---

<section class="py-24 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader title="Our Human-Led, AI-Assisted Workflow" />

    <div class="mt-16 max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {steps.map((step, index) => (
                <div class="bg-white p-6 rounded-xl border border-brand-border/60 shadow-sm hover:shadow-md transition-shadow relative">
                    <div class="w-10 h-10 bg-brand-navy text-white rounded-full flex items-center justify-center font-bold mb-4">
                        {step.number}
                    </div>
                    <h3 class="font-bold text-brand-navy mb-2">{step.title}</h3>
                    <p class="text-sm text-brand-textMuted">{step.description}</p>

                    {index < steps.length - 1 && (
                        <div class="hidden xl:block absolute top-1/2 -right-4 w-4 h-0.5 bg-brand-border z-0"></div>
                    )}
                </div>
            ))}
        </div>
    </div>
  </div>
</section>
