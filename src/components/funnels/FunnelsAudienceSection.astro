---
---
<section class="py-20 bg-slate-50 border-y border-slate-100">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-[#27496D] mb-4">Who Needs Funnels and Automation?</h2>
      <p class="text-lg text-slate-600">Connecting marketing flow with the learner experience.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        {
          title: 'Course Creators',
          situation: 'Have a course but struggle to sell it.',
          need: 'Clear path from lead magnet to email sequence to course purchase.',
          outcome: 'Automated enrollments and clear journey.',
          icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'
        },
        {
          title: 'Coaches and Consultants',
          situation: 'Selling time instead of scalable programs.',
          need: 'Funnels for programs, workshops, cohorts, or memberships.',
          outcome: 'Scalable program sales and automated onboarding.',
          icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z'
        },
        {
          title: 'Educators',
          situation: 'Manual enrollment and student communication.',
          need: 'Enrollment pages, course access emails, and student onboarding.',
          outcome: 'Less admin work, better student experience.',
          icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
        },
        {
          title: 'Training Companies',
          situation: 'Need to scale B2B or B2C training delivery.',
          need: 'Scalable lead capture, follow-up, and client onboarding workflows.',
          outcome: 'Professional, automated client acquisition and delivery.',
          icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
        },
        {
          title: 'Online Academies',
          situation: 'Managing multiple courses and learning paths.',
          need: 'Funnels for multiple courses, programs, or learning pathways.',
          outcome: 'Clear navigation and targeted sales flows.',
          icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10'
        },
        {
          title: 'Businesses & Internal Teams',
          situation: 'Manual employee or partner training.',
          need: 'Onboarding workflows, training access emails, and automated communication.',
          outcome: 'Streamlined, trackable internal training.',
          icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z'
        }
      ].map(card => (
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-slate-50 text-[#27496D] rounded-xl flex items-center justify-center mb-6 border border-slate-100">
             <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={card.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#27496D] mb-4">{card.title}</h3>

          <div class="space-y-4">
            <div>
              <span class="text-xs font-semibold uppercase tracking-wider text-slate-400 block mb-1">Situation</span>
              <p class="text-sm text-slate-600">{card.situation}</p>
            </div>
            <div>
              <span class="text-xs font-semibold uppercase tracking-wider text-[#77BA55] block mb-1">Need</span>
              <p class="text-sm text-slate-700 font-medium">{card.need}</p>
            </div>
            <div>
              <span class="text-xs font-semibold uppercase tracking-wider text-blue-500 block mb-1">Outcome</span>
              <p class="text-sm text-slate-600">{card.outcome}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
