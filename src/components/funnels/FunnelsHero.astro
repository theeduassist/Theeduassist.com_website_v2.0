---
---
<section class="py-20 lg:py-32 bg-slate-50 relative overflow-hidden">
  <!-- Soft Background Accents -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-sky-100 rounded-full blur-[100px] opacity-40 mix-blend-multiply transform translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[#F3FAF0] rounded-full blur-[80px] opacity-60 mix-blend-multiply transform -translate-x-1/3 translate-y-1/3"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[#27496D] tracking-tight mb-6">
        Build Funnels and Automations That Connect Leads, Sales, and Learning
      </h1>
      <p class="text-lg md:text-xl text-slate-600 mb-10 max-w-3xl mx-auto leading-relaxed">
        TheEduAssist helps creators, coaches, consultants, educators, academies, and training businesses connect lead capture, landing pages, email follow-up, sales pages, checkout, course access, student onboarding, and post-purchase communication into one smoother learning-business journey.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
        <a href="/book-free-audit/" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-[#77BA55] rounded-xl hover:bg-[#65A344] transition-all duration-200 shadow-sm hover:shadow-md w-full sm:w-auto">
          Get 24-48 Hour Review
        </a>
        <a href="#funnel-workflow" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-[#27496D] bg-white border border-slate-200 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all duration-200 w-full sm:w-auto">
          See Funnel Workflow
        </a>
      </div>

      <!-- Trust Chips -->
      <div class="flex flex-wrap justify-center gap-3">
        {['Lead Capture', 'Landing Pages', 'Email Sequences', 'Offers & Checkout', 'Course Access', 'Student Onboarding', 'Launch Automation', 'Funnel QA'].map(chip => (
          <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-white border border-slate-200 text-sm font-medium text-slate-600 shadow-sm">
            {chip}
          </span>
        ))}
      </div>
    </div>

    <!-- Hero Visual: Course Funnel Journey -->
    <div class="mt-20 max-w-5xl mx-auto bg-white rounded-2xl shadow-sm border border-slate-100 p-8 lg:p-12 relative">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-px bg-gradient-to-r from-transparent via-[#77BA55] to-transparent opacity-30"></div>

      <div class="flex flex-col md:flex-row justify-between items-center relative z-10 gap-6 md:gap-2">
        <!-- Connecting Line (Desktop) -->
        <div class="hidden md:block absolute top-1/2 left-0 right-0 h-0.5 bg-slate-100 -z-10"></div>

        {/* Step 1: Attract */}
        <div class="flex flex-col items-center text-center w-full md:w-auto group">
          <div class="w-16 h-16 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center mb-4 text-[#27496D] group-hover:border-[#77BA55]/30 group-hover:shadow-sm transition-all relative">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
            </svg>
            <div class="hidden md:block absolute top-1/2 -right-[2rem] w-[2rem] h-0.5 bg-slate-200"></div>
          </div>
          <span class="text-sm font-semibold text-[#27496D]">Visitor</span>
          <span class="text-xs text-slate-500 mt-1">Lead Magnet</span>
        </div>

        {/* Step 2: Nurture */}
        <div class="flex flex-col items-center text-center w-full md:w-auto group">
          <div class="w-16 h-16 rounded-2xl bg-[#F3FAF0] border border-[#77BA55]/20 flex items-center justify-center mb-4 text-[#77BA55] relative shadow-sm">
             <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div class="hidden md:block absolute top-1/2 -left-[2rem] w-[2rem] h-0.5 bg-slate-200"></div>
            <div class="hidden md:block absolute top-1/2 -right-[2rem] w-[2rem] h-0.5 bg-slate-200"></div>
          </div>
          <span class="text-sm font-semibold text-[#27496D]">Nurture</span>
          <span class="text-xs text-slate-500 mt-1">Email Sequence</span>
        </div>

        {/* Step 3: Convert */}
        <div class="flex flex-col items-center text-center w-full md:w-auto group">
          <div class="w-16 h-16 rounded-2xl bg-sky-50 border border-sky-100 flex items-center justify-center mb-4 text-sky-600 group-hover:border-sky-200 transition-all relative">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
            <div class="hidden md:block absolute top-1/2 -left-[2rem] w-[2rem] h-0.5 bg-slate-200"></div>
            <div class="hidden md:block absolute top-1/2 -right-[2rem] w-[2rem] h-0.5 bg-slate-200"></div>
          </div>
          <span class="text-sm font-semibold text-[#27496D]">Sales Page</span>
          <span class="text-xs text-slate-500 mt-1">Checkout</span>
        </div>

        {/* Step 4: Access */}
        <div class="flex flex-col items-center text-center w-full md:w-auto group">
          <div class="w-16 h-16 rounded-2xl bg-indigo-50 border border-indigo-100 flex items-center justify-center mb-4 text-indigo-600 group-hover:border-indigo-200 transition-all relative">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <div class="hidden md:block absolute top-1/2 -left-[2rem] w-[2rem] h-0.5 bg-slate-200"></div>
            <div class="hidden md:block absolute top-1/2 -right-[2rem] w-[2rem] h-0.5 bg-slate-200"></div>
          </div>
          <span class="text-sm font-semibold text-[#27496D]">Course Access</span>
          <span class="text-xs text-slate-500 mt-1">Student Onboarding</span>
        </div>

        {/* Step 5: Learn */}
        <div class="flex flex-col items-center text-center w-full md:w-auto group">
          <div class="w-16 h-16 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center mb-4 text-[#27496D] group-hover:border-[#77BA55]/30 group-hover:shadow-sm transition-all relative">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
             <div class="hidden md:block absolute top-1/2 -left-[2rem] w-[2rem] h-0.5 bg-slate-200"></div>
          </div>
          <span class="text-sm font-semibold text-[#27496D]">Learning</span>
          <span class="text-xs text-slate-500 mt-1">Ongoing Support</span>
        </div>

      </div>
    </div>
  </div>
</section>
