    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-16 items-stretch">

      {/* Package 4 */}
      <div class="bg-white rounded-2xl border border-slate-200 p-8 flex flex-col hover:border-[#77BA55]/50 hover:shadow-md transition-all h-full">
