        <h3 class="text-xl font-bold text-[#27496D] mb-2">Funnel Strategy Map</h3>
        <p class="text-sm text-slate-500 mb-2 min-h-[40px]"><span class="font-semibold text-slate-700">Best for:</span> Creators and businesses that need a clear funnel plan before building.</p>
        <p class="text-sm text-slate-500 mb-6 pb-4 border-b border-slate-100"><span class="font-semibold text-slate-700">Timeline:</span> 1-2 weeks</p>
        <div class="text-3xl font-bold text-[#27496D] mb-6">
          <span class="text-lg font-normal text-slate-500 block mb-1">Starting from</span>
          $500
        </div>
        <p class="text-sm font-semibold text-slate-700 mb-4 uppercase tracking-wider">Includes:</p>
        <ul class="space-y-3 mb-8 flex-grow">
          {['Funnel audit or planning call', 'Offer journey map', 'Lead magnet path', 'Email sequence outline', 'Checkout/access flow map', 'Automation recommendations'].map(feature => (
            <li class="flex items-start gap-3 text-sm text-slate-700">
              <svg class="w-5 h-5 text-[#77BA55] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {feature}
            </li>
          ))}
        </ul>
        <div class="mt-auto flex flex-col space-y-3">
          <a href="/book-free-audit/?package=content-conversion-kit&source=package-card" data-package-slug="content-conversion-kit" data-package-price="From $400" class="tawk-package-btn block w-full py-3 px-4 bg-[#27496D] text-white text-center font-semibold rounded-md border border-transparent hover:bg-brand-navy transition-colors focus-ring">Start This Package</a>
          <p class="text-xs text-brand-textMuted text-center leading-tight">Talk to our team first so we can confirm the right package, scope, timeline, and payment next step.</p>
          <a href="/book-free-audit/?package=content-conversion-kit&source=package-card" class="block w-full text-center py-3 px-4 bg-white text-slate-700 font-semibold rounded-xl border border-slate-300 hover:bg-slate-50 transition-colors shadow-sm focus-ring">
            Submit Project Details
