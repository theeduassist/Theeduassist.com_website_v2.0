---
interface Props {
  countryData: any;
  cities: any[];
}

const { countryData, cities } = Astro.props;
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="mb-12 border-b pb-8">
    <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">E-Learning Services in {countryData.name}</h1>
    <p class="text-xl text-slate-600 leading-relaxed max-w-4xl">{countryData.intro}</p>
  </div>

  <!-- Quick Answer -->
  {countryData.quickAnswer && (
    <div class="bg-brand-softBg border border-brand-accent/20 rounded-xl p-8 mb-16 shadow-sm">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">Quick Answer</h2>
      <p class="text-slate-700">{countryData.quickAnswer}</p>
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
    <div>
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Market Overview</h2>
        <ul class="space-y-4 text-slate-700">
            <li><strong class="text-brand-primary">Key Buyers:</strong> {countryData.buyers.join(', ')}</li>
            <li><strong class="text-brand-primary">Top Industries:</strong> {countryData.industries.join(', ')}</li>
            <li><strong class="text-brand-primary">Preferred Platforms:</strong> {countryData.platforms.join(', ')}</li>
        </ul>
    </div>
    <div class="bg-brand-softBg p-8 rounded-xl border border-brand-accent/10">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Need Help with a Project?</h3>
        <p class="text-slate-700 mb-6">We provide remote e-learning consulting and development for clients across {countryData.name}.</p>
        <a href={countryData.ctaPrimary?.link || "/book-free-audit/"} class="inline-block bg-brand-accent text-white font-bold py-3 px-8 rounded hover:bg-brand-primary transition-colors">
          {countryData.ctaPrimary?.text || "Get 24-48 Hour Review"}
        </a>
    </div>
  </div>

  <div class="mb-16">
    <h2 class="text-2xl font-bold text-brand-navy mb-8">Cities in {countryData.name}</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {cities.map(c => (
          <a href={`/locations/${c.slug}/`} class="p-4 bg-white border border-slate-200 rounded hover:border-brand-accent text-center font-medium text-slate-700 hover:text-brand-primary transition-colors">
            {c.cityName}
          </a>
        ))}
    </div>
  </div>

  <div class="mb-16">
    <h2 class="text-3xl font-bold text-brand-navy mb-8">Related Services</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      <a href="/services/custom-elearning-development/" class="block text-center text-brand-primary hover:text-brand-accent font-medium bg-white p-4 rounded border border-slate-200 shadow-sm">Custom E-Learning</a>
      <a href="/services/lms-implementation-migration/" class="block text-center text-brand-primary hover:text-brand-accent font-medium bg-white p-4 rounded border border-slate-200 shadow-sm">LMS Migration</a>
      <a href="/services/ai-powered-elearning/" class="block text-center text-brand-primary hover:text-brand-accent font-medium bg-white p-4 rounded border border-slate-200 shadow-sm">AI E-Learning</a>
      <a href="/kajabi-services/" class="block text-center text-brand-primary hover:text-brand-accent font-medium bg-white p-4 rounded border border-slate-200 shadow-sm">Kajabi Setup</a>
    </div>
  </div>

  <!-- FAQs -->
  {countryData.faqQuestions && countryData.faqQuestions.length > 0 && (
    <div class="mb-20">
      <h2 class="text-3xl font-bold text-brand-navy mb-8 border-b pb-4">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {countryData.faqQuestions.map(faq => (
          <div class="bg-white border border-slate-200 p-6 rounded-lg shadow-sm">
            <h3 class="text-xl font-bold text-brand-primary mb-3">{faq.q}</h3>
            <p class="text-slate-700 leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  )}

</div>
