---
import Button from '../ui/Button.astro';

const situations = [
  {
    title: "I have an idea but no course structure",
    explanation: "You know what you want to teach, but need help organizing it into modules and outcomes.",
    recommended: "Course Creation & Curriculum Design",
    link: "/services/custom-elearning-development/" // Adjusted to closest existing route or generic
  },
  {
    title: "I have PDFs, slides, videos, or notes",
    explanation: "You have existing materials that need to be turned into a professional online course.",
    recommended: "Content Conversion + Instructional Design",
    link: "/services/custom-elearning-development/"
  },
  {
    title: "I need a Kajabi website or course setup",
    explanation: "You need help building your Kajabi site, products, offers, and student access.",
    recommended: "Kajabi Website & Course Setup",
    link: "/kajabi-services/"
  },
  {
    title: "I need to move from WordPress, Drive, or an old LMS",
    explanation: "You want to migrate your content to a cleaner, more organized learning system.",
    recommended: "LMS Implementation & Migration",
    link: "/services/lms-implementation-migration/"
  },
  {
    title: "I want funnels, email follow-up, checkout, and onboarding",
    explanation: "You need the marketing and student onboarding systems connected to your course.",
    recommended: "Funnels & Automation",
    link: "/book-free-audit/" // Fallback route
  },
  {
    title: "I need help improving an existing course",
    explanation: "You have a live course but need to optimize the learner experience and materials.",
    recommended: "Ongoing Support & Maintenance",
    link: "/contact/" // Fallback route
  }
];
---

<section id="service-finder" class="py-20 md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-primary mb-4">Not Sure What You Need Yet?</h2>
      <p class="text-lg text-brand-textMuted">Start with where you are right now.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {situations.map((item) => (
        <div class="brand-card p-8 flex flex-col h-full hover-lift group border-t-4 border-t-transparent hover:border-t-brand-accent transition-all duration-300">
          <h3 class="text-xl font-bold text-brand-textMain mb-3 leading-tight">{item.title}</h3>
          <p class="text-brand-textMuted mb-6 flex-grow">{item.explanation}</p>

          <div class="pt-6 border-t border-brand-border mt-auto">
            <span class="block text-xs font-semibold uppercase tracking-wider text-brand-textMuted mb-2">Recommended Service</span>
            <span class="block text-brand-primary font-bold mb-4">{item.recommended}</span>

            <a href={item.link} class="inline-flex items-center text-sm font-semibold text-brand-accent hover:text-brand-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 rounded px-1 -ml-1">
              Explore Service
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
