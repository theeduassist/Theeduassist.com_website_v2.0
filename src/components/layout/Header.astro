---
import { getSiteSettings, getNavigation } from '../../sanity/queries';
import MobileMenu from './MobileMenu.astro';
import { aiAssistants } from '../../data/aiAssistants';
import { siteNavigation } from '../../data/siteNavigation';

const siteSettings = await getSiteSettings();
const site = siteSettings || { name: 'TheEduAssist', email: 'Info@theeduassist.com', social: {} };

const navigation = await getNavigation();

---
<header class="bg-white/90 backdrop-blur-md border-b border-brand-border/50 relative z-50 sticky top-0 shadow-sm transition-all duration-300">
    <div class="max-w-[1500px] mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
        <a href="/" class="flex items-center space-x-3 focus-ring rounded-sm group shrink-0 min-w-0" aria-label="TheEduAssist Home">
            <div class="h-11 w-11 md:h-12 md:w-12 rounded-full overflow-hidden shrink-0 min-w-0 flex items-center justify-center">
                <img src="/brand/theeduassist-logo-official.svg" alt="TheEduAssist e-learning design agency logo" class="h-full w-full object-contain" height="48" width="48" />
            </div>
            <div class="hidden md:flex flex-col">
                <span class="font-bold text-brand-primary text-xl leading-tight group-hover:text-brand-accent transition-colors duration-300">TheEduAssist</span>
                <span class="text-xs text-brand-textMuted font-medium uppercase tracking-wider">E-Learning Design Agency</span>
            </div>
        </a>
        <nav class="hidden xl:flex gap-4 xl:gap-6 items-center relative" aria-label="Main Navigation">
            {siteNavigation.map((item) => (
                item.enabled ? (
                    item.type === 'link' ? (
                        <a href={item.href} class="text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 px-2 xl:px-3 py-2 font-medium focus-ring rounded-md transition-all duration-300 whitespace-nowrap">{item.label}</a>
                    ) : item.type === 'dropdown' ? (
                        <div class="relative group nav-dropdown-container">
                            <button class="text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 px-2 xl:px-3 py-2 font-medium focus-ring rounded-md transition-all duration-300 inline-flex items-center whitespace-nowrap dropdown-toggle-btn" aria-expanded="false" aria-controls={`dropdown-${item.id}`}>
                                {item.label}
                                <svg class="ml-1 w-4 h-4 text-brand-textMuted group-hover:text-brand-accent transition-transform duration-200 transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div id={`dropdown-${item.id}`} class="absolute left-0 mt-2 w-48 bg-white/95 backdrop-blur-md rounded-xl shadow-xl border border-brand-border/50 opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition-all duration-200 transform origin-top translate-y-2 group-hover:translate-y-0 focus-within:translate-y-0 z-50 overflow-hidden dropdown-menu">
                                <div class="py-2">
                                    {item.groups?.map(group => (
                                        group.links.map((subItem) => (
                                            <a href={subItem.href} class="block px-4 py-2.5 text-sm font-medium text-brand-textMain hover:bg-brand-softBg hover:text-brand-primary transition-colors focus-ring whitespace-nowrap">
                                                {subItem.label}
                                            </a>
                                        ))
                                    ))}
                                </div>
                            </div>
                        </div>
                    ) : item.type === 'mega-menu' ? (
                        <div class="group nav-mega-container static-mega">
                            <button class="text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 px-2 xl:px-3 py-2 font-medium focus-ring rounded-md transition-all duration-300 inline-flex items-center whitespace-nowrap mega-toggle-btn" aria-expanded="false" aria-controls={`mega-menu-${item.id}`}>
                                {item.label}
                                <svg class="ml-1 w-4 h-4 text-brand-textMuted group-hover:text-brand-accent transition-transform duration-200 transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <!-- Mega Menu Dropdown -->
                            <div id={`mega-menu-${item.id}`} class="absolute left-1/2 top-full z-50 mt-2 w-[calc(100vw-2rem)] max-w-[800px] -translate-x-1/2 box-border bg-white/95 backdrop-blur-md rounded-xl shadow-xl border border-brand-border/50 opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition-all duration-200 transform origin-top translate-y-2 group-hover:translate-y-0 focus-within:translate-y-0 z-50 p-6 flex gap-8 min-w-0 mega-menu-dropdown">
                                {item.groups?.map((group) => (
                                    <div class="flex-1 min-w-[200px]">
                                        <h3 class="text-xs font-bold text-brand-textMuted uppercase tracking-wider mb-3">{group.label}</h3>
                                        <ul class="space-y-2">
                                            {group.links.map((subLink) => (
                                                <li>
                                                    <a href={subLink.href} class="group/link flex items-center text-sm font-medium text-brand-textMain hover:text-brand-primary transition-colors focus-ring p-2 -mx-2 rounded-md hover:bg-brand-softBg">
                                                        <span class="mr-2 text-brand-accent group-hover/link:text-brand-primary transition-colors">
                                                            {subLink.icon === 'LayoutGrid' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>}
                                                            {subLink.icon === 'PenTool' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>}
                                                            {subLink.icon === 'Database' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>}
                                                            {subLink.icon === 'Cpu' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>}
                                                            {subLink.icon === 'RefreshCw' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>}
                                                            {subLink.icon === 'Workflow' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="6" height="6" rx="1"></rect><rect x="15" y="15" width="6" height="6" rx="1"></rect><path d="M6 9v3a2 2 0 0 0 2 2h7a2 2 0 0 1 2 2v3"></path></svg>}
                                                            {subLink.icon === 'LifeBuoy' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="4"></circle><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"></line><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"></line><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"></line><line x1="14.83" y1="9.17" x2="18.36" y2="5.64"></line><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"></line></svg>}
                                                        </span>
                                                        {subLink.label}
                                                    </a>
                                                </li>
                                            ))}
                                        </ul>
                                    </div>
                                ))}
                            </div>
                        </div>
                    ) : null
                ) : null
            ))}

            <div class="flex items-center ml-2 xl:ml-4 pl-4 xl:pl-6 border-l border-brand-border/60">
                <a href="/book-free-audit/" class="bg-brand-accent text-white px-5 py-2.5 rounded-md font-semibold hover-lift click-press focus-ring transition-all duration-300 hover:bg-brand-primary shadow hover:shadow-md whitespace-nowrap">Get 24–48 Hour Review</a>
            </div>
        </nav>
        <div class="xl:hidden flex items-center">
            <MobileMenu />
        </div>
    </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const dropdowns = document.querySelectorAll('.nav-dropdown-container, .nav-mega-container');

    dropdowns.forEach(dropdown => {
      const toggleBtn = dropdown.querySelector('.dropdown-toggle-btn, .mega-toggle-btn');
      const menuContent = dropdown.querySelector('.dropdown-menu, .mega-menu-dropdown');
      const chevron = dropdown.querySelector('.lucide-chevron-down');
      let isOpen = false;
      let closeTimeout = null;

      const openMenu = () => {
        // Close others
        dropdowns.forEach(other => {
          if (other !== dropdown) {
            const otherBtn = other.querySelector('.dropdown-toggle-btn, .mega-toggle-btn');
            if (otherBtn && otherBtn.getAttribute('aria-expanded') === 'true') {
              other.dispatchEvent(new CustomEvent('close-dropdown'));
            }
          }
        });

        isOpen = true;
        if(toggleBtn) toggleBtn.setAttribute('aria-expanded', 'true');
        menuContent.classList.remove('opacity-0', 'invisible', 'translate-y-2');
        menuContent.classList.add('opacity-100', 'visible', 'translate-y-0');
        if(chevron) chevron.classList.add('rotate-180');
      };

      const closeMenu = () => {
        isOpen = false;
        if(toggleBtn) toggleBtn.setAttribute('aria-expanded', 'false');
        menuContent.classList.remove('opacity-100', 'visible', 'translate-y-0');
        menuContent.classList.add('opacity-0', 'invisible', 'translate-y-2');
        if(chevron) chevron.classList.remove('rotate-180');
      };

      dropdown.addEventListener('close-dropdown', closeMenu);

      // Hover
      dropdown.addEventListener('mouseenter', () => {
        clearTimeout(closeTimeout);
        if (!isOpen) openMenu();
      });

      dropdown.addEventListener('mouseleave', () => {
        closeTimeout = setTimeout(() => {
          if (isOpen) closeMenu();
        }, 150); // small delay to make it smooth
      });

      // Click on toggle
      if (toggleBtn) {
        toggleBtn.addEventListener('click', (e) => {
          e.preventDefault();
          if (isOpen) {
            closeMenu();
          } else {
            openMenu();
          }
        });
      }

      // Keyboard support
      dropdown.addEventListener('keydown', (e) => {
        // Escape to close
        if (e.key === 'Escape' && isOpen) {
          closeMenu();
          if(toggleBtn) toggleBtn.focus();
        }
      });

      // Focus leaves navigation (Shift+Tab or Tab out)
      dropdown.addEventListener('focusout', (e) => {
        // If the new element receiving focus is not inside this dropdown
        if (!dropdown.contains(e.relatedTarget)) {
          closeMenu();
        }
      });
    });

    // Click outside to close all
    document.addEventListener('click', (e) => {
      dropdowns.forEach(dropdown => {
        const toggleBtn = dropdown.querySelector('.dropdown-toggle-btn, .mega-toggle-btn');
        if (toggleBtn && toggleBtn.getAttribute('aria-expanded') === 'true') {
          if (!dropdown.contains(e.target)) {
            dropdown.dispatchEvent(new CustomEvent('close-dropdown'));
          }
        }
      });
    });
  });
</script>
