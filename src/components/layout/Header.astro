---
import { getSiteSettings, getNavigation } from '../../sanity/queries';
import MobileMenu from './MobileMenu.astro';
import { aiAssistants } from '../../data/aiAssistants';

const siteSettings = await getSiteSettings();
const site = siteSettings || { name: 'TheEduAssist', email: 'Info@theeduassist.com', social: {} };

const navigation = await getNavigation();

const desktopNav = navigation?.header || [
    { label: 'Home', href: '/' },
    { label: 'Services', href: '/services/' },
    { label: 'Platforms', href: '/platforms/' },
    { label: 'Case Studies', href: '/case-studies/' },
    { label: 'Blog', href: '/blog/' },
];

const aboutDropdown = [
    { label: 'About TheEduAssist', href: '/about/' },
    { label: 'Contact', href: '/contact/' },
];

const servicesDropdown = [
    { label: 'All Services', href: '/services/' },
    { label: 'Course Creation & Curriculum Design', href: '/services/custom-elearning-development/' },
    { label: 'Kajabi Website & Course Setup', href: '/kajabi-services/' },
    { label: 'LMS Implementation & Migration', href: '/services/lms-implementation-migration/' },
    { label: 'AI-Powered E-Learning Support', href: '/services/ai-powered-elearning/' },
    { label: 'Content Conversion', href: '/services/content-conversion/' },
    { label: 'Funnels & Automation', href: '/services/funnels-automation/' },
    { label: 'Ongoing Support & Maintenance', href: '/services/ongoing-support-maintenance/' },
];

---
<header class="bg-white/90 backdrop-blur-md border-b border-brand-border/50 relative z-50 sticky top-0 shadow-sm transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
        <a href="/" class="flex items-center space-x-3 focus-ring rounded-sm group shrink-0" aria-label="TheEduAssist Home">
            <img src="/brand/theeduassist-logo.svg" alt="TheEduAssist e-learning design agency logo" class="h-10 w-auto object-contain" />
            <div class="hidden md:flex flex-col">
                <span class="font-bold text-brand-primary text-xl leading-tight group-hover:text-brand-accent transition-colors duration-300">TheEduAssist</span>
                <span class="text-xs text-brand-textMuted font-medium uppercase tracking-wider">E-Learning Design Agency</span>
            </div>
        </a>
        <nav class="hidden lg:flex space-x-3 xl:space-x-4 items-center relative">
            {desktopNav.map((item) => (
                item.label === 'Services' ? (
                    <div class="relative group">
                        <button class="text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 px-3 py-2 font-medium focus-ring rounded-md transition-all duration-300 inline-flex items-center" aria-expanded="false" aria-haspopup="true">
                            {item.label}
                            <svg class="ml-1 w-4 h-4 text-brand-textMuted group-hover:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div class="absolute left-0 mt-2 w-72 bg-white/95 backdrop-blur-md rounded-xl shadow-xl border border-brand-border/50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top translate-y-2 group-hover:translate-y-0 z-50 overflow-hidden">
                            <div class="py-2">
                                {servicesDropdown.map((subItem, index) => (
                                    <a href={subItem.href} class={`block px-4 py-2.5 text-sm font-medium text-brand-textMain hover:bg-brand-softBg hover:text-brand-primary transition-colors focus-ring ${index === 0 ? 'border-b border-brand-border/30 font-bold mb-1' : ''}`}>
                                        {subItem.label}
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                ) : (
                    <a href={item.href} class="text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 px-3 py-2 font-medium focus-ring rounded-md transition-all duration-300">{item.label}</a>
                )
            ))}

            <div class="relative group">
                <button class="text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 px-3 py-2 font-medium focus-ring rounded-md transition-all duration-300 inline-flex items-center" aria-expanded="false" aria-haspopup="true">
                    About
                    <svg class="ml-1 w-4 h-4 text-brand-textMuted group-hover:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
                <div class="absolute left-0 mt-2 w-56 bg-white/95 backdrop-blur-md rounded-xl shadow-xl border border-brand-border/50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top translate-y-2 group-hover:translate-y-0 z-50 overflow-hidden">
                    <div class="py-2">
                        {aboutDropdown.map((item, index) => (
                            <a href={item.href} class="block px-4 py-2.5 text-sm font-medium text-brand-textMain hover:bg-brand-softBg hover:text-brand-primary transition-colors focus-ring">
                                {item.label}
                            </a>
                        ))}
                    </div>
                </div>
            </div>

            <div class="flex items-center ml-2 xl:ml-4 pl-4 xl:pl-6 border-l border-brand-border/60">
                <a href="/book-free-audit/" class="bg-brand-accent text-white px-5 py-2.5 rounded-md font-semibold hover-lift click-press focus-ring transition-all duration-300 hover:bg-brand-primary shadow hover:shadow-md whitespace-nowrap">Get 24–48 Hour Review</a>
            </div>
        </nav>
        <div class="lg:hidden flex items-center">
            <MobileMenu />
        </div>
    </div>
</header>
