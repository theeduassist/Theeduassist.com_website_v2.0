---
import { siteNavigation } from '../../data/siteNavigation';
---

<mobile-menu class="relative block">
  <button
    id="mobile-menu-btn"
    type="button"
    class="inline-flex items-center justify-center p-2 rounded-md text-brand-primary hover:text-brand-navy hover:bg-brand-softBg focus:outline-none transition-colors focus-ring"
    aria-controls="mobile-menu-panel"
    aria-expanded="false"
  >
    <span class="sr-only">Open main menu</span>
    <span class="mr-2 font-medium">Menu</span>
    <!-- Icon when menu is closed. -->
    <svg id="icon-closed" class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
    <!-- Icon when menu is open. -->
    <svg id="icon-open" class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu-panel"
    class="hidden absolute top-full right-0 mt-2 w-80 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 overflow-y-auto max-h-[85vh] z-50 origin-top-right transition-opacity duration-200 pb-4"
  >
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      {siteNavigation.map((item) => {
        if (!item.enabled) return null;

        if (item.type === 'link') {
            return (
                <a href={item.href} class="block px-3 py-3 rounded-md text-base font-medium text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 focus-ring mobile-link">
                    {item.label}
                </a>
            );
        }

        if (item.type === 'dropdown' || item.type === 'mega-menu') {
            return (
                <div class="mobile-accordion-group border-y border-brand-border/30 my-1 py-1">
                    <div class="w-full flex justify-between items-center rounded-md text-base font-medium text-brand-textMain hover:bg-brand-accent/10">
                        {item.href ? (
                            <a href={item.href} class="px-3 py-3 flex-grow hover:text-brand-accent focus-ring mobile-link">{item.label}</a>
                        ) : (
                            <span class="px-3 py-3 flex-grow">{item.label}</span>
                        )}
                        <button class="mobile-accordion-btn px-4 py-3 hover:text-brand-accent focus-ring flex items-center justify-center" aria-expanded="false" aria-controls={`mobile-panel-${item.id}`} aria-label={`Toggle ${item.label} submenu`}>
                            <svg class="mobile-accordion-icon w-5 h-5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                    </div>
                    <div id={`mobile-panel-${item.id}`} class="mobile-accordion-list hidden pl-4 pr-2 py-2 space-y-4 bg-brand-softBg/50 rounded-b-md border-t border-brand-border/30 mt-1">
                        {item.groups?.map(group => (
                            <div class="space-y-1">
                                {group.label && <h4 class="px-3 text-xs font-bold uppercase tracking-wider text-brand-textMuted mb-2">{group.label}</h4>}
                                {group.links.map((subLink) => (
                                    <a href={subLink.href} class="block px-3 py-2 rounded-md text-sm font-medium text-brand-textMain hover:text-brand-primary hover:bg-brand-accent/10 focus-ring mobile-link">
                                        {subLink.label}
                                    </a>
                                ))}
                            </div>
                        ))}
                    </div>
                </div>
            );
        }
        return null;
      })}

      <div class="pt-4 mt-2 border-t border-brand-border/30 px-2">
          <a href="/book-free-audit/" class="block px-3 py-3 rounded-md text-base font-bold text-white bg-brand-accent hover:bg-brand-primary focus-ring mobile-link text-center w-full shadow-sm">
            Get 24–48 Hour Review
          </a>
      </div>
    </div>
  </div>
</mobile-menu>

<script>
  class MobileMenu extends HTMLElement {
    constructor() {
      super();
      this.btn = this.querySelector('#mobile-menu-btn');
      this.panel = this.querySelector('#mobile-menu-panel');

      this.accordionBtns = this.querySelectorAll('.mobile-accordion-btn');

      this.iconClosed = this.querySelector('#icon-closed');
      this.iconOpen = this.querySelector('#icon-open');
      this.links = this.querySelectorAll('.mobile-link');
      this.isOpen = false;

      this.toggleMenu = this.toggleMenu.bind(this);
      this.closeMenu = this.closeMenu.bind(this);
      this.handleEscape = this.handleEscape.bind(this);

      this.btn?.addEventListener('click', this.toggleMenu);

      this.accordionBtns.forEach(btn => {
          btn.addEventListener('click', this.toggleAccordion.bind(this));
      });

      window.addEventListener('keydown', this.handleEscape);
      this.links.forEach(link => link.addEventListener('click', this.closeMenu));
    }

    toggleAccordion(e: Event) {
      e.stopPropagation();
      const btn = e.currentTarget as HTMLButtonElement;
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      const controlsId = btn.getAttribute('aria-controls');
      const list = this.querySelector(`#${controlsId}`);
      const icon = btn.querySelector('.mobile-accordion-icon');

      btn.setAttribute('aria-expanded', (!isExpanded).toString());
      if (isExpanded) {
        list?.classList.add('hidden');
        icon?.classList.remove('rotate-180');
      } else {
        list?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
      }
    }

    toggleMenu() {
      this.isOpen = !this.isOpen;
      this.btn?.setAttribute('aria-expanded', this.isOpen.toString());
      if (this.isOpen) {
        this.panel?.classList.remove('hidden');
        this.iconClosed?.classList.add('hidden');
        this.iconClosed?.classList.remove('block');
        this.iconOpen?.classList.remove('hidden');
        this.iconOpen?.classList.add('block');
      } else {
        this.panel?.classList.add('hidden');
        this.iconClosed?.classList.remove('hidden');
        this.iconClosed?.classList.add('block');
        this.iconOpen?.classList.add('hidden');
        this.iconOpen?.classList.remove('block');
      }
    }

    closeMenu() {
      if (this.isOpen) {
        this.toggleMenu();
      }
    }

    handleEscape(e: KeyboardEvent) {
      if (e.key === 'Escape' && this.isOpen) {
        this.closeMenu();
        if (this.btn instanceof HTMLElement) {
          this.btn.focus();
        }
      }
    }
  }

  customElements.define('mobile-menu', MobileMenu);
</script>
