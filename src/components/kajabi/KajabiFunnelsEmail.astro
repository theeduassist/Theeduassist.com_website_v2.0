---
---
<section class="py-16 bg-white border-b border-brand-border/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Connect Lead Capture, Funnels and Email Journeys</h2>
      <p class="text-lg text-brand-textMain">We map out and build the automated communications that turn visitors into subscribers, and subscribers into engaged learners.</p>
    </div>

    <div class="max-w-4xl mx-auto mb-16 overflow-hidden">
      <div class="p-6 bg-brand-softBg rounded-xl border border-brand-border/50 shadow-sm relative">
        <h3 class="text-lg font-bold text-center text-brand-navy mb-8 border-b border-brand-border/50 pb-4">Example Sales Journey Flow</h3>

        <div class="flex flex-col md:flex-row justify-between items-center relative z-10 px-4">

          <div class="flex flex-col items-center mb-6 md:mb-0 w-24">
            <div class="w-12 h-12 bg-blue-100 text-brand-primary rounded-full flex items-center justify-center mb-2 shadow-sm border border-blue-200">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
            </div>
            <span class="text-xs font-bold text-center text-slate-700">Landing Page</span>
          </div>

          <div class="hidden md:block flex-1 border-t-2 border-dashed border-brand-primary/30 mx-2"></div>
          <div class="md:hidden h-6 border-l-2 border-dashed border-brand-primary/30 my-1"></div>

          <div class="flex flex-col items-center mb-6 md:mb-0 w-24">
            <div class="w-12 h-12 bg-blue-100 text-brand-primary rounded-full flex items-center justify-center mb-2 shadow-sm border border-blue-200">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <span class="text-xs font-bold text-center text-slate-700">Form</span>
          </div>

          <div class="hidden md:block flex-1 border-t-2 border-dashed border-brand-primary/30 mx-2"></div>
          <div class="md:hidden h-6 border-l-2 border-dashed border-brand-primary/30 my-1"></div>

          <div class="flex flex-col items-center mb-6 md:mb-0 w-24">
            <div class="w-12 h-12 bg-green-100 text-green-700 rounded-full flex items-center justify-center mb-2 shadow-sm border border-green-200">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <span class="text-xs font-bold text-center text-slate-700">Email Sequence</span>
          </div>

          <div class="hidden md:block flex-1 border-t-2 border-dashed border-brand-primary/30 mx-2"></div>
          <div class="md:hidden h-6 border-l-2 border-dashed border-brand-primary/30 my-1"></div>

          <div class="flex flex-col items-center mb-6 md:mb-0 w-24">
            <div class="w-12 h-12 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center mb-2 shadow-sm border border-amber-200">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <span class="text-xs font-bold text-center text-slate-700">Offer Checkout</span>
          </div>

          <div class="hidden md:block flex-1 border-t-2 border-dashed border-brand-primary/30 mx-2"></div>
          <div class="md:hidden h-6 border-l-2 border-dashed border-brand-primary/30 my-1"></div>

          <div class="flex flex-col items-center w-24">
            <div class="w-12 h-12 bg-purple-100 text-purple-700 rounded-full flex items-center justify-center mb-2 shadow-sm border border-purple-200">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"></path></svg>
            </div>
            <span class="text-xs font-bold text-center text-slate-700">Onboarding</span>
          </div>

        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-xl font-bold text-brand-navy mb-4">Lead Generation and Funnels</h3>
        <ul class="space-y-3 text-brand-textMain">
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <span>Lead-generation forms and opt-in pages</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <span>Lead magnet delivery configuration</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <span>Funnel planning and dedicated Funnel Pages</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <span>Sales journey structuring</span>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-xl font-bold text-brand-navy mb-4">Email Marketing</h3>
        <ul class="space-y-3 text-brand-textMain">
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <span>Email broadcasts and sequences/campaigns</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <span>Welcome, launch, and post-purchase communication</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <span>Tags, segmentation, and event-related flows</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
            <span>Unsubscribe and consent fundamentals configuration</span>
          </li>
        </ul>
      </div>
    </div>

  </div>
</section>
