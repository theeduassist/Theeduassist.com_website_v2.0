<section class="py-16 bg-brand-softBg border-b border-brand-border/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Choose the Kajabi Support That Matches Your Project</h2>
      <p class="text-lg text-brand-textMain">From strategic reviews to complete implementations and ongoing management.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <div class="bg-white rounded-xl p-8 border border-brand-border shadow-sm flex flex-col h-full">
        <h3 class="text-xl font-bold text-brand-navy mb-2">Kajabi Review and Recommendations</h3>
