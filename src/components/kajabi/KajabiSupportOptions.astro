        <div class="pt-6 border-t border-brand-border/50">
          <a href="/book-free-kajabi-audit/" class="block w-full text-center px-4 py-2 border border-brand-primary text-brand-primary font-bold rounded hover:bg-brand-primary hover:text-white transition-colors">
