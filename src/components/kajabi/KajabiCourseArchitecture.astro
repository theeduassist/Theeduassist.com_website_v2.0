<section class="py-16 bg-white border-b border-brand-border/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-6">Turn Your Expertise into a Structured Kajabi Course</h2>
        <p class="text-lg text-brand-textMain mb-6">Instructional design comes before platform setup. We support audience and learning-goal review to build an intentional curriculum map.</p>

        <ul class="space-y-3 text-brand-textMain mb-8">
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span>
            <span>Outline modules, lessons, and the required learning sequence</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span>
            <span>Organize text, audio, video, downloads, and supporting resources</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span>
            <span>Configure quizzes, assessments, and drip or scheduled delivery (where supported)</span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-secondary mt-1 mr-3"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span>
            <span>Design learner progression, course navigation, and onboarding instructions</span>
          </li>
        </ul>

        <a href="/contact/" class="inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-bold rounded-md text-white bg-brand-primary hover:bg-brand-primary/90 transition-colors shadow-sm">
          Discuss Your Course Build
          <svg class="ml-2 -mr-1 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>

      <div class="bg-brand-softBg p-8 rounded-2xl border border-brand-border/50">
        <h3 class="text-xl font-bold text-brand-navy mb-6 pb-4 border-b border-brand-border">Our Structured Process</h3>
        <ol class="space-y-4">
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold text-sm">1</div>
            <div>
              <span class="font-bold text-brand-navy block">Review the source content</span>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold text-sm">2</div>
            <div>
              <span class="font-bold text-brand-navy block">Define learning outcomes</span>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold text-sm">3</div>
            <div>
              <span class="font-bold text-brand-navy block">Build the curriculum map</span>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold text-sm">4</div>
            <div>
              <span class="font-bold text-brand-navy block">Organize modules and lessons</span>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold text-sm">5</div>
            <div>
              <span class="font-bold text-brand-navy block">Plan activities and assessments</span>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold text-sm">6</div>
            <div>
              <span class="font-bold text-brand-navy block">Prepare Kajabi-ready content</span>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-secondary text-white flex items-center justify-center font-bold text-sm">7</div>
            <div>
              <span class="font-bold text-brand-navy block">Build and test the learner journey</span>
            </div>
          </li>
        </ol>
      </div>

    </div>
  </div>
</section>
