---
---
<section class="py-16 bg-brand-softBg border-b border-brand-border/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <div class="order-2 lg:order-1 relative">
        <div class="bg-white rounded-xl border border-brand-border shadow-md overflow-hidden relative">
          <!-- Conceptual mockup of a checkout flow -->
          <div class="bg-slate-100 px-4 py-2 border-b border-slate-200 flex items-center space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-amber-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
            <div class="ml-4 text-xs text-slate-400 font-medium tracking-wide w-full text-center pr-12">Secure Checkout</div>
          </div>
          <div class="p-6 md:p-8 space-y-6">
            <div class="w-1/3 h-6 bg-slate-200 rounded"></div>
            <div class="space-y-3">
              <div class="h-10 bg-slate-100 rounded border border-slate-200 w-full"></div>
              <div class="h-10 bg-slate-100 rounded border border-slate-200 w-full"></div>
            </div>

            <div class="pt-4 border-t border-slate-100 space-y-3">
              <div class="flex justify-between items-center">
                <div class="h-4 bg-slate-200 rounded w-1/4"></div>
                <div class="h-4 bg-slate-300 rounded w-1/6"></div>
              </div>
              <div class="flex justify-between items-center">
                <div class="h-4 bg-slate-200 rounded w-1/3"></div>
                <div class="h-4 bg-slate-300 rounded w-1/6"></div>
              </div>
            </div>

            <div class="pt-2">
              <div class="h-12 bg-brand-primary rounded w-full flex items-center justify-center">
                <div class="h-4 bg-white/50 rounded w-1/4"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">Create a Clear Checkout and Post-Purchase Experience</h2>
        <p class="text-lg text-brand-textMain mb-6">We configure Kajabi’s checkout flow to ensure a seamless transition from sales page to student onboarding.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 text-brand-textMain mb-8">
          <ul class="space-y-3">
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Enhanced Checkout and styling</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Checkout sections and blocks</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Mobile-responsive layouts</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Form fields and terms consent</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Coupons configuration</span>
            </li>
          </ul>

          <ul class="space-y-3">
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Order bumps (where supported)</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Upsells (where supported)</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Checkout redirects</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Thank-you page destinations</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-secondary mt-0.5 mr-2">✓</span>
              <span>Customer account access paths</span>
            </li>
          </ul>
        </div>

        <div class="bg-white p-5 rounded-lg border border-brand-border/50">
          <p class="text-sm font-bold text-brand-navy mb-2">Our Checkout Delivery Standard</p>
          <p class="text-sm text-brand-textMain">All checkout work includes design, configuration, connection testing, mobile testing, and user-experience review before launch.</p>
        </div>
      </div>

    </div>
  </div>
</section>
