---
---
<section class="py-16 bg-brand-softBg border-b border-brand-border/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">More Than a Kajabi Website or Course Upload</h2>
      <p class="text-lg text-brand-textMain">A complete Kajabi setup may connect website pages, Funnels, Products, Offers, checkout, email campaigns, Automations, and the customer Library. The final architecture depends on your specific offer and chosen plan.</p>
    </div>

    <div class="bg-white p-6 sm:p-10 rounded-2xl border border-brand-border shadow-md max-w-5xl mx-auto overflow-x-auto">
      <div class="min-w-[600px] flex flex-col md:flex-row items-center justify-between gap-4 py-4">

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-slate-100 border border-slate-200 mb-2">
            <span class="text-sm font-semibold text-slate-700">Visitor</span>
          </div>
          <div class="h-6 border-l-2 border-brand-primary/30 my-1 md:hidden"></div>
          <svg class="w-5 h-5 text-brand-primary/50 hidden md:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </div>

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-blue-50 border border-blue-100 mb-2">
            <span class="text-sm font-semibold text-brand-navy">Website, Landing Page or Funnel</span>
          </div>
          <div class="h-6 border-l-2 border-brand-primary/30 my-1 md:hidden"></div>
          <svg class="w-5 h-5 text-brand-primary/50 hidden md:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </div>

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-blue-50 border border-blue-100 mb-2">
            <span class="text-sm font-semibold text-brand-navy">Form or Offer</span>
          </div>
          <div class="h-6 border-l-2 border-brand-primary/30 my-1 md:hidden"></div>
          <svg class="w-5 h-5 text-brand-primary/50 hidden md:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </div>

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-green-50 border border-green-100 mb-2">
            <span class="text-sm font-semibold text-brand-secondary">Checkout</span>
          </div>
          <div class="h-6 border-l-2 border-brand-primary/30 my-1 md:hidden"></div>
          <svg class="w-5 h-5 text-brand-primary/50 hidden md:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </div>

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-green-50 border border-green-100 mb-2">
            <span class="text-sm font-semibold text-brand-secondary">Confirmation</span>
          </div>
          <div class="h-6 border-l-2 border-brand-primary/30 my-1 md:hidden"></div>
          <svg class="w-5 h-5 text-brand-primary/50 hidden md:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </div>

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-purple-50 border border-purple-100 mb-2">
            <span class="text-sm font-semibold text-purple-900">Account & Login</span>
          </div>
          <div class="h-6 border-l-2 border-brand-primary/30 my-1 md:hidden"></div>
          <svg class="w-5 h-5 text-brand-primary/50 hidden md:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </div>

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-purple-50 border border-purple-100 mb-2">
            <span class="text-sm font-semibold text-purple-900">Library</span>
          </div>
          <div class="h-6 border-l-2 border-brand-primary/30 my-1 md:hidden"></div>
          <svg class="w-5 h-5 text-brand-primary/50 hidden md:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </div>

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-brand-primary text-white mb-2 shadow-sm">
            <span class="text-sm font-bold">Course or Product</span>
          </div>
          <div class="h-6 border-l-2 border-brand-primary/30 my-1 md:hidden"></div>
          <svg class="w-5 h-5 text-brand-primary/50 hidden md:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </div>

        <div class="flex flex-col items-center flex-1">
          <div class="w-full text-center p-3 rounded bg-amber-50 border border-amber-100 mb-2">
            <span class="text-sm font-semibold text-amber-900">Follow-up & Support</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
