<section class="py-16 bg-white border-b border-brand-border/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Test the System Before It Reaches Customers</h2>
      <p class="text-lg text-brand-textMain">A successful launch requires technical verification across the entire learner journey.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

      <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/50">
        <h3 class="text-lg font-bold text-brand-navy mb-4 border-b border-brand-border pb-2">Website & Pages</h3>
        <ul class="space-y-2 text-sm text-brand-textMain">
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Desktop & mobile layout</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Navigation & links</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Buttons & forms</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Page titles & metadata</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Domain behavior & redirects</li>
        </ul>
      </div>

      <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/50">
        <h3 class="text-lg font-bold text-brand-navy mb-4 border-b border-brand-border pb-2">Products</h3>
        <ul class="space-y-2 text-sm text-brand-textMain">
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Module & lesson order</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Content display & videos</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Downloads & quizzes</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Access & drip settings</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Learner navigation</li>
        </ul>
      </div>

      <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/50">
        <h3 class="text-lg font-bold text-brand-navy mb-4 border-b border-brand-border pb-2">Sales & Checkout</h3>
        <ul class="space-y-2 text-sm text-brand-textMain">
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Product/Offer connections</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Pricing & coupons</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Checkout experience</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Order bumps / upsells</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Thank-you destination</li>
        </ul>
      </div>

      <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/50">
        <h3 class="text-lg font-bold text-brand-navy mb-4 border-b border-brand-border pb-2">Email & Automation</h3>
        <ul class="space-y-2 text-sm text-brand-textMain">
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Form triggers</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Email delivery initiation</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Tags & sequences</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Purchase triggers</li>
          <li class="flex"><span class="text-brand-secondary mr-2">✓</span> Automation conditions</li>
        </ul>
      </div>

    </div>

  </div>
</section>
