---
---
<section class="py-16 bg-white border-b border-brand-border/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Design the Complete Journey, Not Just Individual Pages</h2>
      <p class="text-lg text-brand-textMain">We review, organize, design, configure, test, and document the entire pathway your customer experiences—from first click to course completion.</p>
    </div>

    <div class="relative max-w-5xl mx-auto">
      <!-- Desktop vertical line -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-1 bg-brand-primary/20 -translate-x-1/2"></div>

      <div class="space-y-12 relative z-10">

        <!-- Stage 1 -->
        <div class="flex flex-col md:flex-row items-center">
          <div class="md:w-1/2 md:pr-12 md:text-right mb-6 md:mb-0">
            <h3 class="text-2xl font-bold text-brand-navy mb-2">1. Discovery</h3>
            <p class="text-brand-textMain">Website, Blog, Landing Page or referral. We structure the top-of-funnel entry points.</p>
          </div>
          <div class="w-12 h-12 bg-white rounded-full border-4 border-brand-primary flex items-center justify-center flex-shrink-0 font-bold text-brand-primary z-10 mx-auto md:mx-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <div class="md:w-1/2 md:pl-12 hidden md:block"></div>
        </div>

        <!-- Stage 2 -->
        <div class="flex flex-col md:flex-row items-center">
          <div class="md:w-1/2 md:pr-12 hidden md:block"></div>
          <div class="w-12 h-12 bg-white rounded-full border-4 border-brand-secondary flex items-center justify-center flex-shrink-0 font-bold text-brand-secondary z-10 mx-auto md:mx-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          </div>
          <div class="md:w-1/2 md:pl-12 md:text-left mt-6 md:mt-0 text-center md:text-left">
            <h3 class="text-2xl font-bold text-brand-navy mb-2">2. Lead Capture</h3>
            <p class="text-brand-textMain">Form, registration or lead magnet. We configure the opt-in mechanisms to secure contact data.</p>
          </div>
        </div>

        <!-- Stage 3 -->
        <div class="flex flex-col md:flex-row items-center">
          <div class="md:w-1/2 md:pr-12 md:text-right mb-6 md:mb-0">
            <h3 class="text-2xl font-bold text-brand-navy mb-2">3. Offer</h3>
            <p class="text-brand-textMain">Sales page, Offer and pricing setup. We design the commercial presentation.</p>
          </div>
          <div class="w-12 h-12 bg-white rounded-full border-4 border-brand-primary flex items-center justify-center flex-shrink-0 font-bold text-brand-primary z-10 mx-auto md:mx-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div class="md:w-1/2 md:pl-12 hidden md:block"></div>
        </div>

        <!-- Stage 4 -->
        <div class="flex flex-col md:flex-row items-center">
          <div class="md:w-1/2 md:pr-12 hidden md:block"></div>
          <div class="w-12 h-12 bg-white rounded-full border-4 border-brand-secondary flex items-center justify-center flex-shrink-0 font-bold text-brand-secondary z-10 mx-auto md:mx-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          </div>
          <div class="md:w-1/2 md:pl-12 md:text-left mt-6 md:mt-0 text-center md:text-left">
            <h3 class="text-2xl font-bold text-brand-navy mb-2">4. Purchase</h3>
            <p class="text-brand-textMain">Checkout, payment and confirmation. We configure and test the transaction pathway.</p>
          </div>
        </div>

        <!-- Stage 5 -->
        <div class="flex flex-col md:flex-row items-center">
          <div class="md:w-1/2 md:pr-12 md:text-right mb-6 md:mb-0">
            <h3 class="text-2xl font-bold text-brand-navy mb-2">5. Access</h3>
            <p class="text-brand-textMain">Account creation, login and Library. We streamline how customers actually enter the platform.</p>
          </div>
          <div class="w-12 h-12 bg-white rounded-full border-4 border-brand-primary flex items-center justify-center flex-shrink-0 font-bold text-brand-primary z-10 mx-auto md:mx-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
          </div>
          <div class="md:w-1/2 md:pl-12 hidden md:block"></div>
        </div>

        <!-- Stage 6 -->
        <div class="flex flex-col md:flex-row items-center">
          <div class="md:w-1/2 md:pr-12 hidden md:block"></div>
          <div class="w-12 h-12 bg-white rounded-full border-4 border-brand-secondary flex items-center justify-center flex-shrink-0 font-bold text-brand-secondary z-10 mx-auto md:mx-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
          </div>
          <div class="md:w-1/2 md:pl-12 md:text-left mt-6 md:mt-0 text-center md:text-left">
            <h3 class="text-2xl font-bold text-brand-navy mb-2">6. Learning</h3>
            <p class="text-brand-textMain">Course, Coaching, Community or Product. We organize the actual educational environment.</p>
          </div>
        </div>

        <!-- Stage 7 -->
        <div class="flex flex-col md:flex-row items-center">
          <div class="md:w-1/2 md:pr-12 md:text-right mb-6 md:mb-0">
            <h3 class="text-2xl font-bold text-brand-navy mb-2">7. Follow-Up</h3>
            <p class="text-brand-textMain">Email, Automations, support and future Offers. We map the ongoing retention and cross-sell communications.</p>
          </div>
          <div class="w-12 h-12 bg-white rounded-full border-4 border-brand-primary flex items-center justify-center flex-shrink-0 font-bold text-brand-primary z-10 mx-auto md:mx-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <div class="md:w-1/2 md:pl-12 hidden md:block"></div>
        </div>

      </div>
    </div>
  </div>
</section>
