---
// src/components/kajabi/KajabiFinalCTA.astro
---
<section class="py-24 bg-[#27496D] relative overflow-hidden">
  <!-- Subtle background pattern/shape -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-white opacity-5 rounded-full blur-3xl transform translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#77BA55] opacity-10 rounded-full blur-3xl transform -translate-x-1/3 translate-y-1/3 pointer-events-none"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Ready to Build or Improve Your Kajabi System?</h2>
    <p class="text-xl text-blue-100 mb-10 max-w-2xl mx-auto leading-relaxed">
      Get a 24-48 hour review and we'll review your current setup, content, offer, pages, funnel, emails, automations, and student experience to show what needs to be structured, built, fixed, or improved.
    </p>

    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/book-free-audit/?service=kajabi-website-course-setup&source=service-page" class="inline-flex justify-center items-center px-8 py-4 rounded-md bg-[#77BA55] text-white font-bold text-lg hover:bg-[#65a346] transition-colors shadow-lg hover:shadow-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-[#27496D] focus-visible:ring-[#77BA55]">
        Get Your Course Reviewed in 24–48 Hours
      </a>
      <button type="button" data-service-slug="kajabi-website-course-setup" class="tawk-service-btn inline-flex justify-center items-center px-8 py-4 rounded-md bg-transparent text-white font-bold text-lg border-2 border-white/20 hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-[#27496D] focus-visible:ring-white">Start This Service</button>
    </div>
  </div>

<script>
  import { openStartServiceChat } from '../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-service-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget;
        openStartServiceChat({
          serviceSlug: target.dataset.serviceSlug || '',
          pageUrl: window.location.href,
          pageTitle: document.title,
        });
      });
    });
  });
</script>
</section>
