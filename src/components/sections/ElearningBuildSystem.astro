---
// src/components/sections/ElearningBuildSystem.astro
const { process } = Astro.props;

const defaultSteps = [
    { title: "Knowledge Extraction", desc: "We pull the best ideas out of your head and your hard drive." },
    { title: "Curriculum Design", desc: "Structuring modules and lessons for maximum learner success." },
    { title: "Content Production", desc: "Creating the actual videos, PDFs, and text your students will consume." },
    { title: "Platform Build", desc: "Setting up Kajabi, your LMS, or your membership site perfectly." },
    { title: "Automation Setup", desc: "Connecting the tech so sales, emails, and access happen automatically." },
    { title: "Student Experience", desc: "Ensuring onboarding, communities, and support systems are flawless." }
];

const steps = process?.steps?.map((s: any) => ({ title: s.title, desc: s.description })) || defaultSteps;
---
<section class="py-20 md:py-28 bg-brand-softBg overflow-hidden relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">The Complete E-Learning Build System</h2>
            <p class="text-lg text-brand-textMuted">A proven framework for turning raw expertise into a scalable online business.</p>
        </div>

        <div class="bg-white p-8 md:p-16 rounded-3xl shadow-xl border border-brand-border/60 relative">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative z-10">
                {steps.map((block: any, index: number) => (
                    <div class="bg-brand-softBg border border-brand-border p-6 rounded-2xl hover:shadow-md transition-all hover:-translate-y-1 relative group">
                        <div class="absolute -top-4 -left-4 w-8 h-8 rounded-full bg-brand-accent text-white flex items-center justify-center font-bold text-sm shadow-md">{index + 1}</div>
                        <h3 class="text-xl font-bold text-brand-navy mb-3">{block.title}</h3>
                        <p class="text-brand-textMain text-sm">{block.desc}</p>
                    </div>
                ))}
            </div>

            <!-- Visual Connecting Lines (Desktop Only) -->
            <svg class="hidden lg:block absolute inset-0 w-full h-full z-0 pointer-events-none opacity-20" preserveAspectRatio="none">
                <path d="M 200 100 Q 300 50 400 100 T 600 100" fill="none" stroke="currentColor" class="text-brand-accent" stroke-width="2" stroke-dasharray="4 4" />
                <path d="M 200 300 Q 300 250 400 300 T 600 300" fill="none" stroke="currentColor" class="text-brand-accent" stroke-width="2" stroke-dasharray="4 4" />
            </svg>
        </div>
    </div>
</section>
