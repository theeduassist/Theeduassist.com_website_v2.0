---
import Button from '../ui/Button.astro';
---
<section class="py-24 bg-white relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-full bg-blue-50/50 -skew-y-2 transform origin-top-left -z-10"></div>
  <div class="max-w-4xl mx-auto px-4 text-center">
    <div class="inline-block px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-bold mb-6 tracking-wide uppercase">
      Featured Service
    </div>
    <h2 class="text-3xl md:text-4xl font-bold mb-6 text-slate-900">Expert Kajabi Services</h2>
    <p class="text-lg md:text-xl text-slate-600 mb-10 leading-relaxed max-w-2xl mx-auto">
      From course setup and website design to funnels, email automation, content upload, and migration, we help you build a cleaner Kajabi system that is easier to launch and manage.
    </p>
    <Button href="/kajabi-services/" variant="primary" size="lg">
      Explore Kajabi Services
    </Button>
  </div>
</section>
