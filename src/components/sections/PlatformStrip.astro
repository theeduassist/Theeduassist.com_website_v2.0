---
import Badge from '../ui/Badge.astro';
import { getPlatformsForBadges } from '../../sanity/queries';

const platforms = await getPlatformsForBadges();
---
<section class="py-12 border-y border-slate-200 bg-white">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h2 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-6">Platforms We Support</h2>
    <div class="flex flex-wrap justify-center gap-3">
      {platforms.map(p => (
        <Badge variant="outline">{p}</Badge>
      ))}
    </div>
    <p class="text-xs text-slate-400 mt-6">Platform support does not imply official partnership unless stated.</p>
  </div>
</section>
