---
<section class="py-20 md:py-28 bg-white border-b border-brand-border/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-4xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-brand-navy mb-6 leading-tight">
                AI Ethics & Responsible AI Training for Global Teams
            </h2>
            <p class="text-lg md:text-xl text-brand-textMuted leading-relaxed max-w-3xl mx-auto">
                Enterprises are adopting AI faster than most teams can be trained. TheEduAssist helps corporate L&D, HR, compliance, and operations teams turn AI ethics policies, responsible AI guidance, and internal rules into structured online training programs employees can actually follow.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
            {[
                { title: "AI Literacy Training", desc: "Build foundational AI understanding for all employees to ensure safe and effective use." },
                { title: "Responsible AI Use", desc: "Train teams on data privacy, copyright awareness, and safe prompting habits." },
                { title: "AI Policy-to-Training Conversion", desc: "Convert internal AI governance documents into plain-language learning modules." },
                { title: "LMS-Ready Employee Modules", desc: "Structured, ready-to-upload SCORM or xAPI packages for Docebo, TalentLMS, and more." },
                { title: "Scenario-Based Learning", desc: "Practical knowledge checks based on real workplace AI dilemmas and escalations." },
                { title: "Global Team Rollout", desc: "Role-based training paths for HR, Sales, Support, and Operations teams." }
            ].map(card => (
                <div class="bg-brand-softBg p-8 rounded-2xl border border-brand-border/50 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center text-brand-primary mb-6 shadow-sm">
                        <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-brand-navy mb-3">{card.title}</h3>
                    <p class="text-brand-textMain leading-relaxed">{card.desc}</p>
                </div>
            ))}
        </div>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
            <a href="/services/ai-ethics-corporate-training/" class="w-full sm:w-auto bg-brand-primary text-white px-8 py-3.5 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-brand-navy shadow-md text-center">
                Build AI Ethics Training
            </a>
            <a href="/book-free-audit/" class="w-full sm:w-auto bg-white text-brand-navy border border-brand-border px-8 py-3.5 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-brand-softBg shadow-sm text-center">
                Get 24–48 Hour Review
            </a>
        </div>
    </div>
</section>
