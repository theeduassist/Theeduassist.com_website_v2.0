---
const services = [
  {
    title: "Course Creation & Curriculum Design",
    description: "We structure your raw knowledge into clear modules, actionable lessons, and logical learner journeys.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>`,
    link: "/services/custom-elearning-development/"
  },
  {
    title: "Kajabi Website & Course Setup",
    description: "Complete build-outs of your Kajabi platform, from marketing pages to backend course product delivery.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>`,
    link: "/kajabi-services/"
  },
  {
    title: "LMS Implementation & Migration",
    description: "Seamlessly move your content between platforms or launch a brand new Learning Management System.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>`,
    link: "/services/lms-implementation-migration/"
  },
  {
    title: "Instructional Design & Learner Experience",
    description: "Applying proven educational psychology so students actually finish your course and get results.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>`,
    link: "/services/"
  },
  {
    title: "AI-Powered E-Learning Assistance",
    description: "Leverage AI workflows to rapidly generate lesson scripts, quizzes, outlines, and support materials.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>`,
    link: "/services/ai-assistance/"
  },
  {
    title: "Content Conversion",
    description: "Turn webinars, old PDFs, or live coaching recordings into polished, evergreen digital course assets.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>`,
    link: "/services/"
  },
  {
    title: "Funnels & Automation",
    description: "Build the marketing systems that sell your course, from lead magnets to automated email sequences.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>`,
    link: "/services/"
  },
  {
    title: "Ongoing Support & Maintenance",
    description: "Continuous updates, platform management, and technical troubleshooting so you can focus on teaching.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>`,
    link: "/contact/"
  }
];
---
<section class="py-24 bg-white relative">
    <!-- Decorative background element -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-brand-softBg/50 -skew-x-12 -z-10 origin-top-right"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <span class="text-brand-accent font-bold tracking-wider uppercase text-sm mb-2 block">Our Capabilities</span>
            <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Everything You Need to Build, Launch, and Improve Online Learning</h2>
            <p class="text-lg text-brand-textMuted">We handle the heavy lifting of platform architecture, instructional design, and marketing systems so you can focus on sharing your expertise.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {services.map((service) => (
                <div class="bg-white p-6 rounded-2xl border border-brand-border shadow-sm hover:shadow-card hover:-translate-y-1 transition-all duration-300 flex flex-col group">
                    <div class="w-12 h-12 bg-brand-softBg text-brand-primary rounded-lg flex items-center justify-center mb-5 group-hover:bg-brand-primary group-hover:text-white transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon}></svg>
                    </div>
                    <h3 class="text-lg font-bold text-brand-navy mb-2 leading-tight">{service.title}</h3>
                    <p class="text-sm text-brand-textMuted leading-relaxed mb-6 flex-grow">{service.description}</p>
                    <a href={service.link} class="inline-flex items-center text-sm font-semibold text-brand-accent hover:text-brand-primary transition-colors mt-auto group-hover:underline underline-offset-4">
                        Learn more
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </a>
                </div>
            ))}
        </div>
    </div>
</section>
