---
const { ctaBlocks = [] } = Astro.props;

// Use CMS data if available and valid
let displayTitle = "Ready to Build a Better Learning Experience?";
let displayDescription = "Share your course idea, Kajabi setup, LMS, or existing learning content. We’ll review it and recommend the clearest next step for structuring, building, or improving it.";
let primaryLabel = "Get a 24–48 Hour Review";
let primaryHref = "/book-free-audit/";
let secondaryLabel = "Contact Our Team";
let secondaryHref = "/contact/";

if (ctaBlocks && ctaBlocks.length > 0) {
    const cmsCta = ctaBlocks[0];
    if (cmsCta.title && cmsCta.title !== "primary-cta") displayTitle = cmsCta.title;
    if (cmsCta.description) displayDescription = cmsCta.description;
    if (cmsCta.primaryAction?.label) primaryLabel = cmsCta.primaryAction.label;
    if (cmsCta.primaryAction?.href) primaryHref = cmsCta.primaryAction.href;
    if (cmsCta.secondaryAction?.label) secondaryLabel = cmsCta.secondaryAction.label;
    if (cmsCta.secondaryAction?.href) secondaryHref = cmsCta.secondaryAction.href;
}
---
<section class="py-24 bg-brand-primary text-white relative overflow-hidden">
    <!-- Decorative background -->
    <div class="absolute inset-0 z-0 opacity-10">
        <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path d="M0,100 C30,50 70,50 100,0 L100,100 Z" fill="currentColor"></path>
        </svg>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight">{displayTitle}</h2>
        <p class="text-xl text-slate-300 mb-10 leading-relaxed">
            {displayDescription}
        </p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
            <a href={primaryHref} class="w-full sm:w-auto bg-brand-accent text-white px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white hover:text-brand-navy shadow-lg text-center">
                {primaryLabel}
            </a>
            <a href={secondaryHref} class="w-full sm:w-auto bg-transparent border-2 border-white/30 text-white px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white/10 text-center">
                {secondaryLabel}
            </a>
        </div>
    </div>
</section>
