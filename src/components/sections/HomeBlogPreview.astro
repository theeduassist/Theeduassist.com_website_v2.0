---
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';

const posts = [
  {
    title: "How to Convert Legacy Training Content to Modern eLearning",
    label: "Blog migration in progress",
    link: "/blog/"
  },
  {
    title: "How to Build a Corporate eLearning Program on a Budget",
    label: "Blog migration in progress",
    link: "/blog/"
  },
  {
    title: "Kajabi Updates and What Course Creators Should Know",
    label: "Blog migration in progress",
    link: "/blog/"
  }
];
---
<section class="py-24 bg-brand-softBg px-4 border-t border-brand-border/60">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 pb-4">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold text-brand-navy mb-2">Course News & Blogs</h2>
        <p class="text-brand-textMuted text-lg">Helpful guides on LMS migration, Kajabi, AI learning, course design, and online training systems.</p>
      </div>
      <div class="mt-6 md:mt-0">
         <Button href="/blog/" variant="outline" size="md">
            Visit Blog
         </Button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {posts.map(post => (
        <a href={post.link} class="block h-full group focus-ring rounded-2xl">
          <Card className="flex flex-col h-full bg-white border border-brand-border/60 group-hover:border-brand-accent/30 group-hover:shadow-md hover-lift transition-all">
            <div class="mb-4">
              <span class="inline-block bg-brand-softBlue text-brand-primary text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider">
                {post.label}
              </span>
            </div>
            <h3 class="text-xl font-bold mb-4 text-brand-navy group-hover:text-brand-accent transition-colors flex-grow">
               {post.title}
            </h3>
            <div class="mt-auto pt-4 border-t border-brand-border/60 flex items-center text-brand-primary font-medium text-sm group-hover:text-brand-accent transition-colors click-press">
              Read More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
          </Card>
        </a>
      ))}
    </div>
  </div>
</section>
