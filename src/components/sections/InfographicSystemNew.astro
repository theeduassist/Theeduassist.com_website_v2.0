---
const blocks = [
    {
        title: "Knowledge Extraction",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>`
    },
    {
        title: "Curriculum Design",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>`
    },
    {
        title: "Content Production",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>`
    },
    {
        title: "Platform Build",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>`
    },
    {
        title: "Automation Setup",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>`
    },
    {
        title: "Student Experience",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>`
    }
];
---
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-16">The Complete E-Learning Build System</h2>

        <div class="relative max-w-5xl mx-auto">
            <!-- Connecting Lines SVG -->
            <svg class="absolute inset-0 w-full h-full z-0 hidden md:block" preserveAspectRatio="none" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.5">
                <path d="M 16 25 L 50 25 L 84 25" class="text-brand-accent animate-draw-line" />
                <path d="M 50 25 L 50 75" class="text-brand-accent animate-draw-line" style="animation-delay: 0.5s;" />
                <path d="M 16 75 L 50 75 L 84 75" class="text-brand-accent animate-draw-line" style="animation-delay: 1s;" />
            </svg>

            <!-- Grid Layout -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
                {blocks.slice(0, 3).map((block, index) => (
                    <div class="bg-white p-8 rounded-2xl border border-brand-border shadow-soft hover-lift group">
                        <div class="w-16 h-16 mx-auto bg-brand-softGreen text-brand-accent rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={block.icon}></svg>
                        </div>
                        <h3 class="text-xl font-bold text-brand-navy">{block.title}</h3>
                    </div>
                ))}
            </div>

            <!-- Central Arrow indicator -->
            <div class="hidden md:flex justify-center my-8 relative z-10">
                 <div class="w-12 h-12 bg-white rounded-full border border-brand-border shadow-sm flex items-center justify-center text-brand-accent animate-bounce">
                     <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                 </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10 mt-8 md:mt-0">
                {blocks.slice(3, 6).map((block, index) => (
                    <div class="bg-white p-8 rounded-2xl border border-brand-border shadow-soft hover-lift group">
                        <div class="w-16 h-16 mx-auto bg-brand-softGreen text-brand-accent rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={block.icon}></svg>
                        </div>
                        <h3 class="text-xl font-bold text-brand-navy">{block.title}</h3>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
