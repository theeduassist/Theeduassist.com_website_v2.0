---
import Button from '../ui/Button.astro';
---
<section class="py-24 bg-brand-navy text-center px-4 relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-brand-accent/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-3xl mx-auto relative z-10">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">Ready to Turn Your Expertise Into a Professional Online Course System?</h2>
        <p class="text-lg md:text-xl text-slate-300 mb-10 leading-relaxed font-medium">Get a 24-48 hour review and we’ll review your current content, platform, course idea, or Kajabi setup and show you what needs to be structured, built, fixed, or improved.</p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
            <Button href="/book-free-audit/?source=homepage-cta" variant="primary" size="lg" class="w-full sm:w-auto shadow-lg bg-brand-accent text-brand-navy hover:bg-white border-none">Get 24–48 Hour Review</Button>
            <Button href="/book-free-audit/?source=homepage-cta" variant="outline" size="lg" class="w-full sm:w-auto border-slate-500 text-white hover:bg-slate-800">Contact TheEduAssist</Button>
        </div>
    </div>
</section>
