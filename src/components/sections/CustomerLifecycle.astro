---
// src/components/sections/CustomerLifecycle.astro
---
<section class="py-20 md:py-28 bg-brand-navy text-white relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 -mt-20 -mr-20 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-20">
            <h2 class="text-3xl md:text-4xl font-extrabold mb-4">From Raw Knowledge to a Complete Learning System</h2>
            <p class="text-lg text-slate-300">We guide you through the entire lifecycle—from extracting your expertise to launching a professional course platform.</p>
        </div>

        <div class="relative">
            <!-- Connecting Line (Desktop) -->
            <div class="hidden lg:block absolute top-1/2 left-0 w-full h-1 bg-white/10 -translate-y-1/2 z-0"></div>

            <div class="grid grid-cols-1 lg:grid-cols-6 gap-6 relative z-10">
                {[
                    { step: "1", title: "Discover", client: "Ideas, notes, goals", edu: "Strategy Session", gets: "Clarity & Direction" },
                    { step: "2", title: "Structure", client: "Target audience", edu: "Course Outline", gets: "Learning Path" },
                    { step: "3", title: "Create", client: "Rough content", edu: "Instructional Design", gets: "Lesson Assets" },
                    { step: "4", title: "Build", client: "Brand assets", edu: "Platform Setup", gets: "Ready System" },
                    { step: "5", title: "Launch", client: "Traffic", edu: "Funnels & QA", gets: "Live Course" },
                    { step: "6", title: "Improve", client: "Feedback", edu: "Ongoing Support", gets: "Better Learner Experience" }
                ].map((item, index) => (
                    <div class="flex flex-col relative group">
                        <!-- Mobile connecting line -->
                        {index !== 5 && <div class="lg:hidden absolute left-8 top-16 bottom-[-2rem] w-0.5 bg-white/10 z-0"></div>}

                        <div class="flex items-center lg:justify-center mb-4 relative z-10">
                            <div class="w-16 h-16 rounded-full bg-brand-primary border-4 border-brand-navy flex items-center justify-center font-bold text-xl text-brand-accent group-hover:bg-brand-accent group-hover:text-white transition-colors duration-300 shadow-lg">
                                {item.step}
                            </div>
                            <div class="ml-4 lg:hidden">
                                <span class="font-bold text-lg">{item.title}</span>
                            </div>
                        </div>

                        <div class="ml-20 lg:ml-0 bg-white/5 backdrop-blur-sm p-4 rounded-xl border border-white/10 text-center flex-grow hover:bg-white/10 transition-colors duration-300">
                            <span class="font-bold text-white text-sm mb-3 hidden lg:block h-10">{item.title}</span>
                            <div class="space-y-2 text-xs text-left">
                                <p><span class="text-slate-400">You bring:</span><br/><span class="font-medium text-white">{item.client}</span></p>
                                <p><span class="text-slate-400">We do:</span><br/><span class="font-medium text-brand-accent">{item.edu}</span></p>
                                <p><span class="text-slate-400">You get:</span><br/><span class="font-medium text-white">{item.gets}</span></p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
