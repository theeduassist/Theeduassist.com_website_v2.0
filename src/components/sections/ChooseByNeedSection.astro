---
---
<section class="py-20 md:py-28 bg-slate-50 border-y border-brand-border/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16 text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-6">Choose by what you need to build</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Find the right starting point based on where you are in the process.
        </p>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Card 1 -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 flex flex-col">
            <h3 class="text-lg font-bold text-brand-navy mb-2">I need to plan my course first</h3>
            <p class="text-xs text-brand-primary font-bold uppercase tracking-wide mb-4">Course Clarity Blueprint</p>
            <div class="mt-auto pt-4 border-t border-slate-100">
                <p class="text-sm font-semibold text-slate-700 mb-3">From $500</p>
                <button type="button" class="tawk-need-btn w-full bg-brand-primary/10 text-brand-primary hover:bg-brand-primary hover:text-white px-4 py-2 rounded-md font-bold text-sm transition-colors focus-ring" data-package-slug="course-clarity-blueprint" data-package-name="Course Clarity Blueprint" data-package-price="From $500">
                    Start This Package
                </button>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 flex flex-col">
            <h3 class="text-lg font-bold text-brand-navy mb-2">I have PDFs, slides, videos, or books</h3>
            <p class="text-xs text-brand-primary font-bold uppercase tracking-wide mb-4">Content Conversion Kit</p>
            <div class="mt-auto pt-4 border-t border-slate-100">
                <p class="text-sm font-semibold text-slate-700 mb-3">From $900</p>
                <button type="button" class="tawk-need-btn w-full bg-brand-primary/10 text-brand-primary hover:bg-brand-primary hover:text-white px-4 py-2 rounded-md font-bold text-sm transition-colors focus-ring" data-package-slug="content-conversion-kit" data-package-name="Content Conversion Kit" data-package-price="From $900">
                    Start This Package
                </button>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 flex flex-col">
            <h3 class="text-lg font-bold text-brand-navy mb-2">I need Kajabi setup</h3>
            <p class="text-xs text-brand-primary font-bold uppercase tracking-wide mb-4">Kajabi Setup Sprint</p>
            <div class="mt-auto pt-4 border-t border-slate-100">
                <p class="text-sm font-semibold text-slate-700 mb-3">From $1,500</p>
                <button type="button" class="tawk-need-btn w-full bg-brand-primary/10 text-brand-primary hover:bg-brand-primary hover:text-white px-4 py-2 rounded-md font-bold text-sm transition-colors focus-ring" data-package-slug="kajabi-setup-sprint" data-package-name="Kajabi Setup Sprint" data-package-price="From $1,500">
                    Start This Package
                </button>
            </div>
        </div>

        <!-- Card 4 -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 flex flex-col">
            <h3 class="text-lg font-bold text-brand-navy mb-2">I need Thinkific, LearnWorlds, Skool...</h3>
            <p class="text-xs text-brand-primary font-bold uppercase tracking-wide mb-4">Course + Platform Build</p>
            <div class="mt-auto pt-4 border-t border-slate-100">
                <p class="text-sm font-semibold text-slate-700 mb-3">From $4,000</p>
                <button type="button" class="tawk-need-btn w-full bg-brand-primary/10 text-brand-primary hover:bg-brand-primary hover:text-white px-4 py-2 rounded-md font-bold text-sm transition-colors focus-ring" data-package-slug="course-platform-build" data-package-name="Course + Platform Build" data-package-price="From $4,000">
                    Start This Package
                </button>
            </div>
        </div>

        <!-- Card 5 -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 flex flex-col">
            <h3 class="text-lg font-bold text-brand-navy mb-2">I need LMS migration or corporate setup</h3>
            <p class="text-xs text-brand-primary font-bold uppercase tracking-wide mb-4">LMS Map / Enterprise</p>
            <div class="mt-auto pt-4 border-t border-slate-100">
                <p class="text-sm font-semibold text-slate-700 mb-3">From $700 / Custom</p>
                <button type="button" class="tawk-talk-btn w-full border border-slate-300 text-slate-700 hover:bg-slate-50 px-4 py-2 rounded-md font-bold text-sm transition-colors focus-ring" data-intent="lms_corporate_setup" data-source="choose-need-lms">
                    Talk to Sales
                </button>
            </div>
        </div>

        <!-- Card 6 -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 flex flex-col">
            <h3 class="text-lg font-bold text-brand-navy mb-2">I need SCORM, Rise, Storyline...</h3>
            <p class="text-xs text-brand-primary font-bold uppercase tracking-wide mb-4">Custom E-Learning</p>
            <div class="mt-auto pt-4 border-t border-slate-100">
                <p class="text-sm font-semibold text-slate-700 mb-3">Scope-based</p>
                <button type="button" class="tawk-talk-btn w-full border border-slate-300 text-slate-700 hover:bg-slate-50 px-4 py-2 rounded-md font-bold text-sm transition-colors focus-ring" data-intent="scorm_custom_elearning" data-source="choose-need-scorm">
                    Talk to Sales
                </button>
            </div>
        </div>

        <!-- Card 7 -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 flex flex-col">
            <h3 class="text-lg font-bold text-brand-navy mb-2">I already have a course and need help</h3>
            <p class="text-xs text-brand-primary font-bold uppercase tracking-wide mb-4">Ongoing Support</p>
            <div class="mt-auto pt-4 border-t border-slate-100">
                <p class="text-sm font-semibold text-slate-700 mb-3">From $600/month</p>
                <button type="button" class="tawk-need-btn w-full bg-brand-primary/10 text-brand-primary hover:bg-brand-primary hover:text-white px-4 py-2 rounded-md font-bold text-sm transition-colors focus-ring" data-package-slug="ongoing-course-support" data-package-name="Ongoing Course Support" data-package-price="From $600/month">
                    Start This Package
                </button>
            </div>
        </div>

        <!-- Card 8 -->
        <div class="bg-brand-navy rounded-2xl p-6 border border-brand-accent/30 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 flex flex-col relative overflow-hidden text-white">
            <div class="absolute right-0 top-0 w-32 h-32 bg-brand-accent/20 rounded-full blur-2xl translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
            <h3 class="text-lg font-bold mb-2 relative z-10">I am not sure</h3>
            <p class="text-xs text-brand-accent font-bold uppercase tracking-wide mb-4 relative z-10">Guided scoping</p>
            <div class="mt-auto pt-4 border-t border-white/10 relative z-10">
                <p class="text-sm font-semibold text-slate-300 mb-3">Guided after review</p>
                <button type="button" class="tawk-talk-btn w-full bg-brand-accent text-white hover:bg-white hover:text-brand-navy px-4 py-2 rounded-md font-bold text-sm transition-all focus-ring" data-intent="not_sure_scoping" data-source="choose-need-notsure">
                    Talk to Sales
                </button>
            </div>
        </div>

    </div>
</section>

<script>
    import { openStartPackageChat, openGeneralSalesChat } from "../../utils/tawkSales";
    document.addEventListener("DOMContentLoaded", () => {
      // Start This Package Buttons
      const packageBtns = document.querySelectorAll(".tawk-need-btn");
      packageBtns.forEach(btn => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLButtonElement;
          openStartPackageChat({
            packageSlug: target.dataset.packageSlug || "",
            packageName: target.dataset.packageName || "",
            packagePrice: target.dataset.packagePrice || "",
            pageUrl: window.location.href,
            pageTitle: document.title,
            sourceCta: "choose-by-need-grid"
          });
        });
      });

      // Talk to Sales Buttons
      const talkBtns = document.querySelectorAll(".tawk-talk-btn");
      talkBtns.forEach(btn => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLButtonElement;
          openGeneralSalesChat({
            intent: target.dataset.intent || "general_inquiry",
            sourceCta: target.dataset.source || "choose-by-need-grid"
          });
        });
      });
    });
</script>
