---
---
<section class="py-20 md:py-28 bg-brand-navy overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16 max-w-3xl mx-auto">
             <div class="inline-flex items-center space-x-2 bg-brand-accent/20 text-brand-accent px-4 py-2 rounded-full text-sm font-bold mb-6">
                 <span>Corporate & Enterprise</span>
             </div>
             <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight">
                 Premium learning systems for modern teams
             </h2>
             <p class="text-lg md:text-xl text-slate-300 leading-relaxed">
                 TheEduAssist plans and builds structured, scalable learning environments for organizations requiring high-quality employee, partner, and customer education.
             </p>
        </div>

        <!-- Bento Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-2 gap-4 md:gap-6 mb-16">

            <!-- Large Focus Block -->
            <div class="col-span-1 md:col-span-2 md:row-span-2 bg-white/5 border border-white/10 rounded-3xl p-8 md:p-12 flex flex-col justify-between hover:bg-white/10 transition-colors duration-300">
                <div>
                    <h3 class="text-2xl font-bold text-white mb-4">Comprehensive Training Solutions</h3>
                    <p class="text-slate-300 mb-8 max-w-lg">Build targeted learning paths, structured onboarding systems, and compliance portals. We handle the content conversion, platform setup, and SCORM/xAPI development.</p>
                </div>
                <div class="grid grid-cols-2 gap-4">
                     {['Employee onboarding', 'Compliance training', 'AI ethics training', 'Partner training', 'Customer education', 'Internal academies', 'LMS migration', 'SCORM/xAPI content'].map((useCase) => (
                        <div class="flex items-center space-x-3 text-slate-200">
                             <div class="w-6 h-6 rounded-full bg-brand-accent/20 flex items-center justify-center flex-shrink-0">
                                 <svg class="w-3.5 h-3.5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                             </div>
                             <span class="text-sm font-medium">{useCase}</span>
                        </div>
                     ))}
                </div>
            </div>

            <!-- Smaller Blocks -->
            <div class="col-span-1 bg-white/5 border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition-colors duration-300 flex flex-col justify-center">
                 <div class="w-12 h-12 bg-brand-primary rounded-xl flex items-center justify-center mb-6">
                      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                 </div>
                 <h3 class="text-xl font-bold text-white mb-2">Role-Based Paths</h3>
                 <p class="text-sm text-slate-400">Customized learning journeys tailored to specific organizational roles and competencies.</p>
            </div>

            <div class="col-span-1 bg-gradient-to-br from-brand-primary/40 to-brand-accent/20 border border-brand-accent/30 rounded-3xl p-8 hover:opacity-90 transition-opacity duration-300 flex flex-col justify-center relative overflow-hidden">
                 <div class="absolute -right-6 -top-6 w-32 h-32 bg-brand-accent/20 rounded-full blur-2xl"></div>
                 <div class="w-12 h-12 bg-white/10 backdrop-blur-sm rounded-xl flex items-center justify-center mb-6 relative z-10 border border-white/20">
                      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                 </div>
                 <h3 class="text-xl font-bold text-white mb-2 relative z-10">Global Team Rollout</h3>
                 <p class="text-sm text-slate-300 relative z-10">Scalable delivery methods designed to deploy training seamlessly across worldwide teams.</p>
            </div>

        </div>

        <!-- Action Area -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
             <a href="/book-free-audit/" class="w-full sm:w-auto bg-brand-accent text-white px-8 py-4 rounded-md font-bold hover:bg-white hover:text-brand-navy transition-colors focus-ring shadow-lg text-center text-lg">
                 Start an Enterprise Project
             </a>
             <a href="/services/" class="w-full sm:w-auto bg-transparent border border-slate-400 text-white px-8 py-4 rounded-md font-bold hover:bg-white/10 transition-colors focus-ring text-center text-lg">
                 Explore Services
             </a>
        </div>

    </div>
</section>
