---
const steps = [
  {
    title: "Content",
    copy: "Lessons, scripts, slides, PDFs, videos, assessments, and activities.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`
  },
  {
    title: "LMS/Course Platform",
    copy: "Kajabi, Moodle, WordPress LMS, LearnWorlds, Thinkific, Teachable, or other course platforms.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />`
  },
  {
    title: "Automation",
    copy: "Forms, emails, checkout, access rules, reminders, and learner communication.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`
  },
  {
    title: "Learner Access",
    copy: "Clean structure, clear navigation, mobile-friendly access, and guided progress.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />`
  },
  {
    title: "Engagement",
    copy: "Microlearning, scenarios, quizzes, interaction, community, and feedback loops.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`
  },
  {
    title: "Analytics",
    copy: "Progress tracking, completion insight, learner gaps, and improvement planning.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />`
  }
];
---

<section class="py-24 bg-brand-softBlue px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Your learning system needs more than a course page</h2>
      <p class="text-lg text-brand-textMuted leading-relaxed">
        A professional online learning setup connects content, platform, automation, access, engagement, and improvement.
      </p>
    </div>

    <!-- Desktop Horizontal Flow -->
    <div class="hidden lg:flex items-stretch justify-between relative">
      <div class="absolute top-1/2 left-0 right-0 h-0.5 bg-brand-border/60 -translate-y-1/2 z-0 hidden lg:block"></div>

      {steps.map((step, index) => (
        <div class="relative z-10 flex flex-col items-center flex-1 px-2 group">
          <div class="bg-white border-2 border-brand-softGreen text-brand-accent w-16 h-16 rounded-full flex items-center justify-center mb-4 shadow-sm group-hover:scale-110 group-hover:border-brand-accent/30 group-hover:bg-brand-softGreen transition-all duration-300 relative">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={step.icon} />
          </div>
          <div class="bg-white p-4 rounded-xl border border-brand-border/60 shadow-sm text-center w-full h-full">
            <h3 class="font-bold text-brand-navy mb-2 text-sm">{step.title}</h3>
            <p class="text-xs text-brand-textMuted">{step.copy}</p>
          </div>

          {index < steps.length - 1 && (
             <svg class="w-6 h-6 text-brand-border/80 absolute -right-3 top-[1.75rem] z-20 hidden xl:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
             </svg>
          )}
        </div>
      ))}
    </div>

    <!-- Mobile Vertical Flow -->
    <div class="flex lg:hidden flex-col space-y-6 relative">
      <div class="absolute top-0 bottom-0 left-8 w-0.5 bg-brand-border/60 z-0"></div>

      {steps.map((step, index) => (
        <div class="relative z-10 flex items-start group">
          <div class="bg-white border-2 border-brand-softGreen text-brand-accent w-16 h-16 rounded-full flex items-center justify-center shadow-sm group-hover:scale-110 group-hover:border-brand-accent/30 group-hover:bg-brand-softGreen transition-all duration-300 shrink-0 mt-2">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={step.icon} />
          </div>
          <div class="bg-white p-5 rounded-xl border border-brand-border/60 shadow-sm ml-6 flex-1 hover-lift hover:border-brand-accent/30 transition-colors">
            <h3 class="font-bold text-brand-navy mb-2 text-lg">{step.title}</h3>
            <p class="text-sm text-brand-textMuted">{step.copy}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
