---
interface Props {
  blogFaqs?: any[];
  relatedFaqs?: any[];
}

const { blogFaqs = [], relatedFaqs = [] } = Astro.props;

// Combine and deduplicate
const allFaqs = [...(blogFaqs || []), ...(relatedFaqs || [])].filter(
  (v, i, a) => a.findIndex((t) => (t.question === v.question)) === i
);

const hasFaqs = allFaqs.length > 0;
---
{hasFaqs && (
  <div class="my-16">
    <h3 class="text-3xl font-bold text-slate-800 mb-8">Frequently Asked Questions</h3>
    <div class="space-y-4 max-w-4xl mx-auto" itemscope itemtype="https://schema.org/FAQPage">
      {allFaqs.map((faq, index) => (
        <details class="group bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all open:ring-2 open:ring-[var(--color-primary)] open:border-transparent" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-lg text-slate-800 hover:text-[var(--color-primary)] transition-colors focus:outline-none focus-visible:bg-slate-50" itemprop="name">
            <span>{faq.question}</span>
            <span class="transition-transform duration-300 group-open:-rotate-180 text-slate-400 group-hover:text-[var(--color-primary)]">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-slate-600 leading-relaxed border-t border-slate-100 mt-2 bg-slate-50" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text">
              {typeof faq.answer === 'string' ? (
                <p>{faq.answer}</p>
              ) : (
                <div set:html={faq.answer} />
              )}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
)}
