---
const filterChips = [
  { label: 'All', value: 'all' },
  { label: 'LMS', value: 'lms' },
  { label: 'Kajabi', value: 'kajabi' },
  { label: 'Course Creation', value: 'course creation' },
  { label: 'AI E-Learning', value: 'ai' },
  { label: 'Corporate Training', value: 'corporate' },
  { label: 'Instructional Design', value: 'instructional' },
  { label: 'Content Conversion', value: 'conversion' },
  { label: 'Platform Guides', value: 'platform' },
  { label: 'Funnels & Automation', value: 'funnel' },
];
---
<div class="mb-12 bg-white p-6 rounded-lg shadow-sm border border-slate-200">
  <div class="flex flex-col md:flex-row gap-4 items-center mb-6">
    <div class="relative w-full md:w-1/2">
      <label for="blog-search" class="sr-only">Search articles</label>
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <input
        type="search"
        id="blog-search"
        class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-md leading-5 bg-white placeholder-slate-500 focus:outline-none focus:placeholder-slate-400 focus:ring-1 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)] sm:text-sm transition-colors"
        placeholder="Search guides, checklists, and articles..."
      />
    </div>

    <div class="w-full md:w-auto flex justify-end flex-grow">
      <button id="clear-filters" class="text-sm text-slate-500 hover:text-[var(--color-primary)] transition-colors px-3 py-2 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
        Clear filters
      </button>
    </div>
  </div>

  <div class="space-y-4">
    <div>
      <h3 class="text-sm font-medium text-slate-700 mb-2">Filter by Topic:</h3>
      <div class="flex flex-wrap gap-2" id="tag-filters">
        {filterChips.map((chip, index) => (
          <button
            class={`filter-chip px-4 py-2 bg-slate-50 border border-slate-200 rounded-full text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-[var(--color-primary)] aria-pressed:bg-[var(--color-primary)] aria-pressed:text-white aria-pressed:border-[var(--color-primary)] ${index === 0 ? 'bg-[var(--color-primary)] text-white border-[var(--color-primary)]' : ''}`}
            data-filter-value={chip.value}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {chip.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="mt-4 pt-4 border-t border-slate-100 flex justify-between items-center text-sm text-slate-500">
    <span id="search-result-count">Showing all articles</span>
  </div>
</div>

<script>
  function setupSearchFilters() {
    const searchInput = document.getElementById('blog-search') as HTMLInputElement;
    const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement;
    const chips = document.querySelectorAll('.filter-chip');
    const resultCount = document.getElementById('search-result-count');
    const cards = document.querySelectorAll('article.blog-card'); // Updated selector
    const noResultsMsg = document.getElementById('no-results-message');

    if (!searchInput || !cards.length) return;

    let activeTags = new Set();
    let currentQuery = '';

    const filterCards = () => {
      let visibleCount = 0;

      cards.forEach((card: any) => {
        const title = card.getAttribute('data-title')?.toLowerCase() || '';
        const excerpt = card.getAttribute('data-excerpt')?.toLowerCase() || '';
        const tags = (card.getAttribute('data-tags') || '').split(',').filter(Boolean);
        const category = card.getAttribute('data-category')?.toLowerCase() || '';

        // Format category as tag for matching
        const catSlug = category.replace(/[^a-z0-9]+/g, '-');

        const matchesSearch = currentQuery === '' ||
                              title.includes(currentQuery) ||
                              excerpt.includes(currentQuery) ||
                              category.includes(currentQuery);

        const matchesTags = activeTags.size === 0 ||
                            activeTags.has('all') ||
                            [...activeTags].some(tag => {
                               // Topic mapping to handle "General" gracefully
                               const t = tag.toLowerCase();
                               const allContent = `${title} ${excerpt} ${category} ${tags.join(' ')}`.toLowerCase();

                               if (t === 'lms') return allContent.includes('lms') || allContent.includes('moodle') || allContent.includes('talentlms') || allContent.includes('absorb') || allContent.includes('docebo') || allContent.includes('learndash') || allContent.includes('learnworlds') || allContent.includes('teachable') || allContent.includes('thinkific');
                               if (t === 'kajabi') return allContent.includes('kajabi');
                               if (t === 'ai') return allContent.includes('ai ') || allContent.includes('artificial intelligence');
                               if (t === 'corporate') return allContent.includes('corporate') || allContent.includes('employee') || allContent.includes('compliance') || allContent.includes('onboarding');
                               if (t === 'instructional') return allContent.includes('instructional') || allContent.includes('curriculum') || allContent.includes('learner experience');
                               if (t === 'conversion') return allContent.includes('conversion') || allContent.includes('pdf') || allContent.includes('slide') || allContent.includes('video') || allContent.includes('sop');
                               if (t === 'platform') return allContent.includes('platform') || allContent.includes('lms') || allContent.includes('kajabi') || allContent.includes('learndash');
                               if (t === 'funnel') return allContent.includes('funnel') || allContent.includes('automation');
                               if (t === 'course creation') return allContent.includes('course creation') || allContent.includes('create course');

                               return tags.includes(t) || catSlug.includes(t);
                            });

        // We only hide the card itself. We shouldn't touch the wrapper here.
        // Wait, the wrapper controls layout in AllArticlesGrid.
        const wrapper = card.closest('.article-card-wrapper');

        if (matchesSearch && matchesTags) {
          card.style.display = '';
          if (wrapper) wrapper.style.display = ''; // Make wrapper visible if filter matches
          visibleCount++;
        } else {
          card.style.display = 'none';
          if (wrapper) wrapper.style.display = 'none';
        }
      });

      // Update Load More button visibility
      const loadMoreBtn = document.getElementById('load-more-btn');
      if (loadMoreBtn && loadMoreBtn.parentElement) {
          if (activeTags.size > 0 && !activeTags.has('all')) {
              // If filtering, we might just want to hide load more since we're showing all matched
              loadMoreBtn.parentElement.style.display = 'none';

              // Ensure all matched are visible, removing 'hidden' from wrappers
              cards.forEach((card: any) => {
                  const wrapper = card.closest('.article-card-wrapper');
                  if (wrapper && card.style.display !== 'none') {
                      wrapper.classList.remove('hidden');
                  }
              });
          } else if (currentQuery !== '') {
              loadMoreBtn.parentElement.style.display = 'none';
              cards.forEach((card: any) => {
                  const wrapper = card.closest('.article-card-wrapper');
                  if (wrapper && card.style.display !== 'none') {
                      wrapper.classList.remove('hidden');
                  }
              });
          } else {
              loadMoreBtn.parentElement.style.display = '';
              // Reset the initial 12 visibility if we clear filters
              let count = 0;
              cards.forEach((card: any) => {
                  const wrapper = card.closest('.article-card-wrapper');
                  if (wrapper) {
                      if (count < 12) {
                          wrapper.classList.remove('hidden');
                      } else {
                          wrapper.classList.add('hidden');
                      }
                      count++;
                  }
              });
          }
      }

      // Update UI
      if (resultCount) {
        resultCount.textContent = visibleCount === cards.length
          ? 'Showing all articles'
          : `Showing ${visibleCount} article${visibleCount !== 1 ? 's' : ''}`;
      }

      if (noResultsMsg) {
          noResultsMsg.style.display = visibleCount === 0 ? 'block' : 'none';
      }

      if (clearBtn) {
        clearBtn.disabled = currentQuery === '' && activeTags.size === 0;
      }
    };

    // Event Listeners
    searchInput.addEventListener('input', (e) => {
      currentQuery = (e.target as HTMLInputElement).value.toLowerCase();
      filterCards();

      if (window.dataLayer && typeof window.trackEvent === 'function' && currentQuery.length > 2) {
          // Debounce this in a real app, keeping simple for now
          window.trackEvent('blog_search', { search_term: currentQuery });
      }
    });

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const tag = chip.getAttribute('data-filter-value');

        if (tag === 'all') {
            activeTags.clear();
            chips.forEach(c => c.setAttribute('aria-pressed', 'false'));
            chip.setAttribute('aria-pressed', 'true');
        } else {
            const isPressed = chip.getAttribute('aria-pressed') === 'true';

            // Remove 'all' if selected
            const allChip = Array.from(chips).find(c => c.getAttribute('data-filter-value') === 'all');
            if (allChip) allChip.setAttribute('aria-pressed', 'false');

            if (isPressed) {
              chip.setAttribute('aria-pressed', 'false');
              activeTags.delete(tag);
            } else {
              chip.setAttribute('aria-pressed', 'true');
              activeTags.add(tag);

              if (window.dataLayer && typeof window.trackEvent === 'function') {
                  window.trackEvent('blog_filter_tag', { tag: tag });
              }
            }
        }

        filterCards();
      });
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        currentQuery = '';
        activeTags.clear();

        chips.forEach(c => c.setAttribute('aria-pressed', 'false'));
        filterCards();
      });
    }
  }

  setupSearchFilters();
  document.addEventListener('astro:page-load', setupSearchFilters);
</script>
