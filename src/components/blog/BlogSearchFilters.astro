---
// Lightweight client-side search UI
---
<div class="mb-12">
  <div class="max-w-xl mx-auto mb-8 relative">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
      <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
    <input
      type="search"
      id="blog-search-input"
      class="block w-full pl-10 pr-4 py-4 bg-white border border-slate-200 rounded-xl shadow-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent transition-shadow"
      placeholder="Search guides, platforms, topics..."
    />
  </div>

  <div class="flex flex-wrap justify-center gap-2" id="blog-category-filters">
    <button data-filter="all" class="px-4 py-2 rounded-full text-sm font-medium bg-[var(--color-primary)] text-white transition-colors">
      All
    </button>
    {['Course Creation', 'Kajabi', 'LMS', 'AI in E-Learning', 'Instructional Design', 'Corporate Training', 'Comparisons', 'Guides'].map(cat => (
      <button data-filter={cat.toLowerCase().replace(/[^a-z0-9]+/g, '-')} class="px-4 py-2 rounded-full text-sm font-medium bg-white text-slate-600 border border-slate-200 hover:bg-slate-50 transition-colors">
        {cat}
      </button>
    ))}
  </div>
</div>

<script>
  function setupSearch() {
    const input = document.getElementById('blog-search-input') as HTMLInputElement;
    const filterButtons = document.querySelectorAll('#blog-category-filters button');
    const cards = document.querySelectorAll('.blog-card-container');
    const emptyState = document.getElementById('blog-empty-state');
    const latestHeading = document.getElementById('latest-articles-heading');

    if (!input || !filterButtons.length) return;

    let currentFilter = 'all';
    let currentQuery = '';

    function filterPosts() {
      let visibleCount = 0;

      cards.forEach((cardEl) => {
        const card = cardEl as HTMLElement;
        const title = (card.dataset.title || '').toLowerCase();
        const excerpt = (card.dataset.excerpt || '').toLowerCase();
        const category = (card.dataset.category || '').toLowerCase();
        const tags = (card.dataset.tags || '').toLowerCase();

        const matchesQuery = !currentQuery || title.includes(currentQuery) || excerpt.includes(currentQuery);

        // Very loose filter matching to handle differences in formatting
        let matchesCategory = currentFilter === 'all';
        if (!matchesCategory) {
           const normCat = category.replace(/[^a-z0-9]/g, '');
           const normFilter = currentFilter.replace(/[^a-z0-9]/g, '');
           const normTags = tags.replace(/[^a-z0-9]/g, '');

           matchesCategory = normCat.includes(normFilter) || normFilter.includes(normCat) || normTags.includes(normFilter);

           // Special fallbacks based on requested names vs DB names
           if (!matchesCategory) {
              if (currentFilter.includes('lms') && (normCat.includes('platform') || normTags.includes('platform'))) matchesCategory = true;
              if (currentFilter.includes('ai') && (normCat.includes('tech') || normTags.includes('tech'))) matchesCategory = true;
              if (currentFilter.includes('course') && (normCat.includes('design') || normTags.includes('design'))) matchesCategory = true;
           }
        }

        if (matchesQuery && matchesCategory) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (emptyState) {
        emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
      }
      if (latestHeading) {
        latestHeading.style.display = visibleCount === 0 ? 'none' : 'block';
      }
    }

    input.addEventListener('input', (e) => {
      currentQuery = (e.target as HTMLInputElement).value.toLowerCase();
      filterPosts();
    });

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active class
        filterButtons.forEach(b => {
          b.classList.remove('bg-[var(--color-primary)]', 'text-white');
          b.classList.add('bg-white', 'text-slate-600');
        });
        btn.classList.remove('bg-white', 'text-slate-600');
        btn.classList.add('bg-[var(--color-primary)]', 'text-white');

        currentFilter = btn.getAttribute('data-filter') || 'all';
        filterPosts();
      });
    });
  }

  setupSearch();
  document.addEventListener('astro:page-load', setupSearch);
</script>
