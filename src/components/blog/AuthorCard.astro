---
interface Props {
  name?: string;
}
const { name = "TheEduAssist Team" } = Astro.props;
---
<div class="my-16 p-8 bg-slate-50 border border-slate-200 rounded-2xl flex flex-col md:flex-row gap-6 items-center md:items-start text-center md:text-left">
  <div class="w-24 h-24 bg-slate-200 rounded-full flex-shrink-0 flex items-center justify-center text-slate-500 font-bold text-3xl shadow-inner border-4 border-white">
    {name.charAt(0)}
  </div>
  <div>
    <h3 class="text-xl font-bold text-slate-800 mb-2">{name}</h3>
    <p class="text-[var(--color-primary)] font-medium text-sm mb-3">E-Learning & Course Creation Experts</p>
    <p class="text-slate-600 text-sm leading-relaxed max-w-2xl">
      TheEduAssist helps creators, coaches, and training teams design better online courses, Kajabi systems, LMS experiences, and AI-powered learning content.
      This guide was created to help you build practical, launch-ready e-learning programs.
    </p>
  </div>
</div>
