---
import BlogCard from './BlogCard.astro';
import type { NormalizedBlogPost } from '../../lib/content/getAllBlogPosts';

interface Props {
  currentSlug: string;
  category: string;
  allPosts: NormalizedBlogPost[];
  currentTags?: string[];
}

const { currentSlug, category, allPosts = [], currentTags = [] } = Astro.props;

// Define topic clusters
const topicClusters: Record<string, string[]> = {
  'Kajabi': ['kajabi', 'kajabi setup', 'kajabi website', 'kajabi course upload', 'kajabi drip', 'kajabi funnel', 'kajabi seo', 'kajabi landing page', 'course launch'],
  'Corporate Training': ['corporate training', 'gamification', 'compliance training', 'employee training', 'scenario based learning', 'l&d', 'instructional design', 'workplace learning'],
  'LMS': ['lms', 'lms migration', 'lms implementation', 'learning management system', 'scorm', 'learner reporting', 'online academy'],
  'Course Creation': ['course creation', 'curriculum design', 'content conversion', 'online course', 'learning design', 'course outline', 'lesson structure'],
  'AI E-learning': ['ai elearning', 'ai course creation', 'ai learning support', 'training automation', 'ai content conversion']
};

// Ensure allPosts is strictly public already, but filter by current slug
const related = allPosts
  .filter(p => p.slug !== currentSlug)
  .filter(p => {
    // Loop prevention rule
    if (currentSlug === 'kajabi-website-speed-optimization-strong-tips-by-the-eduassist' && p.slug === 'gamification-corporate-training') return false;
    if (currentSlug === 'gamification-corporate-training' && p.slug === 'kajabi-website-speed-optimization-strong-tips-by-the-eduassist') return false;
    return true;
  })
  .map(p => {
    let score = 0;

    // Exact category match (only if category isn't just 'General')
    if (category && category !== 'General' && p.category === category) {
      score += 3;
    }

    // Tag matching
    if (currentTags.length > 0 && p.tags && p.tags.length > 0) {
      const matchingTags = p.tags.filter((t: string) => currentTags.includes(t));
      score += matchingTags.length * 2;
    }

    // Cluster matching
    if (p.tags && p.tags.length > 0) {
      for (const [clusterName, clusterTags] of Object.entries(topicClusters)) {
        const hasCurrentCluster = currentTags.some(t => clusterTags.includes(t.toLowerCase()));
        const hasPostCluster = p.tags.some((t: string) => clusterTags.includes(t.toLowerCase()));
        if (hasCurrentCluster && hasPostCluster) {
           score += 1.5;
           break;
        }
      }
    }

    // Newer post fallback
    const dateScore = p.publishedAt ? new Date(p.publishedAt).getTime() / (1000 * 60 * 60 * 24 * 365) : 0;
    score += (dateScore * 0.001); // Minor weight for newer posts

    return { post: p, score };
  })
  .filter(item => item.score > 0) // Strictly require score > 0 so 'General' fallback posts aren't shown if no actual relation
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(item => item.post);
---
{related.length > 0 && (
  <section class="mt-20 pt-16 border-t border-slate-200">
    <div class="mb-10 text-center md:text-left">
      <h2 class="text-3xl font-bold text-slate-800">Related Articles</h2>
      <p class="text-slate-600 mt-2">More insights and guides tailored to this topic.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {related.map(post => (
        <BlogCard
          title={post.title}
          slug={post.slug}
          excerpt={post.excerpt}
          category={post.category}
          readTimeMinutes={post.readingTime}
          publishedAt={post.publishedAt}
          image={post.heroImage}
          imageAlt={post.heroImageAlt}
          tags={post.tags}
        />
      ))}
    </div>
  </section>
)}
