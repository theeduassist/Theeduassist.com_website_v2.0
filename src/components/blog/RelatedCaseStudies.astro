---
import { caseStudies } from '../../data/caseStudies';

interface Props {
  slugs?: string[];
  category?: string;
}

const { slugs = [], category } = Astro.props;

// Determine which case studies to show
let matchedStudies = [];

if (slugs && slugs.length > 0) {
  // Use explicitly defined slugs
  matchedStudies = caseStudies.filter(cs => slugs.includes(cs.slug));
} else if (category) {
  // Infer from category if slugs are missing
  const categoryMap: Record<string, string[]> = {
    "Course Creation": ["business-analytics-corporate-training", "sqa-aligned-vocational-training"],
    "Kajabi": ["business-analytics-corporate-training"],
    "LMS Migration": ["sqa-aligned-vocational-training", "language-courses-book-publisher"],
    "Content Conversion": ["language-courses-book-publisher", "sqa-aligned-vocational-training"],
    "AI E-Learning": ["business-analytics-corporate-training"],
    "Course Strategy": ["business-analytics-corporate-training", "sqa-aligned-vocational-training", "language-courses-book-publisher"],
  };

  const mappedSlugs = categoryMap[category] || [];
  matchedStudies = caseStudies.filter(cs => mappedSlugs.includes(cs.slug));
}

// Slice to max 3 and ensure only published/existing ones are used
matchedStudies = matchedStudies.slice(0, 3);

if (matchedStudies.length === 0) {
  return; // Render nothing if no relevant case studies exist
}
---

<section class="mt-16 pt-12 border-t border-slate-200">
  <div class="mb-8">
    <h2 class="text-3xl font-bold text-slate-800 mb-4">Related Case Studies</h2>
    <p class="text-slate-600 text-lg max-w-3xl">
      See how TheEduAssist has helped organizations turn training, books, and business knowledge into structured online learning systems.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {matchedStudies.map(study => (
      <article class="bg-white rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-all flex flex-col overflow-hidden group">
        <div class="p-6 flex flex-col flex-grow">
          {study.relatedServices && study.relatedServices.length > 0 && (
            <div class="mb-4 flex flex-wrap gap-2">
              {study.relatedServices.slice(0, 1).map(service => (
                <span class="inline-block px-3 py-1 bg-slate-50 text-slate-600 border border-slate-100 text-xs font-medium rounded-full">
                  {service.replace(/-/g, ' ')}
                </span>
              ))}
            </div>
          )}

          <h3 class="text-xl font-bold text-slate-800 mb-3 group-hover:text-[var(--color-primary)] transition-colors leading-snug">
            <a href={`/case-studies/${study.slug}/`}>
              <span class="absolute inset-0 z-10" aria-hidden="true"></span>
              {study.title}
            </a>
          </h3>

          <p class="text-slate-600 text-sm mb-6 line-clamp-3">
            {study.description}
          </p>

          <div class="mt-auto pt-4 border-t border-slate-100 flex items-center text-sm font-medium text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors z-20 relative">
            Read Case Study
            <svg class="ml-1.5 w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
