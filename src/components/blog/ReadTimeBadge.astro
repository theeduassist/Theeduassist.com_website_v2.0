---
interface Props {
  minutes: number;
}
const { minutes } = Astro.props;
---
{minutes > 0 && (
  <span class="inline-flex items-center text-sm text-slate-500 whitespace-nowrap">
    <svg class="w-4 h-4 mr-1.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    {minutes} min read
  </span>
)}
