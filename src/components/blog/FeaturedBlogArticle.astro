---
import ReadTimeBadge from './ReadTimeBadge.astro';
import { getBlogUrl } from '../../utils/blog';

interface Props {
  post: any;
}

const { post } = Astro.props;

if (!post) {
  return null;
}

const pubDate = post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : null;
const safeExcerpt = post.aiSummary || post.excerpt || "Read this featured article to learn more about our e-learning strategies and course building insights.";
const imageSrc = post.heroImage || post.featuredImage?.asset?.url || post.mainImage?.asset?.url;
const imageAlt = post.heroImageAlt || post.title;

const hiddenStatuses = ['review pending', 'draft', 'internal', 'admin', 'private', 'test', 'do not publish'];
const displayCategory = post.category && !hiddenStatuses.includes(post.category.toLowerCase()) ? post.category : 'Featured Article';
---

<div class="mb-16 mt-8">
  <h2 class="text-3xl font-bold text-slate-800 mb-8">Featured Article</h2>
  <article class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden group flex flex-col md:flex-row hover:shadow-xl transition-all duration-300">
     {imageSrc ? (
        <div class="md:w-1/2 overflow-hidden aspect-video md:aspect-auto">
          <img
            src={imageSrc}
            alt={imageAlt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
      ) : (
        <div class="md:w-1/2 overflow-hidden aspect-video md:aspect-auto bg-slate-100 flex items-center justify-center">
          <span class="text-slate-400">No Image</span>
        </div>
      )}

      <div class="p-8 md:p-10 md:w-1/2 flex flex-col justify-center">
        <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-bold uppercase tracking-wider text-[var(--color-primary)] inline-block bg-blue-50 px-3 py-1 rounded-full">
              {displayCategory}
            </span>
            {post.readingTime && post.readingTime > 0 && (
                <ReadTimeBadge minutes={post.readingTime} />
            )}
        </div>

        <h3 class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-slate-800 mb-6 group-hover:text-[var(--color-primary)] transition-colors leading-tight line-clamp-3">
          <a href={getBlogUrl(post) || "#"}>
            <span class="absolute inset-0" aria-hidden="true"></span>
            {post.title}
          </a>
        </h3>

        <p class="text-slate-600 text-lg mb-8 line-clamp-3 leading-relaxed">
          {safeExcerpt}
        </p>

        <div class="mt-auto flex items-center justify-between text-sm text-slate-500 pt-6 border-t border-slate-100">
          <div class="flex gap-4 items-center">
            {pubDate && (
              <time datetime={post.publishedAt} class="font-medium">{pubDate}</time>
            )}
            {post.author && !hiddenStatuses.includes(post.author.toLowerCase()) && (
              <span class="hidden sm:inline">&bull; {post.author}</span>
            )}
          </div>

          <span class="font-bold text-[var(--color-primary)] flex items-center group-hover:text-[var(--color-accent)] transition-colors relative z-10 text-base">
            Read Featured Article
            <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </div>
      </div>
  </article>
</div>
