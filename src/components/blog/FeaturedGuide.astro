---
import { getBlogUrl } from '../../utils/blog';

interface Props {
  post: any;
}
const { post } = Astro.props;

if (!post) return null;

const pubDate = post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : null;
const safeExcerpt = post.excerpt || "Practical advice for course creators and e-learning professionals.";
---
<div class="mb-16">
  <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center gap-2">
    <svg class="w-6 h-6 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
    Featured Guide
  </h2>

  <article class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden group flex flex-col lg:flex-row hover:shadow-md transition-shadow duration-300">
    <a href={getBlogUrl(post) || "#"} class="lg:w-1/2 block overflow-hidden aspect-video lg:aspect-auto relative bg-slate-100">
       {post.heroImage || post.mainImage?.asset?.url ? (
          <img
            src={post.heroImage || post.mainImage?.asset?.url}
            alt={post.heroImageAlt || post.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 absolute inset-0"
            loading="lazy"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center absolute inset-0">
            <span class="text-slate-400">No Image</span>
          </div>
        )}
    </a>

    <div class="p-8 lg:w-1/2 flex flex-col justify-center">
      <span class="text-xs font-bold uppercase tracking-wider text-[var(--color-primary)] mb-4 inline-block bg-[var(--color-primary)]/10 px-3 py-1 rounded-full w-fit">
        {post.category || 'Guide'}
      </span>

      <h3 class="text-2xl md:text-3xl font-bold text-slate-800 mb-4 group-hover:text-[var(--color-primary)] transition-colors leading-tight">
        <a href={getBlogUrl(post) || "#"} class="after:absolute after:inset-0">
          {post.title}
        </a>
      </h3>

      <p class="text-slate-600 mb-6 line-clamp-3 text-lg">
        {safeExcerpt}
      </p>

      <div class="flex items-center gap-4 text-sm text-slate-500 mb-6">
        <div class="flex items-center gap-2">
           <div class="w-8 h-8 bg-slate-200 rounded-full flex items-center justify-center text-slate-600 font-bold text-xs">
              {(post.author || 'T').charAt(0)}
           </div>
           <span class="font-medium text-slate-700">{post.author || 'TheEduAssist'}</span>
        </div>
        <span>&bull;</span>
        {pubDate && <time datetime={post.publishedAt}>{pubDate}</time>}
        {post.readingTime && (
          <>
            <span>&bull;</span>
            <span>{post.readingTime} min read</span>
          </>
        )}
      </div>

      <div class="mt-auto pt-6 border-t border-slate-100 flex items-center justify-between relative z-10">
        <span class="text-xs font-medium text-slate-400 uppercase tracking-wider flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          Built for creators & learning teams
        </span>

        <a href={getBlogUrl(post) || "#"} class="font-bold text-[var(--color-primary)] flex items-center group-hover:text-[var(--color-accent)] transition-colors">
          Read Guide
          <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </article>
</div>
