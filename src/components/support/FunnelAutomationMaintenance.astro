---
// src/components/support/FunnelAutomationMaintenance.astro
---

<section class="py-20 lg:py-24 bg-white border-y border-brand-border/40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
        Keep Funnels, Emails, and Automations Aligned With Your Course
      </h2>
      <p class="text-lg text-brand-textMuted">
        When offers, dates, pricing, course content, or launch plans change, your funnels and automations need to change too. We help keep the full journey aligned.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
      {[
        "Lead magnet updates",
        "Landing page edits",
        "Launch email updates",
        "Nurture sequence updates",
        "Checkout flow review",
        "Post-purchase emails",
        "Student onboarding updates",
        "Automation testing",
        "Tagging cleanup",
        "Launch QA"
      ].map((item) => (
        <div class="flex items-start p-4 bg-brand-softBg rounded-xl border border-brand-border/40">
          <svg class="w-5 h-5 text-brand-accent mt-0.5 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          <span class="text-sm font-medium text-brand-navy">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>
