---
// src/components/support/SupportPackages.astro
---

<section id="packages" class="py-20 lg:py-24 bg-brand-softBg relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
        Ongoing Support & Maintenance Packages
      </h2>
      <p class="text-lg text-brand-textMuted">
        We offer flexible options depending on your courses, platform complexity, update frequency, and support response needs.
      </p>
    </div>

    <!-- Pricing Grid: Top 3 Packages -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      {/* Package 1 */}
      <div class="bg-white rounded-3xl p-8 border border-brand-border/60 shadow-sm flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Course System Checkup</h3>
        <p class="text-brand-textMuted text-sm mb-6 h-16"><span class="font-semibold text-brand-navy">Best for:</span> Course owners who need a one-time review of their course, pages, emails, automations, and student flow.</p>
        <div class="mb-4">
           <span class="text-3xl font-bold text-brand-navy">Starting from $350</span>
        </div>
        <p class="text-sm text-brand-textMuted mb-6 pb-6 border-b border-brand-border/50"><span class="font-semibold text-brand-navy">Timeline:</span> 1-2 weeks</p>

        <p class="text-sm font-semibold text-brand-textMain mb-4 uppercase tracking-wider">Includes:</p>
        <ul class="space-y-3 mb-8 flex-1">
          {["Course/page review", "Broken link check", "Student journey review", "Email/automation notes", "Priority fix list", "Improvement recommendations"].map((feature) => (
             <li class="flex items-start">
               <svg class="w-5 h-5 text-brand-accent mt-0.5 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
               <span class="text-sm text-brand-textMuted">{feature}</span>
             </li>
          ))}
        </ul>
        <div class="mt-auto flex flex-col space-y-3">
          <a href="/book-free-audit/?package=course-content-updates&source=package-card" data-package-slug="course-content-updates" data-package-price="From $300" class="tawk-package-btn block w-full py-3 px-4 bg-brand-primary text-white text-center font-semibold rounded-xl border border-brand-primary hover:bg-brand-navy transition-colors focus-ring">Start This Package</a>
          <p class="text-xs text-brand-textMuted text-center leading-tight">Talk to our team first so we can confirm the right package, scope, timeline, and payment next step.</p>
          <a href="/book-free-audit/?package=course-content-updates&source=package-card" class="block w-full text-center py-3 px-4 bg-white text-slate-700 font-semibold rounded-xl border border-slate-300 hover:bg-slate-50 transition-colors shadow-sm focus-ring">
            Submit Project Details
          </a>
        </div>
      </div>

      {/* Package 2 */}
      <div class="bg-white rounded-3xl p-8 border-2 border-brand-navy shadow-lg flex flex-col h-full relative transform md:-translate-y-4">
        <div class="absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-brand-navy text-white px-4 py-1 rounded-full text-sm font-bold tracking-wide">MOST POPULAR</div>
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Monthly Course Maintenance</h3>
        <p class="text-brand-textMuted text-sm mb-6 h-16"><span class="font-semibold text-brand-navy">Best for:</span> Creators, coaches, and educators who need regular updates to content, pages, resources, and student support materials.</p>
        <div class="mb-4">
           <span class="text-3xl font-bold text-brand-navy">Starting from $600</span><span class="text-brand-textMuted">/month</span>
        </div>
        <p class="text-sm text-brand-textMuted mb-6 pb-6 border-b border-brand-border/50"><span class="font-semibold text-brand-navy">Timeline:</span> Ongoing</p>

        <p class="text-sm font-semibold text-brand-textMain mb-4 uppercase tracking-wider">Includes:</p>
        <ul class="space-y-3 mb-8 flex-1">
          {["Monthly content updates", "Page edits", "Resource updates", "Student FAQ updates", "Basic QA checks", "Monthly summary"].map((feature) => (
             <li class="flex items-start">
               <svg class="w-5 h-5 text-brand-accent mt-0.5 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
               <span class="text-sm text-brand-textMuted">{feature}</span>
             </li>
          ))}
        </ul>
        <div class="mt-auto flex flex-col space-y-3">
          <a href="/book-free-audit/?package=ongoing-course-support&source=package-card" data-package-slug="ongoing-course-support" data-package-price="From $600/month" class="tawk-package-btn block w-full py-3 px-4 bg-brand-accent text-white text-center font-semibold rounded-xl border border-transparent hover:bg-brand-navy transition-colors focus-ring">Start This Package</a>
          <p class="text-xs text-brand-textMuted text-center leading-tight">Talk to our team first so we can confirm the right package, scope, timeline, and payment next step.</p>
          <a href="/book-free-audit/?package=ongoing-course-support&source=package-card" class="block w-full text-center py-3 px-4 bg-white text-slate-700 font-semibold rounded-xl border border-slate-300 hover:bg-slate-50 transition-colors shadow-sm focus-ring">
            Submit Project Details
          </a>
        </div>
      </div>

       {/* Package 3 */}
      <div class="bg-white rounded-3xl p-8 border border-brand-border/60 shadow-sm flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Kajabi/LMS Support Retainer</h3>
        <p class="text-brand-textMuted text-sm mb-6 h-16"><span class="font-semibold text-brand-navy">Best for:</span> Course businesses, academies, and training teams that need ongoing support across Kajabi, LMS content, pages, funnels, and automations.</p>
        <div class="mb-4">
           <span class="text-3xl font-bold text-brand-navy">Starting from $1,200</span><span class="text-brand-textMuted">/month</span>
        </div>
        <p class="text-sm text-brand-textMuted mb-6 pb-6 border-b border-brand-border/50"><span class="font-semibold text-brand-navy">Timeline:</span> Ongoing</p>

        <p class="text-sm font-semibold text-brand-textMain mb-4 uppercase tracking-wider">Includes:</p>
        <ul class="space-y-3 mb-8 flex-1">
          {["Course content updates", "Page and funnel edits", "Email updates", "Automation review", "Student onboarding improvements", "QA checks", "Monthly support summary"].map((feature) => (
             <li class="flex items-start">
               <svg class="w-5 h-5 text-brand-accent mt-0.5 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
               <span class="text-sm text-brand-textMuted">{feature}</span>
             </li>
          ))}
        </ul>
        <div class="mt-auto flex flex-col space-y-3">
          <a href="/book-free-audit/?package=kajabi-platform-health-check&source=package-card" data-package-slug="kajabi-platform-health-check" data-package-price="From $450" class="tawk-package-btn block w-full py-3 px-4 bg-brand-primary text-white text-center font-semibold rounded-xl border border-brand-primary hover:bg-brand-navy transition-colors focus-ring">Start This Package</a>
          <p class="text-xs text-brand-textMuted text-center leading-tight">Talk to our team first so we can confirm the right package, scope, timeline, and payment next step.</p>
          <a href="/book-free-audit/?package=kajabi-platform-health-check&source=package-card" class="block w-full text-center py-3 px-4 bg-white text-slate-700 font-semibold rounded-xl border border-slate-300 hover:bg-slate-50 transition-colors shadow-sm focus-ring">
            Submit Project Details
          </a>
        </div>
      </div>
    </div>

    <!-- Pricing Grid: Bottom 2 Packages -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto mb-12">
        {/* Package 4 */}
      <div class="bg-white rounded-3xl p-8 border border-brand-border/60 shadow-sm flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Launch Support Retainer</h3>
        <p class="text-brand-textMuted text-sm mb-6 h-12 md:h-auto"><span class="font-semibold text-brand-navy">Best for:</span> Creators, academies, or training companies preparing for course launches, cohort openings, webinars, memberships, or program updates.</p>
        <div class="mb-4">
           <span class="text-3xl font-bold text-brand-navy">Starting from $2,000</span><span class="text-brand-textMuted">/month</span>
        </div>
        <p class="text-sm text-brand-textMuted mb-6 pb-6 border-b border-brand-border/50"><span class="font-semibold text-brand-navy">Timeline:</span> Ongoing or minimum 3 months</p>

        <p class="text-sm font-semibold text-brand-textMain mb-4 uppercase tracking-wider">Includes:</p>
        <ul class="space-y-3 mb-8 flex-1">
          {["Launch page updates", "Email sequence updates", "Offer flow review", "Checkout/access checks", "Student onboarding refresh", "Launch QA checklist", "Post-launch cleanup"].map((feature) => (
             <li class="flex items-start">
               <svg class="w-5 h-5 text-brand-accent mt-0.5 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
               <span class="text-sm text-brand-textMuted">{feature}</span>
             </li>
          ))}
        </ul>
        <div class="mt-auto flex flex-col space-y-3">
          <a href="/book-free-audit/?package=student-onboarding-refresh&source=package-card" data-package-slug="student-onboarding-refresh" data-package-price="From $900" class="tawk-package-btn block w-full py-3 px-4 bg-brand-primary text-white text-center font-semibold rounded-xl border border-brand-primary hover:bg-brand-navy transition-colors focus-ring">Start This Package</a>
          <p class="text-xs text-brand-textMuted text-center leading-tight">Talk to our team first so we can confirm the right package, scope, timeline, and payment next step.</p>
          <a href="/book-free-audit/?package=student-onboarding-refresh&source=package-card" class="block w-full text-center py-3 px-4 bg-white text-slate-700 font-semibold rounded-xl border border-slate-300 hover:bg-slate-50 transition-colors shadow-sm focus-ring">
            Submit Project Details
          </a>
        </div>
      </div>

       {/* Package 5 */}
      <div class="bg-white rounded-3xl p-8 border border-brand-border/60 shadow-sm flex flex-col h-full hover:shadow-md transition-shadow bg-gradient-to-br from-white to-brand-softBg">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Custom Support Desk</h3>
        <p class="text-brand-textMuted text-sm mb-6 h-12 md:h-auto"><span class="font-semibold text-brand-navy">Best for:</span> Organizations, academies, and training companies with multiple courses, platforms, teams, or recurring support needs.</p>
        <div class="mb-4">
           <span class="text-3xl font-bold text-brand-navy">Custom quote</span>
        </div>
        <p class="text-sm text-brand-textMuted mb-6 pb-6 border-b border-brand-border/50"><span class="font-semibold text-brand-navy">Timeline:</span> Ongoing</p>

        <p class="text-sm font-semibold text-brand-textMain mb-4 uppercase tracking-wider">Includes:</p>
        <ul class="space-y-3 mb-8 flex-1">
          {["Custom monthly support scope", "Multiple course support", "LMS/Kajabi maintenance", "Content updates", "QA and improvement cycles", "Launch support", "Priority support planning"].map((feature) => (
             <li class="flex items-start">
               <svg class="w-5 h-5 text-brand-accent mt-0.5 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
               <span class="text-sm text-brand-textMuted">{feature}</span>
             </li>
          ))}
        </ul>
        <div class="mt-auto flex flex-col space-y-3">
          <a href="/book-free-audit/?package=custom-support-desk&source=package-card" data-package-slug="custom-support-desk" data-package-price="Custom Quote" class="tawk-package-btn block w-full py-3 px-4 bg-brand-primary text-white text-center font-semibold rounded-xl border border-brand-primary hover:bg-brand-navy transition-colors focus-ring">Start This Package</a>
          <p class="text-xs text-brand-textMuted text-center leading-tight">Talk to our team first so we can confirm the right package, scope, timeline, and payment next step.</p>
          <a href="/book-free-audit/?package=custom-support-desk&source=package-card" class="block w-full text-center py-3 px-4 bg-white text-slate-700 font-semibold rounded-xl border border-slate-300 hover:bg-slate-50 transition-colors shadow-sm focus-ring">
            Submit Project Details
          </a>
        </div>
      </div>
    </div>

    <script>
      import { openStartPackageChat } from '../../utils/tawkSales';
      document.addEventListener('DOMContentLoaded', () => {
        const btns = document.querySelectorAll('.tawk-package-btn');
        btns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const target = e.currentTarget as HTMLButtonElement;
            openStartPackageChat({
              packageSlug: target.dataset.packageSlug || '',
              packagePrice: target.dataset.packagePrice || '',
              pageUrl: window.location.href,
              pageTitle: document.title,
            });
          });
        });
      });
    </script>

    <!-- Case Studies Integration -->
    <div class="mb-12">
      <h3 class="text-xl font-bold text-center text-brand-navy mb-6">See Real Results:</h3>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/case-studies/business-analytics-corporate-training/" class="inline-flex items-center px-4 py-2 bg-white border border-brand-border/60 rounded-full text-sm font-medium text-brand-textMain hover:border-brand-accent hover:text-brand-accent transition-colors shadow-sm">
          Business Analytics for Corporate Teams
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="mt-12 text-center max-w-4xl mx-auto p-6 bg-white rounded-2xl border border-brand-border/50 space-y-4">
       <p class="text-sm text-brand-textMuted leading-relaxed font-semibold text-brand-navy">
         Pricing disclaimer: <span class="font-normal text-brand-textMuted">Starting prices are not fixed final quotes. Final scope depends on content volume, platform, course length, page count, review rounds, automations, integrations, and launch support.</span>
       </p>
       <p class="text-sm text-brand-textMuted leading-relaxed font-normal">
         Need help before starting? Ask our sales team about scope, timeline, and payment next step. A sales representative will help confirm the right package, scope, timeline, and payment next step before your project starts.
       </p>
    </div>
  </div>
</section>