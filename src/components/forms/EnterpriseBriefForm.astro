---
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "";
---
<form id="enterprise-brief-form" action="/api/forms/enterprise-brief" method="POST" class="space-y-6 text-left" novalidate>
    <!-- Hidden Honeypot -->
    <div style="display:none;" aria-hidden="true">
        <label for="hp_field">Do not fill this out</label>
        <input type="text" id="hp_field" name="hp_field" tabindex="-1" autocomplete="off" />
    </div>

    <!-- Error Summary (Hidden by default) -->
    <div id="form-error-summary" class="hidden bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-md" role="alert" tabindex="-1">
        <h3 class="text-red-800 font-medium text-sm">There was a problem with your submission</h3>
        <ul id="form-error-list" class="mt-2 text-sm text-red-700 list-disc list-inside space-y-1"></ul>
    </div>

    <!-- Server Error Message (Hidden by default) -->
    <div id="form-server-error" class="hidden bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-md" role="alert">
        <p class="text-sm text-red-700 font-medium"></p>
    </div>

    <!-- Fallback error from URL if progressive enhancement redirected here -->
    <div id="url-error" class="hidden bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-md" role="alert">
        <p class="text-sm text-red-700 font-medium">There was an issue processing your submission. Please try again or contact us directly.</p>
    </div>

    <fieldset class="border border-slate-200 rounded-lg p-6 bg-slate-50">
        <legend class="text-lg font-bold text-slate-900 px-2">Contact Details</legend>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
            <div>
                <label for="fullName" class="block text-sm font-medium text-slate-700 mb-1">Full Name <span class="text-red-500" aria-hidden="true">*</span></label>
                <input type="text" id="fullName" name="fullName" required maxlength="100" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-brand-accent focus:border-brand-accent transition-colors" autocomplete="name" />
                <p id="fullName-error" class="mt-1 text-sm text-red-600 hidden"></p>
            </div>

            <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Work Email <span class="text-red-500" aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" required maxlength="254" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-brand-accent focus:border-brand-accent transition-colors" autocomplete="email" />
                <p id="email-error" class="mt-1 text-sm text-red-600 hidden"></p>
            </div>

            <div>
                <label for="organization" class="block text-sm font-medium text-slate-700 mb-1">Organization Name <span class="text-red-500" aria-hidden="true">*</span></label>
                <input type="text" id="organization" name="organization" required maxlength="160" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-brand-accent focus:border-brand-accent transition-colors" autocomplete="organization" />
                <p id="organization-error" class="mt-1 text-sm text-red-600 hidden"></p>
            </div>

            <div>
                <label for="role" class="block text-sm font-medium text-slate-700 mb-1">Role or Job Function <span class="text-red-500" aria-hidden="true">*</span></label>
                <input type="text" id="role" name="role" required maxlength="120" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-brand-accent focus:border-brand-accent transition-colors" autocomplete="organization-title" />
                <p id="role-error" class="mt-1 text-sm text-red-600 hidden"></p>
            </div>
        </div>
    </fieldset>

    <fieldset class="border border-slate-200 rounded-lg p-6 bg-slate-50 mt-6">
        <legend class="text-lg font-bold text-slate-900 px-2">Project Information</legend>
        <div class="space-y-6 mt-4">
            <div>
                <label for="projectType" class="block text-sm font-medium text-slate-700 mb-1">Project Type</label>
                <select id="projectType" name="projectType" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-brand-accent focus:border-brand-accent transition-colors bg-white">
                    <option value="">Select a project type...</option>
                    <option value="Employee Onboarding">Employee Onboarding</option>
                    <option value="Workforce Upskilling">Workforce Upskilling</option>
                    <option value="Customer Education">Customer Education</option>
                    <option value="Partner Training">Partner Training</option>
                    <option value="Internal Academy">Internal Academy</option>
                    <option value="AI Readiness">AI Readiness</option>
                    <option value="LMS Migration">LMS Migration</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div>
                <label for="projectDescription" class="block text-sm font-medium text-slate-700 mb-1">Project Description & Goals <span class="text-slate-500 font-normal">(Optional)</span></label>
                <p class="text-xs text-slate-500 mb-2">Please share your learning problem, audience, and what you hope to achieve.</p>
                <textarea id="projectDescription" name="projectDescription" rows="4" maxlength="5000" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-brand-accent focus:border-brand-accent transition-colors"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="budgetRange" class="block text-sm font-medium text-slate-700 mb-1">Budget Context <span class="text-slate-500 font-normal">(Optional)</span></label>
                    <select id="budgetRange" name="budgetRange" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-brand-accent focus:border-brand-accent transition-colors bg-white">
                        <option value="">Select a budget range...</option>
                        <option value="Under $5k">Under $5k</option>
                        <option value="$5k - $15k">$5k - $15k</option>
                        <option value="$15k - $50k">$15k - $50k</option>
                        <option value="$50k+">$50k+</option>
                        <option value="Not sure yet">Not sure yet</option>
                    </select>
                </div>
                <div>
                    <label for="procurementRequired" class="block text-sm font-medium text-slate-700 mb-1">Procurement Process Required? <span class="text-slate-500 font-normal">(Optional)</span></label>
                    <select id="procurementRequired" name="procurementRequired" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-brand-accent focus:border-brand-accent transition-colors bg-white">
                        <option value="">Please select...</option>
                        <option value="Yes">Yes</option>
                        <option value="No">No</option>
                        <option value="Not sure">Not sure</option>
                    </select>
                </div>
            </div>
        </div>
    </fieldset>

    <div class="pt-4 border-t border-slate-200">
        <label class="flex items-start">
            <input type="checkbox" id="privacyConsent" name="privacyConsent" required class="mt-1 h-4 w-4 text-brand-accent border-slate-300 rounded focus:ring-brand-accent" />
            <span class="ml-3 text-sm text-slate-600">
                I acknowledge that this information will be used by TheEduAssist to review my project request.
                For more details, please review our <a href="/privacy-policy/" class="text-brand-accent hover:underline" target="_blank">Privacy Policy</a>. <span class="text-red-500" aria-hidden="true">*</span>
            </span>
        </label>
        <p id="privacyConsent-error" class="mt-1 text-sm text-red-600 hidden ml-7"></p>
    </div>

    {turnstileSiteKey && (
        <div class="cf-turnstile mt-4" data-sitekey={turnstileSiteKey} data-theme="light"></div>
        <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    )}

    <div class="pt-6 text-center sm:text-left">
        <button
            type="submit"
            id="submitBtn"
            class="w-full sm:w-auto px-8 py-3 bg-brand-navy text-white font-bold rounded-md hover:bg-brand-primary transition-colors focus-ring shadow-md hover:shadow-lg disabled:opacity-70 flex justify-center items-center"
        >
            <span class="btn-text">Submit Project Brief</span>
            <svg class="w-5 h-5 ml-2 btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            <svg class="w-5 h-5 ml-2 hidden animate-spin btn-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        </button>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('enterprise-brief-form');
        if (!form) return;

        const submitBtn = document.getElementById('submitBtn');
        const btnText = submitBtn.querySelector('.btn-text');
        const btnIcon = submitBtn.querySelector('.btn-icon');
        const btnSpinner = submitBtn.querySelector('.btn-spinner');
        const errorSummary = document.getElementById('form-error-summary');
        const errorList = document.getElementById('form-error-list');
        const serverError = document.getElementById('form-server-error');

        const clearErrors = () => {
            errorSummary.classList.add('hidden');
            errorList.innerHTML = '';
            serverError.classList.add('hidden');
            const urlError = document.getElementById('url-error');
            if(urlError) urlError.classList.add('hidden');
            form.querySelectorAll('.text-red-600').forEach(el => el.classList.add('hidden'));
            form.querySelectorAll('.border-red-500').forEach(el => el.classList.remove('border-red-500'));
        };

        // Check for URL error param
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('error') === 'submission_failed') {
            const urlError = document.getElementById('url-error');
            if(urlError) urlError.classList.remove('hidden');
            // Remove the param without reloading
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
        }

        const showError = (fieldId, message) => {
            const field = document.getElementById(fieldId);
            const errorElement = document.getElementById(`${fieldId}-error`);

            if (field) field.classList.add('border-red-500');
            if (errorElement) {
                errorElement.textContent = message;
                errorElement.classList.remove('hidden');
            }

            const li = document.createElement('li');
            const link = document.createElement('a');
            link.href = `#${fieldId}`;
            link.textContent = message;
            link.className = 'hover:underline';
            link.addEventListener('click', (e) => {
                e.preventDefault();
                field.focus();
            });
            li.appendChild(link);
            errorList.appendChild(li);
        };

        const setLoading = (isLoading) => {
            if (isLoading) {
                submitBtn.disabled = true;
                btnText.textContent = 'Submitting...';
                btnIcon.classList.add('hidden');
                btnSpinner.classList.remove('hidden');
            } else {
                submitBtn.disabled = false;
                btnText.textContent = 'Submit Project Brief';
                btnIcon.classList.remove('hidden');
                btnSpinner.classList.add('hidden');
            }
        };

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            clearErrors();

            let hasErrors = false;

            // Client-side validation
            const fullName = document.getElementById('fullName');
            if (!fullName.value.trim()) {
                showError('fullName', 'Full Name is required.');
                hasErrors = true;
            }

            const email = document.getElementById('email');
            const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!email.value.trim() || !emailPattern.test(email.value)) {
                showError('email', 'Valid Work Email is required.');
                hasErrors = true;
            }

            const organization = document.getElementById('organization');
            if (!organization.value.trim()) {
                showError('organization', 'Organization Name is required.');
                hasErrors = true;
            }

            const role = document.getElementById('role');
            if (!role.value.trim()) {
                showError('role', 'Role is required.');
                hasErrors = true;
            }

            const privacyConsent = document.getElementById('privacyConsent');
            if (!privacyConsent.checked) {
                showError('privacyConsent', 'You must agree to the Privacy Policy.');
                hasErrors = true;
            }

            if (hasErrors) {
                errorSummary.classList.remove('hidden');
                errorSummary.focus();

                // Track error event
                if (typeof window.gtag === 'function') {
                    window.gtag('event', 'enterprise_form_error', {
                        form_id: 'enterprise_project_brief_form',
                        error_type: 'client_validation',
                        page_type: 'project_brief'
                    });
                }
                return;
            }

            setLoading(true);

            try {
                const formData = new FormData(form);

                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                let data;
                try {
                    data = await response.json();
                } catch(e) {
                    // Fallback if not json
                    serverError.querySelector('p').textContent = 'An unexpected server response occurred. Please try again.';
                    serverError.classList.remove('hidden');
                    serverError.focus();
                    if (window.turnstile) {
                        window.turnstile.reset();
                    }
                    setLoading(false);
                    return;
                }

                if (response.ok && data.success) {

                    // Track successful lead generation
                    if (typeof window.gtag === 'function') {
                        window.gtag('event', 'generate_lead', {
                            form_id: 'enterprise_project_brief_form',
                            lead_type: 'enterprise',
                            project_type: formData.get('projectType') || 'unspecified',
                            budget_range: formData.get('budgetRange') || 'unspecified',
                            procurement_required: formData.get('procurementRequired') || 'unspecified'
                        });
                    }

                    // Redirect
                    window.location.href = data.redirectUrl || '/enterprise-solutions/project-brief/thank-you/';
                } else {
                    // Handle server errors
                    if (data.errors) {
                        for (const [field, message] of Object.entries(data.errors)) {
                            showError(field, message);
                        }
                        errorSummary.classList.remove('hidden');
                        errorSummary.focus();
                    } else if (data.message) {
                        serverError.querySelector('p').textContent = data.message;
                        serverError.classList.remove('hidden');
                        serverError.focus();

                        // Reset turnstile if it exists
                        if (window.turnstile) {
                            window.turnstile.reset();
                        }
                    }

                    if (typeof window.gtag === 'function') {
                        window.gtag('event', 'enterprise_form_error', {
                            form_id: 'enterprise_project_brief_form',
                            error_type: 'server_validation',
                            page_type: 'project_brief'
                        });
                    }
                }
            } catch (error) {
                serverError.querySelector('p').textContent = 'A network error occurred. Please try again.';
                serverError.classList.remove('hidden');
                serverError.focus();
                if (window.turnstile) {
                    window.turnstile.reset();
                }
            } finally {
                setLoading(false);
            }
        });
    });
</script>
