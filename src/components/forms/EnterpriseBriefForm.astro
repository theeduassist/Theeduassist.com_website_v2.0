---
import FormField from './FormField.astro';
import FormSelect from './FormSelect.astro';
import FormCheckbox from './FormCheckbox.astro';
import FormErrorSummary from './FormErrorSummary.astro';
import TurnstileField from './TurnstileField.astro';
import PrivacyAcknowledgement from './PrivacyAcknowledgement.astro';

const projectTypes = [
  { value: 'onboarding', label: 'Employee Onboarding' },
  { value: 'upskilling', label: 'Workforce Upskilling' },
  { value: 'compliance', label: 'Compliance Training' },
  { value: 'customer', label: 'Customer Education' },
  { value: 'partner', label: 'Partner Training' },
  { value: 'academy', label: 'Internal Learning Academy' },
  { value: 'ai_readiness', label: 'AI Workforce Readiness' },
  { value: 'other', label: 'Other' }
];

const audiences = [
  { value: 'internal', label: 'Internal Employees' },
  { value: 'external', label: 'External Customers' },
  { value: 'partners', label: 'Partners or Vendors' },
  { value: 'mixed', label: 'Mixed Audience' }
];

const contentStatus = [
  { value: 'none', label: 'No content yet (Need full design)' },
  { value: 'raw', label: 'Raw materials (PDFs, PPTs, Docs)' },
  { value: 'existing', label: 'Existing eLearning (Needs update/migration)' },
  { value: 'mixed', label: 'Mixed (Some raw, some existing)' }
];

const platforms = [
  { value: 'none', label: 'None selected yet' },
  { value: 'kajabi', label: 'Kajabi' },
  { value: 'workday', label: 'Workday Learning' },
  { value: 'cornerstone', label: 'Cornerstone OnDemand' },
  { value: 'docebo', label: 'Docebo' },
  { value: 'custom', label: 'Custom/Other LMS' },
  { value: 'unsure', label: 'Not sure / Need recommendation' }
];

const projectScopes = [
  { value: 'small', label: 'Small (1-2 courses)' },
  { value: 'medium', label: 'Medium (3-5 courses or curriculum)' },
  { value: 'large', label: 'Large (Complete academy or system)' },
  { value: 'unsure', label: 'Not sure yet' }
];

const timings = [
  { value: 'immediate', label: 'Immediate (Within 1 month)' },
  { value: 'short', label: 'Short-term (1-3 months)' },
  { value: 'medium', label: 'Medium-term (3-6 months)' },
  { value: 'planning', label: 'Planning phase (6+ months)' }
];
---

<form action="/api/forms/enterprise-brief" method="POST" id="enterprise-brief-form" class="space-y-8 max-w-full overflow-hidden p-1">
  <FormErrorSummary id="brief-form-errors" />

  <fieldset class="border border-slate-200 rounded-md p-4 sm:p-6 bg-white max-w-full overflow-hidden">
    <legend class="text-lg font-semibold text-brand-navy px-2">Contact Information</legend>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
      <FormField name="fullName" label="Full name" required={true} placeholder="Jane Doe" />
      <FormField name="email" label="Work email" type="email" required={true} placeholder="jane@company.com" />
      <FormField name="organization" label="Organization name" required={true} placeholder="Acme Corp" />
      <FormField name="role" label="Role or job function" required={true} placeholder="L&D Director" />
    </div>
  </fieldset>

  <fieldset class="border border-slate-200 rounded-md p-4 sm:p-6 bg-white max-w-full overflow-hidden">
    <legend class="text-lg font-semibold text-brand-navy px-2">Project Overview</legend>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
      <FormSelect name="projectType" label="Project type" options={projectTypes} required={true} />
      <FormSelect name="audience" label="Primary audience" options={audiences} required={true} />
      <FormSelect name="contentStatus" label="Current content status" options={contentStatus} required={true} />
      <FormSelect name="platform" label="Current or preferred platform" options={platforms} required={true} />
      <FormSelect name="scope" label="Approximate project scope" options={projectScopes} required={true} />
      <FormSelect name="timing" label="Target timing" options={timings} required={true} />
    </div>

    <div class="mt-6">
      <label for="objective" class="block text-sm font-medium text-slate-700 mb-1">Project objective <span class="text-red-500">*</span></label>
      <textarea id="objective" name="objective" rows="3" required maxlength="1500" class="w-full border border-slate-300 rounded-md p-2.5 focus:ring-2 focus:ring-blue-500 bg-white" placeholder="What is the main goal of this initiative?"></textarea>
    </div>

    <div class="mt-6">
      <label for="description" class="block text-sm font-medium text-slate-700 mb-1">Project description <span class="text-red-500">*</span></label>
      <textarea id="description" name="description" rows="5" required maxlength="5000" class="w-full border border-slate-300 rounded-md p-2.5 focus:ring-2 focus:ring-blue-500 bg-white" placeholder="Please describe the project details, constraints, and specific requirements."></textarea>
    </div>
  </fieldset>

  <fieldset class="border border-slate-200 rounded-md p-4 sm:p-6 bg-white max-w-full overflow-hidden">
    <legend class="text-lg font-semibold text-brand-navy px-2">Additional Options</legend>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
      <FormField name="website" label="Organization website (Optional)" type="url" placeholder="https://" />
      <FormField name="country" label="Country or primary region (Optional)" placeholder="e.g. UK, USA" />
    </div>
  </fieldset>

  <!-- Honeypot field to trap bots. Hidden from visual flow. -->
  <div class="hidden" aria-hidden="true">
    <label for="website_url">Do not fill this out if you are human</label>
    <input type="text" id="website_url" name="website_url" tabindex="-1" autocomplete="off" />
  </div>

  <PrivacyAcknowledgement />

  <div class="space-y-4">
    <FormCheckbox name="privacyPolicy" label="I acknowledge the Privacy Policy and data handling notice." required={true} />
    <FormCheckbox name="marketingOptIn" label="I agree to receive occasional updates about TheEduAssist services (Optional)." />
  </div>

  <div class="mt-8 max-w-full overflow-hidden">
    <TurnstileField />
  </div>

  <div class="mt-6">
    <button type="submit" id="submit-brief-btn" class="w-full sm:w-auto bg-brand-green hover:bg-green-600 text-brand-navy font-bold py-3 px-8 rounded-md transition-colors focus:ring-2 focus:ring-offset-2 focus:ring-brand-green">
      Submit Project Brief
    </button>
  </div>
</form>

<script>
  import { trackGenerateLead, trackEnterpriseFormError } from '../../lib/analytics/eventContract';

  const form = document.getElementById('enterprise-brief-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-brief-btn') as HTMLButtonElement;
  const errorSummary = document.getElementById('brief-form-errors') as HTMLDivElement;
  const errorList = document.getElementById('brief-form-errors-list') as HTMLUListElement;

  if (form) {
    // Basic JS progressive enhancement
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot check
      const hp = (document.getElementById('website_url') as HTMLInputElement).value;
      if (hp) return;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerText = 'Submitting...';
      }

      errorSummary.classList.add('hidden');
      errorList.innerHTML = '';

      const formData = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Accept': 'application/json'
          },
          body: formData
        });

        if (response.ok) {
          // Fire Analytics
          trackGenerateLead({
            form_id: 'enterprise-brief-form',
            lead_type: 'enterprise_brief',
            page_type: 'form_submission',
            project_type: formData.get('projectType') as string || 'unknown',
            audience_category: formData.get('audience') as string || 'unknown',
            platform_category: formData.get('platform') as string || 'unknown',
            budget_range: 'unknown',
            procurement_required: 'unknown'
          });

          window.location.href = '/enterprise-solutions/project-brief/?success=true';
        } else {
          const result = await response.json().catch(() => ({ error: 'An unexpected error occurred. Please try again.' }));

          trackEnterpriseFormError({
            form_id: 'enterprise-brief-form',
            error_type: result.error || 'server_error',
            field_category: 'submission',
            page_type: 'form_submission'
          });

          const li = document.createElement('li');
          li.textContent = result.error || 'An unexpected error occurred. Please try again.';
          errorList.appendChild(li);
          errorSummary.classList.remove('hidden');
          errorSummary.focus();

          // Reset Turnstile if error
          if (window.turnstile) {
            window.turnstile.reset();
          }
        }
      } catch (err) {
        trackEnterpriseFormError({
          form_id: 'enterprise-brief-form',
          error_type: 'network_error',
          field_category: 'submission',
          page_type: 'form_submission'
        });

        const li = document.createElement('li');
        li.textContent = 'A network error occurred. Please try again.';
        errorList.appendChild(li);
        errorSummary.classList.remove('hidden');
        errorSummary.focus();

        if (window.turnstile) {
            window.turnstile.reset();
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerText = 'Submit Project Brief';
        }
      }
    });
  }

  // Check for error code or success in URL params (non-JS flow)
  if (typeof window !== 'undefined') {
    const params = new URLSearchParams(window.location.search);
    if (params.get('success') === 'true') {
        const successMsg = document.createElement('div');
        successMsg.className = 'bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4';
        successMsg.role = 'alert';
        successMsg.innerHTML = '<strong class="font-bold">Success!</strong><span class="block sm:inline"> Your project brief has been submitted successfully.</span>';
        form.parentNode?.insertBefore(successMsg, form);
        form.reset();

        // Remove the query param without refreshing the page
        const newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.replaceState({path:newUrl}, '', newUrl);
    } else if (params.get('form') === 'error' && params.get('code')) {
      if (errorSummary && errorList) {
        const li = document.createElement('li');
        li.textContent = `Submission failed (Code: ${params.get('code')}). Please try again or contact us directly.`;
        errorList.appendChild(li);
        errorSummary.classList.remove('hidden');
        errorSummary.focus();

        trackEnterpriseFormError({
          form_id: 'enterprise-brief-form',
          error_type: params.get('code') as string,
          field_category: 'submission',
          page_type: 'form_submission'
        });
      }
    }
  }
</script>
