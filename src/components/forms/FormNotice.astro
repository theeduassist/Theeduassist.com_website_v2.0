---
export interface Props {
  message?: string;
  type?: 'info' | 'warning' | 'error' | 'success';
}

const {
  message = "The form backend is currently being integrated. Please email us directly or book a call.",
  type = 'info'
} = Astro.props;

const colors = {
  info: 'bg-blue-50 text-blue-800 border-blue-100',
  warning: 'bg-yellow-50 text-yellow-800 border-yellow-100',
  error: 'bg-red-50 text-red-800 border-red-100',
  success: 'bg-green-50 text-green-800 border-green-100'
};

const bgClass = colors[type];
---

<div class={`p-4 rounded-md border text-sm ${bgClass} mb-6`}>
  {message}
</div>
