---
export interface Props {
  name: string;
  label: string;
  required?: boolean;
  disabled?: boolean;
}

const {
  name,
  label,
  required = false,
  disabled = false
} = Astro.props;
---

<div class="flex items-start">
  <div class="flex items-center h-5">
    <input
      type="checkbox"
      id={name}
      name={name}
      value="true"
      class="w-4 h-4 border border-slate-300 rounded bg-white focus:ring-2 focus:ring-blue-500 disabled:bg-slate-50"
      required={required}
      disabled={disabled}
    />
  </div>
  <label for={name} class="ml-2 text-sm font-medium text-slate-700">
    {label} {required && <span class="text-red-500">*</span>}
  </label>
</div>
