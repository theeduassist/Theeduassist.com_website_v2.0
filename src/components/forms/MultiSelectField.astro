---
export interface Option {
  value: string;
  label: string;
}

export interface Props {
  name: string;
  label: string;
  options: Option[];
  required?: boolean;
  disabled?: boolean;
}

const {
  name,
  label,
  options,
  required = false,
  disabled = false
} = Astro.props;
---

<div>
  <fieldset>
    <legend class="block text-sm font-medium text-slate-700 mb-2">
      {label} {required && <span class="text-red-500">*</span>}
    </legend>
    <div class="space-y-2 max-h-48 overflow-y-auto border border-slate-300 rounded-md p-3 bg-white">
      {options.map((opt) => (
        <div class="flex items-start">
          <div class="flex h-5 items-center">
            <input
              type="checkbox"
              id={`${name}-${opt.value}`}
              name={name}
              value={opt.value}
              class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500 disabled:bg-slate-50 disabled:border-slate-200"
              disabled={disabled}
            />
          </div>
          <div class="ml-3 text-sm">
            <label for={`${name}-${opt.value}`} class={`font-medium ${disabled ? 'text-slate-400' : 'text-slate-700'}`}>
              {opt.label}
            </label>
          </div>
        </div>
      ))}
    </div>
  </fieldset>
</div>
