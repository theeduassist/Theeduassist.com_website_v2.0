---
import { LayoutTemplate, MousePointerClick, Mail, Settings, Users, BookOpen } from 'lucide-react';

const capabilities = [
  { icon: BookOpen, text: "Course architecture" },
  { icon: LayoutTemplate, text: "Kajabi websites" },
  { icon: MousePointerClick, text: "Landing & sales pages" },
  { icon: Settings, text: "Products & Offers" },
  { icon: Mail, text: "Email campaigns" },
  { icon: Users, text: "Customer onboarding" }
];
---
<section class="py-24 bg-brand-navy text-white relative overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute inset-0 z-0 opacity-10">
    <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path d="M0,0 L100,100 L0,100 Z" fill="currentColor"></path>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-16">

      <!-- Visual Side -->
      <div class="w-full lg:w-1/2 order-2 lg:order-1">
        <div class="grid grid-cols-2 gap-4">
          {capabilities.map((item, i) => (
            <div class="bg-white/5 border border-white/10 rounded-xl p-6 flex flex-col items-center text-center hover:bg-white/10 transition-colors">
              <item.icon className="w-8 h-8 text-brand-accent mb-4" aria-hidden="true" />
              <span class="text-sm font-medium text-slate-200">{item.text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Content Side -->
      <div class="w-full lg:w-1/2 order-1 lg:order-2">
        <div class="inline-block bg-brand-accent/20 border border-brand-accent/30 text-brand-accent px-4 py-1.5 rounded-full text-sm font-bold tracking-wide uppercase mb-6">
          Platform Specialty
        </div>
        <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight text-white">
          Build a Connected Kajabi Learning and Sales System
        </h2>
        <p class="text-lg text-slate-300 leading-relaxed mb-10">
          TheEduAssist helps creators, coaches, consultants, educators, training businesses and academies organize and improve their Kajabi courses, websites, Products, Offers, emails, automations and learner journeys.
        </p>

        <p class="text-slate-400 mb-10">
          We support the complete ecosystem: from checkout and funnels to library experience, migration, launch preparation and ongoing support.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/kajabi-services/" class="inline-flex justify-center items-center bg-brand-accent text-white px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white hover:text-brand-navy shadow-sm">
            Explore Kajabi Services
          </a>
          <a href="/book-free-kajabi-audit/" class="inline-flex justify-center items-center bg-transparent border-2 border-white/30 text-white px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white/10">
            Get a Kajabi Review
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
