---
interface Props {
  questions: { q: string; a: string }[];
}

const { questions } = Astro.props;
---
<section class="py-12 bg-white" aria-labelledby="ai-quick-answers">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-brand-softBg p-8 rounded-2xl border border-brand-border/40">
      <h2 id="ai-quick-answers" class="text-2xl font-bold text-brand-navy mb-6">Quick Answers</h2>
      <div class="space-y-6">
        {questions.map((faq) => (
          <div>
            <h3 class="text-lg font-bold text-brand-navy mb-2">{faq.q}</h3>
            <p class="text-brand-textMain text-base leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
