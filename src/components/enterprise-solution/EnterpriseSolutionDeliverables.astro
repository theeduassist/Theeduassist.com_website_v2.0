---
import { Package, CheckCircle2 } from "lucide-react";

interface Props {
  deliverables: string[];
}

const { deliverables } = Astro.props;
---

<section class="py-16 bg-slate-50 border-y border-slate-200">
  <div class="container mx-auto px-4 md:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-12 bg-white rounded-xl shadow-sm border border-slate-200 flex items-center justify-center shrink-0">
          <Package className="w-6 h-6 text-primary" />
        </div>
        <div>
          <h2 class="text-2xl font-bold text-slate-900">Typical Deliverables</h2>
          <p class="text-slate-600 mt-1">Assets and documentation provided during the engagement.</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {deliverables.map(item => (
          <div class="flex items-start gap-3 bg-white p-4 rounded-lg border border-slate-200 shadow-sm">
            <CheckCircle2 className="w-5 h-5 text-primary shrink-0 mt-0.5" />
            <span class="text-slate-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
