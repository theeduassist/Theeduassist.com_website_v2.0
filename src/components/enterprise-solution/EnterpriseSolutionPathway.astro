---
interface PathwayStage {
  title: string;
  description: string;
}

interface Props {
  title?: string;
  description?: string;
  stages: PathwayStage[];
}

const {
  title = "Solution Pathway",
  description = "The typical progression model.",
  stages
} = Astro.props;
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="container mx-auto px-4 md:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">{title}</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">{description}</p>
      </div>

      <div class="space-y-6">
        {stages.map((stage, index) => (
          <div class="relative flex flex-col md:flex-row gap-6 bg-white p-6 md:p-8 rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="absolute top-0 left-0 w-2 h-full bg-primary/20"></div>
            <div class="flex items-center justify-center w-12 h-12 bg-primary/10 rounded-xl text-primary font-bold text-xl shrink-0">
              {index + 1}
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">{stage.title}</h3>
              <p class="text-slate-600 leading-relaxed">{stage.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
