---
import { ArrowRight, Sparkles } from "lucide-react";

interface Props {
  eyebrow: string;
  title: string;
  body: string;
  primaryCtaLabel?: string;
  primaryCtaLink?: string;
  secondaryCtaLabel?: string;
  secondaryCtaLink?: string;
}

const {
  eyebrow,
  title,
  body,
  primaryCtaLabel = "Discuss Your Project",
  primaryCtaLink = "/contact/",
  secondaryCtaLabel = "Get a 24-48 Hour Review",
  secondaryCtaLink = "/book-free-audit/",
} = Astro.props;
---

<header class="relative overflow-hidden bg-slate-900 pt-32 pb-24 lg:pt-40 lg:pb-32">
  <div class="absolute inset-0 bg-[url('/ui/grid-pattern-light.svg')] opacity-5"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-primary/20 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="relative container mx-auto px-4 md:px-6 z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-800 border border-slate-700 text-primary-light mb-8">
        <Sparkles className="w-4 h-4" />
        <span class="text-sm font-semibold tracking-wide uppercase">{eyebrow}</span>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-8">
        {title}
      </h1>

      <p class="text-xl text-slate-300 mb-12 max-w-3xl mx-auto leading-relaxed">
        {body}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={primaryCtaLink}
          class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white px-8 py-4 rounded-lg font-bold transition-all text-lg w-full sm:w-auto"
        >
          {primaryCtaLabel}
          <ArrowRight className="w-5 h-5" />
        </a>
        <a
          href={secondaryCtaLink}
          class="inline-flex items-center justify-center gap-2 bg-slate-800 hover:bg-slate-700 text-white border border-slate-700 hover:border-slate-600 px-8 py-4 rounded-lg font-bold transition-all text-lg w-full sm:w-auto"
        >
          {secondaryCtaLabel}
        </a>
      </div>
    </div>
  </div>
</header>
