---



const categories = [
  { id: 'all', label: 'All Projects' },
  { id: 'course-creation', label: 'Course Creation' },
  { id: 'kajabi-builds', label: 'Kajabi Builds' },
  { id: 'lms-migration', label: 'LMS Migration' },
  { id: 'content-conversion', label: 'Content Conversion' },
  { id: 'ai-elearning', label: 'AI E-Learning Support' },
  { id: 'funnels', label: 'Funnels & Automation' },
  { id: 'support', label: 'Ongoing Support' }
];
---

<!-- <SectionWrapper --> <section className="bg-slate-50 py-12 border-b border-slate-200">
  <!-- <ContentContainer> --> <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-slate-900">Explore by Project Type</h2>
    </div>

    <div class="flex flex-wrap gap-3">
      {categories.map((cat, index) => (
        <a
          href={`#${cat.id}`}
          class={`inline-flex items-center px-4 py-2 rounded-md text-sm font-medium transition-colors ${
            index === 0
            ? 'bg-[#27496D] text-white border border-[#27496D]'
            : 'bg-white text-slate-700 border border-slate-300 hover:bg-slate-50 hover:border-slate-400'
          }`}
        >
          {cat.label}
        </a>
      ))}
    </div>
  </div> <!-- </ContentContainer> -->
</section> <!-- </SectionWrapper> -->
