---


import Card from '../ui/Card.astro';

const services = [
  {
    title: 'Course Creation & Curriculum Design',
    description: 'Structuring content into a logical learner journey.',
    link: '/services/' // fallback since specific route might not exist
  },
  {
    title: 'Kajabi Services',
    description: 'Building and launching complete Kajabi systems.',
    link: '/kajabi-services/'
  },
  {
    title: 'LMS Implementation & Migration',
    description: 'Moving and organizing content across platforms.',
    link: '/services/lms-implementation-migration/'
  },
  {
    title: 'AI-Powered E-Learning Support',
    description: 'Accelerating content conversion with AI tools.',
    link: '/services/ai-powered-elearning/'
  },
  {
    title: 'Content Conversion',
    description: 'Turning raw knowledge into platform-ready assets.',
    link: '/services/content-conversion/'
  },
  {
    title: 'Funnels & Automation',
    description: 'Connecting pages, checkout, and onboarding flows.',
    link: '/services/funnels-automation/'
  },
  {
    title: 'Ongoing Support & Maintenance',
    description: 'Keeping systems running smoothly post-launch.',
    link: '/services/ongoing-support-maintenance/'
  }
];
---

<!-- <SectionWrapper --> <section className="bg-white py-24">
  <!-- <ContentContainer> --> <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-slate-900">Services Behind the Work</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(service => (
        <a href={service.link} class="group block h-full">
          <Card className="flex flex-col h-full bg-slate-50 border-slate-200 group-hover:border-[#27496D] group-hover:shadow-md transition-all">
            <h3 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-[#27496D] transition-colors">
              {service.title}
            </h3>
            <p class="text-slate-600 text-sm mb-4 flex-grow">
              {service.description}
            </p>
            <div class="flex items-center text-sm font-medium text-[#27496D]">
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </Card>
        </a>
      ))}
    </div>
  </div> <!-- </ContentContainer> -->
</section> <!-- </SectionWrapper> -->
