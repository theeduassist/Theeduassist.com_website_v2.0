---
const { study } = Astro.props;
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="mb-10 max-w-3xl">
    <h2 class="text-3xl font-bold text-slate-900 mb-4">The Challenge</h2>
    <p class="text-lg text-slate-600">
      Before working with TheEduAssist, the client faced several hurdles in scaling their learning program effectively.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {study.challenge.map((item: string) => (
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-start group hover:-translate-y-1 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center mr-4 flex-shrink-0 text-red-500">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
             <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <p class="text-slate-700 font-medium text-sm leading-relaxed mt-2">{item}</p>
      </div>
    ))}
  </div>
</section>
