---
const { study } = Astro.props;
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="mb-10 max-w-3xl">
    <h2 class="text-3xl font-bold text-slate-900 mb-4">The Solution</h2>
    <p class="text-lg text-slate-600">
      How we designed and built the custom learning ecosystem.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {study.solution.map((item: string, index: number) => (
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-start">
        <div class="w-8 h-8 rounded-full bg-[#EFF6FF] flex items-center justify-center mr-4 flex-shrink-0 text-[#27496D] font-bold text-sm">
          {index + 1}
        </div>
        <p class="text-slate-700 font-medium text-sm leading-relaxed mt-1.5">{item}</p>
      </div>
    ))}
  </div>
</section>
