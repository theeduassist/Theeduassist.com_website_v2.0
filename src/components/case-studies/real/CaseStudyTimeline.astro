---
const { study } = Astro.props;
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="mb-12">
    <h2 class="text-3xl font-bold text-slate-900 mb-4">Delivery Timeline</h2>
    <p class="text-lg text-slate-600 mb-2">
      {study.sprintModel.description}
    </p>
    <p class="text-xs text-slate-400 italic">
      Public sprint-based delivery model. Exact internal dates are not disclosed.
    </p>
  </div>

  <div class="relative border-l-2 border-slate-200 ml-3 md:ml-6 space-y-8">
    {study.sprintModel.sprints.map((sprint: any) => (
      <div class="relative pl-8 md:pl-12">
        <!-- Node -->
        <div class="absolute w-6 h-6 bg-white border-4 border-[#27496D] rounded-full -left-[13px] top-1.5 shadow"></div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex flex-wrap justify-between items-start gap-4 mb-4">
            <div>
              <span class="inline-block px-2 py-1 rounded text-[10px] font-bold tracking-wide bg-[#EFF6FF] text-[#27496D] uppercase mb-2">
                Sprint {sprint.number} • {sprint.duration}
              </span>
              <h3 class="text-xl font-bold text-slate-900">{sprint.name}</h3>
            </div>
            <div class="bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-100 text-right">
              <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-0.5">Output</p>
              <p class="text-sm font-medium text-[#77BA55]">{sprint.output}</p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-4">
            <div>
               <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Goal</p>
               <p class="text-sm text-slate-700">{sprint.goal}</p>
            </div>
            <div>
               <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Activities</p>
               <p class="text-sm text-slate-700">{sprint.activities}</p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
