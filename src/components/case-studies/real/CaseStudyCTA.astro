---
const { study } = Astro.props;
---
<section class="bg-[#27496D] py-20 mt-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
      Want to Build a Similar Learning System?
    </h2>
    <p class="text-xl text-blue-100 mb-10 leading-relaxed max-w-3xl mx-auto">
      Send us your course, Kajabi, LMS, book, training, or content challenge and TheEduAssist will reply within 24–48 hours with the best service path, estimated scope, and next step.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <a href="/book-free-audit/?source=case-study-cta" class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-bold rounded-md text-white bg-[#77BA55] hover:bg-[#65A344] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[#27496D] focus:ring-[#77BA55] shadow-lg transition-colors duration-200">
        Get 24–48 Hour Review
      </a>
      <button type="button" class="tawk-case-study-btn inline-flex items-center justify-center px-8 py-4 border-2 border-white/20 text-lg font-bold rounded-md text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[#27496D] focus:ring-white transition-colors duration-200 focus-ring">
        Build Something Similar
      </button>
    </div>
  </div>
</section>

<script>
  import { openCaseStudyChat } from '../../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-case-study-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openCaseStudyChat({
          contentType: 'case_study',
          contentTitle: document.title,
          pageUrl: window.location.href,
          pageTitle: document.title
        });
      });
    });
  });
</script>
