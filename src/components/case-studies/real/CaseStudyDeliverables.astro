---
const { study } = Astro.props;
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 bg-slate-100 rounded-3xl my-12 border border-slate-200">
  <div class="mb-10 text-center">
    <h2 class="text-3xl font-bold text-slate-900 mb-4">Work Delivered</h2>
    <p class="text-lg text-slate-600">The assets and systems produced during this engagement.</p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {study.deliverables.map((item: string) => (
      <div class="bg-white px-4 py-6 rounded-xl border border-slate-200 text-center shadow-sm hover:-translate-y-1 transition-transform">
         <svg class="w-8 h-8 text-[#77BA55] mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
         </svg>
         <span class="text-sm font-medium text-slate-800">{item}</span>
      </div>
    ))}
  </div>
</section>

<!-- Why it Worked -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 mt-8">
  <div class="mb-10 max-w-3xl">
    <h2 class="text-3xl font-bold text-slate-900 mb-4">Why It Worked</h2>
    <p class="text-lg text-slate-600">
      This project succeeded because we focused on these core e-learning principles:
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {[
      "Learning structure",
      "Content clarity",
      "LMS readiness",
      "Learner-centered design",
      "Trainer/teacher enablement",
      "QA before launch"
    ].map((item: string) => (
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-start">
        <div class="w-8 h-8 rounded-full bg-[#F3FAF0] flex items-center justify-center mr-4 flex-shrink-0 text-[#77BA55] border border-[#77BA55]/30">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <p class="text-slate-700 font-medium text-sm leading-relaxed mt-1.5">{item}</p>
      </div>
    ))}
  </div>
</section>

<!-- Learning Journey Diagram -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="text-center mb-12">
    <h3 class="text-2xl font-bold text-slate-900 mb-4">The Learner Experience</h3>
    <p class="text-slate-600">The structured path designed for this project's audience.</p>
  </div>

  <div class="flex flex-wrap justify-center items-center gap-2 md:gap-4">
    {study.learningJourney.map((step: string, index: number) => (
      <div class="flex items-center">
        <div class="px-4 py-2 bg-white border border-slate-200 rounded-lg shadow-sm text-sm font-medium text-slate-700">
          {step}
        </div>
        {index < study.learningJourney.length - 1 && (
          <svg class="w-5 h-5 text-slate-300 mx-1 md:mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
      </div>
    ))}
  </div>
</section>
