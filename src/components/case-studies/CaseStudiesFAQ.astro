---



const faqs = [
  {
    question: 'Are these real client case studies?',
    answer: 'Some items may be shown as example builds or portfolio concepts until full client-approved case studies are available. We do not publish client names, results, or screenshots without approval.'
  },
  {
    question: 'Can you show work similar to my project?',
    answer: 'Yes. Get a 24-48 hour review and we can discuss examples that match your course, platform, content, or learning system needs.'
  },
  {
    question: 'Do you work only with Kajabi projects?',
    answer: 'No. Kajabi is one specialty, but TheEduAssist also supports LMS migration, course creation, AI-powered e-learning support, content conversion, funnels, automation, and ongoing support.'
  },
  {
    question: 'Can you work under NDA?',
    answer: 'Yes, project confidentiality and NDA-based work can be discussed during the audit.'
  },
  {
    question: 'Can my project become a case study?',
    answer: 'Only with your permission. We can anonymize details or keep the project private if needed.'
  },
  {
    question: 'What is the best first step?',
    answer: 'Get a 24-48 hour review so we can understand your content, platform, course idea, and launch goals.'
  }
];
---

<!-- <SectionWrapper --> <section className="bg-slate-50 py-24 border-b border-slate-200">
  <!-- <ContentContainer> --> <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">Case Studies FAQ</h2>
      <p class="text-lg text-slate-600">
        Common questions about our project examples and client confidentiality.
      </p>
    </div>

    <div class="max-w-3xl mx-auto divide-y divide-slate-200">
      {faqs.map((faq) => (
        <div class="py-6">
          <h3 class="text-lg font-bold text-slate-900 mb-2">{faq.question}</h3>
          <p class="text-slate-600 leading-relaxed">{faq.answer}</p>
        </div>
      ))}
    </div>
  </div> <!-- </ContentContainer> -->
</section> <!-- </SectionWrapper> -->
