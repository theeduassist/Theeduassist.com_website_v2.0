---
// src/components/content-conversion/FormatConversionSection.astro
---
<section class="py-20 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">Different Content Needs Different Conversion</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <div class="bg-white rounded-2xl p-8 border border-brand-border shadow-sm hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-brand-softBg rounded-xl flex items-center justify-center mb-6">
           <svg class="w-8 h-8 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="text-2xl font-bold text-brand-navy mb-4">PDFs and Documents</h3>
        <p class="text-brand-textMuted mb-6 font-medium">Can become:</p>
        <ul class="space-y-3">
          {["lesson summaries", "module notes", "downloadable guides", "worksheets", "quizzes", "student handouts"].map((item) => (
             <li class="flex items-start">
                <svg class="w-5 h-5 text-brand-accent mr-3 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-brand-textMain font-medium">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white rounded-2xl p-8 border border-brand-border shadow-sm hover:shadow-md transition-shadow relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-brand-softGreen/30 rounded-bl-full -z-10"></div>
        <div class="w-14 h-14 bg-brand-softBg rounded-xl flex items-center justify-center mb-6">
           <svg class="w-8 h-8 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"></path></svg>
        </div>
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Slide Decks</h3>
        <p class="text-brand-textMuted mb-6 font-medium">Can become:</p>
        <ul class="space-y-3">
          {["lesson outlines", "video scripts", "slide narration", "presentation-based lessons", "workbook sections", "recap resources"].map((item) => (
             <li class="flex items-start">
                <svg class="w-5 h-5 text-brand-accent mr-3 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-brand-textMain font-medium">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white rounded-2xl p-8 border border-brand-border shadow-sm hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-brand-softBg rounded-xl flex items-center justify-center mb-6">
           <svg class="w-8 h-8 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Videos and Webinars</h3>
        <p class="text-brand-textMuted mb-6 font-medium">Can become:</p>
        <ul class="space-y-3">
          {["lesson structure", "chapter summaries", "key takeaways", "action steps", "quiz questions", "resource lists", "student support content"].map((item) => (
             <li class="flex items-start">
                <svg class="w-5 h-5 text-brand-accent mr-3 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-brand-textMain font-medium">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
