---
// src/components/content-conversion/ContentInputsSection.astro
---
<section class="py-20 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">What Content Can We Convert?</h2>
      <p class="text-lg text-brand-textMuted bg-white p-4 rounded-lg inline-block border border-brand-border/50 shadow-sm">
        We help organize, rewrite, restructure, and prepare content depending on format, quality, and platform requirements.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
      {[
        "PDFs and documents",
        "Slide decks and presentations",
        "Recorded webinars",
        "Long-form videos",
        "Training manuals",
        "SOPs and internal documents",
        "Coaching frameworks",
        "Workshop notes",
        "Blog posts and articles",
        "Google Drive folders",
        "Old course files",
        "Existing LMS exports"
      ].map((item) => (
        <div class="bg-white px-4 py-4 rounded-lg border border-brand-border/40 text-center shadow-sm hover:shadow-md hover:border-brand-accent/30 transition-all flex flex-col items-center justify-center min-h-[100px]">
          <svg class="w-6 h-6 text-brand-textMuted mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          <span class="text-sm font-semibold text-brand-navy">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>
