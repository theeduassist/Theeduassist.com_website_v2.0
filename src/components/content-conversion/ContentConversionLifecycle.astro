---
// src/components/content-conversion/ContentConversionLifecycle.astro
---
<section id="conversion-process" class="py-24 bg-brand-navy text-white relative overflow-hidden">
  <div class="absolute inset-0 z-0 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:24px_24px] opacity-5"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-6">From Scattered Files to Structured Learning Assets</h2>
    </div>

    <div class="relative max-w-5xl mx-auto">
        <!-- Connecting Line for Desktop -->
        <div class="hidden md:block absolute top-1/2 left-0 w-full h-1 bg-brand-border/30 -translate-y-1/2 z-0"></div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10">
            {[
                { step: "1. Audit", desc: "We review your content volume, format, quality, audience, course goals, and platform needs." },
                { step: "2. Sort", desc: "We organize files into topics, modules, lessons, resources, and support content." },
                { step: "3. Simplify", desc: "We remove repetition, reduce overload, rewrite unclear sections, and make it easier to follow." },
                { step: "4. Structure", desc: "We create lesson flow, module order, resource placement, activities, and completion logic." },
                { step: "5. Convert", desc: "We turn raw files into summaries, scripts, worksheets, quizzes, downloads, and platform-ready assets." },
                { step: "6. Prepare", desc: "We format and organize the content for Kajabi, LMS platforms, course websites, or internal systems." },
                { step: "7. Review", desc: "We check clarity, learner experience, accuracy, file naming, links, and readiness." },
                { step: "8. Improve", desc: "We refine content after feedback, testing, or launch." }
            ].map((item, index) => (
                <div class="bg-white/5 border border-white/10 p-6 rounded-2xl backdrop-blur-sm relative hover:bg-white/10 transition-colors">
                    <div class="absolute -top-4 -left-4 w-10 h-10 bg-brand-accent text-white rounded-full flex items-center justify-center font-bold text-lg shadow-lg">
                        {index + 1}
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-brand-accent mt-2">{item.step.substring(3)}</h3>
                    <p class="text-sm text-brand-textMuted text-gray-300 leading-relaxed">{item.desc}</p>
                </div>
            ))}
        </div>
    </div>
  </div>
</section>
