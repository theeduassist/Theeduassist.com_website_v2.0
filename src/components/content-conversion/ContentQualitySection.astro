---
// src/components/content-conversion/ContentQualitySection.astro
---
<section class="py-20 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-start gap-12 max-w-6xl mx-auto">
      <div class="lg:w-1/3 sticky top-24">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6 leading-tight">
          We Clean the Content Before It Goes Into the Course
        </h2>
        <p class="text-lg text-brand-textMuted leading-relaxed">
          Before content becomes a learning asset, it needs review and cleanup. TheEduAssist checks for repetition, unclear language, missing steps, outdated sections, file naming issues, learner overload, and weak lesson flow.
        </p>
      </div>

      <div class="lg:w-2/3 grid sm:grid-cols-2 gap-4">
        {[
          { title: "Remove duplication", icon: "M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" },
          { title: "Rewrite unclear sections", icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" },
          { title: "Break long content into lessons", icon: "M4 6h16M4 10h16M4 14h16M4 18h16" },
          { title: "Add learner instructions", icon: "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
          { title: "Rename and organize files", icon: "M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" },
          { title: "Create resource hierarchy", icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" },
          { title: "Identify missing assets", icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" },
          { title: "Prepare review checklist", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" }
        ].map((item) => (
          <div class="bg-white p-5 rounded-xl border border-brand-border/60 shadow-sm flex items-center space-x-4">
             <div class="w-10 h-10 bg-brand-softBg rounded-lg flex items-center justify-center shrink-0 text-brand-primary">
                 <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon}></path></svg>
             </div>
             <span class="font-semibold text-brand-navy">{item.title}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
