---
import Button from '../ui/Button.astro';

export interface Props {
  email: string;
}

const { email } = Astro.props;
---

<section class="py-16 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center text-slate-900 mb-12">Choose the Best Way to Reach Us</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Card 1 -->
      <div class="bg-white p-8 rounded-xl border border-slate-200 shadow-sm flex flex-col h-full">
        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">Get a 24-48 Hour Review</h3>
        <p class="text-slate-600 mb-6 flex-grow">
          <strong class="font-medium text-slate-800">Best for:</strong> Course, Kajabi, LMS, content conversion, AI support, funnel, or launch projects.
        </p>
        <Button href="/book-free-audit/" variant="primary" class="w-full text-center">Get 24–48 Hour Review</Button>
      </div>

      <!-- Card 2 -->
      <div class="bg-white p-8 rounded-xl border border-slate-200 shadow-sm flex flex-col h-full">
        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">View Services & Pricing</h3>
        <p class="text-slate-600 mb-6 flex-grow">
          <strong class="font-medium text-slate-800">Best for:</strong> Exploring packages, inclusions, and finding a starting point.
        </p>
        <Button href="/services/" variant="outline" class="w-full text-center">View Services & Starting Prices</Button>
      </div>

      <!-- Card 3 -->
      <div class="bg-white p-8 rounded-xl border border-slate-200 shadow-sm flex flex-col h-full">
        <div class="mb-6 pb-6 border-b border-slate-200">
           <h3 class="text-xl font-bold text-slate-900 mb-3">Email TheEduAssist</h3>
           <p class="text-sm text-slate-600 mb-4">For general questions and partnership inquiries.</p>
           <a href="mailto:Info@theeduassist.com?subject=TheEduAssist%20Project%20Inquiry&body=Hi%20TheEduAssist%2C%0A%0AI%20would%20like%20to%20discuss%20a%20course%2C%20Kajabi%2C%20LMS%2C%20content%20conversion%2C%20or%20e-learning%20project.%0A%0AMy%20project%20details%3A%0A" aria-label="Email TheEduAssist" class="text-blue-600 hover:text-blue-800 font-medium transition-colors">{email}</a>
        </div>

        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">Connect on Social</h3>
        <p class="text-slate-600 mb-6 flex-grow">
          Follow us for eLearning tips, platform updates, and company news.
        </p>
        <div class="flex flex-col gap-3">
          <a href="https://www.linkedin.com/company/theeduassist" target="_blank" rel="noopener noreferrer" class="flex items-center text-slate-600 hover:text-blue-600 transition-colors font-medium">
            <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            LinkedIn
          </a>
          <a href="https://www.instagram.com/theeduassist" target="_blank" rel="noopener noreferrer" class="flex items-center text-slate-600 hover:text-pink-600 transition-colors font-medium">
            <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            Instagram
          </a>
          <a href="https://www.facebook.com/people/Theeduassist/61576126813447/" target="_blank" rel="noopener noreferrer" class="flex items-center text-slate-600 hover:text-blue-800 transition-colors font-medium">
            <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
            Facebook
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
