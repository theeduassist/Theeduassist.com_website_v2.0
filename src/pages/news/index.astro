---
import Layout from "../../layouts/Layout.astro";

const title = "News | TheEduAssist";
const description = "Company news and updates from TheEduAssist.";
const canonicalPath = "/news/";
---

<Layout title={title} description={description} canonicalPath={canonicalPath}>
  <div class="container mx-auto px-4 py-24 text-center max-w-3xl min-h-[60vh] flex flex-col justify-center">
    <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-6">Company News</h1>
    <p class="text-xl text-slate-600 mb-8">
      We're busy building great courses and platforms for our clients. Company news and updates will appear here later.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/blog/" class="px-6 py-3 bg-[var(--color-accent)] text-white font-bold rounded-lg hover:bg-opacity-90 transition-all">Read our Blog</a>
      <a href="/press-releases/" class="px-6 py-3 bg-white text-slate-700 border border-slate-300 font-bold rounded-lg hover:bg-slate-50 transition-all">Press Releases</a>
    </div>
  </div>
</Layout>
