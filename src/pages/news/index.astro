---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";

const title = "News | TheEduAssist";
const description = "TheEduAssist updates, service announcements, platform updates, and e-learning industry notes.";
const canonicalPath = "/news/";
---

<Layout title={title} description={description} canonicalPath={canonicalPath}>
  <div class="container mx-auto px-4 py-24 text-center max-w-3xl min-h-[60vh] flex flex-col justify-center">
    <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-6">Company News</h1>
    <p class="text-xl text-slate-600 mb-8">
      This page will contain TheEduAssist updates, service announcements, platform updates, and e-learning industry notes.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/contact/" class="px-6 py-3 bg-[var(--color-accent)] text-white font-bold rounded-lg hover:bg-opacity-90 transition-all">Contact Us</a>
      <a href="/book-free-audit/" class="px-6 py-3 bg-white text-slate-700 border border-slate-300 font-bold rounded-lg hover:bg-slate-50 transition-all">Get 24–48 Hour Review</a>
    </div>
  </div>
</Layout>
