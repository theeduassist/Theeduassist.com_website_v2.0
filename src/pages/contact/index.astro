---
import Layout from "../../layouts/Layout.astro";
import ContactHero from "../../components/contact/ContactHero.astro";
import ContactOptions from "../../components/contact/ContactOptions.astro";
import ContactFAQ from "../../components/contact/ContactFAQ.astro";
import { webPageSchema, breadcrumbSchema } from '../../lib/seo/schema';

const jsonLd = [
  webPageSchema(
    "Contact TheEduAssist | E-Learning Design Agency",
    "Contact TheEduAssist for online course creation, Kajabi setup, LMS migration, AI-powered e-learning support, content conversion, funnels, automation, and course launch support.",
    "/contact/"
  ),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Contact", urlPath: "/contact/" }
  ])
];

const trustChips = [
  "Course Creation",
  "Kajabi Setup",
  "LMS Migration",
  "AI E-Learning Support",
  "Content Conversion",
  "Funnels & Automation"
];
---
<Layout
  title="Contact TheEduAssist | E-Learning Design Agency"
  description="Contact TheEduAssist for online course creation, Kajabi setup, LMS migration, AI-powered e-learning support, content conversion, funnels, automation, and course launch support."
  canonicalPath="/contact/"
  jsonLd={jsonLd}
>

  <ContactHero
    title="Contact TheEduAssist"
    subtitle="Have a course idea, Kajabi setup, LMS migration, training content, or online learning system that needs structure? Contact TheEduAssist and we’ll help you find the right next step."
    primaryCtaLabel="Get 24–48 Hour Review"
    primaryCtaLink="/book-free-audit/"
    secondaryCtaLabel="Email Us"
    secondaryCtaLink="mailto:Info@theeduassist.com?subject=TheEduAssist%20Project%20Inquiry&body=Hi%20TheEduAssist%2C%0A%0AI%20would%20like%20to%20discuss%20a%20course%2C%20Kajabi%2C%20LMS%2C%20content%20conversion%2C%20or%20e-learning%20project.%0A%0AMy%20project%20details%3A%0A"
    email="Info@theeduassist.com"
    trustChips={trustChips}
  />

  <ContactOptions email="Info@theeduassist.com" />

  <!-- Form Section -->
  <section class="py-24 bg-slate-50 border-t border-slate-200" id="review-form">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white p-4 md:p-10 rounded-xl border border-slate-200 shadow-sm overflow-hidden text-center">

        <h2 class="text-3xl font-bold mb-4 text-slate-900">Get Your Course Reviewed in 24–48 Hours</h2>
        <p class="text-slate-600 max-w-2xl mx-auto text-lg mb-10">
          Share your course, Kajabi, LMS, content, or launch challenge. TheEduAssist team will review your request and reply with the best service path, estimated scope, and next step.
        </p>

        <div class="w-full mx-auto relative rounded-lg border border-slate-100" style="overflow-x: hidden;">
          <iframe
            src="https://docs.google.com/forms/d/e/1FAIpQLSceDHOuoN8pGLzkG80JDiQFFtZRr9mxQTHkVRZnWqe3pnesDA/viewform?embedded=true"
            width="100%"
            height="4800"
            class="border-0 bg-white"
            title="TheEduAssist 24–48 Hour Course Review Form"
            loading="lazy"
          >Loading…</iframe>
        </div>

        <div class="mt-8 text-center border-t border-slate-100 pt-6">
          <p class="text-slate-600 mb-4">Having trouble viewing the form?</p>
          <a
            href="https://docs.google.com/forms/d/e/1FAIpQLSceDHOuoN8pGLzkG80JDiQFFtZRr9mxQTHkVRZnWqe3pnesDA/viewform"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center bg-white text-blue-600 border border-blue-200 hover:bg-blue-50 px-6 py-3 rounded-md font-semibold transition-colors focus-ring"
          >
            Open Review Form in New Tab
          </a>
        </div>
      </div>
    </div>
  </section>

  <ContactFAQ />

</Layout>
