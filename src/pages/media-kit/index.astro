---
import Layout from "../../layouts/Layout.astro";
import { webPageSchema, breadcrumbSchema, organizationSchema } from '../../lib/seo/schema';

const jsonLd = [
  webPageSchema(
    "Media Kit | TheEduAssist",
    "Official boilerplates, brand assets, and company information for TheEduAssist.",
    "/media-kit/"
  ),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Newsroom", urlPath: "/newsroom/" },
    { name: "Media Kit", urlPath: "/media-kit/" }
  ]),
  organizationSchema()
];
---

<Layout
  title="Media Kit | TheEduAssist"
  description="Official boilerplates, brand assets, and company information for TheEduAssist."
  canonicalPath="/media-kit/"
  jsonLd={jsonLd}
>
  <main class="bg-slate-50 min-h-screen py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <span class="text-sm font-semibold uppercase tracking-wider text-[#77BA55] mb-2 inline-block">Official Resources</span>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Media Kit</h1>
        <p class="text-lg text-slate-600">Company facts, boilerplates, and media contacts.</p>
      </div>

      <div class="bg-white p-8 rounded-2xl border border-slate-200 shadow-sm mb-12 space-y-8">
        <section>
          <h2 class="text-2xl font-bold text-slate-800 mb-4 border-b border-slate-100 pb-2">About TheEduAssist</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            TheEduAssist is an e-learning design and course-building agency helping creators, coaches, consultants, educators, training companies, online academies, and businesses turn expertise and training material into structured online courses, Kajabi systems, LMS experiences, and launch-ready digital learning content.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-slate-800 mb-4 border-b border-slate-100 pb-2">Core Services</h2>
          <ul class="list-disc pl-5 text-slate-600 space-y-2">
            <li>Course Creation & Curriculum Design</li>
            <li>Kajabi Website & Course Setup</li>
            <li>LMS Implementation & Migration</li>
            <li>AI-Powered E-Learning Support</li>
            <li>Content Conversion</li>
            <li>Funnels & Automation</li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-bold text-slate-800 mb-4 border-b border-slate-100 pb-2">Media Contact</h2>
          <div class="bg-slate-50 p-4 rounded-lg border border-slate-100">
            <p class="text-slate-700 font-medium mb-1">Press Inquiries</p>
            <a href="mailto:Info@theeduassist.com" class="text-[#27496D] hover:underline">Info@theeduassist.com</a>
          </div>
        </section>

        <section>
           <h2 class="text-xl font-bold text-slate-800 mb-4 border-b border-slate-100 pb-2">Official Links</h2>
           <ul class="space-y-2 text-slate-600">
             <li><span class="font-medium">Website:</span> <a href="https://theeduassist.com/" class="text-[#27496D] hover:underline">https://theeduassist.com/</a></li>
             <li><span class="font-medium">LinkedIn:</span> <a href="https://www.linkedin.com/company/theeduassist" class="text-[#27496D] hover:underline" target="_blank" rel="noopener noreferrer">https://www.linkedin.com/company/theeduassist</a></li>
             <li><span class="font-medium">Instagram:</span> <a href="https://www.instagram.com/theeduassist" class="text-[#27496D] hover:underline" target="_blank" rel="noopener noreferrer">https://www.instagram.com/theeduassist</a></li>
             <li><span class="font-medium">Facebook:</span> <a href="https://www.facebook.com/people/Theeduassist/61576126813447/" class="text-[#27496D] hover:underline" target="_blank" rel="noopener noreferrer">TheEduAssist Facebook Page</a></li>
           </ul>
        </section>
      </div>

    </div>
  </main>
</Layout>