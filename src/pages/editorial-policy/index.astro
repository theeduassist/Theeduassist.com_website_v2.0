---
import Layout from "../../layouts/Layout.astro";
import { webPageSchema, breadcrumbSchema } from '../../lib/seo/schema';

const jsonLd = [
  webPageSchema(
    "Editorial Policy | TheEduAssist",
    "Read TheEduAssist's editorial policy on publishing e-learning, course creation, and platform guides.",
    "/editorial-policy/"
  ),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Editorial Policy", urlPath: "/editorial-policy/" }
  ])
];
---

<Layout
  title="Editorial Policy | TheEduAssist"
  description="Read TheEduAssist's editorial policy on publishing e-learning, course creation, and platform guides."
  canonicalPath="/editorial-policy/"
  jsonLd={jsonLd}
>
  <main class="container mx-auto px-4 py-24 max-w-4xl min-h-screen">
    <h1 class="text-4xl font-bold text-brand-navy mb-8">Editorial Policy</h1>

    <div class="prose prose-lg prose-slate prose-a:text-brand-primary">
      <p>At TheEduAssist, our content is written to help creators, educators, coaches, consultants, and training teams build better online courses, Kajabi platforms, and LMS systems.</p>

      <h2>Content Creation and Accuracy</h2>
      <p>All content is drafted, reviewed, and published with a focus on accuracy, usefulness, and e-learning best practices. Content may be reviewed by instructional design and platform specialists to ensure technical claims are accurate.</p>

      <h2>Updates to Service and Content</h2>
      <p>Service pages and guides are updated periodically when software offerings (like Kajabi or LMS features) or our agency offerings change. We aim to keep all guides as up-to-date as possible.</p>

      <h2>No Unqualified Advice</h2>
      <p>We provide advice on e-learning, course creation, Kajabi, LMS implementation, and instructional design. We do not provide medical, legal, or financial advice.</p>

      <h2>Contact Us</h2>
      <p>If you spot an error, have a correction, or have questions about our content, please contact us at <a href="mailto:Info@theeduassist.com">Info@theeduassist.com</a>.</p>
    </div>
  </main>
</Layout>
