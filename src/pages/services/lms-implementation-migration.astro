---
import Layout from "../../layouts/Layout.astro";

import ServiceHero from "../../components/service-page/ServiceHero.astro";
import ServiceShortAnswer from "../../components/service-page/ServiceShortAnswer.astro";
import ServiceAudience from "../../components/service-page/ServiceAudience.astro";
import ServiceProblems from "../../components/service-page/ServiceProblems.astro";
import ServiceDeliverables from "../../components/service-page/ServiceDeliverables.astro";
import ServiceMigrationProcess from "../../components/service-page/ServiceMigrationProcess.astro";
import ServiceLimitations from "../../components/service-page/ServiceLimitations.astro";
import ServiceRelatedCaseStudies from "../../components/service-page/ServiceRelatedCaseStudies.astro";
import ServiceRelatedContent from "../../components/service-page/ServiceRelatedContent.astro";
import ServiceFAQ from "../../components/service-page/ServiceFAQ.astro";
import ServiceFinalCTA from "../../components/service-page/ServiceFinalCTA.astro";

import { professionalServiceSchema, breadcrumbSchema, faqPageSchema } from '../../lib/seo/schema';

const title = "LMS Implementation and Migration Services | TheEduAssist";
const description = "TheEduAssist helps organizations and training providers define LMS requirements, organize courses, prepare content, configure the learning experience, plan migration and test the system before launch.";

const lmsFaqs = [
  { question: "Can you help select an LMS?", answer: "Yes, we help you compare platforms based on your audience, volume, course types, reporting needs, accessibility, budget, and implementation capacity." },
  { question: "Can you migrate courses from an existing platform?", answer: "Yes, we can move selected learning content and available data from your current system into a new or restructured environment." },
  { question: "Can you move learner data?", answer: "We can move learner data provided your current system allows us to export it cleanly. Unavailable source data cannot be migrated." },
  { question: "Can you organize an existing LMS?", answer: "Yes, if your current LMS has become messy, we can reorganize courses, categories, and user roles to make it clear and usable again." },
  { question: "Do you support SCORM or xAPI?", answer: "Yes, but support depends on the target LMS and the content package. Compatibility must be tested, and not every course needs these standards." },
  { question: "Can you configure users and permissions?", answer: "Yes, we help set up user roles, enrollment structures, and permissions as part of the LMS configuration." },
  { question: "Do you test before launch?", answer: "Yes, we test access, courses, and reporting before planning the final launch and handover." },
  { question: "Can you provide ongoing LMS support?", answer: "Yes, we offer ongoing learning support for planned maintenance, course updates, and system administration." },
  { question: "Is zero-data-loss migration guaranteed?", answer: "No, zero data loss cannot be guaranteed. Migration depends on available exports, source system access, and testing. Custom integrations and unavailable data require manual handling." }
];

const jsonLd = [
  professionalServiceSchema(),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Services", urlPath: "/services/" },
    { name: "LMS Implementation and Migration", urlPath: "/services/lms-implementation-migration/" }
  ]),
  faqPageSchema(lmsFaqs.map(f => ({ questionName: f.question, acceptedAnswerText: f.answer })))
];
---

<Layout
  title={title}
  description={description}
  canonicalPath="/services/lms-implementation-migration/"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <ServiceHero
      eyebrow="LMS Implementation and Migration"
      title="Set Up or Migrate an LMS Around Your Learning Requirements"
      description="TheEduAssist helps organizations and training providers define LMS requirements, organize courses, prepare content, configure the learning experience, plan migration and test the system before launch."
      primaryCtaLabel="Discuss Your LMS Project"
      primaryCtaLink="/contact/"
      secondaryCtaLabel="Get a 24–48 Hour Review"
      secondaryCtaLink="/book-free-audit/"
    />

    <ServiceShortAnswer
      heading="What Is LMS Implementation and Migration?"
      answer="LMS implementation prepares a learning platform for courses, users, content and reporting. LMS migration moves selected learning content and available data from an existing system into a new or restructured environment."
    />

    <ServiceAudience
      audiences={[
        "Corporate L&D teams",
        "Training providers",
        "Academies",
        "Associations",
        "Customer education teams",
        "Organizations replacing a legacy LMS",
        "Teams with disorganized LMS content",
        "Clients moving from manually managed learning",
        "Organizations selecting a platform"
      ]}
    />

    <ServiceProblems
      problems={[
        { problem: "Unclear platform requirements.", solution: "We help define exact needs before selecting software." },
        { problem: "Courses structured inconsistently.", solution: "We build a standard information architecture." },
        { problem: "Outdated LMS configuration.", solution: "We update settings and configure the environment." },
        { problem: "Scattered content.", solution: "We inventory and centralize learning assets." },
        { problem: "Weak user experience.", solution: "We configure branding and learner navigation." },
        { problem: "Unclear roles and permissions.", solution: "We establish clean user access structures." },
        { problem: "Migration uncertainty.", solution: "We plan a step-by-step migration process." },
        { problem: "Duplicated or obsolete courses.", solution: "We remove unneeded content during the move." },
        { problem: "Launch without sufficient testing.", solution: "We verify courses and access before go-live." }
      ]}
    />

    <ServiceDeliverables
      title="Implementation May Include"
      description="We adapt the setup to your specific platform and requirements."
      deliverables={[
        "Requirements gathering",
        "Platform comparison support",
        "Information architecture",
        "Course and category organization",
        "User-role planning",
        "Enrollment structure",
        "Permissions review",
        "Branding configuration",
        "Course setup",
        "Content upload and organization",
        "Assessment setup where supported",
        "Notification planning",
        "Reporting requirements",
        "Testing",
        "Administrator guidance",
        "Launch checklist"
      ]}
    />

    <ServiceMigrationProcess
      stages={[
        { title: "Audit & Inventory", items: ["Audit the current system", "Inventory courses, files and users", "Identify data that can be exported"] },
        { title: "Plan & Clean", items: ["Remove obsolete or duplicate content", "Map the old structure to the new LMS", "Prepare and convert content"] },
        { title: "Configure & Move", items: ["Configure the new environment", "Migrate selected content", "Migrate available data"] },
        { title: "Test & Launch", items: ["Test access, courses and reporting", "Plan launch", "Handover to administrators"] }
      ]}
    />

    <section class="py-16 bg-slate-50 border-b border-slate-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <div>
                <h3 class="text-2xl font-bold text-brand-navy mb-4">Platform Selection</h3>
                <p class="text-slate-700 leading-relaxed mb-6">
                    We do not declare one LMS universally best or publish unsupported platform partnerships. Platform selection must carefully consider:
                </p>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-slate-700">
                    <li class="flex items-start"><span class="text-brand-accent mr-2">•</span> Audience and user volume</li>
                    <li class="flex items-start"><span class="text-brand-accent mr-2">•</span> Course types and content standards</li>
                    <li class="flex items-start"><span class="text-brand-accent mr-2">•</span> Reporting and administration</li>
                    <li class="flex items-start"><span class="text-brand-accent mr-2">•</span> Integrations and security</li>
                    <li class="flex items-start"><span class="text-brand-accent mr-2">•</span> Accessibility and localization</li>
                    <li class="flex items-start"><span class="text-brand-accent mr-2">•</span> Budget and support</li>
                </ul>
            </div>
            <div>
                <h3 class="text-2xl font-bold text-brand-navy mb-4">SCORM and xAPI Support</h3>
                <p class="text-slate-700 leading-relaxed mb-4">
                    SCORM or xAPI support depends heavily on both the target LMS and the specific content package. We test compatibility, but tracking behavior may vary between systems.
                </p>
                <p class="text-slate-700 leading-relaxed">
                    Implementing xAPI may require additional architecture (like an LRS). We help you determine if your courses actually need these standards, as not every platform or learning experience requires them.
                </p>
            </div>
        </div>
      </div>
    </section>

    <ServiceLimitations
      limitations={[
        "Migration depends on source exports and access",
        "Some content may require manual recreation",
        "Custom integrations need separate assessment",
        "Unavailable source data cannot be migrated",
        "Payment details must not be handled insecurely",
        "Downtime and launch planning depend on the client environment",
        "Zero data loss cannot be guaranteed",
        "Final compatibility requires testing"
      ]}
    />

    <section class="py-16 bg-white border-b border-slate-200">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-2xl font-bold text-brand-navy mb-6">Related Services</h2>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="/services/learning-strategy/" class="px-6 py-3 bg-slate-100 text-brand-navy rounded-full font-medium hover:bg-slate-200 transition-colors">Learning Strategy</a>
                <a href="/services/course-development/" class="px-6 py-3 bg-slate-100 text-brand-navy rounded-full font-medium hover:bg-slate-200 transition-colors">Course Development</a>
                <a href="/services/custom-elearning-development/" class="px-6 py-3 bg-slate-100 text-brand-navy rounded-full font-medium hover:bg-slate-200 transition-colors">Custom eLearning</a>
                <a href="/services/content-conversion/" class="px-6 py-3 bg-slate-100 text-brand-navy rounded-full font-medium hover:bg-slate-200 transition-colors">Content Conversion</a>
                <a href="/services/quality-assurance-accessibility/" class="px-6 py-3 bg-slate-100 text-brand-navy rounded-full font-medium hover:bg-slate-200 transition-colors">Quality Assurance</a>
                <a href="/services/ongoing-support-maintenance/" class="px-6 py-3 bg-slate-100 text-brand-navy rounded-full font-medium hover:bg-slate-200 transition-colors">Ongoing Support</a>
            </div>
        </div>
    </section>

    <ServiceRelatedCaseStudies
      slugs={['sqa-aligned-vocational-training', 'business-analytics-corporate-training']}
    />
    <ServiceRelatedContent categories={["LMS", "E-Learning"]} />

    <ServiceFAQ faqs={lmsFaqs} />

    <ServiceFinalCTA serviceSlug="lms-implementation" />
  </main>
</Layout>
