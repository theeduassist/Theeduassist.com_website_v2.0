---
import Layout from "../../layouts/Layout.astro";

import LMSMigrationHero from "../../components/lms/LMSMigrationHero.astro";
import LMSProblemSection from "../../components/lms/LMSProblemSection.astro";
import LMSAudienceSection from "../../components/lms/LMSAudienceSection.astro";
import LMSSourcesSection from "../../components/lms/LMSSourcesSection.astro";
import LMSMigrationLifecycle from "../../components/lms/LMSMigrationLifecycle.astro";
import LMSSetupCapabilities from "../../components/lms/LMSSetupCapabilities.astro";
import LMSPlatformAgnostic from "../../components/lms/LMSPlatformAgnostic.astro";
import LMSContentStandards from "../../components/lms/LMSContentStandards.astro";
import LMSLearnerExperience from "../../components/lms/LMSLearnerExperience.astro";
import LMSComparison from "../../components/lms/LMSComparison.astro";
import LMSEngagementTypes from "../../components/lms/LMSEngagementTypes.astro";
import LMSFAQ from "../../components/lms/LMSFAQ.astro";
import LMSFinalCTA from "../../components/lms/LMSFinalCTA.astro";
import CaseStudyProof from "../../components/case-studies/CaseStudyProof.astro";
import AIAnswerBlock from "../../components/ai/AIAnswerBlock.astro";
import { faqPageSchema } from '../../lib/seo/schema';

const aiAnswers = [
  { q: "What is LMS implementation and migration?", a: "LMS implementation and migration means selecting, configuring, organizing, and moving learning content into a platform where learners can access courses, resources, assessments, and progress tracking clearly." },
  { q: "Can TheEduAssist migrate content from one LMS to another?", a: "Yes. TheEduAssist safely moves courses, media, and learning content between platforms, ensuring the new structure is clean and user-friendly." },
  { q: "Can TheEduAssist organize messy training content?", a: "Yes. They specialize in taking scattered files, PDFs, Google Drive folders, and old courses and rebuilding them into a structured curriculum." }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "LMS Implementation & Migration Services",
    "description": "Safe strategies for moving course content, learners, and media. We support Moodle-style LMS, WordPress LMS, LearnDash, Thinkific, Teachable, TalentLMS, Canvas, Custom LMS, Membership Hubs, Internal Training Portals, and more.",
    "provider": {
      "@type": "Organization",
      "name": "TheEduAssist"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.theeduassist.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Services",
        "item": "https://www.theeduassist.com/services/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "LMS Implementation & Migration Services",
        "item": "https://www.theeduassist.com/services/lms-implementation-migration/"
      }
    ]
  }
];

const lmsFaqs = [
  { question: "What is LMS migration?", answer: "LMS migration is the process of safely moving courses, user data, completion records, and media from an old learning platform to a new one while improving the learning experience." },
  { question: "Which LMS is best for training companies?", answer: "There is no single 'best' LMS. TalentLMS, Docebo, and LearnUpon are strong for B2B/B2C training. We help you select based on your specific audience and business model during the 24-48 Hour Review." },
  { question: "How do you move old training content into an LMS?", answer: "We perform a content audit, structure the curriculum map, clean up files, convert them to standard formats (like SCORM, xAPI, or native modules), and then upload and test them in the new platform." },
  { question: "What is the difference between Kajabi and an LMS?", answer: "Kajabi is an all-in-one marketing, website, and course platform built for creators. An enterprise LMS (like TalentLMS or Docebo) focuses deeply on compliance tracking, reporting, learning paths, and B2B user management without native marketing funnels." },
  { question: "What should a company prepare before LMS implementation?", answer: "A company should prepare access to current course files, a list of learning objectives, branding assets, their ideal timeline, and an understanding of what the old LMS lacked." },
  { question: "Can you migrate content from WordPress?", answer: "Yes. We can help organize WordPress-based course content and rebuild it into a cleaner LMS or e-learning platform structure." },
  { question: "Can you migrate content from Google Drive?", answer: "Yes. We can help organize Google Drive folders, documents, PDFs, videos, and resources into modules, lessons, and learner-friendly assets." }
];

jsonLd.push(faqPageSchema(lmsFaqs));

// SEO
const title = "LMS Implementation & Migration Services | TheEduAssist";
const description = "TheEduAssist helps creators, educators, training companies, academies, and businesses migrate, organize, and rebuild learning content from WordPress, Google Drive, PDFs, old LMS platforms, and scattered files into clean LMS and e-learning systems.";
---

<Layout jsonLd={jsonLd} title={title} description={description}>
  <main>
    <LMSMigrationHero />
    <LMSProblemSection />
    <LMSAudienceSection />
    <LMSSourcesSection />
    <LMSMigrationLifecycle />
    <LMSSetupCapabilities />
    <LMSPlatformAgnostic />
    <LMSContentStandards />
    <LMSLearnerExperience />
    <LMSComparison />
    <CaseStudyProof slugs={['sqa-aligned-vocational-training', 'language-courses-book-publisher']} />

    <section class="py-16 bg-white border-y border-brand-border/30">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center text-brand-navy mb-8">LMS Migration Checklist</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-brand-textMain">
          <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/50">
            <h3 class="font-bold text-brand-primary mb-4 text-xl border-b border-brand-border pb-2">Phase 1: Pre-Migration</h3>
            <ul class="space-y-3">
              <li class="flex items-start"><span class="text-brand-accent mr-2">✓</span> Audit existing courses and media files.</li>
              <li class="flex items-start"><span class="text-brand-accent mr-2">✓</span> Map the new LMS learning paths and categories.</li>
              <li class="flex items-start"><span class="text-brand-accent mr-2">✓</span> Export user data and completion records.</li>
              <li class="flex items-start"><span class="text-brand-accent mr-2">✓</span> Backup all SCORM/xAPI packages.</li>
            </ul>
          </div>
          <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/50">
            <h3 class="font-bold text-brand-primary mb-4 text-xl border-b border-brand-border pb-2">Phase 2: Execution & QA</h3>
            <ul class="space-y-3">
              <li class="flex items-start"><span class="text-brand-accent mr-2">✓</span> Setup platform brand and notification emails.</li>
              <li class="flex items-start"><span class="text-brand-accent mr-2">✓</span> Upload and rebuild course structures.</li>
              <li class="flex items-start"><span class="text-brand-accent mr-2">✓</span> Import user data and assign correct access.</li>
              <li class="flex items-start"><span class="text-brand-accent mr-2">✓</span> Conduct UAT (User Acceptance Testing) before launch.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <LMSEngagementTypes />
    <AIAnswerBlock questions={aiAnswers} />
    <LMSFAQ />
    <LMSFinalCTA />
  </main>
  <script>
    import { openStartServiceChat } from "../../utils/tawkSales";
    document.addEventListener("DOMContentLoaded", () => {
      const btns = document.querySelectorAll(".tawk-service-btn");
      btns.forEach(btn => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLButtonElement;
          openStartServiceChat({
            serviceSlug: target.dataset.serviceSlug || "",
            pageUrl: window.location.href,
            pageTitle: document.title,
          });
        });
      });
    });
  </script>

</Layout>
