---

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "AI-Powered E-Learning Support",
    "description": "TheEduAssist uses AI-assisted, human-reviewed workflows to help creators, educators, academies, and training teams turn raw ideas, PDFs, videos, slides, and notes into course plans, lesson scripts, worksheets, quizzes, summaries, launch content, and platform-ready learning assets.",
    "provider": {
      "@type": "Organization",
      "name": "TheEduAssist"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.theeduassist.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Services",
        "item": "https://www.theeduassist.com/services/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "AI-Powered E-Learning Support",
        "item": "https://www.theeduassist.com/services/ai-powered-elearning/"
      }
    ]
  }
];

import { faqPageSchema } from '../../lib/seo/schema';

const aiElearningFaqs = [
  { question: "How can AI help course creation?", answer: "AI can accelerate course creation by drafting module outlines, generating ideas for assessments, and summarizing lengthy PDFs or videos into digestible microlearning units." },
  { question: "Can AI generate quizzes and assessments?", answer: "Yes. Given a transcript or lesson document, AI can rapidly generate multiple-choice, true/false, and short-answer quiz questions. Human review is required to verify accuracy." },
  { question: "Can AI translate training content?", answer: "Yes. AI translation tools can accurately translate course scripts and generate localized subtitles for global workforces." },
  { question: "What should humans still review?", answer: "Humans must review all AI-generated content for factual accuracy, brand tone, cultural nuance, absence of bias, and overall learner experience." },
  { question: "What are the risks of AI-generated learning content?", answer: "The main risks are 'hallucinations' (factually incorrect statements), generic or boring tone, and the inclusion of biased or copyrighted material." },
  { question: "Can I just use ChatGPT myself?", answer: "Yes, and many clients do. But AI tools usually produce drafts and ideas. TheEduAssist helps turn those ideas into structured, reviewed, platform-ready learning assets and course systems." },
  { question: "Do you store or train AI on my content?", answer: "We do not use client content to train our own AI models. We can discuss privacy needs during the audit and choose a workflow that fits your content sensitivity." }
];

jsonLd.push(faqPageSchema(aiElearningFaqs));

import Layout from "../../layouts/Layout.astro";
import AIElearningHero from "../../components/ai-elearning/AIElearningHero.astro";
import WhyNotDIYAI from "../../components/ai-elearning/WhyNotDIYAI.astro";
import AIServiceBuckets from "../../components/ai-elearning/AIServiceBuckets.astro";
import AICaseExample from "../../components/ai-elearning/AICaseExample.astro";
import AIPricingPackages from "../../components/ai-elearning/AIPricingPackages.astro";
import AIPackageChooser from "../../components/ai-elearning/AIPackageChooser.astro";
import AIWorkflow from "../../components/ai-elearning/AIWorkflow.astro";
import ResponsibleAISection from "../../components/ai-elearning/ResponsibleAISection.astro";
import AIAudienceSection from "../../components/ai-elearning/AIAudienceSection.astro";
import AIDeliverablesGrid from "../../components/ai-elearning/AIDeliverablesGrid.astro";
import AIComparison from "../../components/ai-elearning/AIComparison.astro";
import AIFAQ from "../../components/ai-elearning/AIFAQ.astro";
import AIFinalCTA from "../../components/ai-elearning/AIFinalCTA.astro";
import AIAnswerBlock from "../../components/ai/AIAnswerBlock.astro";

const aiAnswers = [
  { q: "How can AI support e-learning development?", a: "AI can support e-learning by helping structure content, create assessments, summarize material, translate learning assets, support personalization, and maintain learning resources. Human review is still needed for accuracy, ethics, and learner experience." },
  { q: "Can AI help convert raw content into course outlines?", a: "Yes. We use AI to help process large amounts of raw text (like PDFs or transcripts) and propose initial modular structures, saving time before the human review phase." },
  { q: "Does human review remain part of the process?", a: "Absolutely. Human review is mandatory in our workflow to ensure the course doesn't feel generic, tone is correct, and learning objectives are actually met." }
];

---

<Layout jsonLd={jsonLd}
  title="AI-Powered E-Learning Support | Course Planning, Content Conversion & Launch Assets"
  description="TheEduAssist uses AI-assisted, human-reviewed workflows to help creators, educators, academies, and training teams turn raw ideas, PDFs, videos, slides, and notes into course plans, lesson scripts, worksheets, quizzes, summaries, launch content, and platform-ready learning assets."
>

  <AIElearningHero />
  <WhyNotDIYAI />
  <AIServiceBuckets />
  <AICaseExample />
  <AIPricingPackages />
  <AIPackageChooser />
  <AIWorkflow />
  <ResponsibleAISection />
  <AIAudienceSection />
  <AIDeliverablesGrid />
  <AIComparison />

  <section class="py-16 bg-white border-y border-brand-border/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-brand-navy mb-8">Common Course Build Mistakes</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-brand-textMain">
        <ul class="space-y-4">
          <li class="flex items-start">
            <span class="text-red-500 mr-3 font-bold text-xl">❌</span>
            <span><strong>Skipping the Outline:</strong> Using AI to write full lessons before establishing the core curriculum map.</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-500 mr-3 font-bold text-xl">❌</span>
            <span><strong>No Human Review:</strong> Publishing AI-generated quiz questions that test irrelevant or hallucinated details.</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-500 mr-3 font-bold text-xl">❌</span>
            <span><strong>Too Much Content:</strong> Having AI summarize a 500-page manual into another 50-page document instead of microlearning videos.</span>
          </li>
        </ul>
        <ul class="space-y-4">
          <li class="flex items-start">
            <span class="text-red-500 mr-3 font-bold text-xl">❌</span>
            <span><strong>Generic Tone:</strong> Letting AI write the course in a robotic voice, stripping away the creator's unique personality.</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-500 mr-3 font-bold text-xl">❌</span>
            <span><strong>Ignoring Privacy:</strong> Uploading confidential, proprietary business data into public LLMs.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <AIAnswerBlock questions={aiAnswers} />
  <AIFAQ />
  <AIFinalCTA />

  <script>
    import { openStartServiceChat } from "../../utils/tawkSales";
    document.addEventListener("DOMContentLoaded", () => {
      const btns = document.querySelectorAll(".tawk-service-btn");
      btns.forEach(btn => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLButtonElement;
          openStartServiceChat({
            serviceSlug: target.dataset.serviceSlug || "",
            pageUrl: window.location.href,
            pageTitle: document.title,
          });
        });
      });
    });
  </script>

</Layout>
