---
import Layout from "../../../layouts/Layout.astro";
import AIAnswerBlock from "../../../components/ai/AIAnswerBlock.astro";
import { professionalServiceSchema, breadcrumbSchema, faqPageSchema } from '../../../lib/seo/schema';

const faqs = [
  { question: "What should employees know before using AI at work?", answer: "Employees should understand data privacy risks (not sharing confidential data with public LLMs), the reality of AI hallucinations (fact-checking outputs), brand voice alignment, and when human oversight is mandatory." },
  { question: "What topics should AI ethics training include?", answer: "Training should cover your internal acceptable use policy, prompt engineering for safety, copyright rules, bias awareness, deepfakes, and practical role-based scenarios." },
  { question: "How do companies reduce AI misuse?", answer: "By providing clear, scenario-based training rather than just a 50-page legal policy. Employees need to see realistic examples of 'what to do' and 'what not to do' in their specific roles." },
  { question: "How do you train employees on responsible AI?", answer: "We convert your high-level AI policies into interactive LMS modules. This includes bite-sized videos, realistic workplace dilemmas, and mandatory knowledge checks before employees are granted AI tool access." },
  { question: "Can you turn our internal AI policy into employee training?", answer: "Yes, this is a core service. We take your internal AI policies, risk guidelines, and compliance rules and structure them into engaging eLearning modules. We create lesson outlines, scripts, quizzes, and manager discussion guides to ensure the policy is actually understood." },
  { question: "Do you provide AI Act compliance training?", answer: "TheEduAssist can help organizations turn AI literacy and responsible AI expectations into employee-friendly training, but we do not provide legal advice or official compliance certification. We can support L&D and compliance teams by converting AI policies, role expectations, and risk guidance into structured modules, scenarios, quizzes, and LMS-ready learning materials." },
  { question: "Which LMS platforms can support AI ethics training?", answer: "Our structured training can be uploaded to almost any modern enterprise LMS, including Docebo, Absorb LMS, TalentLMS, LearnUpon, Litmos, iSpring Learn, Moodle, and Canvas. We can also provide SCORM packages built with tools like Articulate Rise." },
  { question: "Can you create SCORM or xAPI-ready AI ethics modules?", answer: "Yes. If your enterprise requires SCORM or xAPI formats for tracking and compliance reporting, we can develop the modules using authoring tools like Articulate 360, ensuring they integrate perfectly with your existing tracking infrastructure." },
  { question: "How long does an AI ethics training project take?", answer: "Timelines depend on the scope. A basic AI literacy starter package can take 2-4 weeks, while a comprehensive, role-based global rollout with SCORM modules and custom policy conversion can take 6-12 weeks." },
  { question: "How do we start an enterprise AI training project with TheEduAssist?", answer: "The best way to start is to request a 24-48 Hour Review. Share your current AI policy or training goals with us, and we will outline a recommended curriculum structure, timeline, and delivery format tailored to your team." }
];

const jsonLd = [
  professionalServiceSchema(),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Services", urlPath: "/services/" },
    { name: "AI Ethics & Responsible AI Training", urlPath: "/services/ai-ethics-corporate-training/" }
  ]),
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "AI Ethics & Responsible AI Training Development",
    "provider": {
      "@type": "Organization",
      "name": "TheEduAssist"
    },
    "areaServed": {
      "@type": "GeoShape",
      "address": "Global / remote"
    },
    "description": "Convert AI ethics policies, responsible AI guidelines, and AI literacy needs into LMS-ready employee training programs, scenarios, quizzes, and global rollout content."
  },
  faqPageSchema(faqs)
];

const metaTitle = "AI Ethics Training for Employees | Responsible AI Corporate Training | TheEduAssist";
const metaDescription = "TheEduAssist helps enterprises convert AI ethics policies, responsible AI guidelines, and AI literacy needs into LMS-ready employee training programs, scenarios, quizzes, and global rollout content.";
const canonicalPath = "/services/ai-ethics-corporate-training/";
---

<Layout title={metaTitle} description={metaDescription} canonicalPath={canonicalPath} jsonLd={jsonLd}>

  {/* Hero Section */}
  <section class="relative pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden bg-brand-navy text-white border-b border-brand-border/30">
      <div class="absolute inset-0 z-0 bg-[radial-gradient(#ffffff20_1px,transparent_1px)] [background-size:16px_16px] opacity-20"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-primary opacity-20 blur-[100px] rounded-full pointer-events-none -z-10"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 max-w-4xl mx-auto leading-tight">
              AI Ethics & Responsible AI Training for Global Teams
          </h1>
          <p class="text-lg md:text-xl text-slate-300 mb-10 max-w-3xl mx-auto leading-relaxed">
              TheEduAssist helps enterprises, HR teams, L&D departments, and compliance leaders turn AI ethics policies and responsible AI guidance into structured employee training. We design LMS-ready modules, scenarios, quizzes, role-based learning paths, and practical resources that help teams use AI more safely and responsibly.
          </p>
          <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mb-8">
              <a href="/book-free-audit/" class="w-full sm:w-auto bg-brand-accent text-white px-8 py-3.5 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white hover:text-brand-navy shadow-md text-center">
                  Get 24–48 Hour Review
              </a>
              <a href="#lms-options" class="w-full sm:w-auto bg-transparent border border-slate-500 text-white px-8 py-3.5 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-slate-800 hover:border-slate-400 text-center">
                  Explore LMS Support
              </a>
          </div>
          <p class="text-sm text-slate-400 max-w-2xl mx-auto font-medium tracking-wide">
              Built for global teams, corporate L&D, HR, compliance, operations, and enterprise training departments.
          </p>
      </div>
  </section>

  {/* Quick Answer */}
  <section class="py-12 bg-brand-softBg">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="bg-white p-8 rounded-2xl border border-brand-border/50 shadow-sm">
              <h2 class="text-lg font-bold text-brand-primary mb-3 uppercase tracking-wider text-center">Quick Answer</h2>
              <p class="text-brand-textMain text-center text-lg leading-relaxed font-medium">
                  TheEduAssist provides AI ethics and responsible AI training development for companies that need to educate employees on safe, ethical, and practical AI use. We help convert internal AI policies, risk guidance, and leadership expectations into structured LMS-ready learning modules, quizzes, scenarios, and rollout materials.
              </p>
          </div>
      </div>
  </section>

  {/* Who This Is For */}
  <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Who Needs Responsible AI Training?</h2>
              <p class="text-lg text-brand-textMuted">Designed to align and educate the teams driving your global operations.</p>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
              {[
                  "Enterprise L&D teams", "HR departments", "Compliance teams", "Operations teams",
                  "Customer support teams", "Sales teams", "Managers and team leads", "Global workforce training teams",
                  "SaaS and tech companies", "Financial services teams", "Healthcare organizations", "Consulting firms"
              ].map(item => (
                  <div class="bg-slate-50 border border-brand-border/40 p-4 rounded-xl text-center font-semibold text-brand-navy hover:border-brand-accent/50 transition-colors">
                      {item}
                  </div>
              ))}
          </div>
      </div>
  </section>

  {/* What We Help You Build */}
  <section class="py-20 bg-brand-navy text-white relative overflow-hidden">
      <div class="absolute right-0 top-0 w-1/2 h-full bg-brand-primary/10 skew-x-12 transform origin-top-right z-0"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
              <div>
                  <h2 class="text-3xl md:text-4xl font-bold mb-6">How TheEduAssist Builds AI Ethics Training</h2>
                  <p class="text-lg text-slate-300 mb-8 leading-relaxed">
                      We translate complex AI governance and policy language into practical, engaging, and highly structured learning paths. Our approach ensures employees don't just read rules, but understand how to apply them safely in their daily work.
                  </p>
                  <ul class="space-y-4">
                      {[
                          "AI ethics & AI literacy modules",
                          "Generative AI workplace safety training",
                          "Internal AI policy training conversion",
                          "Human oversight & escalation workflows",
                          "Role-based AI training paths",
                          "Scenario-based knowledge checks",
                          "LMS upload-ready content",
                          "SCORM/xAPI-ready packages where needed"
                      ].map(item => (
                          <li class="flex items-start text-slate-200">
                              <svg class="w-6 h-6 text-brand-accent mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                              <span class="font-medium text-lg">{item}</span>
                          </li>
                      ))}
                  </ul>
              </div>
              <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl">
                  <h3 class="text-xl font-bold text-brand-accent mb-6">What Should Employees Learn Before Using AI at Work?</h3>
                  <div class="space-y-4">
                      {[
                          "What AI can and cannot do",
                          "Responsible use of generative AI",
                          "Data privacy and confidential information",
                          "Bias, fairness, and inclusion",
                          "Human review and accountability",
                          "Hallucinations and output verification",
                          "Safe prompting at work",
                          "AI use in HR, sales, support, and operations",
                          "Internal policy and escalation rules",
                          "Copyright and content ownership awareness"
                      ].map(topic => (
                          <div class="bg-white/10 px-4 py-3 rounded-lg border border-white/5 flex items-center">
                              <div class="w-2 h-2 rounded-full bg-brand-accent mr-3"></div>
                              <span class="text-sm font-medium">{topic}</span>
                          </div>
                      ))}
                  </div>
              </div>
          </div>
      </div>
  </section>

  {/* Enterprise Learning Lifecycle */}
  <section class="py-20 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Enterprise Learning Lifecycle</h2>
              <p class="text-lg text-brand-textMuted">A structured approach to transforming policy into practice.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {[
                  { num: "1", title: "Discover", desc: "Review your AI policy, employee roles, platforms, risks, and training goals." },
                  { num: "2", title: "Structure", desc: "Convert policies and guidance into learning outcomes, modules, lessons, and assessments." },
                  { num: "3", title: "Create", desc: "Develop scripts, summaries, worksheets, quizzes, scenarios, and manager guides." },
                  { num: "4", title: "Build", desc: "Prepare LMS-ready content for enterprise systems like Docebo, TalentLMS, or Litmos." },
                  { num: "5", title: "Launch", desc: "Support rollout planning, learner onboarding, and internal communications." },
                  { num: "6", title: "Improve", desc: "Review completion flow, knowledge gaps, feedback, and future training updates." }
              ].map(step => (
                  <div class="bg-white p-8 rounded-2xl border border-brand-border/60 shadow-sm relative">
                      <div class="text-5xl font-extrabold text-brand-softBlue absolute top-4 right-6 opacity-40">{step.num}</div>
                      <h3 class="text-xl font-bold text-brand-navy mb-3 relative z-10">{step.title}</h3>
                      <p class="text-brand-textMain relative z-10">{step.desc}</p>
                  </div>
              ))}
          </div>
      </div>
  </section>

  {/* LMS Delivery Options */}
  <section id="lms-options" class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center max-w-3xl mx-auto mb-12">
              <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Can AI Ethics Training Be Delivered Through an LMS?</h2>
              <p class="text-lg text-brand-textMuted">TheEduAssist can prepare AI ethics training for enterprise LMS and course platforms depending on your setup. Built for internal training, onboarding, and workforce enablement.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              <div class="border border-brand-border p-6 rounded-xl">
                  <h3 class="font-bold text-brand-primary mb-4 border-b border-brand-border pb-2">Enterprise LMS</h3>
                  <ul class="space-y-2 text-sm text-brand-textMain">
                      <li>• Docebo</li><li>• Absorb LMS</li><li>• TalentLMS</li><li>• LearnUpon</li><li>• Litmos</li><li>• iSpring Learn</li><li>• 360Learning</li>
                  </ul>
              </div>
              <div class="border border-brand-border p-6 rounded-xl">
                  <h3 class="font-bold text-brand-primary mb-4 border-b border-brand-border pb-2">Academic LMS</h3>
                  <ul class="space-y-2 text-sm text-brand-textMain">
                      <li>• Moodle</li><li>• Canvas</li><li>• Blackboard</li><li>• Brightspace</li>
                  </ul>
              </div>
              <div class="border border-brand-border p-6 rounded-xl">
                  <h3 class="font-bold text-brand-primary mb-4 border-b border-brand-border pb-2">Authoring Tools</h3>
                  <ul class="space-y-2 text-sm text-brand-textMain">
                      <li>• Articulate Rise</li><li>• Storyline</li><li>• iSpring Suite</li><li>• SCORM/xAPI workflows</li>
                  </ul>
              </div>
              <div class="border border-brand-border p-6 rounded-xl">
                  <h3 class="font-bold text-brand-primary mb-4 border-b border-brand-border pb-2">Knowledge Systems</h3>
                  <ul class="space-y-2 text-sm text-brand-textMain">
                      <li>• SharePoint</li><li>• Google Drive</li><li>• Notion</li><li>• Confluence</li><li>• Existing SOP libraries</li>
                  </ul>
              </div>
          </div>
      </div>
  </section>

  {/* Role-Based Training Paths */}
  <section class="py-20 bg-brand-softBg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Can AI literacy training be role-based?</h2>
              <p class="text-lg text-brand-textMuted">Yes. Different teams face different AI risks. We design targeted paths.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {[
                  { role: "All Employees", focus: "AI literacy, safe AI use, data privacy, output verification." },
                  { role: "Managers", focus: "Oversight, escalation, team guidance, policy reinforcement." },
                  { role: "HR Teams", focus: "Responsible AI use in hiring, performance, employee data, and communication." },
                  { role: "Sales and Support", focus: "Customer-facing AI use, accuracy, confidentiality, tone, and escalation." },
                  { role: "Operations", focus: "Process automation awareness, human review, SOP integration." },
                  { role: "L&D and Training Teams", focus: "AI-assisted content creation, review workflows, quality assurance." }
              ].map(path => (
                  <div class="bg-white p-6 rounded-xl shadow-sm border border-brand-border/40 hover:border-brand-primary transition-colors">
                      <h3 class="text-lg font-bold text-brand-navy mb-2">{path.role}</h3>
                      <p class="text-brand-textMain text-sm leading-relaxed">{path.focus}</p>
                  </div>
              ))}
          </div>
      </div>
  </section>

  {/* AI Ethics Training Packages */}
  <section class="py-20 bg-white border-y border-brand-border/30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">AI Ethics Training Packages</h2>
              <p class="text-lg text-brand-textMuted">Choose the structure that fits your organization's rollout needs.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
              {[
                  { title: "AI Literacy Starter", bestFor: "small teams or first rollout", items: ["Training outline", "3–5 short modules", "Knowledge checks", "Employee quick guide", "LMS-ready structure"] },
                  { title: "Responsible AI Team Training", bestFor: "departments and growing teams", items: ["5–8 modules", "Role-based scenarios", "Quizzes", "Manager discussion guide", "LMS upload support", "Completion flow recommendations"] },
                  { title: "Enterprise AI Ethics Program", bestFor: "large organizations and global teams", items: ["Full curriculum map", "Role-based learning paths", "Scenario-based modules", "SCORM/xAPI-ready option", "LMS implementation support", "Internal rollout materials", "Feedback and improvement plan"] },
                  { title: "Custom AI Policy Conversion", bestFor: "organizations with existing AI policies", items: ["Policy review for training structure", "Module design", "Plain-language employee lessons", "Assessments", "LMS-ready content", "Update plan"] }
              ].map(pkg => (
                  <div class="border border-brand-border rounded-2xl p-6 flex flex-col hover:shadow-lg transition-shadow">
                      <h3 class="text-xl font-bold text-brand-primary mb-2">{pkg.title}</h3>
                      <div class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-6 pb-4 border-b border-brand-border">Best for: {pkg.bestFor}</div>
                      <ul class="space-y-3 flex-grow mb-8">
                          {pkg.items.map(item => (
                              <li class="flex items-start text-sm text-brand-textMain">
                                  <svg class="w-4 h-4 text-brand-accent mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                  {item}
                              </li>
                          ))}
                      </ul>
                  </div>
              ))}
          </div>

          <div class="text-center">
              <a href="/book-free-audit/" class="inline-block bg-brand-navy text-white px-8 py-3.5 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-brand-primary shadow-md">
                  Request Enterprise Training Review
              </a>
          </div>
      </div>
  </section>

  {/* Disclaimer */}
  <section class="py-8 bg-slate-100 border-b border-brand-border/30">
      <div class="max-w-5xl mx-auto px-4 text-center">
          <p class="text-xs text-slate-500 font-medium max-w-4xl mx-auto">
              Disclaimer: TheEduAssist provides training design and learning content support. We do not provide legal advice or official compliance certification. We help organizations build LMS-ready materials to communicate their internal rules clearly. No fake compliance promises.
          </p>
      </div>
  </section>

  {/* AI Answer Block */}
  <AIAnswerBlock questions={[{ q: "What is AI ethics training for employees?", a: "AI ethics training helps employees understand safe, responsible, and practical AI use, including data privacy, bias, hallucinations, transparency, workplace policy, and human oversight." }]} />

  {/* FAQ Section */}
  <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16">
              <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Frequently Asked Questions</h2>
          </div>
          <div class="space-y-4">
              {faqs.map((faq, index) => (
                  <details class="group border border-brand-border/60 rounded-xl bg-white overflow-hidden" open={index === 0}>
                      <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-brand-navy hover:text-brand-primary transition-colors focus-ring">
                          <span class="pr-6">{faq.question}</span>
                          <span class="transition group-open:rotate-180 text-brand-accent">
                              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                          </span>
                      </summary>
                      <div class="text-brand-textMain p-6 pt-0 leading-relaxed border-t border-brand-border/30 mt-2">
                          {faq.answer}
                      </div>
                  </details>
              ))}
          </div>
      </div>
  </section>

  {/* Bottom CTA */}
  <section class="py-24 bg-brand-navy text-white text-center px-4 relative overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-full bg-brand-primary opacity-20 blur-[120px] rounded-full pointer-events-none"></div>
      <div class="max-w-4xl mx-auto relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight">Need to turn AI policies into employee training?</h2>
          <p class="text-lg md:text-xl text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed">
              Share your AI policy, training goals, LMS setup, or employee learning needs. TheEduAssist will review your material and suggest the best structure for an AI ethics or responsible AI training rollout. Human-reviewed course design. Remote/global delivery.
          </p>
          <a href="/book-free-audit/" class="inline-block bg-brand-accent text-white px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white hover:text-brand-navy shadow-lg">
              Get 24–48 Hour Review
          </a>
      </div>
  </section>

</Layout>
