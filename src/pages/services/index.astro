---
import Layout from "../../layouts/Layout.astro";
import ServiceHero from "../../components/service-page/ServiceHero.astro";
import ServiceShortAnswer from "../../components/service-page/ServiceShortAnswer.astro";
import ProblemNavigator from "../../components/service-page/ProblemNavigator.astro";
import ServiceFamilyOverview from "../../components/service-page/ServiceFamilyOverview.astro";
import LiveServicesGrid from "../../components/service-page/LiveServicesGrid.astro";
import ServiceLifecycle from "../../components/services/ServiceLifecycle.astro";
import KajabiSpecialtyCallout from "../../components/service-page/KajabiSpecialtyCallout.astro";
import OrganizationalLearningCallout from "../../components/service-page/OrganizationalLearningCallout.astro";
import ContentModernizationCallout from "../../components/service-page/ContentModernizationCallout.astro";
import EngagementModel from "../../components/service-page/EngagementModel.astro";
import CaseStudyProof from "../../components/case-studies/CaseStudyProof.astro";
import ServiceSelectionGuidance from "../../components/service-page/ServiceSelectionGuidance.astro";
import ServiceFAQ from "../../components/service-page/ServiceFAQ.astro";
import ServicesFinalCTA from "../../components/services/ServicesFinalCTA.astro";

import { professionalServiceSchema, breadcrumbSchema, faqPageSchema } from '../../lib/seo/schema';

const faqs = [
  { question: "What services does TheEduAssist provide?", answer: "TheEduAssist provides learning strategy, instructional design, custom eLearning development, course and curriculum development, LMS implementation, Kajabi services, content conversion, AI-supported learning workflows, quality assurance and ongoing learning support." },
  { question: "How do I know which service I need?", answer: "If you are unsure where to start, you can request a 24-48 Hour Review. We will look at your goals, audience, and existing materials to recommend the clearest starting point." },
  { question: "Can you work with content that already exists?", answer: "Yes. Our Content Conversion service modernizes old materials, PDFs, presentations, and videos into structured digital learning content." },
  { question: "Do you work with both organizations and course creators?", answer: "Yes, we support organizations (such as internal training teams and businesses) as well as individual course creators, coaches, and consultants." },
  { question: "Can you help select or implement an LMS?", answer: "Yes, our LMS Implementation and Migration service helps you set up, organize, or move your learning management system." },
  { question: "Is Kajabi included in your wider e-learning services?", answer: "Kajabi is a specialist capability for us. While we offer custom eLearning and LMS services, we maintain a dedicated focus for our Kajabi clients to ensure their courses integrate perfectly with their sales systems." },
  { question: "Can services be combined in one project?", answer: "Absolutely. Many projects involve multiple services, such as combining Learning Strategy, Custom eLearning Development, and LMS Implementation." },
  { question: "What happens during the 24–48 Hour Review?", answer: "You share your goals, existing content, and preferred platform. TheEduAssist reviews your information and recommends the clearest starting point." },
  { question: "Do you offer ongoing support?", answer: "Yes, we offer Ongoing Support & Maintenance for continuing content updates, platform maintenance, and quality assurance once your system is live." }
];

const structuredData = [
  professionalServiceSchema(),
  breadcrumbSchema([
    { name: 'Home', item: '/' },
    { name: 'Services', item: '/services/' }
  ]),
  faqPageSchema(faqs.map(f => ({ questionName: f.question, acceptedAnswerText: f.answer })))
];
---

<Layout
  title="E-Learning and Course Development Services | TheEduAssist"
  description="Explore learning strategy, instructional design, custom eLearning, LMS, Kajabi, content conversion, AI-supported learning and ongoing support from TheEduAssist."
  canonical="/services/"
  schema={structuredData}
>
  <main id="main-content">

    <ServiceHero
      eyebrow="E-Learning, Course Development and Learning Technology Services"
      title="Build the Right Learning Experience, Content and Delivery System"
      description="TheEduAssist helps organizations, academies, creators and training teams plan, design, build, modernize and support structured digital learning experiences."
      primaryCtaLabel="Get a 24–48 Hour Review"
      primaryCtaLink="/book-free-audit/"
      secondaryCtaLabel="Find the Right Service"
      secondaryCtaLink="#problem-navigator"
    />

    <div class="bg-brand-navy border-t border-white/10 py-4 text-center text-slate-300 text-sm font-medium tracking-wide">
        Strategy &bull; Instructional design &bull; Course development &bull; LMS &bull; Kajabi &bull; Content modernization &bull; Ongoing support
    </div>

    <ServiceShortAnswer
      heading="What Services Does TheEduAssist Provide?"
      answer="TheEduAssist provides learning strategy, instructional design, custom eLearning development, course and curriculum development, LMS implementation, Kajabi services, content conversion, AI-supported learning workflows, quality assurance and ongoing learning support."
    />

    <div id="problem-navigator">
      <ProblemNavigator />
    </div>

    <ServiceFamilyOverview />

    <LiveServicesGrid />

    <ServiceLifecycle />

    <KajabiSpecialtyCallout />

    <OrganizationalLearningCallout />

    <ContentModernizationCallout />

    <EngagementModel />

    <section class="py-24 bg-slate-50 border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <CaseStudyProof
                slugs={[
                    'sqa-aligned-vocational-training',
                    'business-analytics-corporate-teams',
                    'language-courses-book-publisher'
                ]}
            />
        </div>
    </section>

    <ServiceSelectionGuidance />

    <ServiceFAQ faqs={faqs} />

    <section class="py-24 bg-brand-navy text-white text-center px-4">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl md:text-4xl font-bold mb-6">Not Sure Which Learning Service Fits Your Project?</h2>
            <p class="text-lg text-slate-300 mb-10 leading-relaxed">
                Share your goals, existing content and preferred platform. TheEduAssist will review the information and recommend the clearest starting point.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="/book-free-audit/" class="inline-flex justify-center items-center px-8 py-4 bg-brand-accent text-white rounded-md font-bold text-lg hover:bg-white hover:text-brand-navy transition-all shadow-lg hover-lift click-press focus-ring">
                    Get a 24–48 Hour Review
                </a>
                <a href="/contact/" class="inline-flex justify-center items-center px-8 py-4 bg-transparent text-white border-2 border-white/20 rounded-md font-bold text-lg hover:bg-white/10 transition-all focus-ring hover-lift click-press">
                    Contact Our Team
                </a>
            </div>
        </div>
    </section>

  </main>
</Layout>
