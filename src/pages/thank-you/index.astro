---

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Thank You",
    "description": "Thank you for contacting TheEduAssist.",
    "url": "https://theeduassist.com/thank-you/"
  }
];

import Layout from "../../layouts/Layout.astro";
import Button from "../../components/ui/Button.astro";
---
<Layout title="Thank You | TheEduAssist" description="Thank you for contacting TheEduAssist. Your course, Kajabi, LMS, or e-learning audit request has been received.">

  <section class="py-24 bg-slate-50 text-center px-4 flex-grow flex flex-col justify-center items-center min-h-[60vh]">
    <div class="w-16 h-16 bg-[#77BA55]/20 text-[#77BA55] rounded-full flex items-center justify-center mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1 class="text-4xl font-bold text-slate-900 mb-6">Thank You for Reaching Out</h1>

    <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-10 leading-relaxed">
      Thanks for contacting TheEduAssist. If you submitted a Google Form, your review request has been received and you will get a confirmation directly.
      <br/><br/>
      If you used our internal fallback form, your request was generated as an email. <span class="font-medium text-slate-800">Please make sure to hit send in your email application.</span> Once received, we’ll review your details and be in touch soon with the next steps.
    </p>

    <div class="bg-white p-8 rounded-lg shadow-sm border border-slate-200 max-w-2xl w-full mb-16 text-left">
      <h2 class="font-bold text-slate-900 mb-4 text-xl">Next Steps</h2>
      <ul class="space-y-4 mb-8">
        <li class="flex items-start">
          <div class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold mr-3 mt-0.5 text-sm">1</div>
          <p class="text-slate-700">Check your inbox for our reply.</p>
        </li>
        <li class="flex items-start">
          <div class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold mr-3 mt-0.5 text-sm">2</div>
          <p class="text-slate-700">Prepare any course content, URLs, PDFs, slides, videos, or platform details.</p>
        </li>
        <li class="flex items-start">
          <div class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold mr-3 mt-0.5 text-sm">3</div>
          <p class="text-slate-700">Book a 30-minute session if you want to discuss faster.</p>
        </li>
      </ul>
      <div class="text-center">
        <Button href="https://calendly.com/eduassist-talk/30min" variant="primary" target="_blank" rel="noopener noreferrer">Book 30-Minute Session</Button>
      </div>
    </div>

    <div class="max-w-4xl mx-auto w-full">
      <h2 class="font-bold text-slate-900 mb-6 text-xl">Useful Links</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/services/" class="bg-white p-4 rounded border border-slate-200 hover:border-blue-400 hover:shadow-sm transition-all text-slate-700 font-medium text-sm sm:text-base">Explore Services</a>
        <a href="/kajabi-services/" class="bg-white p-4 rounded border border-slate-200 hover:border-blue-400 hover:shadow-sm transition-all text-slate-700 font-medium text-sm sm:text-base">Kajabi Services</a>
        <a href="/services/#lms-migration" class="bg-white p-4 rounded border border-slate-200 hover:border-blue-400 hover:shadow-sm transition-all text-slate-700 font-medium text-sm sm:text-base">LMS Migration</a>
        <a href="/services/#ai-elearning" class="bg-white p-4 rounded border border-slate-200 hover:border-blue-400 hover:shadow-sm transition-all text-slate-700 font-medium text-sm sm:text-base">AI-Powered E-Learning Support</a>
        <a href="/case-studies/" class="bg-white p-4 rounded border border-slate-200 hover:border-blue-400 hover:shadow-sm transition-all text-slate-700 font-medium text-sm sm:text-base">Case Studies</a>
        <a href="/contact/" class="bg-white p-4 rounded border border-slate-200 hover:border-blue-400 hover:shadow-sm transition-all text-slate-700 font-medium text-sm sm:text-base">Contact</a>
      </div>
    </div>

  </section>

</Layout>
