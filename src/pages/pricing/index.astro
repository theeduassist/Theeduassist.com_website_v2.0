---
import Layout from "../../layouts/Layout.astro";

const title = "Pricing | TheEduAssist";
const description = "TheEduAssist pricing packages are being finalized.";
const canonicalPath = "https://www.theeduassist.com/pricing/";
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
>
  <main class="container mx-auto px-4 py-24 max-w-4xl text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-8">Pricing</h1>
    <p class="text-xl text-brand-textMain mb-12">
      TheEduAssist pricing packages are being finalized. For now, book a free audit and we will recommend the right package based on your course, content, platform, and launch needs.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="/book-free-audit/" class="bg-brand-accent text-white px-8 py-4 rounded-md font-bold text-lg hover:bg-opacity-90 transition-colors w-full sm:w-auto shadow-md">
        Book Free Audit &rarr;
      </a>
      <a href="/contact/" class="bg-transparent text-brand-navy border border-brand-navy hover:bg-brand-softBg px-8 py-4 rounded-md font-bold text-lg transition-colors w-full sm:w-auto">
        Contact Us &rarr;
      </a>
    </div>
  </main>
</Layout>