---
import Layout from "../../layouts/Layout.astro";

const title = "Pricing | Course Creation, Kajabi Setup & LMS Services | TheEduAssist";
const description = "Explore TheEduAssist pricing for course creation, Kajabi setup, LMS migration, content conversion, AI-powered e-learning support, and ongoing course support.";
const canonicalPath = "/pricing/";

const faqs = [
  { question: "Are these fixed prices?", answer: "These prices are starting points. Final pricing depends on content volume, course length, platform, pages, automations, integrations, review rounds, and timeline. Scope is confirmed after review." },
  { question: "Can TheEduAssist work with existing course material?", answer: "Yes. We can convert raw content, PDFs, slides, and recordings into structured e-learning content." },
  { question: "Do you only work with Kajabi?", answer: "No. While we are Kajabi experts, we also work with various LMS platforms, Skool, Thinkific, LearnWorlds, and custom setups." },
  { question: "Can you migrate content from another LMS?", answer: "Yes. We handle content mapping, structure planning, and full LMS migrations." },
  { question: "Can you help with AI-supported course development?", answer: "Yes, we leverage AI tools to assist with course structure, content conversion, and interactive elements." },
  { question: "Do you offer monthly support?", answer: "Yes. We offer ongoing support for updates, optimization, and platform maintenance." },
  { question: "What happens after I request a 24–48 Hour Review?", answer: "We review your needs, content, and goals, then provide a recommended scope, package, and timeline within 24-48 hours." }
];

