---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import AIAnswerBlock from "../../components/ai/AIAnswerBlock.astro";

const title = "Pricing | Course Creation, Kajabi Setup & LMS Builds | TheEduAssist";
const description = "Explore TheEduAssist pricing for course creation, Kajabi setup, LMS migration, content conversion, AI-powered e-learning support, and ongoing course support.";
const canonicalPath = "https://www.theeduassist.com/pricing/";

const packages = [
  {
    title: "Course Clarity Blueprint",
    price: "Starting at $500",
    bestFor: "Creators, coaches, consultants, educators, and businesses that need a clear course plan before building.",
    desc: "A strategy-first package to turn raw expertise, workshop ideas, PDFs, slides, or rough training content into a structured course plan. Perfect for planning <a href='/services/custom-elearning-development/' class='text-brand-accent underline'>custom e-learning development</a>.",
    features: [
      "Course idea review",
      "Audience and learner goal clarification",
      "Course outcome mapping",
      "Module and lesson outline",
      "Learner journey structure",
      "Platform recommendation",
      "Launch-readiness notes"
    ],
    timeline: "3–5 business days",
    ctaText: "Get 24–48 Hour Review",
    ctaLink: "/book-free-audit/"
  },
  {
    title: "Content Conversion Kit",
    price: "Starting at $900",
    bestFor: "Teams that already have content and need it converted into learner-friendly course material.",
    desc: "Convert PDFs, slides, documents, webinars, scripts, or training recordings into structured lessons, worksheets, activities, and course-ready assets. Highly requested as part of our <a href='/services/ai-powered-elearning/' class='text-brand-accent underline'>AI-powered e-learning support</a>.",
    features: [
      "Existing content review",
      "Lesson restructuring",
      "Slide/PDF-to-course conversion",
      "Worksheets or learner activities",
      "Quiz/checkpoint suggestions",
      "Course upload-ready content structure",
      "Learner experience cleanup"
    ],
    timeline: "1–2 weeks depending on content volume",
    ctaText: "Start Content Conversion",
    ctaLink: "/book-free-audit/"
  },
  {
    title: "Kajabi Setup Sprint",
    price: "Starting at $1,500",
    bestFor: "Creators and businesses that want a polished Kajabi course, website, funnel, or offer setup.",
    desc: "A focused Kajabi build for turning your course or offer into a clean, branded, and launch-ready Kajabi experience.",
    features: [
      "Kajabi product/course setup",
      "Website or landing page setup",
      "Offer and checkout setup",
      "Email sequence or basic automation setup",
      "Upload of course content provided by client",
      "Navigation and student access setup",
      "Mobile and desktop QA",
      "Launch checklist"
    ],
    timeline: "1–3 weeks depending on scope",
    ctaText: "Build My Kajabi Setup",
    ctaLink: "/book-free-audit/"
  },
  {
    title: "LMS Migration Map",
    price: "Starting at $700",
    bestFor: "Businesses, educators, and training teams moving from one LMS or platform to another.",
    desc: "A migration planning package for moving courses, learners, content, or training programs without losing structure or clarity.",
    features: [
      "Current platform review",
      "New platform recommendation",
      "Content inventory",
      "Migration structure",
      "Course and learner access planning",
      "Risk and gap notes",
      "Migration timeline",
      "Implementation roadmap"
    ],
    timeline: "3–7 business days",
    ctaText: "Plan My Migration",
    ctaLink: "/book-free-audit/"
  },
  {
    title: "Course + Platform Build",
    price: "Starting at $4,000",
    bestFor: "Clients who need a complete course and platform experience built from strategy to launch.",
    desc: "A full-service build for clients who want TheEduAssist to structure the course, design the learning journey, build the platform, and prepare the launch system.",
    features: [
      "Course strategy",
      "Curriculum design",
      "Module and lesson structure",
      "Content conversion support",
      "Platform setup",
      "Kajabi or LMS build",
      "Funnel/landing page support",
      "Basic automation setup",
      "QA and launch support",
      "Handoff guidance"
    ],
    timeline: "3–8 weeks depending on content, platform, and integrations",
    badge: "Most comprehensive",
    ctaText: "Discuss Full Build",
    ctaLink: "/book-free-audit/"
  },
  {
    title: "Ongoing Course Support",
    price: "Starting at $600/month",
    bestFor: "Course creators, academies, and businesses that need maintenance, updates, platform help, and learning experience support after launch.",
    desc: "Monthly support to keep your course, Kajabi setup, LMS, automations, and learning experience clean and updated.",
    features: [
      "Course updates",
      "Platform support",
      "Content upload support",
      "Funnel or email update support",
      "Learner experience improvements",
      "Monthly QA checks",
      "Minor design/content fixes",
      "Technical coordination support"
    ],
    timeline: "Monthly retainer",
    ctaText: "Ask About Support",
    ctaLink: "/contact/"
  },
  {
    title: "Custom LMS / Enterprise Build",
    price: "Custom quote",
    bestFor: "Training companies, online academies, organizations, and businesses with larger e-learning systems.",
    desc: "A custom-scoped service for multi-course platforms, LMS implementation, migration, integrations, team workflows, or larger training ecosystems.",
    features: [
      "Discovery and requirements review",
      "Platform architecture",
      "LMS implementation planning",
      "Curriculum and learner journey support",
      "Multi-course setup",
      "Migration and integrations planning",
      "Admin/team workflow support",
      "QA and launch planning",
      "Ongoing support options"
    ],
    timeline: "Custom timeline after discovery",
    badge: "For larger systems",
    ctaText: "Request Custom Quote",
    ctaLink: "/contact/"
  }
];

const faqs = [
  { question: "Are these fixed prices?", answer: "They are starting prices. Final pricing depends on content volume, platform, integrations, and timeline." },
  { question: "Can you work only on Kajabi?", answer: "Yes. TheEduAssist supports Kajabi setup, course upload, landing pages, offers, checkout, emails, automations, and launch QA." },
  { question: "Can you help if I already have content?", answer: "Yes. The Content Conversion Kit is designed for PDFs, slides, webinars, documents, scripts, or existing training content." },
  { question: "Can you help choose the right LMS?", answer: "Yes. LMS recommendation and migration planning are part of the LMS Migration Map and larger LMS implementation services." },
  { question: "Do you provide ongoing support?", answer: "Yes. Monthly support starts at $600/month depending on the level of updates and platform support needed." },
  { question: "Do you offer custom pricing?", answer: "Yes. Larger LMS, academy, training company, and multi-course builds are quoted after discovery." }
];

---

<Layout title={title} description={description} canonicalPath={canonicalPath}>
  {/* Hero Section */}
  <section class="bg-brand-softBg py-20 pb-12 border-b border-brand-border/30">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-navy mb-6">Clear Pricing for Course, Kajabi, LMS & E-Learning Builds</h1>
      <p class="text-xl md:text-2xl text-brand-textMuted mb-10 max-w-3xl mx-auto">
        Choose the right starting point for turning your expertise, training content, or learning program into a structured, launch-ready online learning experience.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-8">
        <a href="/book-free-audit/" class="bg-brand-accent text-white px-8 py-4 rounded-md font-bold text-lg hover:bg-brand-primary transition-colors focus-ring w-full sm:w-auto shadow-md">Get 24–48 Hour Review →</a>
        <a href="/contact/" class="bg-white text-brand-navy border border-brand-border px-8 py-4 rounded-md font-bold text-lg hover:bg-slate-50 transition-colors focus-ring w-full sm:w-auto">Contact Us →</a>
      </div>
      <div class="text-sm text-brand-textMuted max-w-2xl mx-auto space-y-2">
        <p>✓ For creators, coaches, consultants, educators, training companies, online academies, and businesses.</p>
        <p>✓ Pricing is starting-from and final scope depends on content volume, platform, integrations, and timeline.</p>
      </div>
    </div>
  </section>

  {/* Pricing Overview / Map */}
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-3xl font-bold text-center text-brand-navy mb-10">Which package is right for you?</h2>
      <div class="bg-brand-softBg rounded-2xl p-6 md:p-10 border border-brand-border/30">
        <ul class="space-y-4 text-brand-textMain font-medium md:text-lg">
          <li class="flex items-start">
            <span class="text-brand-accent mr-3 mt-1">→</span>
            <span>Need clarity first? <strong class="text-brand-navy">Start with Course Clarity Blueprint.</strong></span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-accent mr-3 mt-1">→</span>
            <span>Have content but need it turned into a course? <strong class="text-brand-navy">Choose Content Conversion Kit.</strong></span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-accent mr-3 mt-1">→</span>
            <span>Need Kajabi built properly? <strong class="text-brand-navy">Choose Kajabi Setup Sprint.</strong></span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-accent mr-3 mt-1">→</span>
            <span>Moving from another platform? <strong class="text-brand-navy">Choose LMS Migration Map.</strong></span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-accent mr-3 mt-1">→</span>
            <span>Need complete course + platform build? <strong class="text-brand-navy">Choose Course + Platform Build.</strong></span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-accent mr-3 mt-1">→</span>
            <span>Need monthly support? <strong class="text-brand-navy">Choose Ongoing Course Support.</strong></span>
          </li>
          <li class="flex items-start">
            <span class="text-brand-accent mr-3 mt-1">→</span>
            <span>Need a larger/custom system? <strong class="text-brand-navy">Choose Custom LMS / Enterprise Build.</strong></span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* Main Package Cards */}
  <section class="py-20 bg-slate-50 border-y border-brand-border/30">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {packages.map(pkg => (
          <div class="bg-white rounded-2xl shadow-sm border border-brand-border/50 p-8 flex flex-col hover:shadow-lg transition-shadow relative">
            {pkg.badge && (
              <div class="absolute -top-4 right-6 bg-brand-navy text-white text-xs font-bold uppercase tracking-wider py-1.5 px-3 rounded-full shadow-sm">
                {pkg.badge}
              </div>
            )}
            <h3 class="text-2xl font-bold text-brand-navy mb-2">{pkg.title}</h3>
            <div class="text-3xl font-bold text-brand-primary mb-4">{pkg.price}</div>
            <div class="mb-6 pb-6 border-b border-brand-border/30">
              <span class="text-sm font-bold text-brand-textMain block mb-1">Best for:</span>
              <p class="text-sm text-brand-textMuted">{pkg.bestFor}</p>
            </div>
            <p class="text-brand-textMain mb-8 font-medium"><Fragment set:html={pkg.desc} /></p>

            <div class="flex-grow mb-8">
              <span class="text-sm font-bold text-brand-textMain block mb-3">What's included:</span>
              <ul class="space-y-3">
                {pkg.features.map(feat => (
                  <li class="flex items-start text-sm text-brand-textMuted">
                    <svg class="w-5 h-5 text-brand-accent mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    {feat}
                  </li>
                ))}
              </ul>
            </div>

            <div class="mt-auto">
              <div class="bg-brand-softBg p-4 rounded-md mb-6">
                <span class="text-sm font-bold text-brand-textMain block mb-1">Timeline:</span>
                <span class="text-sm text-brand-textMuted">{pkg.timeline}</span>
              </div>
              <a href={pkg.ctaLink} class="block text-center w-full px-6 py-3 bg-brand-primary text-white font-bold rounded-lg hover:bg-brand-navy transition-colors focus-ring">
                {pkg.ctaText}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Detailed Comparison Table */}
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-brand-navy mb-12">Compare Packages</h2>
      <div class="overflow-x-auto rounded-xl border border-brand-border/50 shadow-sm">
        <table class="w-full text-left border-collapse min-w-[800px]">
          <thead>
            <tr class="bg-brand-softBg text-brand-navy border-b border-brand-border/50">
              <th class="p-5 font-bold w-1/5">Package</th>
              <th class="p-5 font-bold w-1/5">Starting Price</th>
              <th class="p-5 font-bold w-1/4">Best For</th>
              <th class="p-5 font-bold w-1/6">Timeline</th>
              <th class="p-5 font-bold">Main Outcome</th>
            </tr>
          </thead>
          <tbody class="text-brand-textMain text-sm">
            <tr class="border-b border-brand-border/30 hover:bg-slate-50 transition-colors">
              <td class="p-5 font-bold text-brand-primary">Course Clarity Blueprint</td>
              <td class="p-5">$500</td>
              <td class="p-5 text-brand-textMuted">Needing a course plan before building</td>
              <td class="p-5">3–5 business days</td>
              <td class="p-5">Structured course plan ready for build</td>
            </tr>
            <tr class="border-b border-brand-border/30 hover:bg-slate-50 transition-colors">
              <td class="p-5 font-bold text-brand-primary">Content Conversion Kit</td>
              <td class="p-5">$900</td>
              <td class="p-5 text-brand-textMuted">Turning existing content into course material</td>
              <td class="p-5">1–2 weeks</td>
              <td class="p-5">Course-ready assets and lessons</td>
            </tr>
            <tr class="border-b border-brand-border/30 hover:bg-slate-50 transition-colors">
              <td class="p-5 font-bold text-brand-primary">Kajabi Setup Sprint</td>
              <td class="p-5">$1,500</td>
              <td class="p-5 text-brand-textMuted">Focused Kajabi course & offer setup</td>
              <td class="p-5">1–3 weeks</td>
              <td class="p-5">Launch-ready Kajabi experience</td>
            </tr>
            <tr class="border-b border-brand-border/30 hover:bg-slate-50 transition-colors">
              <td class="p-5 font-bold text-brand-primary">LMS Migration Map</td>
              <td class="p-5">$700</td>
              <td class="p-5 text-brand-textMuted">Planning platform changes</td>
              <td class="p-5">3–7 business days</td>
              <td class="p-5">Clear roadmap for migrating content</td>
            </tr>
            <tr class="border-b border-brand-border/30 hover:bg-slate-50 transition-colors">
              <td class="p-5 font-bold text-brand-primary">Course + Platform Build</td>
              <td class="p-5">$4,000</td>
              <td class="p-5 text-brand-textMuted">Complete strategy, design & build</td>
              <td class="p-5">3–8 weeks</td>
              <td class="p-5">Fully built, customized learning platform</td>
            </tr>
            <tr class="border-b border-brand-border/30 hover:bg-slate-50 transition-colors">
              <td class="p-5 font-bold text-brand-primary">Ongoing Course Support</td>
              <td class="p-5">$600/month</td>
              <td class="p-5 text-brand-textMuted">Post-launch maintenance & updates</td>
              <td class="p-5">Monthly</td>
              <td class="p-5">Clean, updated platform & content</td>
            </tr>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="p-5 font-bold text-brand-primary">Custom LMS / Enterprise Build</td>
              <td class="p-5">Custom</td>
              <td class="p-5 text-brand-textMuted">Larger e-learning systems & academies</td>
              <td class="p-5">Custom</td>
              <td class="p-5">Scalable training ecosystem</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* Enterprise & Corporate Training Add-Ons */}
  <section class="py-20 bg-white border-y border-brand-border/30">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Enterprise & Corporate Training Add-Ons</h2>
        <p class="text-lg text-brand-textMuted">Specialized support for global organizations, AI ethics compliance, and corporate rollout.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="bg-slate-50 rounded-2xl border border-brand-border/50 p-6 flex flex-col hover:shadow-md transition-shadow">
          <h3 class="text-xl font-bold text-brand-navy mb-2">AI Ethics Training Add-On</h3>
          <div class="text-brand-primary font-bold mb-4">Starts after review</div>
          <p class="text-sm text-brand-textMuted mb-6 flex-grow">For companies adding responsible AI lessons to an existing LMS or course.</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>AI ethics training outline</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Employee learning path</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Scenario-based lessons</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Quiz/checkpoint design</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>LMS-ready content structure</li>
          </ul>
        </div>

        <div class="bg-slate-50 rounded-2xl border border-brand-border/50 p-6 flex flex-col hover:shadow-md transition-shadow">
          <h3 class="text-xl font-bold text-brand-navy mb-2">Corporate LMS Rollout Support</h3>
          <div class="text-brand-primary font-bold mb-4">Starts after review</div>
          <p class="text-sm text-brand-textMuted mb-6 flex-grow">For teams launching training across departments.</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Course structure</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>LMS upload support</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Learner flow</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Completion tracking</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Internal rollout guidance</li>
          </ul>
        </div>

        <div class="bg-slate-50 rounded-2xl border border-brand-border/50 p-6 flex flex-col hover:shadow-md transition-shadow">
          <h3 class="text-xl font-bold text-brand-navy mb-2">AI Policy-to-Training Conversion</h3>
          <div class="text-brand-primary font-bold mb-4">Starts after review</div>
          <p class="text-sm text-brand-textMuted mb-6 flex-grow">For companies with internal AI policy documents.</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Policy-to-module mapping</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Plain-language lessons</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Employee guide</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Manager guide</li>
            <li class="flex items-start text-sm text-brand-textMain"><span class="text-brand-accent mr-2">•</span>Assessment questions</li>
          </ul>
        </div>

        <div class="bg-brand-navy rounded-2xl border border-brand-navy p-6 flex flex-col hover:shadow-lg transition-shadow relative text-white">
          <div class="absolute -top-3 right-4 bg-brand-accent text-white text-[10px] font-bold uppercase tracking-wider py-1 px-2 rounded-full">Best for enterprise teams</div>
          <h3 class="text-xl font-bold text-white mb-2">Enterprise Custom Program</h3>
          <div class="text-white font-bold mb-4">Scoped after 24–48 Hour Review</div>
          <p class="text-sm text-slate-300 mb-6 flex-grow">For global organizations.</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start text-sm text-slate-200"><span class="text-brand-accent mr-2">•</span>Role-based curriculum</li>
            <li class="flex items-start text-sm text-slate-200"><span class="text-brand-accent mr-2">•</span>Multi-department paths</li>
            <li class="flex items-start text-sm text-slate-200"><span class="text-brand-accent mr-2">•</span>SCORM/xAPI option</li>
            <li class="flex items-start text-sm text-slate-200"><span class="text-brand-accent mr-2">•</span>LMS support</li>
            <li class="flex items-start text-sm text-slate-200"><span class="text-brand-accent mr-2">•</span>Dedicated review process</li>
          </ul>
        </div>
      </div>

      <div class="text-center">
        <a href="/book-free-audit/" class="inline-block px-8 py-3.5 bg-brand-primary text-white font-bold rounded-lg hover:bg-brand-navy transition-colors focus-ring shadow-sm">
          Request Enterprise Training Review
        </a>
      </div>
    </div>
  </section>

  {/* What affects pricing & Not included */}
  <section class="py-16 bg-slate-50 border-y border-brand-border/30">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-bold text-brand-navy mb-6">What affects final pricing</h3>
          <ul class="space-y-3">
            {[
              "number of courses/modules",
              "content condition and volume",
              "platform choice",
              "Kajabi/LMS setup complexity",
              "migration needs",
              "funnels and automations",
              "branding/design depth",
              "integrations",
              "timeline urgency",
              "ongoing support needs"
            ].map(item => (
              <li class="flex items-start text-brand-textMain">
                <svg class="w-5 h-5 text-brand-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="capitalize first-letter:uppercase">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-2xl font-bold text-brand-navy mb-6">What is not included by default</h3>
          <ul class="space-y-3">
            {[
              "Paid platform subscriptions",
              "third-party software fees",
              "ad spend",
              "professional video production unless separately scoped",
              "large custom software development unless separately scoped",
              "copywriting beyond agreed course/page scope",
              "advanced integrations unless included in proposal"
            ].map(item => (
              <li class="flex items-start text-brand-textMuted">
                <svg class="w-5 h-5 text-slate-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="first-letter:uppercase">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

