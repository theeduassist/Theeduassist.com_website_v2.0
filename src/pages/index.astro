---
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomeCapabilityStrip from "../components/home/HomeCapabilityStrip.astro";
import AudiencePathways from "../components/home/AudiencePathways.astro";
import ProblemNavigator from "../components/home/ProblemNavigator.astro";

// New Phase 2 Part 2 Components
import HomeServices from "../components/home/HomeServices.astro";
import LearningBuildSystem from "../components/home/LearningBuildSystem.astro";
import OrganizationalLearning from "../components/home/OrganizationalLearning.astro";
import KajabiSpecialty from "../components/home/KajabiSpecialty.astro";
import LearningTransformation from "../components/home/LearningTransformation.astro";
import FeaturedCaseStudies from "../components/home/FeaturedCaseStudies.astro";
import SupportLevels from "../components/home/SupportLevels.astro";
import BlogPreview from "../components/home/BlogPreview.astro";
import HomeFAQ from "../components/home/HomeFAQ.astro";

import FinalCTA from "../components/sections/FinalCTA.astro";

import { organizationSchema, websiteSchema, professionalServiceSchema } from '../lib/seo/schema';
import { getCtaBlocks } from '../sanity/queries';

let ctaBlocks = [];
try {
  ctaBlocks = await getCtaBlocks();
} catch (e) {
  console.warn("Could not fetch CTA blocks from Sanity on Homepage");
}

const jsonLd = [
  organizationSchema(),
  websiteSchema(),
  professionalServiceSchema()
];
---
<Layout
  title="TheEduAssist | E-Learning, Course Development, LMS and Kajabi Services"
  description="TheEduAssist helps organizations, academies, creators and training teams plan, design and build online courses, LMS experiences, Kajabi systems and structured digital learning programs."
  canonicalPath="/"
  jsonLd={jsonLd}
>

  <HomeHero />

  <HomeCapabilityStrip />

  <AudiencePathways />

  <ProblemNavigator />

  <HomeServices />

  <LearningBuildSystem />

  <OrganizationalLearning />

  <KajabiSpecialty />

  <LearningTransformation />

  <FeaturedCaseStudies />

  <SupportLevels />

  <BlogPreview />

  <HomeFAQ />

  <FinalCTA ctaBlocks={ctaBlocks} />

</Layout>
