---
import Layout from "../../layouts/Layout.astro";
import { getAllPublicRoutes } from "../../lib/content/getAllPublicRoutes";
import { getBlogPostSummaries, isPublicBlogSummary } from "../../lib/content/getAllBlogPosts";

// Fetch data
const routes = await getAllPublicRoutes();
const publicRoutes = routes.filter(r => r.includeInSitemap); // Use includeInSitemap to check if route exists globally

const allBlogs = await getBlogPostSummaries();
const publicBlogs = allBlogs.filter(isPublicBlogSummary).slice(0, 18); // Max 18

// Helper to check if a route exists
const routeExists = (path: string) => publicRoutes.some(r => r.path === path);
const getRouteTitle = (path: string) => publicRoutes.find(r => r.path === path)?.title.split(' |')[0];

// Main Pages
const mainPages = [
    { path: '/', title: 'Home' },
    { path: '/about-us/', title: 'About Us' },
    { path: '/services/', title: 'Services' },
    { path: '/pricing/', title: 'Pricing' },
    { path: '/book-free-audit/', title: 'Get 24–48 Hour Review' },
    { path: '/contact/', title: 'Contact' },
    { path: '/blog/', title: 'Blog' },
    { path: '/platforms/', title: 'Platforms' },
    { path: '/locations/', title: 'Locations' },
    { path: '/case-studies/', title: 'Case Studies' },
].filter(p => routeExists(p.path));

// Core Services
const coreServices = [
    { path: '/services/custom-elearning-development/', title: 'Custom eLearning Development', desc: 'Bespoke course creation and structured learning experiences.' },
    { path: '/services/lms-implementation-migration/', title: 'LMS Implementation & Migration', desc: 'Setup and migration of Learning Management Systems.' },
    { path: '/kajabi-services/', title: 'Kajabi Services', desc: 'Complete setup and design of your Kajabi platform.' },
    { path: '/services/ai-powered-elearning/', title: 'AI-Powered E-Learning', desc: 'AI-assisted course generation and content structuring.' },
    { path: '/services/ai-ethics-corporate-training/', title: 'AI Ethics & Responsible AI Training', desc: 'Convert responsible AI policies into structured training.' },
    { path: '/services/content-conversion/', title: 'Content Conversion', desc: 'Turn PDFs, videos, and PPTs into interactive courses.' },
    { path: '/services/funnels-automation/', title: 'Funnels & Automation', desc: 'Marketing funnels and student onboarding workflows.' },
    { path: '/services/ongoing-support-maintenance/', title: 'Ongoing Support & Maintenance', desc: 'Continuous updates and support for learning platforms.' }
].filter(p => routeExists(p.path));

// Platforms
const platformCategories = [
    {
        name: 'Creator Platforms',
        items: ['Kajabi', 'Thinkific', 'Teachable', 'LearnWorlds', 'Podia', 'Skool']
    },
    {
        name: 'LMS / Corporate Platforms',
        items: ['Moodle', 'TalentLMS', 'Docebo', 'LearnUpon', 'Absorb LMS', 'Litmos']
    },
    {
        name: 'Authoring / Standards',
        items: ['Articulate 360', 'Rise', 'Storyline', 'iSpring', 'SCORM', 'xAPI', 'H5P']
    }
];

// Locations
const locationRegions = [
    {
        name: 'North America',
        cities: [
            { path: '/locations/united-states/', title: 'United States' },
            { path: '/locations/canada/', title: 'Canada' },
            { path: '/locations/new-york/', title: 'New York' },
            { path: '/locations/toronto/', title: 'Toronto' }
        ]
    },
    {
        name: 'Europe',
        cities: [
            { path: '/locations/united-kingdom/', title: 'United Kingdom' },
            { path: '/locations/london/', title: 'London' },
            { path: '/locations/manchester/', title: 'Manchester' }
        ]
    },
    {
        name: 'Middle East',
        cities: [
            { path: '/locations/uae/', title: 'UAE' },
            { path: '/locations/dubai/', title: 'Dubai' },
            { path: '/locations/abu-dhabi/', title: 'Abu Dhabi' },
            { path: '/locations/saudi-arabia/', title: 'Saudi Arabia' },
            { path: '/locations/riyadh/', title: 'Riyadh' }
        ]
    },
    {
        name: 'Asia Pacific',
        cities: [
            { path: '/locations/australia/', title: 'Australia' },
            { path: '/locations/sydney/', title: 'Sydney' },
            { path: '/locations/singapore/', title: 'Singapore' }
        ]
    },
    {
        name: 'South Asia',
        cities: [
            { path: '/locations/pakistan/', title: 'Pakistan' },
            { path: '/locations/lahore/', title: 'Lahore' },
            { path: '/locations/karachi/', title: 'Karachi' },
            { path: '/locations/islamabad/', title: 'Islamabad' }
        ]
    }
].map(region => ({
    ...region,
    cities: region.cities.filter(city => routeExists(city.path))
})).filter(region => region.cities.length > 0);

// Case Studies
const caseStudies = publicRoutes.filter(r => r.pageType === 'case-study-detail');

// Legal and Utility
const legalPages = [
    { path: '/privacy-policy/', title: 'Privacy Policy' },
    { path: '/terms-and-conditions/', title: 'Terms and Conditions' },
    { path: '/llms.txt', title: 'llms.txt' },
    { path: '/ai-summary.md', title: 'AI Summary' },
    { path: '/services-summary.md', title: 'Services Summary' },
]; // Not fully checking route existence for raw files easily, but .md and .txt we'll assume exist if they are required.

// Actually check routes for legal pages for safety:
const safeLegalPages = legalPages.filter(p => p.path.endsWith('.md') || p.path.endsWith('.txt') || routeExists(p.path));

---

<Layout
    title="Website Sitemap | TheEduAssist"
    description="Browse TheEduAssist website pages, services, blog guides, platform support pages, location pages, case studies, and contact options from one organized sitemap."
    canonicalPath="/sitemap/"
    type="website"
>
    <!-- HERO -->
    <div class="bg-brand-navy pt-32 pb-24 text-white text-center px-4">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-5xl font-bold mb-6">TheEduAssist Website Sitemap</h1>
            <p class="text-xl text-slate-300 mb-4">
                Explore the main pages, services, blog guides, platform support pages, location pages, and company resources on TheEduAssist.
            </p>
            <p class="text-lg text-slate-400 mb-8 max-w-2xl mx-auto">
                Use this page to quickly find course design services, Kajabi support, LMS migration help, AI-powered e-learning resources, pricing, blog articles, and contact options.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="/services/" class="bg-brand-primary hover:bg-brand-accent text-white font-medium py-3 px-6 rounded-lg transition-colors">Explore Services</a>
                <a href="/book-free-audit/" class="bg-white hover:bg-slate-100 text-brand-navy font-medium py-3 px-6 rounded-lg transition-colors">Get 24–48 Hour Review</a>
                <a href="/blog/" class="bg-brand-secondary hover:opacity-90 text-white font-medium py-3 px-6 rounded-lg transition-colors">Read Blog Guides</a>
            </div>
        </div>
    </div>

    <div class="bg-slate-50 min-h-screen py-24">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">

            <!-- MAIN PAGES -->
            <section>
                <h2 class="text-3xl font-bold text-brand-navy mb-8 border-b border-slate-200 pb-4">Main Pages</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    {mainPages.map(page => (
                        <a href={page.path} class="block bg-white p-4 rounded-xl border border-slate-200 hover:border-brand-primary shadow-sm hover:shadow-md transition-all text-brand-navy font-medium">
                            {page.title}
                        </a>
                    ))}
                </div>
            </section>

            <!-- CORE SERVICES -->
            <section>
                <h2 class="text-3xl font-bold text-brand-navy mb-8 border-b border-slate-200 pb-4">Core Services</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {coreServices.map(service => (
                        <a href={service.path} class="block bg-white p-6 rounded-xl border border-slate-200 hover:border-brand-primary shadow-sm hover:shadow-md transition-all">
                            <h3 class="text-lg font-bold text-brand-navy mb-2">{service.title}</h3>
                            <p class="text-slate-600 text-sm">{service.desc}</p>
                        </a>
                    ))}
                </div>
            </section>

            <!-- BLOG GUIDES -->
            <section>
                <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 border-b border-slate-200 pb-4">
                    <h2 class="text-3xl font-bold text-brand-navy mb-4 md:mb-0">Blog Guides</h2>
                    <a href="/blog/" class="text-brand-primary font-medium hover:underline flex items-center">
                        View All Blog Articles
                        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {publicBlogs.map((post: any) => (
                        <a href={`/blog/${post.slug}/`} class="block bg-white p-6 rounded-xl border border-slate-200 hover:border-brand-primary shadow-sm hover:shadow-md transition-all flex flex-col h-full">
                            <div class="flex-grow">
                                <span class="inline-block text-xs font-semibold text-brand-secondary uppercase tracking-wider mb-2">{post.category || 'Guide'}</span>
                                <h3 class="text-lg font-bold text-brand-navy mb-3 line-clamp-2">{post.title}</h3>
                                <p class="text-slate-600 text-sm line-clamp-2">{post.aiSummary || post.excerpt || ''}</p>
                            </div>
                        </a>
                    ))}
                </div>
            </section>

            <!-- PLATFORM SUPPORT -->
            <section>
                <h2 class="text-3xl font-bold text-brand-navy mb-4">Platform Support</h2>
                <p class="text-slate-600 mb-8 border-b border-slate-200 pb-4">Platform names are third-party tools. Support does not imply official partnership unless stated.</p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {platformCategories.map(category => (
                        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                            <h3 class="text-xl font-bold text-brand-navy mb-4">{category.name}</h3>
                            <ul class="space-y-2">
                                {category.items.map(item => {
                                    // Make a safe URL slug
                                    const slug = item.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
                                    const path = `/platforms/${slug}/`;
                                    const exists = routeExists(path);
                                    return (
                                        <li class="flex items-center text-slate-700">
                                            <svg class="w-4 h-4 mr-2 text-brand-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                                            {exists ? (
                                                <a href={path} class="hover:text-brand-primary transition-colors">{item}</a>
                                            ) : (
                                                <a href="/platforms/" class="hover:text-brand-primary transition-colors">{item}</a>
                                            )}
                                        </li>
                                    );
                                })}
                            </ul>
                        </div>
                    ))}
                </div>
            </section>

            <!-- LOCATIONS -->
            <section>
                <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 border-b border-slate-200 pb-4">
                    <h2 class="text-3xl font-bold text-brand-navy mb-4 md:mb-0">Locations</h2>
                    <a href="/locations/" class="text-brand-primary font-medium hover:underline flex items-center">
                        View All Locations
                        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {locationRegions.map(region => (
                        <div>
                            <h3 class="text-xl font-bold text-brand-navy mb-4">{region.name}</h3>
                            <ul class="space-y-2">
                                {region.cities.map(city => (
                                    <li>
                                        <a href={city.path} class="text-slate-600 hover:text-brand-primary transition-colors flex items-center">
                                            <span class="w-1.5 h-1.5 bg-brand-secondary rounded-full mr-2"></span>
                                            {city.title}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </section>

            <!-- CASE STUDIES -->
            {caseStudies.length > 0 && (
                <section>
                    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 border-b border-slate-200 pb-4">
                        <h2 class="text-3xl font-bold text-brand-navy mb-4 md:mb-0">Case Studies</h2>
                        <a href="/case-studies/" class="text-brand-primary font-medium hover:underline flex items-center">
                            View All Case Studies
                            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        {caseStudies.map(cs => (
                             <a href={cs.path} class="block bg-white p-6 rounded-xl border border-slate-200 hover:border-brand-primary shadow-sm hover:shadow-md transition-all">
                                <h3 class="text-lg font-bold text-brand-navy mb-2">{cs.title.split(' |')[0]}</h3>
                                {cs.description && <p class="text-slate-600 text-sm line-clamp-2">{cs.description}</p>}
                            </a>
                        ))}
                    </div>
                </section>
            )}

            <!-- LEGAL AND UTILITY -->
            <section>
                <h2 class="text-3xl font-bold text-brand-navy mb-8 border-b border-slate-200 pb-4">Legal & Utility</h2>
                <div class="flex flex-wrap gap-4">
                    {safeLegalPages.map(page => (
                        <a href={page.path} class="bg-white px-4 py-2 rounded-lg border border-slate-200 text-sm text-slate-600 hover:text-brand-navy hover:border-slate-300 transition-colors">
                            {page.title}
                        </a>
                    ))}
                </div>
            </section>

        </div>
    </div>

    <!-- FINAL CTA -->
    <div class="bg-white py-24 border-t border-slate-100">
        <div class="max-w-3xl mx-auto px-4 text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">Need help choosing the right service?</h2>
            <p class="text-lg text-slate-600 mb-8">
                Get 24–48 Hour Review and we’ll look at your course idea, Kajabi setup, LMS, content, or learning workflow and suggest the clearest next step.
            </p>
            <a href="/book-free-audit/" class="inline-block bg-brand-primary hover:bg-brand-accent text-white font-bold py-4 px-8 rounded-lg shadow-md transition-all hover:shadow-lg transform hover:-translate-y-0.5">
                Get 24–48 Hour Review
            </a>
        </div>
    </div>
</Layout>
