---
import Layout from "../../../layouts/Layout.astro";
import { blogCategories } from "../../../data/blogArchitecture";
import { fetchFromSanity } from "../../../sanity/client";
import { blogPostSummariesQuery } from "../../../lib/blog/queries";
import { normalizeBlogPost } from "../../../lib/blog/normalizeBlogPost";
import BlogCard from "../../../components/blog/BlogCard.astro";
import BlogCTA from "../../../components/blog/BlogCTA.astro";

export async function getStaticPaths() {
  return blogCategories
    .filter((cat) => cat.publicVisibility)
    .map((category) => {
      return {
        params: { slug: category.slug },
        props: { category },
      };
    });
}

const { category } = Astro.props;

// Fetch all posts and filter locally (or could update GROQ for category specific).
// For static site generation, this is fine since it runs at build time.
const allPostsRaw = await fetchFromSanity(blogPostSummariesQuery, {}, { useCdn: false, tags: ["website.blog.summaries"] });
const allPosts = Array.isArray(allPostsRaw) ? allPostsRaw.map(normalizeBlogPost) : [];

// Filter based on normalized category
const categoryPosts = allPosts.filter(p => p.primaryCategory === category.id);
const hasContent = categoryPosts.length > 0;

if (!hasContent) {
  // Return 404 or similar, but the instruction is "no empty category is indexed".
  // Let's set index to false if empty.
}

const seoTitle = `${category.title} Guides and Articles | TheEduAssist`;
const seoDescription = category.description;
---

<Layout
  title={seoTitle}
  description={seoDescription}
  canonicalPath={`/blog/category/${category.slug}/`}
  robots={hasContent && category.sitemapVisibility ? "index, follow" : "noindex, follow"}
>
  <main class="w-full flex-grow flex flex-col bg-slate-50 overflow-hidden">
    <!-- Hero Section -->
    <section class="w-full py-16 md:py-24 px-6 md:px-12 max-w-7xl mx-auto flex flex-col items-center text-center">
      <div class="mb-4 text-sm font-semibold text-brand-green uppercase tracking-wider">
        Blog Category
      </div>
      <h1 class="text-3xl md:text-5xl font-bold text-brand-blue mb-6">
        {category.title}
      </h1>
      <p class="text-lg md:text-xl text-slate-700 max-w-2xl mb-8">
        {category.description}
      </p>
    </section>

    <!-- Articles Grid -->
    <section class="w-full py-12 px-6 md:px-12 max-w-7xl mx-auto">
      {hasContent ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {categoryPosts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <h2 class="text-2xl font-bold text-slate-700 mb-4">No articles yet</h2>
          <p class="text-slate-600">We're currently writing practical guidance for this topic.</p>
        </div>
      )}
    </section>

    <div class="mt-8 mb-20 px-6 md:px-12 max-w-7xl mx-auto w-full">
      <BlogCTA />
    </div>
  </main>
</Layout>
