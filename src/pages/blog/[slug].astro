---
export const prerender = true;
import BlogArticleLayout from '../../layouts/BlogArticleLayout.astro';
import PortableTextRenderer from '../../components/blog/PortableTextRenderer.tsx';
import BlogTableOfContents from '../../components/blog/BlogTableOfContents.astro';
import RelatedArticles from '../../components/blog/RelatedArticles.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';
import ArticleShareButtons from '../../components/blog/ArticleShareButtons.astro';
import BlogFAQs from '../../components/blog/BlogFAQs.astro';

import { fetchFromSanity } from '../../sanity/client';
import { blogPostSlugsQuery, blogPostDetailQuery } from '../../lib/blog/queries';
import { normalizeBlogPost } from '../../lib/blog/normalizeBlogPost';
import { extractHeadings } from '../../utils/extractHeadings';

export async function getStaticPaths() {
  const postsRaw = await fetchFromSanity(blogPostSlugsQuery);
  return postsRaw.map((p: any) => ({
    params: { slug: p.slug },
    props: { slug: p.slug }
  }));
}

const { slug } = Astro.params;

const rawPost = await fetchFromSanity(blogPostDetailQuery, { slug }, { useCdn: false, tags: ["website.blog.detail"] });
if (!rawPost) {
  return new Response("Not found", { status: 404 });
}
const post = normalizeBlogPost(rawPost);

// Direct Answer support
// We can extract a 'directAnswer' if it exists or use a field from Sanity.
// For now, if 'shortAnswer' is added in sanity, we'd render it. We'll use a placeholder logic if we had it.
const hasDirectAnswer = !!post.shortAnswer;

const headings = extractHeadings(post.body);
const showToc = headings.length >= 2;

const schemaData = {
  "@context": "https://schema.org",
  "@type": post.contentType === 'press-release' ? "NewsArticle" : "Article",
  "headline": post.title,
  "description": post.excerpt,
  "image": post.featuredImage ? [post.featuredImage] : undefined,
  "datePublished": post.datePublished,
  "dateModified": post.dateModified || post.datePublished,
  "author": {
    "@type": post.author?.schemaType || "Organization",
    "name": post.author?.name || "TheEduAssist Editorial Team"
  },
  "publisher": {
    "@type": "Organization",
    "name": "TheEduAssist",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.theeduassist.com/ui/theeduassist-logo-icon.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.theeduassist.com${post.canonical}`
  }
};
---

<BlogArticleLayout
  title={`${post.title} | TheEduAssist`}
  description={post.excerpt}
  canonicalPath={post.canonical}
  image={post.featuredImage}
  type="article"
  publishDate={post.datePublished}
  modifiedDate={post.dateModified}
  authorName={post.author?.name}
  robots={post.robots}
  jsonLd={[schemaData]}
>
  <!-- Schema inserted via layout -->

  <main class="w-full flex-grow flex flex-col bg-slate-50 relative pb-20">
    <article class="w-full">
      <!-- Article Header -->
      <header class="w-full bg-white pt-16 pb-12 px-6 md:px-12 border-b border-slate-200">
        <div class="max-w-4xl mx-auto">
          <!-- Breadcrumbs / Content Type -->
          <nav class="flex items-center text-sm font-medium text-slate-500 mb-6 space-x-2" aria-label="Breadcrumb">
            <a href="/blog/" class="hover:text-brand-green transition-colors">Blog</a>
            <span>/</span>
            <a href={`/blog/category/${post.primaryCategory}/`} class="hover:text-brand-green transition-colors capitalize">{post.primaryCategory.replace('-', ' ')}</a>
            <span>/</span>
            <span class="text-brand-blue capitalize">{post.contentType.replace('-', ' ')}</span>
          </nav>

          <h1 class="text-3xl md:text-5xl font-bold text-brand-blue leading-tight mb-6">
            {post.title}
          </h1>

          {post.excerpt && (
            <p class="text-lg md:text-xl text-slate-600 mb-8 leading-relaxed">
              {post.excerpt}
            </p>
          )}

          <!-- Author and Meta -->
          <div class="flex flex-wrap items-center gap-6 py-6 border-t border-slate-100">
            {post.author && (
              <div class="flex items-center gap-3">
                {post.author.profileImage && (
                  <img src={post.author.profileImage} alt={post.author.name} class="w-10 h-10 rounded-full object-cover bg-slate-100" />
                )}
                <div class="flex flex-col">
                  <span class="text-sm font-semibold text-brand-blue">{post.author.name}</span>
                  <a href={`/authors/${post.author.slug}/`} class="text-xs text-brand-green hover:underline">View Profile</a>
                </div>
              </div>
            )}

            <div class="flex flex-col">
              <span class="text-xs text-slate-500 uppercase tracking-wider font-semibold">Published</span>
              <time class="text-sm font-medium text-slate-700" datetime={post.datePublished}>
                {new Date(post.datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>

            {post.dateModified && post.dateModified !== post.datePublished && (
              <div class="flex flex-col">
                <span class="text-xs text-slate-500 uppercase tracking-wider font-semibold">Updated</span>
                <time class="text-sm font-medium text-slate-700" datetime={post.dateModified}>
                  {new Date(post.dateModified).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
            )}

            {post.readingTime && (
               <div class="flex flex-col">
                <span class="text-xs text-slate-500 uppercase tracking-wider font-semibold">Reading Time</span>
                <span class="text-sm font-medium text-slate-700">{post.readingTime} min</span>
              </div>
            )}
          </div>
        </div>
      </header>

      <!-- Featured Image -->
      {post.featuredImage && (
        <div class="w-full max-w-5xl mx-auto px-6 md:px-12 -mt-8 relative z-10">
          <img
            src={post.featuredImage}
            alt={post.featuredImageAlt || post.title}
            class="w-full h-auto aspect-video object-cover rounded-xl shadow-md border border-slate-200 bg-slate-100"
            width="1024"
            height="576"
          />
        </div>
      )}

      <!-- Layout with Sidebar for TOC -->
      <div class="w-full max-w-7xl mx-auto px-6 md:px-12 py-12 flex flex-col lg:flex-row gap-12">

        {/* Main Content */}
        <div class={`w-full ${showToc ? 'lg:w-2/3 lg:pr-8' : 'max-w-4xl mx-auto'}`}>

          {hasDirectAnswer && (
            <div class="bg-brand-blue/5 border border-brand-blue/10 rounded-xl p-6 md:p-8 mb-10">
              <h2 class="text-xl font-bold text-brand-blue mb-4">The Short Answer</h2>
              <div class="prose prose-slate prose-brand max-w-none">
                <p>{post.shortAnswer}</p>
              </div>
            </div>
          )}

          <div class="prose prose-slate prose-lg md:prose-xl prose-brand max-w-none prose-headings:scroll-mt-24 prose-a:text-brand-green hover:prose-a:text-brand-blue prose-img:rounded-xl">
            {post.body && post.body.length > 0 ? (
              <PortableTextRenderer value={post.body} />
            ) : (
              <p>Content is being updated.</p>
            )}
          </div>

          <!-- Sources -->
          {post.sources && post.sources.length > 0 && (
             <div class="mt-16 pt-8 border-t border-slate-200">
               <h3 class="text-xl font-bold text-slate-800 mb-4">Sources and References</h3>
               <ul class="space-y-3 text-sm text-slate-600">
                 {post.sources.map((source: any, i: number) => (
                   <li class="pl-4 border-l-2 border-slate-200">
                     {source.url ? (
                       <a href={source.url} target="_blank" rel="noopener noreferrer" class="hover:text-brand-green hover:underline">
                         {source.label || source.title || source.url}
                       </a>
                     ) : (
                       <span>{source.label || source.title}</span>
                     )}
                   </li>
                 ))}
               </ul>
             </div>
          )}

          <div class="mt-12">
            <ArticleShareButtons url={`https://www.theeduassist.com${post.canonical}`} title={post.title} />
          </div>
        </div>

        {/* Sidebar */}
        {showToc && (
          <aside class="w-full lg:w-1/3 order-first lg:order-last mb-12 lg:mb-0">
            <div class="sticky top-24">
              <BlogTableOfContents headings={headings} />
              <div class="mt-8 hidden lg:block">
                 <BlogCTA variant="sidebar" />
              </div>
            </div>
          </aside>
        )}
      </div>
    </article>

    <!-- Author block at bottom -->
    {post.author && (
      <section class="w-full py-12 px-6 md:px-12 bg-white border-y border-slate-200">
        <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center md:items-start gap-6">
           {post.author.profileImage && (
             <img src={post.author.profileImage} alt={post.author.name} class="w-24 h-24 rounded-full object-cover shadow-sm" />
           )}
           <div class="text-center md:text-left">
             <h3 class="text-xl font-bold text-brand-blue mb-2">Written by {post.author.name}</h3>
             <p class="text-slate-600 mb-4">{post.author.shortBio}</p>
             <a href={`/authors/${post.author.slug}/`} class="text-brand-green font-medium hover:underline">View full profile</a>
           </div>
        </div>
      </section>
    )}

    {/* Related Articles */}
    {post.relatedArticleSlugs && post.relatedArticleSlugs.length > 0 && (
      <RelatedArticles currentSlug={post.slug} relatedSlugs={post.relatedArticleSlugs} />
    )}

    {/* Final CTA */}
    <div class="py-16 px-6 md:px-12 max-w-7xl mx-auto w-full">
      <BlogCTA />
    </div>

  </main>
</BlogArticleLayout>
