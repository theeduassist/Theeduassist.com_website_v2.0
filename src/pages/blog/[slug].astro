---
export const prerender = true;
import BlogArticleLayout from '../../layouts/BlogArticleLayout.astro';
import PortableTextRenderer from '../../components/blog/PortableTextRenderer.tsx';
import ArticleMetaBar from '../../components/blog/ArticleMetaBar.astro';
import BlogTableOfContents from '../../components/blog/BlogTableOfContents.astro';
import RelatedArticles from '../../components/blog/RelatedArticles.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';
import AuthorCard from '../../components/blog/AuthorCard.astro';
import ArticleShareButtons from '../../components/blog/ArticleShareButtons.astro';
import BlogFAQs from '../../components/blog/BlogFAQs.astro';
import RelatedCaseStudies from '../../components/blog/RelatedCaseStudies.astro';

import { getAllBlogPosts } from '../../lib/content/getAllBlogPosts';
import { extractHeadings } from '../../utils/extractHeadings';
import { getFallbackDescription } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();

  // Filter out posts that do not have valid body or content
  // posts is already strictly filtered by getAllBlogPosts()
  const validPosts = posts;

  return validPosts.map(post => {
    return {
      params: { slug: post.slug },
      props: { post, allPosts: validPosts }
    };
  });
}

const { post, allPosts } = Astro.props;

if (!post) {
  throw new Error("Post not found");
}

const schemaFaqs = [
  ...(post.relatedFaqs || [])
    .filter((faq: any) => faq && faq.showOnSite === true && faq.question && faq.answer),
  ...(post.blogFaqs || [])
    .filter((faq: any) => faq && faq.showOnPage === true && faq.includeInSchema === true && faq.question && faq.answer)
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.seoTitle || post.title,
  "description": post.seoDescription || post.excerpt || getFallbackDescription(post.content, post.body),
  "author": { "@type": "Person", "name": post.author || "TheEduAssist Team" },
  "datePublished": post.publishedAt ? new Date(post.publishedAt).toISOString() : undefined,
  "dateModified": (post.updatedAt || post.publishedAt) ? new Date(post.updatedAt || post.publishedAt).toISOString() : undefined,
  "image": (() => {
    const rawImage = post.seo?.ogImage?.asset?.url || post.heroImage || post.mainImage?.asset?.url;
    if (!rawImage) return undefined;
    if (rawImage.startsWith('http')) return rawImage;
    return `https://www.theeduassist.com${rawImage}`;
  })(),
  "publisher": {
    "@type": "Organization",
    "name": "TheEduAssist",
    "url": "https://www.theeduassist.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.theeduassist.com/blog/${post.slug}/`
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.theeduassist.com/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.theeduassist.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": `https://www.theeduassist.com/blog/${post.slug}/` }
  ]
};

const schemas: any[] = [articleSchema, breadcrumbSchema];

if (schemaFaqs.length > 0) {
  const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": schemaFaqs.map((faq: any) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": typeof faq.answer === 'string' ? faq.answer : 'Answer available on site.'
      }
    }))
  };
  schemas.push(faqSchema);
}

const headings = extractHeadings(post.body || []);
const tocEnabled = headings.length > 0;
---

<BlogArticleLayout
  title={post.seoTitle || `${post.title} | TheEduAssist Blog`}
  description={post.seoDescription || post.excerpt || getFallbackDescription(post.content, post.body)}
  canonicalPath={post.canonicalUrl || `/blog/${post.slug}/`}
  ogImage={post.seo?.ogImage?.asset?.url || post.heroImage || post.mainImage?.asset?.url}
  twitterCardType={post.seo?.twitterCardType}
  type="article"
  jsonLd={schemas}
>
  <article class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto">
      <header class="mb-10 text-center mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-slate-800 leading-tight">
          {post.title}
        </h1>
        {post.excerpt && (
          <p class="text-xl text-slate-600 mb-8 leading-relaxed max-w-3xl mx-auto">
            {post.excerpt}
          </p>
        )}
      </header>

      {post.aiSummary ? (
      <div class="bg-slate-50 p-6 rounded-xl border border-slate-200 mb-10 max-w-3xl mx-auto text-left shadow-sm">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            Quick Summary
        </h2>
        <ul class="list-disc pl-5 space-y-2 text-slate-700">
          {(typeof post.aiSummary === 'string' ? post.aiSummary.split('\n').filter(s => s.trim().length > 0).slice(0, 5) : []).map((bullet: string) => (
             <li>{bullet.replace(/^-\s*/, '').split(' ').slice(0, 18).join(' ') + (bullet.split(' ').length > 18 ? '...' : '')}</li>
          ))}
        </ul>
      </div>
  ) : (
      <div class="bg-slate-50 p-6 rounded-xl border border-slate-200 mb-10 max-w-3xl mx-auto text-left shadow-sm">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            Quick Summary
        </h2>
        <ul class="list-disc pl-5 space-y-2 text-slate-700">
           <li>{post.excerpt ? post.excerpt.split(' ').slice(0, 18).join(' ') + '...' : 'Practical guide for course creators and e-learning platforms.'}</li>
           {headings.slice(0, 3).map((h: any) => <li>{h.text}</li>)}
        </ul>
      </div>
  )}

      {post.heroImage && (
        <div class="mb-12 rounded-2xl overflow-hidden shadow-md max-w-4xl mx-auto aspect-w-16 aspect-h-9 bg-slate-100">
          <img
            src={post.heroImage}
            alt={post.heroImageAlt || post.title}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )}

      <div class="max-w-3xl mx-auto">
        <nav class="text-sm text-slate-500 mb-8 font-medium" aria-label="Breadcrumb">
    <ol class="list-none p-0 inline-flex items-center gap-2">
      <li><a href="/" class="hover:text-[var(--color-primary)] transition-colors">Home</a></li>
      <li><span class="text-slate-300">/</span></li>
      <li><a href="/blog/" class="hover:text-[var(--color-primary)] transition-colors">Blog</a></li>
      <li><span class="text-slate-300">/</span></li>
      <li><span class="text-slate-800 truncate block max-w-[200px] md:max-w-xs" aria-current="page">{post.title}</span></li>
    </ol>
  </nav>

        <ArticleMetaBar
          category={post.category}
          publishedAt={post.publishedAt}
          updatedAt={post.updatedAt}
          author={post.author}
          readTimeMinutes={post.readingTime}
        />

        {post.updatedAt && post.updatedAt !== post.publishedAt && (
           <p class="text-xs text-slate-500 mt-2 mb-8 text-center italic">Last updated on {new Date(post.updatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        )}

        <div class="flex flex-col md:flex-row gap-10 mt-10">
          {tocEnabled && (
            <aside class="md:w-1/4 hidden md:block">
              <div class="sticky top-24">
                <BlogTableOfContents headings={headings} />
              </div>
            </aside>
          )}

          <!-- Main Content -->
          <div class={`prose prose-lg prose-slate prose-a:text-[var(--color-brand-primary)] hover:prose-a:text-[var(--color-brand-accent)] max-w-none ${tocEnabled ? 'md:w-3/4' : 'md:w-full'}`}>
            {post.body ? (
              <PortableTextRenderer value={post.body} />
            ) : (
              <div set:html={post.content || ""} />
            )}

            <div class="mt-12 pt-8 border-t border-slate-100">
               <ArticleShareButtons
                 url={`https://www.theeduassist.com/blog/${post.slug}/`}
                 title={post.title}
               />
            </div>

            <BlogCTA />
          </div>
        </div>
      </div>

      <!-- Tags -->
      {post.tags && post.tags.length > 0 && (
        <div class="max-w-3xl mx-auto mt-12 mb-16">
          <div class="flex flex-wrap gap-2">
            {post.tags.map((tag: string) => (
              <span class="px-3 py-1 bg-slate-100 text-slate-600 text-sm rounded-full">
                {tag.replace(/-/g, ' ')}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Related Modules/CTA -->
      <div class="max-w-4xl mx-auto mt-16 pt-8">

        {post.relatedServices && post.relatedServices.length > 0 && (
          <div class="my-12">
            <h3 class="text-2xl font-bold text-slate-800 mb-6">Related Services</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {post.relatedServices.map((service: any) => (
                <a href={service.slug?.current ? `/services/${service.slug.current}/` : service.slug || '#'} class="block bg-white border border-slate-200 rounded-xl p-6 hover:shadow-md transition-shadow">
                  <h4 class="font-bold text-lg text-[var(--color-primary)] mb-2">{service.title}</h4>
                  <p class="text-slate-600 text-sm">{service.description}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        {post.relatedPlatforms && post.relatedPlatforms.length > 0 && (
          <div class="my-12">
            <h3 class="text-2xl font-bold text-slate-800 mb-6">Platforms Discussed</h3>
            <div class="flex flex-wrap gap-4">
              {post.relatedPlatforms.map((platform: any) => (
                <div class="bg-slate-50 border border-slate-200 rounded-lg px-4 py-2 flex items-center text-slate-700 font-medium">
                  {platform.name}
                </div>
              ))}
            </div>
          </div>
        )}

        <AuthorCard name={post.author} />

        <RelatedCaseStudies
          slugs={post.relatedCaseStudies}
          category={post.category}
        />

        {post.sources && post.sources.length > 0 && (
          <div class="my-12 pt-8 border-t border-slate-200">
            <h3 class="text-xl font-bold text-slate-800 mb-4">Sources & References</h3>
            <ul class="list-disc pl-5 space-y-2 text-slate-600 text-sm">
              {post.sources.map((source: any) => (
                <li>
                  {source.url ? (
                    <a href={source.url} target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">
                      {source.label || source.url}
                    </a>
                  ) : (
                    <span>{source.label}</span>
                  )}
                  {source.notes && <span class="text-slate-500 italic ml-2">- {source.notes}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}

        <BlogFAQs blogFaqs={post.blogFaqs} relatedFaqs={post.relatedFaqs} />

        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8 md:p-12 text-center my-12 shadow-sm relative overflow-hidden">
          <div class="relative z-10 max-w-2xl mx-auto">
            <h2 class="text-3xl font-bold text-slate-800 mb-4">Need help turning your expertise into a structured online learning experience?</h2>
            <p class="text-slate-600 mb-8 text-lg">
              Talk to TheEduAssist about course planning, platform setup, LMS migration, or content conversion.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/book-free-audit/" class="blog-cta-btn inline-flex items-center justify-center px-8 py-4 bg-[var(--color-accent)] text-white font-bold rounded-lg hover:bg-opacity-90 transition-transform hover:-translate-y-0.5 focus:ring-2 focus:ring-offset-2 focus:ring-[var(--color-accent)] focus:outline-none" data-cta-label="Get 24–48 Hour Review">
                Get 24–48 Hour Review &rarr;
              </a>
            </div>
          </div>
        </div>

        <RelatedArticles
          currentSlug={post.slug}
          category={post.category}
          allPosts={allPosts}
          currentTags={post.tags}
        />
      </div>
    </div>
  </article>
</BlogArticleLayout>
