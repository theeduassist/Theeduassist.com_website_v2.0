---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import BlogHero from '../../../components/blog/BlogHero.astro';
import BlogSearchFilters from '../../../components/blog/BlogSearchFilters.astro';
import FeaturedBlogArticle from '../../../components/blog/FeaturedBlogArticle.astro';
import LatestArticles from '../../../components/blog/LatestArticles.astro';
import AllArticlesGrid from '../../../components/blog/AllArticlesGrid.astro';
import QuickBlogQuestions from '../../../components/blog/QuickBlogQuestions.astro';
import IndexBlogFAQs from '../../../components/blog/IndexBlogFAQs.astro';
import BlogCTA from '../../../components/blog/BlogCTA.astro';

import { getBlogPostSummaries } from '../../../lib/content/getAllBlogPosts';
import { faqs as indexFaqs } from '../../../components/blog/IndexBlogFAQs.astro';

export async function getStaticPaths({ paginate }) {
  let posts = [];
  try {
    posts = await getBlogPostSummaries();
  } catch (e) {
    console.log("Error fetching blog posts for index pagination");
  }
  return paginate(posts, { pageSize: 12 });
}

const { page } = Astro.props;

// Determine if we are on the first page to show hero and featured sections
const isFirstPage = page.currentPage === 1;

// On the first page, the first post in the paginated array is the featured post
const featuredPost = (isFirstPage && page.data.length > 0) ? page.data[0] : null;

// The rest of the posts for the grid
const gridPosts = isFirstPage ? page.data.slice(1) : page.data;

// SEO details
const titleText = isFirstPage
  ? "Blog | Course Creation, Kajabi, LMS & E-Learning Insights | TheEduAssist"
  : `Blog - Page ${page.currentPage} | TheEduAssist`;
const title = titleText;
const description = "Read TheEduAssist articles on course creation, Kajabi setup, LMS implementation, instructional design, AI-powered e-learning, content conversion, and online course launches.";

const canonicalPath = isFirstPage ? "/blog/" : `/blog/page/${page.currentPage}/`;
const ogTitle = title;
const ogDescription = description;

// Basic WebPage schema for the hub
const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": title,
  "description": description,
  "url": `https://theeduassist.com${canonicalPath}`,
  "publisher": {
    "@type": "Organization",
    "name": "TheEduAssist",
    "url": "https://theeduassist.com/"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": indexFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  jsonLd={[schema, faqSchema]}
>
  {isFirstPage && <BlogHero />}

  <main class="container mx-auto px-4 py-12 max-w-6xl">
    {page.data.length === 0 ? (
      <div class="text-center py-20 bg-slate-50 rounded-lg border border-slate-200 border-dashed">
        <p class="text-xl text-slate-600">New articles coming soon.</p>
      </div>
    ) : (
      <>
        {isFirstPage && featuredPost && (
          <FeaturedBlogArticle post={featuredPost} />
        )}

        {isFirstPage && (
          <div class="mb-12">
              <BlogSearchFilters />
          </div>
        )}

        {isFirstPage && (
          <LatestArticles currentSlug={featuredPost?.slug?.current || featuredPost?.slug} />
        )}

        <AllArticlesGrid posts={gridPosts} page={page} isFirstPage={isFirstPage} />

        <QuickBlogQuestions />

        <IndexBlogFAQs />

        <div class="mt-20">
            <BlogCTA />
        </div>
      </>
    )}
  </main>

</Layout>
