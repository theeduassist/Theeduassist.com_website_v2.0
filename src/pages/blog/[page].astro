---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { getAllBlogPosts } from '../../lib/content/getAllBlogPosts';

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();
  const POSTS_PER_PAGE = 9;

  // Exclude featured post from index and offset properly
  // Index shows posts 1-9 (10 posts total on first page conceptually, 1 featured + 9 grid)
  const remainingPosts = posts.length > 10 ? posts.slice(10) : [];
  const totalPages = Math.ceil(remainingPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages }).map((_, i) => {
    return {
      params: { page: (i + 2).toString() },
      props: {
        posts: remainingPosts.slice(i * POSTS_PER_PAGE, (i + 1) * POSTS_PER_PAGE),
        currentPage: i + 2,
        totalPages: totalPages + 1
      },
    };
  });
}

const { page } = Astro.params;
const { posts, currentPage, totalPages } = Astro.props;

if (!posts || posts.length === 0) {
  return Astro.redirect('/blog/');
}

const title = `Blog Page ${currentPage} | TheEduAssist`;
const description = `Browse page ${currentPage} of TheEduAssist e-learning and course creation articles.`;
const canonicalPath = `/blog/${currentPage}/`;
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  type="website"
>
  <div class="bg-slate-50 py-12 border-b border-slate-200">
    <div class="container mx-auto px-4 max-w-6xl text-center">
      <h1 class="text-3xl font-bold text-slate-800">TheEduAssist Blog - Page {currentPage}</h1>
    </div>
  </div>

  <main class="container mx-auto px-4 py-16 max-w-6xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      {posts.map(post => (
        <BlogCard
          title={post.title}
          slug={post.slug?.current || post.slug}
          excerpt={post.excerpt}
          category={post.category || 'Guide'}
          readTimeMinutes={post.readingTime}
          publishedAt={post.publishedAt}
          image={post.heroImage || post.mainImage?.asset?.url}
          imageAlt={post.heroImageAlt || post.mainImage?.alt}
          tags={post.tags}
        />
      ))}
    </div>

    <div class="flex justify-center items-center gap-4">
      <a href={currentPage === 2 ? "/blog/" : `/blog/${currentPage - 1}/`} class="px-6 py-2 border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 transition-colors">
        &larr; Previous
      </a>
      <span class="text-slate-500 font-medium">Page {currentPage} of {totalPages}</span>
      {currentPage < totalPages ? (
        <a href={`/blog/${currentPage + 1}/`} class="px-6 py-2 border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 transition-colors">
          Next &rarr;
        </a>
      ) : (
        <span class="px-6 py-2 border border-slate-200 rounded-lg text-slate-400 cursor-not-allowed">
          Next &rarr;
        </span>
      )}
    </div>
  </main>
</Layout>
