---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found | TheEduAssist">
  <main class="max-w-4xl mx-auto px-4 py-16 text-center mt-12 mb-12">
    <h1 class="text-4xl font-bold mb-6 text-brand-navy">We could not find that page</h1>
    <p class="text-lg text-brand-textMuted mb-8 max-w-2xl mx-auto leading-relaxed">
      TheEduAssist has been reorganizing its website, so the page may have moved. You can explore our services, visit the Kajabi Services page, read the blog, or get a 24-48 hour review.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="border border-brand-border hover:bg-brand-softBg text-brand-textMain font-medium py-2 px-6 rounded transition-colors focus-ring">
        Home
      </a>
      <a href="/services/" class="bg-brand-primary hover:bg-brand-navy text-white font-medium py-2 px-6 rounded transition-colors focus-ring">
        Services
      </a>
      <a href="/kajabi-services/" class="border border-brand-border hover:bg-brand-softBg text-brand-textMain font-medium py-2 px-6 rounded transition-colors focus-ring">
        Kajabi Services
      </a>
      <a href="/blog/" class="border border-brand-border hover:bg-brand-softBg text-brand-textMain font-medium py-2 px-6 rounded transition-colors focus-ring">
        Blog
      </a>
      <a href="/contact/" class="border border-brand-border hover:bg-brand-softBg text-brand-textMain font-medium py-2 px-6 rounded transition-colors focus-ring">
        Contact
      </a>
      <a href="/book-free-audit/" class="bg-brand-accent hover:bg-white border border-brand-accent/20 hover:text-brand-primary text-brand-navy font-medium py-2 px-6 rounded transition-colors focus-ring">
        Get 24–48 Hour Review
      </a>
    </div>
  </main>
</Layout>
