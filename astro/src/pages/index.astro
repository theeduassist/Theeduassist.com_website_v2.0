---
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/sections/HomeHero.astro";
import TrustStrip from "../components/sections/TrustStrip.astro";
import AudienceGrid from "../components/sections/AudienceGrid.astro";
import CustomerLifecycle from "../components/sections/CustomerLifecycle.astro";
import CoreServicesGrid from "../components/sections/CoreServicesGrid.astro";
import MultiPlatformSection from "../components/sections/MultiPlatformSection.astro";
import EnterpriseLearningSection from "../components/sections/EnterpriseLearningSection.astro";
import KajabiSpecialty from "../components/sections/KajabiSpecialty.astro";
import AIElearningSupport from "../components/sections/AIElearningSupport.astro";
import ElearningBuildSystem from "../components/sections/ElearningBuildSystem.astro";
import WhyChooseSection from "../components/sections/WhyChooseSection.astro";
import ChooseByNeedSection from "../components/sections/ChooseByNeedSection.astro";
import StartingPoint from "../components/sections/StartingPoint.astro";
import FinalCTA from "../components/sections/FinalCTA.astro";
import SelfDiagnosisMirror from "../components/sections/SelfDiagnosisMirror.astro";
import ImprovementSelector from "../components/sections/ImprovementSelector.astro";
import { organizationSchema, websiteSchema, professionalServiceSchema , faqPageSchema } from '../lib/seo/schema';
import { getAudienceSegments, getAllServices, getAllTestimonials, getTrainingSolutions, getCtaBlocks, getProcessByTitle } from '../sanity/queries';

const audienceSegments = await getAudienceSegments();
const services = await getAllServices();
const testimonials = await getAllTestimonials();
const trainingSolutions = await getTrainingSolutions();
const ctaBlocks = await getCtaBlocks();
const primaryProcess = await getProcessByTitle('Primary Process');

const packageFaqs = [
  { question: "Are these fixed prices?", answer: "No. These are starting prices. Final pricing depends on content volume, course length, platform, pages, automations, integrations, review rounds, and timeline." },
  { question: "What happens when I click Start This Package?", answer: "The sales chat opens so our team can understand your project, confirm the right package, and guide you to the review, payment, or invoice next step." },
  { question: "Do I need to pay before talking to the team?", answer: "No. We recommend confirming the scope first so the project path is clear before payment." },
  { question: "What if I am not sure which package fits?", answer: "Use Talk to Sales or Start This Package and explain your situation. Our team will help you choose the right starting point." },
  { question: "Can you work with Kajabi and other LMS platforms?", answer: "Yes. We support Kajabi, LMS platforms, course websites, content libraries, and online learning workflows." },
  { question: "Can you convert old PDFs, slides, videos, or books into a course?", answer: "Yes. The Content Conversion Kit is designed for turning existing materials into structured online learning content." }
];

const jsonLd = [
  organizationSchema(),
  websiteSchema(),
  professionalServiceSchema()
  ,
  faqPageSchema(packageFaqs)
];
---
<Layout
  title="TheEduAssist | E-Learning Design Agency for Courses, Kajabi & LMS Builds"
  description="TheEduAssist helps creators, coaches, educators, consultants, training companies, academies, and businesses build online courses, Kajabi systems, LMS experiences, funnels, automations, and launch-ready e-learning content."
  jsonLd={jsonLd}
>

  <HomeHero
    title="Turn Your Expertise Into a Launch-Ready Online Learning System"
    subtitle="TheEduAssist helps creators, coaches, educators, consultants, training companies, and online academies design courses, build Kajabi systems, migrate LMS content, create learning assets, and launch professional e-learning experiences."
    primaryCtaLabel="Get a 24–48 Hour Review"
    primaryCtaLink="/book-free-audit/"
    secondaryCtaLabel="Explore Services"
    secondaryCtaLink="/services/"
    trustChips={["Course Design", "Kajabi Builds", "LMS Migration", "AI Course Support", "Funnels & Automation", "Launch Support"]}
  />

  <TrustStrip />

  <AudienceGrid audienceSegments={audienceSegments} />

  <CustomerLifecycle />

  <CoreServicesGrid services={services} />

  <MultiPlatformSection />

  <EnterpriseLearningSection />

  <KajabiSpecialty />

  <AIElearningSupport />

  <ElearningBuildSystem process={primaryProcess} />

  <WhyChooseSection />

  <ChooseByNeedSection />

  <SelfDiagnosisMirror />

  <ImprovementSelector />

  <StartingPoint />

  <FinalCTA ctaBlocks={ctaBlocks} />

</Layout>
