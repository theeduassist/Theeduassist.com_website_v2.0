---
import Layout from "../../layouts/Layout.astro";
import { webPageSchema, breadcrumbSchema } from '../../lib/seo/schema';

const title = "Cookie Policy";
const description = "Learn about how TheEduAssist uses cookies and analytics tools to improve website performance and user experience.";
const canonicalPath = "/cookie-policy/";

const jsonLd = [
  webPageSchema(title, description, canonicalPath),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: title, urlPath: canonicalPath }
  ])
];
---
<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <div class="max-w-3xl mx-auto px-4 py-24 prose prose-slate">
    <h1>Cookie Policy</h1>
    <p>Last updated: {new Date().toLocaleDateString()}</p>

    <h2>1. What are cookies?</h2>
    <p>Cookies are small text files that are placed on your device when you visit a website. They help the site remember your actions and preferences over a period of time.</p>

    <h2>2. How we use cookies</h2>
    <p>TheEduAssist uses cookies primarily for essential website functionality and to understand how visitors interact with our site. We use this information to improve our services and user experience.</p>

    <h2>3. Third-Party Analytics Tools</h2>
    <p>We may use the following third-party services that utilize cookies:</p>
    <ul>
      <li><strong>Google Analytics 4 (GA4):</strong> To understand website traffic and visitor behavior.</li>
      <li><strong>Microsoft Clarity:</strong> To understand how users navigate our pages through heatmaps and session recordings.</li>
      <li><strong>Calendly:</strong> To facilitate the booking of our free audit sessions.</li>
    </ul>

    <h2>4. Managing Cookies</h2>
    <p>You can control and/or delete cookies as you wish. You can delete all cookies that are already on your computer and you can set most browsers to prevent them from being placed. However, if you do this, you may have to manually adjust some preferences every time you visit a site and some services and functionalities may not work.</p>

    <p class="italic mt-8 text-sm text-slate-500">Legal review recommended before launch.</p>
  </div>
</Layout>
