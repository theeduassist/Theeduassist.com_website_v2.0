---
import Layout from "../../layouts/Layout.astro";
import ServicesHero from "../../components/services/ServicesHero.astro";
import ServiceFinder from "../../components/services/ServiceFinder.astro";
import ServiceLifecycle from "../../components/services/ServiceLifecycle.astro";
import ServicesGrid from "../../components/services/ServicesGrid.astro";
import PlatformSpecialty from "../../components/services/PlatformSpecialty.astro";
import KajabiServiceHighlight from "../../components/services/KajabiServiceHighlight.astro";
import AIWorkflowSection from "../../components/services/AIWorkflowSection.astro";
import ServicesComparison from "../../components/services/ServicesComparison.astro";
import StartingPoint from "../../components/sections/StartingPoint.astro";
import ServicesFAQ from "../../components/services/ServicesFAQ.astro";
import ServicesFinalCTA from "../../components/services/ServicesFinalCTA.astro";
import CaseStudyProof from "../../components/case-studies/CaseStudyProof.astro";

import { professionalServiceSchema, breadcrumbSchema , faqPageSchema } from '../../lib/seo/schema';
import { getAllServices } from '../../sanity/queries';

const services = await getAllServices();

const packageFaqs = [
  { question: "Are these fixed prices?", answer: "No. They are starting investments and budget guides. Final pricing depends on content volume, course length, platform, pages, automations, integrations, review rounds, and timeline." },
  { question: "What happens when I click Start This Package?", answer: "The sales chat opens so our team can understand your project, confirm the right package, and guide you to the review, payment, or invoice next step." },
  { question: "Do I need to pay before talking to the team?", answer: "No. We recommend confirming the scope first so the project path is clear before payment." },
  { question: "What if I am not sure which package fits?", answer: "Use Talk to Sales or Start This Package and explain your situation. Our team will help you choose the right starting point." },
  { question: "Can you work with Kajabi and other LMS platforms?", answer: "Yes. We support Kajabi, LMS platforms, course websites, content libraries, and online learning workflows." },
  { question: "Can you convert old PDFs, slides, videos, or books into a course?", answer: "Yes. The Content Conversion Kit is designed for turning existing materials into structured online learning content." }
];

const jsonLd = [
  professionalServiceSchema(),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Services", urlPath: "/services/" }
  ])
  ,
  faqPageSchema(packageFaqs)
];
---
<Layout
  title="TheEduAssist Services | Course Creation, Kajabi, LMS & E-Learning Builds"
  description="Explore TheEduAssist services for course creation, curriculum design, Kajabi setup, LMS migration, instructional design, AI-powered e-learning support, funnels, automation, and launch-ready online learning systems."
  canonicalPath="/services/"
  jsonLd={jsonLd}
>

  <ServicesHero />
  <ServiceFinder />
  <ServiceLifecycle />
  <ServicesGrid services={services} />
  <PlatformSpecialty />
  <KajabiServiceHighlight />
  <AIWorkflowSection />
  <ServicesComparison />
  <CaseStudyProof slugs={['sqa-aligned-vocational-training', 'business-analytics-corporate-training', 'language-courses-book-publisher']} />
  <StartingPoint />
  <ServicesFAQ />
  <ServicesFinalCTA />

  <script>
    import { openStartServiceChat } from "../../utils/tawkSales";
    document.addEventListener("DOMContentLoaded", () => {
      const btns = document.querySelectorAll(".tawk-service-btn");
      btns.forEach(btn => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLButtonElement;
          openStartServiceChat({
            serviceSlug: target.dataset.serviceSlug || "",
            pageUrl: window.location.href,
            pageTitle: document.title,
          });
        });
      });
    });
  </script>

</Layout>
