---
import Button from '../ui/Button.astro';
import SectionHeader from '../ui/SectionHeader.astro';
---

<section id="booking-panel" class="py-16 md:py-24 bg-white relative">
  <div class="container mx-auto px-4 md:px-6 max-w-5xl">

    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8 md:p-12 shadow-sm relative overflow-hidden">
      {/* Decorative accent */}
      <div class="absolute top-0 left-0 w-2 h-full bg-[#77BA55]" aria-hidden="true"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">

        {/* Content Side */}
        <div>
          <h2 class="text-3xl font-bold text-slate-900 mb-4 tracking-tight">Book your 30-minute Kajabi audit</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed">
            Choose a time that works for you. During the audit, we will review your current setup or launch idea and identify the next practical improvements.
          </p>

          <ul class="space-y-4 mb-8">
            {[
              "Your current Kajabi setup or planned course idea",
              "Website or landing page concerns",
              "Course structure questions",
              "Funnel or email automation needs",
              "Migration or content organization issues"
            ].map(item => (
              <li class="flex items-start">
                <svg class="w-6 h-6 text-[#77BA55] mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-700">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* Action Side */}
        <div class="flex flex-col items-center justify-center p-6 bg-white border border-slate-100 rounded-xl shadow-sm text-center">
          <div class="w-16 h-16 bg-[#EFF6FF] rounded-full flex items-center justify-center mb-6 text-[#27496D]">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>

          <h3 class="text-xl font-semibold text-slate-900 mb-2">Ready to review your setup?</h3>
          <p class="text-slate-500 text-sm mb-8">Select a time directly on our calendar.</p>

          <div class="w-full space-y-4">
            <Button href="/book-free-audit/" variant="primary" class="w-full justify-center text-lg py-3" target="_blank" rel="noopener noreferrer">
              Open Booking Calendar
            </Button>

            <div class="text-center">
              <a href="/book-free-audit/" class="text-sm text-slate-500 hover:text-[var(--color-primary)] font-medium transition-colors">
                Contact TheEduAssist &rarr;
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
