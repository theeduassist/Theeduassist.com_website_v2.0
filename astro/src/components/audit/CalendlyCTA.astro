---
import Button from '../ui/Button.astro';
---

<section class="py-16 bg-blue-50 border-t border-b border-blue-100">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl font-bold mb-4 text-slate-900">Prefer to Book a Call Directly?</h2>
    <p class="text-lg text-slate-600 mb-8 max-w-2xl mx-auto">
      Before booking a build call, please submit your project details so we can use the call to discuss scope, timeline, and next step instead of starting from zero.
    </p>
    <Button
      href="https://calendly.com/eduassist-talk/30min"
      variant="primary"
      size="lg"
      class="bg-[#77BA55] border-[#77BA55] hover:bg-green-600"
      target="_blank"
      rel="noopener noreferrer"
    >
      Book 30-Minute Session
    </Button>
  </div>
</section>
