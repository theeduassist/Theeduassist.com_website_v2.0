---


---

<!-- <SectionWrapper --> <section className="bg-white py-24">
  <!-- <ContentContainer> --> <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-slate-900">Featured Example Build</h2>
    </div>

    <div class="bg-slate-50 rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
      <div class="grid lg:grid-cols-2 gap-0">

        <div class="p-8 lg:p-12">
          <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold tracking-wide bg-[#EFF6FF] text-[#27496D] border border-blue-100 uppercase mb-6">
            Example Build
          </div>

          <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">
            From Scattered Expertise to a Launch-Ready Course System
          </h3>

          <div class="mb-6">
            <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-1">Client Type</p>
            <p class="text-slate-800 font-medium">Creator / Coach / Consultant</p>
          </div>

          <div class="space-y-6">
            <div>
              <h4 class="text-lg font-semibold text-slate-900 mb-2">The Challenge</h4>
              <p class="text-slate-600">
                The client has expertise, PDFs, notes, and videos, but no course structure, no learner journey, and no platform-ready assets.
              </p>
            </div>

            <div>
              <h4 class="text-lg font-semibold text-slate-900 mb-2">TheEduAssist Approach</h4>
              <ul class="list-disc pl-5 text-slate-600 space-y-1">
                <li>Audited existing content</li>
                <li>Created learner profile and course promise</li>
                <li>Built module and lesson map</li>
                <li>Converted raw content into lesson assets</li>
                <li>Planned worksheets, quizzes, and downloads</li>
                <li>Prepared Kajabi/LMS-ready structure</li>
                <li>Created launch checklist and onboarding flow</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="bg-slate-100 p-8 lg:p-12 border-t lg:border-t-0 lg:border-l border-slate-200 flex flex-col justify-between">
          <div>
            <h4 class="text-lg font-semibold text-slate-900 mb-4">Deliverables</h4>
            <div class="grid grid-cols-2 gap-3 mb-8">
              {[
                'Course blueprint',
                'Module map',
                'Lesson structure',
                'Worksheets',
                'Quizzes',
                'Student FAQ',
                'Platform-ready folder structure',
                'Launch checklist'
              ].map(item => (
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-[#77BA55] mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-sm text-slate-700">{item}</span>
                </div>
              ))}
            </div>

            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm mb-8">
              <h4 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-2">Outcome</h4>
              <p class="text-slate-800 font-medium">
                A clearer course system ready to build, launch, and improve.
              </p>
            </div>
          </div>

          <div>
            <a href="/services/" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-[#27496D] hover:bg-[#1A334D] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#27496D] transition-colors duration-200 w-full sm:w-auto">
              View Course Creation Services
            </a>
          </div>
        </div>

      </div>
    </div>
  </div> <!-- </ContentContainer> -->
</section> <!-- </SectionWrapper> -->
