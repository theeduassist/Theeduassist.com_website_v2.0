---



const beforePoints = [
  'Scattered content',
  'Unclear course structure',
  'No learner journey',
  'Disconnected pages',
  'Missing emails',
  'Manual access',
  'Confusing onboarding',
  'No QA checklist'
];

const afterPoints = [
  'Course map',
  'Modules and lessons',
  'Learner journey',
  'Platform-ready assets',
  'Connected funnel',
  'Automated onboarding',
  'Clear student instructions',
  'Launch checklist'
];
---

<!-- <SectionWrapper --> <section className="bg-slate-50 py-24 border-b border-slate-200">
  <!-- <ContentContainer> --> <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">The Before and After We Look For</h2>
      <p class="text-lg text-slate-600">
        We transform chaotic content and disconnected tools into structured, launch-ready learning experiences.
      </p>
    </div>

    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8 lg:gap-12 relative">
      <!-- VS Badge -->
      <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 bg-white rounded-full border border-slate-200 shadow-sm items-center justify-center z-10 font-bold text-slate-400">
        VS
      </div>

      <!-- Before -->
      <div class="bg-white rounded-2xl p-8 border border-red-100 shadow-sm">
        <div class="flex items-center mb-6 border-b border-slate-100 pb-4">
          <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center mr-4 text-red-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900">Before</h3>
        </div>

        <ul class="space-y-4">
          {beforePoints.map(point => (
            <li class="flex items-center text-slate-600">
              <svg class="w-5 h-5 text-red-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {point}
            </li>
          ))}
        </ul>
      </div>

      <!-- After -->
      <div class="bg-white rounded-2xl p-8 border border-[#77BA55]/30 shadow-md relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-[#F3FAF0] rounded-bl-full -z-10"></div>

        <div class="flex items-center mb-6 border-b border-slate-100 pb-4">
          <div class="w-10 h-10 rounded-full bg-[#F3FAF0] flex items-center justify-center mr-4 text-[#77BA55]">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900">After</h3>
        </div>

        <ul class="space-y-4">
          {afterPoints.map(point => (
            <li class="flex items-center text-slate-800 font-medium">
              <svg class="w-5 h-5 text-[#77BA55] mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {point}
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div> <!-- </ContentContainer> -->
</section> <!-- </SectionWrapper> -->
