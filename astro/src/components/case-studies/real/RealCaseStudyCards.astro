---
import { caseStudies } from "../../../data/caseStudies";
import Card from "../../ui/Card.astro";

interface Props {
  caseStudies?: any[];
}

const { caseStudies: sanityCaseStudies = [] } = Astro.props;

const staticStudies = caseStudies.filter(c => c.isRealProject);

const displays = sanityCaseStudies.length > 0
  ? sanityCaseStudies.map(s => ({
      title: s.title,
      summary: s.summary,
      slug: s.slug?.current || s.slug,
      clientType: s.clientType,
      industry: s.industry,
      challenge: s.challenge || [],
      deliverables: s.deliverables || [],
      services: s.services || [],
      isRealProject: true
    }))
  : staticStudies;
---

<section class="bg-white py-24 border-b border-slate-200" id="featured">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-slate-900">Featured Real Projects</h2>
      <p class="text-slate-600 mt-2 text-lg">See how we transform complex challenges into structured learning outcomes.</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      {displays.map((study) => (
        <Card className="flex flex-col h-full bg-white border border-slate-200 hover:shadow-lg transition-shadow duration-300">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold tracking-wide bg-[#F3FAF0] text-[#27496D] border border-[#77BA55]/30 uppercase mb-4">
              Real Project
            </span>
            <h3 class="text-xl font-bold text-slate-900 leading-tight mb-2">
              {study.title}
            </h3>
            <p class="text-sm text-slate-600 line-clamp-3">
              {study.summary}
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4 mb-6 text-sm">
             <div>
                <p class="font-semibold text-slate-500 uppercase tracking-wider text-[10px] mb-1">Client Type</p>
                <p class="text-slate-800 font-medium leading-snug">{study.clientType}</p>
             </div>
             <div>
                <p class="font-semibold text-slate-500 uppercase tracking-wider text-[10px] mb-1">Industry</p>
                <p class="text-slate-800 font-medium leading-snug">{study.industry}</p>
             </div>
          </div>

          <div class="mb-6 flex-grow">
            <p class="font-semibold text-slate-900 text-sm mb-2">Main Challenge:</p>
            <p class="text-sm text-slate-600 mb-4">{study.challenge[0]}</p>

            <p class="font-semibold text-slate-900 text-sm mb-2">Key Deliverables:</p>
            <ul class="space-y-1">
              {study.deliverables.slice(0, 3).map((item) => (
                <li class="flex items-start text-sm text-slate-600">
                  <svg class="w-4 h-4 text-[#77BA55] mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
              {study.deliverables.length > 3 && (
                 <li class="text-xs text-slate-400 italic pl-6">...and more</li>
              )}
            </ul>
          </div>

          <div class="pt-6 border-t border-slate-100 mt-auto">
             <div class="mb-4">
                <p class="text-xs text-slate-500 font-medium">
                  <span class="text-slate-400">Services:</span> {study.services.slice(0, 2).join(', ')}
                </p>
             </div>
             <a href={`/case-studies/${study.slug}/`} class="inline-flex items-center justify-center w-full px-4 py-2 border border-slate-300 text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#27496D] transition-colors duration-200 group">
                Read Case Study
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 text-slate-400 group-hover:text-slate-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                   <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
             </a>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>
