---
// src/components/lms/LMSSetupCapabilities.astro
import Card from "../ui/Card.astro";

const capabilities = [
  "Course categories",
  "Modules and lessons",
  "Resource libraries",
  "Video lessons",
  "Downloadable materials",
  "Quizzes and assessments",
  "Certificates if platform supports them",
  "Student onboarding",
  "User roles and access paths",
  "Progress tracking structure",
  "Internal training pathways",
  "Content update workflow",
  "Email or notification flow where supported",
  "Reporting-ready course structure"
];
---

<section class="py-24 bg-[#F8FAFC]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold mb-4 text-[#27496D]">What We Can Help Set Up Inside Your LMS</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-8">We configure the technical elements so you can focus on teaching.</p>

      <!-- Starting point pricing overlay -->
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm max-w-2xl mx-auto text-left flex flex-col md:flex-row gap-6 items-center">
         <div class="flex-grow">
            <h3 class="text-xl font-bold text-[#27496D] mb-1">LMS Setup & Migration</h3>
            <p class="text-2xl font-bold text-slate-800 mb-2">Starting from $700</p>
            <p class="text-sm text-slate-600"><span class="font-semibold text-slate-800">Best for:</span> Training companies, academies, internal training teams.</p>
            <p class="text-sm text-slate-600"><span class="font-semibold text-slate-800">Timeline:</span> 2-6 weeks depending on content.</p>
         </div>
         <div class="w-full md:w-auto flex flex-col gap-3 shrink-0">
            <a href="/book-free-audit/?package=lms-migration-map&source=package-card" data-package-slug="lms-migration-map" data-package-price="From $700" class="tawk-package-btn inline-flex justify-center items-center px-6 py-3 border border-transparent text-sm font-semibold rounded-lg text-white bg-[#27496D] hover:bg-opacity-90 transition-colors focus-ring">Start This Package</a>
            <p class="text-xs text-slate-500 text-center leading-tight max-w-[200px]">Talk to our team first so we can confirm the right package, scope, timeline, and payment next step.</p>
            <a href="/book-free-audit/?package=lms-migration-map&source=package-card" class="inline-flex justify-center items-center px-6 py-3 border border-slate-300 text-sm font-semibold rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors">Submit Project Details</a>
         </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {capabilities.map((cap) => (
        <Card class="flex items-start p-5 hover:border-[#77BA55]/50 transition-colors bg-white">
           <div class="flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#77BA55]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
           </div>
           <p class="ml-3 text-slate-700 font-medium text-sm leading-snug">{cap}</p>
        </Card>
      ))}
    </div>

    <!-- Case Studies Integration -->
    <div class="mb-12">
      <h3 class="text-xl font-bold text-center text-[#27496D] mb-6">See Real Results:</h3>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/case-studies/business-analytics-corporate-training/" class="inline-flex items-center px-4 py-2 bg-white border border-slate-200 rounded-full text-sm font-medium text-slate-700 hover:border-[#77BA55] hover:text-[#77BA55] transition-colors shadow-sm">
          Business Analytics for Corporate Teams
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>

    <div class="max-w-4xl mx-auto text-center text-sm text-slate-500 bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
      <span class="font-semibold text-slate-800">Pricing disclaimer:</span> Starting prices are not fixed final quotes. Final scope depends on content volume, platform, course length, page count, review rounds, automations, integrations, and launch support.
    </div>
  </div>

<script>
  import { openStartPackageChat } from '../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-package-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget;
        openStartPackageChat({
          packageSlug: target.dataset.packageSlug || '',
          packagePrice: target.dataset.packagePrice || '',
          pageUrl: window.location.href,
          pageTitle: document.title,
        });
      });
    });
  });
</script>
</section>