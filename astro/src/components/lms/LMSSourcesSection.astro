---
// src/components/lms/LMSSourcesSection.astro
import Card from "../ui/Card.astro";

const sources = [
  "WordPress course pages",
  "Google Drive folders",
  "PDFs and documents",
  "Slide decks",
  "Video libraries",
  "Old LMS platforms",
  "Email-based training",
  "Internal SOPs and training files",
  "Existing Kajabi content",
  "Membership or course websites"
];
---

<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row gap-12 items-center">

      <div class="lg:w-1/3">
        <h2 class="text-3xl font-bold mb-6 text-[#27496D]">We Help Move Content From Scattered Systems</h2>
        <p class="text-lg text-slate-600 mb-6">
          We help organize, map, rebuild, and migrate content depending on the platform and content format.
        </p>
        <div class="p-6 bg-[#F3FAF0] border border-[#77BA55]/20 rounded-xl">
          <p class="text-sm text-slate-700 font-medium">
            Not every migration is a 1-click import. We handle the manual organization, structuring, and mapping required to move raw files into a true learning experience.
          </p>
        </div>
      </div>

      <div class="lg:w-2/3 w-full">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {sources.map((source) => (
            <div class="flex items-center p-4 bg-slate-50 border border-slate-200 rounded-lg hover:border-[#77BA55] hover:bg-white transition-colors group">
              <div class="w-8 h-8 rounded-full bg-white border border-slate-200 flex items-center justify-center mr-4 group-hover:border-[#77BA55] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400 group-hover:text-[#77BA55]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-slate-700 font-medium">{source}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
