---
// src/components/lms/LMSFinalCTA.astro
---

<section class="py-24 bg-[#27496D] relative overflow-hidden">

  <div class="absolute inset-0 opacity-10">
    <div class="absolute w-96 h-96 bg-white rounded-full blur-3xl -top-20 -right-20"></div>
    <div class="absolute w-96 h-96 bg-[#77BA55] rounded-full blur-3xl -bottom-20 -left-20"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
      Ready to Clean Up or Migrate Your Learning System?
    </h2>
    <p class="text-xl text-blue-100 mb-10 leading-relaxed max-w-3xl mx-auto">
      Get a 24-48 hour review and we'll review your current content, platform, folders, course structure, and learner journey to show what needs to be organized, rebuilt, migrated, or improved.
    </p>

    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/book-free-audit/?service=lms-implementation-migration&source=service-page" target="_blank" rel="noopener noreferrer" aria-label="Get a 24-48 hour review on Calendly" class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-lg font-semibold rounded-lg text-white bg-[#77BA55] hover:bg-[#65a347] transition-colors shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[#77BA55] focus-visible:ring-offset-[#27496D]">
        Get Your Course Reviewed in 24–48 Hours
      </a>
      <button
        type="button"
        data-service-slug="lms-implementation-migration"
        class="tawk-service-btn inline-flex justify-center items-center px-8 py-4 border border-blue-200 text-lg font-semibold rounded-lg text-white hover:bg-white/10 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-white focus-visible:ring-offset-[#27496D] focus-ring"
      >
        Start This Service
      </button>
    </div>
  </div>

<script>
  import { openStartServiceChat } from '../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-service-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget;
        openStartServiceChat({
          serviceSlug: target.dataset.serviceSlug || '',
          pageUrl: window.location.href,
          pageTitle: document.title,
        });
      });
    });
  });
</script>
</section>
