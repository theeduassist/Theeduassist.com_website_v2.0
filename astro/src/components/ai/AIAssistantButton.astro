---
import type { AIAssistant } from '../../data/aiAssistants';

interface Props {
    assistant: AIAssistant;
    variant?: 'badge' | 'button' | 'icon';
    class?: string;
}

const { assistant, variant = 'button', class: className = '' } = Astro.props;

const baseClasses = "inline-flex items-center justify-center transition-all focus-ring focus:outline-none";

const variants = {
    badge: "px-3 py-1.5 bg-slate-100 hover:bg-white text-slate-700 hover:text-brand-primary text-xs font-medium rounded-full border border-slate-200 hover:border-brand-accent/30 shadow-sm whitespace-nowrap",
    button: "w-full px-4 py-2 bg-slate-50 hover:bg-brand-softBg text-slate-700 hover:text-brand-primary text-sm font-medium rounded-md border border-slate-200 hover:border-brand-primary/30 text-left justify-start",
    icon: "p-2 bg-white hover:bg-slate-50 text-slate-600 rounded-md border border-slate-200 hover:border-slate-300"
};

const classes = `${baseClasses} ${variants[variant]} ${className}`;
---

<button
    type="button"
    class={`ai-assistant-btn ${classes}`}
    data-ai-id={assistant.id}
    data-ai-url={assistant.baseUrl}
    data-ai-name={assistant.name}
    aria-label={`Open ${assistant.name}`}
>
    {variant === 'badge' && (
        <span class="w-2 h-2 rounded-full bg-brand-primary/40 mr-2 group-hover:bg-brand-accent transition-colors"></span>
    )}
    <span>{variant === 'badge' ? assistant.shortLabel : assistant.name}</span>
</button>
