---
export interface Props {
  name: string;
  label: string;
  type?: 'text' | 'email' | 'url' | 'tel';
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
}

const {
  name,
  label,
  type = 'text',
  placeholder = '',
  required = false,
  disabled = false
} = Astro.props;
---

<div>
  <label for={name} class="block text-sm font-medium text-slate-700 mb-1">
    {label} {required && <span class="text-red-500">*</span>}
  </label>
  <input
    type={type}
    id={name}
    name={name}
    class="w-full border border-slate-300 rounded-md p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-slate-50 disabled:text-slate-500"
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    maxlength="255"
  />
</div>
