---
const mainLinks = [
    { label: 'Home', href: '/' },
    { label: 'Platforms', href: '/platforms/' },
    { label: 'Pricing', href: '/services/' },
    { label: 'Case Studies', href: '/case-studies/' },
    { label: 'Blog', href: '/blog/' },
];

const aboutLinks = [
    { label: 'About TheEduAssist', href: '/about/' },
    { label: 'Contact', href: '/contact/' },
];

const serviceLinks = [
    { label: 'All Services', href: '/services/' },
    { label: 'Course Creation & Curriculum Design', href: '/services/custom-elearning-development/' },
    { label: 'Kajabi Website & Course Setup', href: '/kajabi-services/' },
    { label: 'LMS Implementation & Migration', href: '/services/lms-implementation-migration/' },
    { label: 'AI-Powered E-Learning Support', href: '/services/ai-powered-elearning/' },
    { label: 'Content Conversion', href: '/services/content-conversion/' },
    { label: 'Funnels & Automation', href: '/services/funnels-automation/' },
    { label: 'Ongoing Support & Maintenance', href: '/services/ongoing-support-maintenance/' },
];
---

<mobile-menu class="relative block">
  <button
    id="mobile-menu-btn"
    type="button"
    class="inline-flex items-center justify-center p-2 rounded-md text-brand-primary hover:text-brand-navy hover:bg-brand-softBg focus:outline-none transition-colors focus-ring"
    aria-controls="mobile-menu-panel"
    aria-expanded="false"
  >
    <span class="sr-only">Open main menu</span>
    <span class="mr-2 font-medium">Menu</span>
    <!-- Icon when menu is closed. -->
    <svg id="icon-closed" class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
    <!-- Icon when menu is open. -->
    <svg id="icon-open" class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu-panel"
    class="hidden absolute top-full right-0 mt-2 w-72 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 overflow-y-auto max-h-[80vh] z-50 origin-top-right transition-opacity duration-200"
  >
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      {mainLinks.slice(0, 1).map((link) => (
        <a href={link.href} class="block px-3 py-2 rounded-md text-base font-medium text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 focus-ring mobile-link">
          {link.label}
        </a>
      ))}

      <!-- Services Expandable -->
      <div class="mobile-services-group border-y border-brand-border/30 my-1 py-1">
        <button id="mobile-services-btn" class="w-full flex justify-between items-center px-3 py-2 rounded-md text-base font-medium text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 focus-ring" aria-expanded="false">
          Services
          <svg id="mobile-services-icon" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div id="mobile-services-list" class="hidden pl-4 pr-2 py-1 space-y-1 bg-brand-softBg/50 rounded-b-md">
          {serviceLinks.map((link, index) => (
            <a href={link.href} class={`block px-3 py-2 rounded-md text-sm font-medium text-brand-textMuted hover:text-brand-primary hover:bg-brand-accent/10 focus-ring mobile-link ${index === 0 ? 'font-bold text-brand-textMain mb-1' : ''}`}>
              {link.label}
            </a>
          ))}
        </div>
      </div>

      {mainLinks.slice(1).map((link) => (
        <a href={link.href} class="block px-3 py-2 rounded-md text-base font-medium text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 focus-ring mobile-link">
          {link.label}
        </a>
      ))}

      <!-- About Expandable -->
      <div class="mobile-services-group border-y border-brand-border/30 my-1 py-1">
        <button id="mobile-about-btn" class="w-full flex justify-between items-center px-3 py-2 rounded-md text-base font-medium text-brand-textMain hover:text-brand-accent hover:bg-brand-accent/10 focus-ring" aria-expanded="false">
          About
          <svg id="mobile-about-icon" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div id="mobile-about-list" class="hidden pl-4 pr-2 py-1 space-y-1 bg-brand-softBg/50 rounded-b-md">
          {aboutLinks.map((link) => (
            <a href={link.href} class="block px-3 py-2 rounded-md text-sm font-medium text-brand-textMuted hover:text-brand-primary hover:bg-brand-accent/10 focus-ring mobile-link">
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <a href="/book-free-audit/" class="block px-3 py-2 mt-2 rounded-md text-base font-bold text-white bg-brand-accent hover:bg-brand-primary focus-ring mobile-link text-center">
        Get 24–48 Hour Review
      </a>
    </div>
  </div>
</mobile-menu>

<script>
  class MobileMenu extends HTMLElement {
    constructor() {
      super();
      this.btn = this.querySelector('#mobile-menu-btn');
      this.panel = this.querySelector('#mobile-menu-panel');
      this.servicesBtn = this.querySelector('#mobile-services-btn');
      this.servicesList = this.querySelector('#mobile-services-list');
      this.servicesIcon = this.querySelector('#mobile-services-icon');

      this.aboutBtn = this.querySelector('#mobile-about-btn');
      this.aboutList = this.querySelector('#mobile-about-list');
      this.aboutIcon = this.querySelector('#mobile-about-icon');

      this.iconClosed = this.querySelector('#icon-closed');
      this.iconOpen = this.querySelector('#icon-open');
      this.links = this.querySelectorAll('.mobile-link');
      this.isOpen = false;

      this.toggleMenu = this.toggleMenu.bind(this);
      this.closeMenu = this.closeMenu.bind(this);
      this.handleEscape = this.handleEscape.bind(this);

      this.btn?.addEventListener('click', this.toggleMenu);
      this.servicesBtn?.addEventListener('click', this.toggleServices.bind(this));
      this.aboutBtn?.addEventListener('click', this.toggleAbout.bind(this));
      window.addEventListener('keydown', this.handleEscape);
      this.links.forEach(link => link.addEventListener('click', this.closeMenu));
    }

    toggleServices(e: Event) {
      e.stopPropagation();
      const isExpanded = this.servicesBtn?.getAttribute('aria-expanded') === 'true';
      this.servicesBtn?.setAttribute('aria-expanded', (!isExpanded).toString());
      if (isExpanded) {
        this.servicesList?.classList.add('hidden');
        this.servicesIcon?.classList.remove('rotate-180');
      } else {
        this.servicesList?.classList.remove('hidden');
        this.servicesIcon?.classList.add('rotate-180');
      }
    }

    toggleAbout(e: Event) {
      e.stopPropagation();
      const isExpanded = this.aboutBtn?.getAttribute('aria-expanded') === 'true';
      this.aboutBtn?.setAttribute('aria-expanded', (!isExpanded).toString());
      if (isExpanded) {
        this.aboutList?.classList.add('hidden');
        this.aboutIcon?.classList.remove('rotate-180');
      } else {
        this.aboutList?.classList.remove('hidden');
        this.aboutIcon?.classList.add('rotate-180');
      }
    }

    toggleMenu() {
      this.isOpen = !this.isOpen;
      this.btn?.setAttribute('aria-expanded', this.isOpen.toString());
      if (this.isOpen) {
        this.panel?.classList.remove('hidden');
        this.iconClosed?.classList.add('hidden');
        this.iconClosed?.classList.remove('block');
        this.iconOpen?.classList.remove('hidden');
        this.iconOpen?.classList.add('block');
      } else {
        this.panel?.classList.add('hidden');
        this.iconClosed?.classList.remove('hidden');
        this.iconClosed?.classList.add('block');
        this.iconOpen?.classList.add('hidden');
        this.iconOpen?.classList.remove('block');
      }
    }

    closeMenu() {
      if (this.isOpen) {
        this.toggleMenu();
      }
    }

    handleEscape(e: KeyboardEvent) {
      if (e.key === 'Escape' && this.isOpen) {
        this.closeMenu();
        if (this.btn instanceof HTMLElement) {
          this.btn.focus();
        }
      }
    }
  }

  customElements.define('mobile-menu', MobileMenu);
</script>
