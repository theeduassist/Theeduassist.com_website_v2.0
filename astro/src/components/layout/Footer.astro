            <div class="relative z-10 text-center md:text-left">
                <h3 class="text-2xl md:text-3xl font-bold text-white mb-2">Ready to build a better learning experience?</h3>
                <p class="text-slate-300">Get a 24-48 hour review to review your current content or Kajabi setup.</p>
            </div>
            <a href="/book-free-audit/" class="relative z-10 shrink-0 bg-brand-accent text-white px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white hover:text-brand-navy shadow-lg text-center">
                Get 24–48 Hour Review
            </a>
        </div>
    </div>

    <!-- Logo & Description Row -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
            <a href="/" class="inline-block focus-ring rounded-sm mb-4">
                <img src="/brand/theeduassist-logo.svg" alt="TheEduAssist e-learning design agency logo" class="h-10 w-auto object-contain brightness-0 invert" />
            </a>
            <p class="text-slate-400 text-sm max-w-md leading-relaxed">
                TheEduAssist is a multi-platform e-learning design and course-building agency helping experts and businesses build structured, launch-ready learning systems.
            </p>
        </div>
    </div>

    <!-- 4-Column Navigation -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-2 md:grid-cols-4 gap-8 mb-16">
        <div>
            <h4 class="text-white font-bold mb-6 tracking-wider uppercase text-sm">Services</h4>
            <ul class="space-y-3 text-sm">
                {navigation.services.map((item) => (
                    <li><a href={item.href} class="text-slate-400 hover:text-brand-accent transition-colors focus-ring inline-block">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div>
            <h4 class="text-white font-bold mb-6 tracking-wider uppercase text-sm">Solutions</h4>
            <ul class="space-y-3 text-sm">
