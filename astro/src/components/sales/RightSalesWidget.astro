---
// src/components/sales/RightSalesWidget.astro
---

<div id="right-sales-widget" class="fixed right-0 top-1/2 -translate-y-1/2 z-50 transform translate-x-full transition-transform duration-300 md:translate-x-0 hidden sm:block">
  <button
    type="button"
    id="tawk-right-sales-btn"
    class="bg-brand-navy hover:bg-brand-accent text-white py-3 px-2 rounded-l-md shadow-lg shadow-brand-navy/20 border-y border-l border-brand-navy/50 flex flex-col items-center justify-center space-y-2 group transition-colors focus-ring"
    aria-label="Talk to Sales"
  >
    <div class="rotate-180" style="writing-mode: vertical-rl;">
      <span class="text-sm font-bold uppercase tracking-wider whitespace-nowrap">Talk to Sales</span>
    </div>
    <div class="bg-brand-accent/20 p-1.5 rounded-full mt-2 group-hover:bg-white/20 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
      </svg>
    </div>
  </button>

  <div class="absolute right-full top-1/2 -translate-y-1/2 mr-2 w-max max-w-[200px] bg-white text-slate-700 text-xs py-2 px-3 rounded shadow-lg border border-slate-200 opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity whitespace-normal text-center hidden md:block">
    Need help choosing a package?
  </div>
</div>

<script>
  import { openGeneralSalesChat } from '../../utils/tawkSales';

  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('tawk-right-sales-btn');
    if (btn) {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openGeneralSalesChat({
          intent: 'sales_payment_guidance',
          sourceCta: 'right-floating-talk-to-sales'
        });
      });
    }
  });
</script>
