---
// src/components/course-creation/CourseAudienceSection.astro
const audiences = [
  {
    title: "Creators and Coaches",
    situation: "Have expertise, coaching frameworks, or personal methods.",
    need: "Need to turn them into a structured course or membership.",
    outcome: "A scalable, structured learning program.",
    icon: "M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"
  },
  {
    title: "Consultants",
    situation: "Have workshops, client frameworks, or professional knowledge.",
    need: "Need to convert them into repeatable learning programs.",
    outcome: "Repeatable assets that save time and scale impact.",
    icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
  },
  {
    title: "Educators",
    situation: "Have teaching content and academic material.",
    need: "Need to organize it into modules, lessons, activities, and assessments.",
    outcome: "An engaging online delivery format.",
    icon: "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
  },
  {
    title: "Training Companies",
    situation: "Have manuals, training decks, videos, or instructor-led material.",
    need: "Need scalable digital programs built from existing assets.",
    outcome: "A standardized digital training catalog.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
  },
  {
    title: "Online Academies",
    situation: "Have multiple courses or ongoing content needs.",
    need: "Need consistent course structure, learner pathways, and repeatable curriculum systems.",
    outcome: "A cohesive, professional academy experience.",
    icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
  },
  {
    title: "Businesses and Internal Teams",
    situation: "Have onboarding documents, SOPs, or department knowledge.",
    need: "Need them organized into structured employee learning journeys.",
    outcome: "Efficient, trackable internal training.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
  }
];
---
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">
        Who Needs Course Creation and Curriculum Design?
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {audiences.map((audience) => (
        <div class="bg-brand-softBg p-8 rounded-2xl border border-brand-border/60 shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col h-full group">
          <div class="flex items-center space-x-4 mb-6">
             <div class="bg-white p-3 rounded-xl border border-brand-border/50 shadow-sm text-brand-primary group-hover:text-brand-accent transition-colors duration-300">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={audience.icon}></path></svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy">{audience.title}</h3>
          </div>

          <div class="space-y-4 flex-grow">
            <div>
              <span class="text-xs font-bold uppercase tracking-wider text-brand-textMuted mb-1 block">Current Situation</span>
              <p class="text-sm text-brand-textMain">{audience.situation}</p>
            </div>
            <div>
              <span class="text-xs font-bold uppercase tracking-wider text-brand-textMuted mb-1 block">Course Design Need</span>
              <p class="text-sm text-brand-textMain">{audience.need}</p>
            </div>
          </div>

          <div class="mt-6 pt-4 border-t border-brand-border/60">
             <span class="text-xs font-bold uppercase tracking-wider text-brand-accent mb-1 block">Desired Outcome</span>
             <p class="text-sm font-medium text-brand-navy">{audience.outcome}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
