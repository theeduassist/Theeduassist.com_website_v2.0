const alignmentSteps = [
    { label: "Learner Goal", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
    { label: "Learning Outcome", icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" },
    { label: "Lesson Content", icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
    { label: "Practice Activity", icon: "M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" },
    { label: "Assessment", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" },
    { label: "Resource", icon: "M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" },
    { label: "Completion Point", icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" }
];
---
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
          Curriculum Design That Helps Learners Progress
        </h2>
        <p class="text-lg text-brand-textMuted leading-relaxed mb-6">
          A strong curriculum is not just a list of topics. It connects learning outcomes, lesson order, activities, assessments, resources, and platform flow so students can move from starting point to result.
        </p>
        <p class="text-lg text-brand-textMuted leading-relaxed mb-8">
          TheEduAssist designs course structure around what learners need to understand, practice, and complete, not just what the expert wants to say.
        </p>
        <div class="bg-brand-softBlue p-6 rounded-xl border border-blue-100">
             <h4 class="font-bold text-brand-navy mb-2 flex items-center">
                 <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                 Action-Based Outcomes
             </h4>
             <p class="text-sm text-brand-navy/80">
                 We use measurable, action-based outcomes where appropriate so learners know exactly what they should be able to do after each module or lesson.
             </p>
        </div>
      </div>

      <div class="bg-brand-softBg p-8 rounded-3xl border border-brand-border/60 shadow-lg">
          <h3 class="text-xl font-bold text-brand-navy mb-8 text-center">Alignment Model</h3>
          <div class="space-y-4 relative">
              <!-- Connecting Line -->
              <div class="absolute left-6 top-6 bottom-6 w-0.5 bg-brand-border z-0"></div>

              {alignmentSteps.map((step, index) => (
                  <div class="flex items-center space-x-4 relative z-10 group">
                      <div class={`w-12 h-12 rounded-full flex items-center justify-center shrink-0 border-2 transition-colors duration-300 ${index === 0 || index === alignmentSteps.length - 1 ? 'bg-brand-primary border-brand-primary text-white' : 'bg-white border-brand-accent/30 text-brand-accent group-hover:bg-brand-accent group-hover:text-white'}`}>
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.icon}></path></svg>
                      </div>
                      <div class="bg-white px-4 py-3 rounded-lg border border-brand-border shadow-sm flex-grow font-medium text-brand-navy flex items-center justify-between">
                          <span>{step.label}</span>
                          {index < alignmentSteps.length - 1 && (
                              <svg class="w-4 h-4 text-brand-border" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                          )}
                      </div>
                  </div>
              ))}
          </div>
      </div>

    </div>
  </div>
</section>
