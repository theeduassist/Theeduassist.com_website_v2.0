---
// src/components/course-creation/ContentConversionSection.astro
const inputs = [
  "PDFs",
  "Slide decks",
  "Videos",
  "Webinar recordings",
  "Workshop notes",
  "Training manuals",
  "SOPs",
  "Google Drive folders",
  "Blog posts",
  "Coaching frameworks"
];

const outputs = [
  "Course map",
  "Modules",
  "Lessons",
  "Lesson summaries",
  "Scripts",
  "Worksheets",
  "Quizzes",
  "Resource list",
  "Platform-ready structure"
];
---
<section class="py-20 bg-brand-softBg relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">
        Turn Existing Material Into Course-Ready Lessons
      </h2>
      <p class="text-lg text-brand-textMuted leading-relaxed">
        Already have content? TheEduAssist can help convert it into a course structure instead of starting from scratch.
      </p>
    </div>

    <div class="flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-16">

      <!-- Input Column -->
      <div class="w-full lg:w-5/12 bg-white p-8 rounded-2xl border border-brand-border shadow-sm">
        <h3 class="text-xl font-bold text-brand-textMuted mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"></path></svg>
          Raw Input
        </h3>
        <div class="flex flex-wrap gap-2">
          {inputs.map((item) => (
            <span class="bg-brand-softBg text-brand-textMain text-sm font-medium px-3 py-1.5 rounded-full border border-brand-border/60">
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- Arrow -->
      <div class="hidden lg:flex flex-col items-center justify-center w-2/12 relative">
          <div class="absolute w-full h-0.5 bg-gradient-to-r from-brand-border via-brand-accent to-brand-primary z-0"></div>
          <div class="bg-brand-accent p-3 rounded-full text-white shadow-lg relative z-10 animate-pulse-slow">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </div>
      </div>

      <div class="flex lg:hidden justify-center my-4">
          <div class="bg-brand-accent p-3 rounded-full text-white shadow-md">
              <svg class="w-6 h-6 transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </div>
      </div>

      <!-- Output Column -->
      <div class="w-full lg:w-5/12 bg-brand-navy p-8 rounded-2xl border border-brand-navy shadow-lg text-white">
         <h3 class="text-xl font-bold text-white mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Structured Output
        </h3>
        <div class="flex flex-wrap gap-2">
          {outputs.map((item) => (
            <span class="bg-white/10 text-white text-sm font-medium px-3 py-1.5 rounded-full border border-white/20">
              {item}
            </span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
