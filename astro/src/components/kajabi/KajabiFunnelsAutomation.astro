---
// src/components/kajabi/KajabiFunnelsAutomation.astro
---
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div>
        <h2 class="text-3xl font-bold text-slate-900 mb-6">Kajabi Funnels That Connect Marketing, Sales, and Learning</h2>
        <p class="text-lg text-slate-600 mb-8">
          TheEduAssist can connect your entire journey to support conversions and make the experience clearer for your audience.
        </p>

        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          {
            ['Lead magnet pages', 'Opt-in forms', 'Email sequences', 'Sales pages', 'Checkout offers', 'Purchase automations', 'Course access', 'Student onboarding', 'Follow-up emails'].map((item) => (
              <li class="flex items-center text-slate-700">
                <svg class="w-5 h-5 text-[#77BA55] mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm font-medium">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Funnel Visual -->
      <div class="bg-slate-50 p-8 rounded-2xl border border-slate-200">
        <div class="flex flex-col space-y-3">
          {
            [
              { label: 'Visitor', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z', color: 'bg-slate-200 text-slate-600' },
              { label: 'Lead', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', color: 'bg-blue-100 text-blue-700' },
              { label: 'Email Nurture', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', color: 'bg-blue-100 text-blue-700' },
              { label: 'Offer', icon: 'M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7', color: 'bg-indigo-100 text-indigo-700' },
              { label: 'Checkout', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', color: 'bg-indigo-100 text-indigo-700' },
              { label: 'Course Access', icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', color: 'bg-green-100 text-green-700' },
              { label: 'Student Onboarding', icon: 'M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.514', color: 'bg-green-100 text-green-700' }
            ].map((step, index, array) => (
              <div class="flex flex-col items-center">
                <div class="w-full flex items-center justify-between bg-white p-3 rounded-lg shadow-sm border border-slate-100">
                  <span class="text-sm font-bold text-slate-800">{step.label}</span>
                  <div class={`w-8 h-8 rounded flex items-center justify-center ${step.color}`}>
                     <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.icon} />
                      </svg>
                  </div>
                </div>
                {index < array.length - 1 && (
                  <svg class="w-5 h-5 text-slate-300 my-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                  </svg>
                )}
              </div>
            ))
          }
        </div>
      </div>

    </div>
  </div>
</section>
