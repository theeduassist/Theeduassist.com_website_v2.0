---
---
<section class="py-20 bg-white border-t border-slate-100">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-[#27496D] mb-6">Simple Automation Logic That Reduces Manual Work</h2>
      <p class="text-lg text-slate-600">
        TheEduAssist helps plan automation logic around triggers, conditions, actions, and student stages. We map out the rules before building so the system works reliably.
      </p>
    </div>

    <!-- Logic Model Visual -->
    <div class="bg-slate-50 rounded-3xl p-8 md:p-12 border border-slate-100 mb-16 relative overflow-hidden">
      <!-- Decorative background -->
      <div class="absolute inset-0 bg-grid-slate-100/[0.5] [mask-image:linear-gradient(0deg,white,rgba(255,255,255,0.6))] -z-10"></div>

      <div class="flex flex-col md:flex-row items-stretch justify-center gap-6">

        {/* WHEN (Trigger) */}
        <div class="flex-1 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative z-10">
          <div class="text-xs font-bold tracking-wider text-slate-400 uppercase mb-2">Trigger</div>
          <h3 class="text-xl font-bold text-[#27496D] mb-3">When...</h3>
          <p class="text-sm text-slate-600">A visitor opts in, buys, clicks, joins, completes a lesson, or submits a form.</p>
        </div>

        {/* Arrow/Connector */}
        <div class="hidden md:flex items-center justify-center -mx-3 z-20">
          <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center border-4 border-slate-50 text-slate-400">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </div>

        {/* BUT ONLY IF (Condition) */}
        <div class="flex-1 bg-white p-6 rounded-2xl border border-amber-100 shadow-sm relative z-10 shadow-amber-500/5">
          <div class="text-xs font-bold tracking-wider text-amber-500 uppercase mb-2">Condition</div>
          <h3 class="text-xl font-bold text-amber-700 mb-3">But only if...</h3>
          <p class="text-sm text-slate-600">The contact matches the right offer, stage, tag, audience, or course path.</p>
        </div>

         {/* Arrow/Connector */}
         <div class="hidden md:flex items-center justify-center -mx-3 z-20">
          <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center border-4 border-slate-50 text-slate-400">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </div>

        {/* THEN (Action) */}
        <div class="flex-1 bg-[#F3FAF0] p-6 rounded-2xl border border-[#77BA55]/20 shadow-sm relative z-10">
          <div class="text-xs font-bold tracking-wider text-[#77BA55] uppercase mb-2">Action</div>
          <h3 class="text-xl font-bold text-[#27496D] mb-3">Then...</h3>
          <p class="text-sm text-slate-700">Send email, apply tag, grant access, send instructions, or notify team.</p>
        </div>

      </div>
    </div>

    <!-- Examples List -->
    <div class="max-w-3xl mx-auto">
      <h3 class="text-lg font-bold text-[#27496D] mb-6 text-center">Common Automation Examples</h3>
      <div class="space-y-4">
        {[
          { text: 'When someone downloads a lead magnet, send the welcome sequence.' },
          { text: 'When someone buys a course, grant access and send onboarding.' },
          { text: 'When someone joins a waitlist, tag them and send launch updates.' },
          { text: 'When a student starts the course, send first-week support content.' }
        ].map((example, i) => (
          <div class="flex items-start gap-4 p-4 rounded-xl bg-white border border-slate-100 hover:border-slate-200 transition-colors shadow-sm">
            <div class="w-6 h-6 rounded-full bg-slate-50 border border-slate-200 flex items-center justify-center shrink-0 mt-0.5">
              <span class="text-xs font-bold text-slate-500">{i + 1}</span>
            </div>
            <p class="text-slate-700 text-sm md:text-base">{example.text}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
