---
---
<section class="py-20 bg-slate-50 border-y border-slate-100">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-slate-100 relative overflow-hidden">
       {/* Background Decoration */}
      <div class="absolute top-0 right-0 w-64 h-64 bg-slate-50 rounded-bl-full -z-10 border-l border-b border-slate-100"></div>

      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-[#27496D] mb-4">Already Have a Funnel? We Can Audit and Improve It</h2>
        <p class="text-lg text-slate-600">
          Find friction points, fix broken automations, and connect the missing pieces.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-4 gap-x-8 mb-12">
        {[
          'Page message clarity',
          'CTA placement',
          'Lead magnet flow',
          'Email sequence gaps',
          'Checkout friction',
          'Offer clarity',
          'Automation logic',
          'Tagging and segmentation',
          'Student onboarding',
          'Broken links',
          'Mobile experience',
          'Funnel QA checklist'
        ].map(item => (
          <div class="flex items-center gap-3 py-2 border-b border-slate-50 last:border-0 md:last:border-b md:[&:nth-last-child(-n+3)]:border-0">
            <svg class="w-5 h-5 text-[#77BA55] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-slate-700 text-sm font-medium">{item}</span>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a href="/book-free-audit/" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-[#77BA55] rounded-xl hover:bg-[#65A344] transition-all duration-200 shadow-sm hover:shadow-md w-full sm:w-auto">
          Get 24-48 Hour Review
        </a>
      </div>
    </div>
  </div>
</section>
