---
---
<section class="py-24 bg-[#27496D] relative overflow-hidden">
  <!-- Abstract Decorative Elements -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-white opacity-5 rounded-full blur-[120px] transform translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-[#77BA55] opacity-10 rounded-full blur-[100px] transform -translate-x-1/3 translate-y-1/3"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight tracking-tight">
        Ready to Connect Your Course, Funnel, Emails, and Student Journey?
      </h2>
      <p class="text-lg md:text-xl text-blue-100 mb-10 max-w-3xl mx-auto leading-relaxed">
        Get a 24-48 hour review and we’ll review your current course offer, landing pages, emails, checkout, automations, and onboarding flow to show what needs to be connected, fixed, or improved.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/book-free-audit/?service=funnels-automation&source=service-page" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-[#27496D] bg-white rounded-xl hover:bg-slate-50 transition-all duration-200 shadow-lg hover:shadow-xl w-full sm:w-auto border border-transparent">
          Get Your Course Reviewed in 24–48 Hours
        </a>
        <button
          type="button"
          data-service-slug="funnels-automation"
          class="tawk-service-btn inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-transparent border border-white/30 rounded-xl hover:bg-white/10 hover:border-white/50 transition-all duration-200 w-full sm:w-auto focus-ring"
        >
          Start This Service
        </button>
      </div>
    </div>
  </div>

<script>
  import { openStartServiceChat } from '../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-service-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget;
        openStartServiceChat({
          serviceSlug: target.dataset.serviceSlug || '',
          pageUrl: window.location.href,
          pageTitle: document.title,
        });
      });
    });
  });
</script>
</section>
