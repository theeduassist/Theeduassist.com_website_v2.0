---
// src/components/ai-elearning/WhyNotDIYAI.astro
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';
---

<section class="py-24 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader
      title="Why Not Just Ask AI Yourself?"
      description="You can use ChatGPT, Claude, Gemini, or other AI tools for ideas and drafts. But most creators and organizations do not need more random output. They need a structured course production workflow."
    />

    <div class="grid md:grid-cols-2 gap-8 mt-12 max-w-5xl mx-auto">

      <!-- DIY Card -->
      <Card className="border-t-4 border-t-slate-400 opacity-90">
        <div class="flex items-center space-x-3 mb-6">
            <div class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center text-slate-500">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-700">DIY AI Output</h3>
        </div>
        <ul class="space-y-4">
            {[
                "Generic outline",
                "Too many ideas",
                "No learning sequence",
                "No platform structure",
                "No quality review",
                "No launch workflow"
            ].map(item => (
                <li class="flex items-start">
                    <svg class="w-5 h-5 text-slate-400 mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    <span class="text-slate-600 font-medium">{item}</span>
                </li>
            ))}
        </ul>
      </Card>

      <!-- TheEduAssist Card -->
      <Card className="border-t-4 border-t-brand-navy shadow-lg relative transform md:-translate-y-2">
        <div class="absolute -top-4 -right-4 bg-brand-accent text-white text-xs font-bold px-3 py-1 rounded-full shadow-sm">
            Structured Workflow
        </div>
        <div class="flex items-center space-x-3 mb-6">
            <div class="w-12 h-12 bg-brand-softBlue rounded-full flex items-center justify-center text-brand-navy">
                <img src="/brand/theeduassist-logo-mark.svg" alt="" class="w-6 h-6 brightness-0" />
            </div>
            <h3 class="text-2xl font-bold text-brand-navy">TheEduAssist AI-Powered Support</h3>
        </div>
        <ul class="space-y-4">
            {[
                "Course strategy",
                "Curriculum structure",
                "Learner journey",
                "Human review",
                "Kajabi/LMS-ready assets",
                "Launch support"
            ].map(item => (
                <li class="flex items-start">
                    <svg class="w-5 h-5 text-brand-accent mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                    <span class="text-brand-navy font-bold">{item}</span>
                </li>
            ))}
        </ul>
      </Card>

    </div>

    <div class="mt-16 text-center max-w-3xl mx-auto">
        <p class="text-lg text-brand-textMain font-medium p-6 bg-white rounded-xl shadow-sm border border-brand-border/50">
            <span class="text-brand-navy font-bold">Key message:</span> Use AI yourself if you only need ideas. Work with TheEduAssist if you need a structured, branded, learner-friendly, platform-ready course system.
        </p>
    </div>
  </div>
</section>
