---
// src/components/ai-elearning/AIPackageChooser.astro
import SectionHeader from '../ui/SectionHeader.astro';
---

<section class="py-20 bg-white border-t border-brand-border/40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader title="How to Choose the Right AI Support Package" />

    <div class="grid md:grid-cols-2 gap-6 mt-12 max-w-5xl mx-auto">

      <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/60 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-navy mb-2 flex items-center">
            <svg class="w-5 h-5 text-brand-accent mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            Choose AI Course Clarity Sprint if:
        </h3>
        <p class="text-brand-textMain">You have an idea but need direction, structure, and a course map.</p>
      </div>

      <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/60 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-navy mb-2 flex items-center">
            <svg class="w-5 h-5 text-brand-accent mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
            Choose AI Content Conversion Kit if:
        </h3>
        <p class="text-brand-textMain">You already have content but need it turned into lessons, scripts, worksheets, and quizzes.</p>
      </div>

      <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/60 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-navy mb-2 flex items-center">
            <svg class="w-5 h-5 text-brand-accent mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            Choose AI Course Production Sprint if:
        </h3>
        <p class="text-brand-textMain">You want a complete course asset plan before building in Kajabi or an LMS.</p>
      </div>

      <div class="bg-brand-softBg p-6 rounded-xl border border-brand-border/60 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-navy mb-2 flex items-center">
            <svg class="w-5 h-5 text-brand-accent mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
            Choose AI + Kajabi/LMS Launch Build if:
        </h3>
        <p class="text-brand-textMain">You want support from content production through platform setup, launch assets, and student onboarding.</p>
      </div>

    </div>
  </div>
</section>
