---
// src/components/ai-elearning/AICaseExample.astro
import SectionHeader from '../ui/SectionHeader.astro';
---

<section class="py-24 bg-brand-navy text-white relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 -mt-20 -mr-20 w-80 h-80 bg-white opacity-5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-80 h-80 bg-brand-accent opacity-10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <SectionHeader
      title="Example: Turning Scattered Training Content Into a Course System"
      centered={false}
      className="mb-16"
      titleClassName="text-white"
    />

    <div class="grid lg:grid-cols-3 gap-12 items-start">

      <!-- Scenario -->
      <div class="lg:col-span-1 bg-white/5 border border-white/10 p-8 rounded-2xl backdrop-blur-sm">
        <h3 class="text-xl font-bold text-white mb-6 flex items-center">
            <svg class="w-6 h-6 mr-3 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            The Scenario
        </h3>
        <p class="text-slate-300 mb-6">A training company has a wealth of knowledge, but it's scattered:</p>
        <ul class="space-y-3">
            {[
                "8 PDF manuals",
                "12 recorded Zoom trainings",
                "3 PowerPoint decks",
                "Scattered Google Drive folders",
                "No LMS course structure",
                "No quizzes",
                "No onboarding emails"
            ].map(item => (
                <li class="flex items-start text-slate-300">
                    <svg class="w-5 h-5 text-white/50 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    <span>{item}</span>
                </li>
            ))}
        </ul>
      </div>

      <!-- The Workflow Steps -->
      <div class="lg:col-span-2 relative">
         <!-- Connecting Line for Desktop -->
         <div class="hidden md:block absolute left-8 top-8 bottom-8 w-0.5 bg-white/10 z-0"></div>

         <div class="space-y-8 relative z-10">
            <!-- Step 1 -->
            <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="flex-shrink-0 w-16 h-16 rounded-full bg-brand-accent text-brand-navy font-bold text-xl flex items-center justify-center shadow-lg border-4 border-brand-navy">1</div>
                <div class="bg-white/10 border border-white/10 p-6 rounded-xl flex-1 backdrop-blur-sm">
                    <h4 class="font-bold text-lg text-white mb-2">Audit</h4>
                    <p class="text-slate-300">Audit the content and identify what should become modules, lessons, resources, and support assets.</p>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="flex-shrink-0 w-16 h-16 rounded-full bg-white text-brand-navy font-bold text-xl flex items-center justify-center shadow-lg border-4 border-brand-navy">2</div>
                <div class="bg-white/10 border border-white/10 p-6 rounded-xl flex-1 backdrop-blur-sm">
                    <h4 class="font-bold text-lg text-white mb-2">Prompt & Extract</h4>
                    <p class="text-slate-300">Use AI-assisted workflows to summarize long materials, extract key topics, draft lesson structures, and identify missing learning steps.</p>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="flex-shrink-0 w-16 h-16 rounded-full bg-white text-brand-navy font-bold text-xl flex items-center justify-center shadow-lg border-4 border-brand-navy">3</div>
                <div class="bg-white/10 border border-white/10 p-6 rounded-xl flex-1 backdrop-blur-sm">
                    <h4 class="font-bold text-lg text-white mb-2">Human Review</h4>
                    <p class="text-slate-300">Human review and learning design cleanup to remove repetition, fix sequence, create learner outcomes, and improve clarity.</p>
                </div>
            </div>

            <!-- Step 4 -->
            <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="flex-shrink-0 w-16 h-16 rounded-full bg-white text-brand-navy font-bold text-xl flex items-center justify-center shadow-lg border-4 border-brand-navy">4</div>
                <div class="bg-white/10 border border-white/10 p-6 rounded-xl flex-1 backdrop-blur-sm">
                    <h4 class="font-bold text-lg text-white mb-4">Create Platform-Ready Assets</h4>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                        {["Course map", "Lesson titles", "Summaries", "Scripts", "Worksheets", "Quizzes", "Resource list", "Student FAQ", "Onboarding emails"].map(asset => (
                            <div class="bg-white/5 border border-white/10 rounded px-3 py-1.5 text-sm text-slate-300 flex items-center">
                                <svg class="w-3 h-3 text-brand-accent mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                                {asset}
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Step 5 -->
            <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="flex-shrink-0 w-16 h-16 rounded-full bg-brand-accent text-brand-navy font-bold text-xl flex items-center justify-center shadow-lg border-4 border-brand-navy">5</div>
                <div class="bg-white/10 border border-white/10 p-6 rounded-xl flex-1 backdrop-blur-sm">
                    <h4 class="font-bold text-lg text-white mb-2">Prepare</h4>
                    <p class="text-slate-300">Prepare Kajabi/LMS-ready upload structure and launch checklist.</p>
                </div>
            </div>

         </div>
      </div>
    </div>

    <!-- The Outcome -->
    <div class="mt-16 bg-white rounded-2xl p-8 md:p-10 text-center shadow-xl border border-brand-border/20 max-w-4xl mx-auto transform hover:-translate-y-1 transition-transform duration-300">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">The Outcome</h3>
        <p class="text-lg text-brand-textMain leading-relaxed font-medium">
            The client does not just get AI text. They get a cleaner learning system that is easier to build, deliver, and improve.
        </p>
    </div>

  </div>
</section>
