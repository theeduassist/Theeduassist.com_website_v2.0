---
---
<div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl p-8 md:p-12 text-center my-12 shadow-lg relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-[var(--color-primary)] opacity-10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3" aria-hidden="true"></div>

  <div class="relative z-10 max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold text-white mb-4">Ready to improve your Kajabi setup?</h2>
    <p class="text-slate-300 mb-8 text-lg">
      Stop fighting with tech and start focusing on your students. Get a 24-48 hour review to map out your next steps.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/book-free-audit/?source=blog-cta" class="blog-cta-btn inline-flex items-center justify-center px-8 py-4 bg-[var(--color-accent)] text-white font-bold rounded-lg hover:bg-opacity-90 transition-transform hover:-translate-y-0.5 focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 focus:ring-[var(--color-accent)] focus:outline-none" data-cta-label="Get 24–48 Hour Review">
        Get 24–48 Hour Review &rarr;
      </a>
      <button type="button" class="tawk-blog-btn inline-flex items-center justify-center px-8 py-4 bg-transparent border-2 border-slate-600 text-white font-bold rounded-lg hover:bg-slate-800 hover:border-slate-500 transition-colors focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 focus:ring-slate-500 focus:outline-none focus-ring">
        Ask how this applies to my project
      </button>
    </div>
  </div>
</div>

<script>
  import { openBlogChat } from '../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-blog-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openBlogChat({
          contentType: 'blog',
          contentTitle: document.title,
          pageUrl: window.location.href,
          pageTitle: document.title,
          category: 'blog-post'
        });
      });
    });
  });
</script>

<script>
  function setupCtaTracking() {
      const btns = document.querySelectorAll('.blog-cta-btn');
      btns.forEach(btn => {
          btn.addEventListener('click', () => {
              if (window.dataLayer && typeof window.trackEvent === 'function') {
                  window.trackEvent('blog_cta_click', {
                      cta_label: btn.getAttribute('data-cta-label')
                  });
              }
          });
      });
  }
  setupCtaTracking();
  document.addEventListener('astro:page-load', setupCtaTracking);
</script>
