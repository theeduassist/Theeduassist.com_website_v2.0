---
interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---
<div class="flex items-center space-x-4 py-6 border-t border-b border-slate-100 my-10">
  <span class="text-sm font-semibold text-slate-700">Share this guide:</span>
  <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" class="text-slate-400 hover:text-[#0077b5] transition-colors share-btn" data-network="LinkedIn">
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>
  <button type="button" aria-label="Copy Link" class="text-slate-400 hover:text-[var(--color-primary)] transition-colors copy-link-btn share-btn" data-url={url} data-network="Copy Link">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
    </svg>
  </button>
  <span class="copy-success text-xs text-green-600 font-medium opacity-0 transition-opacity ml-2">Copied!</span>
</div>

<script>
  function setupShareButtons() {
    const copyBtns = document.querySelectorAll('.copy-link-btn');
    const shareBtns = document.querySelectorAll('.share-btn');

    copyBtns.forEach(btn => {
      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-url');
        if (!url) return;

        try {
          await navigator.clipboard.writeText(url);
          const successMsg = btn.nextElementSibling as HTMLElement;
          if (successMsg) {
            successMsg.classList.remove('opacity-0');
            setTimeout(() => {
              successMsg.classList.add('opacity-0');
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy', err);
        }
      });
    });

    shareBtns.forEach(btn => {
        btn.addEventListener('click', () => {
             if (window.dataLayer && typeof window.trackEvent === 'function') {
               window.trackEvent('article_share_click', {
                 network: btn.getAttribute('data-network') || 'unknown'
               });
            }
        });
    });
  }

  setupShareButtons();
  document.addEventListener('astro:page-load', setupShareButtons);
</script>
