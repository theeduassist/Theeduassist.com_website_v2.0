---
const steps = [
  {
    title: "Understand",
    copy: "We review your audience, content, platform, and goals.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`
  },
  {
    title: "Structure",
    copy: "We organize modules, learner paths, offers, pages, and access flow.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />`
  },
  {
    title: "Build",
    copy: "We create the course, platform setup, content layout, visuals, and learning assets.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`
  },
  {
    title: "Automate",
    copy: "We connect emails, checkout, lead capture, access rules, and platform workflows.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />`
  },
  {
    title: "Launch",
    copy: "We test, refine, document, and prepare the experience for real learners.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />`
  }
];
---
<section class="py-24 bg-white px-4 border-t border-brand-border/60">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">How we build your learning experience</h2>
      <p class="text-lg text-brand-textMuted leading-relaxed">
        We use a practical process that moves from content review to launch-ready learning.
      </p>
    </div>

    <!-- Desktop Timeline -->
    <div class="hidden md:flex relative items-start justify-between">
      <div class="absolute top-[3rem] left-[10%] right-[10%] h-0.5 bg-brand-border/60 z-0"></div>

      {steps.map((step, index) => (
        <div class="relative z-10 flex flex-col items-center flex-1 px-4 text-center group hover-lift transition-transform motion-reduce:transform-none">
          <div class="w-24 h-24 bg-brand-softBg border border-brand-border/60 rounded-2xl flex flex-col items-center justify-center mb-6 shadow-sm group-hover:border-brand-accent/30 group-hover:bg-brand-softGreen/30 transition-colors">
             <div class="text-brand-accent mb-1">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={step.icon} />
             </div>
             <span class="text-xs font-bold text-brand-textMuted group-hover:text-brand-primary">0{index + 1}</span>
          </div>
          <h3 class="font-bold text-brand-navy mb-3 text-lg group-hover:text-brand-accent transition-colors">{step.title}</h3>
          <p class="text-sm text-brand-textMuted leading-relaxed">{step.copy}</p>
        </div>
      ))}
    </div>

    <!-- Mobile Stacked -->
    <div class="flex md:hidden flex-col space-y-4">
      {steps.map((step, index) => (
        <div class="bg-brand-softBg border border-brand-border/60 rounded-xl p-6 flex items-start gap-4 shadow-sm group hover-lift hover:border-brand-accent/30 transition-all">
          <div class="w-12 h-12 shrink-0 bg-brand-softGreen text-brand-accent rounded-lg flex items-center justify-center font-bold text-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
            {index + 1}
          </div>
          <div>
            <h3 class="font-bold text-brand-navy text-xl mb-2 group-hover:text-brand-accent transition-colors">{step.title}</h3>
            <p class="text-brand-textMuted text-sm">{step.copy}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
