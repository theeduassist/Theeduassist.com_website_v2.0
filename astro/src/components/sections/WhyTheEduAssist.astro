---
import SectionHeader from '../ui/SectionHeader.astro';
---
<section class="py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <SectionHeader title="Why Work With TheEduAssist?" />
    <div class="space-y-6 text-lg text-slate-600 leading-relaxed text-left md:text-center">
      <p>
        We focus on clear, practical, and outcome-driven learning solutions. We don't use generic AI jargon or promise fake results. Our goal is to create structured, engaging learning experiences that work for your organization.
      </p>
      <p>
        Whether you need custom eLearning, LMS migration, or Kajabi setup, we deliver professional work tailored to your specific needs.
      </p>
    </div>
  </div>
</section>
