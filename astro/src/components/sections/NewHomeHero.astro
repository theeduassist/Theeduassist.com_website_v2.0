---
import Button from '../ui/Button.astro';

interface Props {
  title: string;
  subtitle: string;
  primaryCtaLabel: string;
  primaryCtaLink: string;
  secondaryCtaLabel?: string;
  secondaryCtaLink?: string;
  trustChips?: string[];
}

const {
  title,
  subtitle,
  primaryCtaLabel,
  primaryCtaLink,
  secondaryCtaLabel,
  secondaryCtaLink,
  trustChips = [
    "Course Design",
    "Kajabi Builds",
    "LMS Migration",
    "AI Assistance",
    "Funnels & Automation"
  ]
} = Astro.props;
---
<section class="py-24 bg-white text-center px-4 md:py-32 animate-fade-up relative overflow-hidden">
  <!-- Subtle background glowing accents -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-96 bg-brand-softBlue/40 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-4xl mx-auto relative z-10">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-brand-navy mb-6 leading-tight tracking-tight">
      {title}
    </h1>
    <p class="text-lg md:text-xl text-brand-textMuted max-w-3xl mx-auto mb-10 leading-relaxed font-medium">
      {subtitle}
    </p>

    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mb-12">
      <Button href={primaryCtaLink} variant="primary" size="lg" class="w-full sm:w-auto shadow-md hover:shadow-lg">{primaryCtaLabel}</Button>
      {secondaryCtaLabel && secondaryCtaLink && (
        <Button href={secondaryCtaLink} variant="outline" size="lg" class="w-full sm:w-auto">{secondaryCtaLabel}</Button>
      )}
    </div>

    {trustChips && trustChips.length > 0 && (
      <div class="flex flex-wrap justify-center items-center gap-3 md:gap-4 max-w-3xl mx-auto mb-20">
        {trustChips.map((chip) => (
          <div class="flex items-center space-x-2 bg-brand-softBg border border-brand-border/60 px-3 py-1.5 rounded-full text-sm font-medium text-brand-textMain shadow-sm">
            <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
            <span>{chip}</span>
          </div>
        ))}
      </div>
    )}

    <!-- Infographic Visual: TheEduAssist Learning System Engine -->
    <div class="relative max-w-5xl mx-auto">
        <h3 class="sr-only">TheEduAssist Learning System Engine</h3>

        <div class="bg-brand-softBg p-8 md:p-12 rounded-3xl border border-brand-border shadow-soft relative animate-soft-scale">
            <!-- Connecting lines background -->
            <div class="absolute inset-0 z-0">
                <svg class="w-full h-full text-brand-accent/20" preserveAspectRatio="none" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.5">
                    <line x1="50" y1="50" x2="15" y2="25" class="animate-draw-line" />
                    <line x1="50" y1="50" x2="50" y2="15" class="animate-draw-line" style="animation-delay: 0.1s;" />
                    <line x1="50" y1="50" x2="85" y2="25" class="animate-draw-line" style="animation-delay: 0.2s;" />
                    <line x1="50" y1="50" x2="15" y2="75" class="animate-draw-line" style="animation-delay: 0.3s;" />
                    <line x1="50" y1="50" x2="50" y2="85" class="animate-draw-line" style="animation-delay: 0.4s;" />
                    <line x1="50" y1="50" x2="85" y2="75" class="animate-draw-line" style="animation-delay: 0.5s;" />
                </svg>
            </div>

            <!-- Central Core -->
            <div class="relative z-10 flex justify-center items-center mb-8">
                <div class="bg-white p-6 rounded-2xl shadow-card border border-brand-accent/30 flex flex-col items-center justify-center w-48 h-48 relative animate-float">
                    <div class="absolute inset-0 rounded-2xl bg-brand-accent/5 animate-pulse"></div>
                    <img src="/brand/theeduassist-logo-mark.svg" alt="TheEduAssist Logo Mark" class="w-16 h-16 mb-3 relative z-10" />
                    <span class="font-bold text-brand-navy text-center leading-tight relative z-10">Learning System<br/>Core</span>
                </div>
            </div>

            <!-- Surrounding Nodes Grid -->
            <div class="relative z-10 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">Course Strategy</span>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">Curriculum Design</span>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">Kajabi Build</span>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">LMS Migration</span>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">AI Assistance</span>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">Content Production</span>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">Funnels</span>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">Student Experience</span>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center space-x-3 hover-lift group">
                    <div class="bg-brand-softGreen text-brand-accent p-2 rounded-lg group-hover:bg-brand-accent group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <span class="font-semibold text-brand-textMain text-sm">Launch Support</span>
                </div>
            </div>
        </div>
    </div>
  </div>
</section>
