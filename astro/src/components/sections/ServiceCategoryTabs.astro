---
import StatelessTabs from '../ui/StatelessTabs.astro';
import { getAllServices } from '../../sanity/queries';

const services = await getAllServices();
// Derive simple categories from services (group by category field if present)
const categoriesMap = new Map();
for (const s of services) {
  const cat = s.category || 'General';
  if (!categoriesMap.has(cat)) categoriesMap.set(cat, []);
  categoriesMap.get(cat).push(s);
}
const serviceCategories = Array.from(categoriesMap.entries()).map(([title, items]) => ({ title, items }));

const tabs = serviceCategories.map((cat, index) => ({ id: `cat-${index}`, label: cat.title }));
---
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <StatelessTabs tabs={tabs} name="service-categories">
      {serviceCategories.map((cat, index) => (
        <div data-tab-content={`cat-${index}`} class="bg-slate-50 border border-slate-200 rounded-lg p-8">
          <h2 class="text-2xl font-bold text-blue-600 mb-6 border-b border-slate-200 pb-4">{cat.title}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-4">
            {cat.items.map(item => (
              <div class="flex items-start">
                <div class="mt-1 mr-3 text-blue-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                {item.link ? (
                  <a href={item.link} class="text-lg font-medium text-slate-700 hover:text-blue-600 hover:underline transition-colors">{item.label}</a>
                ) : (
                  <span class="text-lg text-slate-700">{item.label}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </StatelessTabs>
  </div>
</section>
