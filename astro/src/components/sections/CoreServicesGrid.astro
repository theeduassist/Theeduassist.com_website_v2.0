---
// src/components/sections/CoreServicesGrid.astro
interface Props {
  services?: any[];
}

const { services = [] } = Astro.props;

const staticServices = [
    { title: "Course Creation & Curriculum Design", desc: "Structure your knowledge into clear, engaging lessons.", href: "/services/custom-elearning-development/" },
    { title: "Kajabi Website & Course Setup", desc: "Complete technical builds on the Kajabi platform.", href: "/kajabi-services/" },
    { title: "LMS Implementation & Migration", desc: "Move your content to a new Learning Management System.", href: "/services/lms-implementation-migration/" },
    { title: "Instructional Design & Learner Experience", desc: "Design learning journeys that improve student success.", href: "/services/" },
    { title: "AI-Powered E-Learning Support", desc: "Accelerate content planning with AI workflows.", href: "/services/ai-assistance/" },
    { title: "Content Conversion", desc: "Turn raw files, PDFs, and videos into structured courses.", href: "/services/content-conversion/" },
    { title: "Funnels & Automation", desc: "Build systems that sell and onboard students automatically.", href: "/services/funnels-automation/" },
    { title: "Ongoing Support & Maintenance", desc: "Keep your platform running smoothly post-launch.", href: "/services/ongoing-support-maintenance/" }
];

const displays = services.length > 0
    ? services.map(s => ({
        title: s.title,
        desc: s.summary || s.description,
        href: s.slug?.current ? `/services/${s.slug.current}/` : s.slug || '#'
      }))
    : staticServices;
---
<section class="py-20 md:py-28 bg-brand-softBg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">Everything You Need to Build, Launch, and Improve Online Learning</h2>
            <p class="text-lg text-brand-textMuted">End-to-end support to transform your expertise into a polished, scalable e-learning experience.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {displays.map(service => (
                <div class="bg-white p-6 rounded-2xl border border-brand-border shadow-sm hover:shadow-lg transition-all duration-300 group flex flex-col h-full">
                    <div class="bg-brand-softGreen w-12 h-12 rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-accent transition-colors duration-300">
                        <svg class="w-6 h-6 text-brand-accent group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <h3 class="text-lg font-bold text-brand-navy mb-2">{service.title}</h3>
                    <p class="text-sm text-brand-textMain mb-6 flex-grow">{service.desc}</p>
                    <a href={service.href} class="text-brand-accent font-semibold text-sm hover:text-brand-primary transition-colors flex items-center mt-auto">
                        Learn more
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
            ))}
        </div>
    </div>
</section>
