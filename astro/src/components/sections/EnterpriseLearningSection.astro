---
---
<section class="py-20 md:py-28 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            <!-- Text Side -->
            <div>
                <div class="inline-flex items-center space-x-2 bg-brand-softBg text-brand-primary px-3 py-1 rounded-full text-sm font-bold mb-6">
                    <span class="w-2 h-2 rounded-full bg-brand-primary"></span>
                    <span>Corporate & Enterprise</span>
                </div>

                <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-6 leading-tight">
                    Corporate and enterprise learning systems
                </h2>

                <p class="text-lg text-slate-600 mb-8 leading-relaxed">
                    For businesses, training departments, institutes, NGOs, publishers, and larger organizations, TheEduAssist can help plan and build structured learning systems for onboarding, compliance training, customer education, partner training, product training, internal academies, LMS migration, and SCORM-ready content.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
                    {['Employee onboarding', 'Compliance training', 'Partner training', 'Customer education', 'Internal academies', 'Multi-department portals', 'LMS migration', 'SCORM/xAPI content'].map(useCase => (
                        <div class="flex items-center space-x-2 text-slate-700">
                            <svg class="w-5 h-5 text-brand-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span class="font-medium text-sm">{useCase}</span>
                        </div>
                    ))}
                </div>

                <div class="bg-slate-50 border border-slate-200 rounded-lg p-5 mb-8 text-sm text-slate-600 leading-relaxed">
                    <strong>Pricing:</strong> Enterprise projects are scoped after discovery. Final pricing depends on platform, learner volume, content volume, integrations, reporting needs, timeline, and support requirements.
                </div>

                <div class="flex flex-col sm:flex-row gap-4">
                    <button type="button" class="tawk-enterprise-btn bg-brand-primary text-white px-6 py-3 rounded-md font-bold hover:bg-brand-navy transition-colors focus-ring shadow-lg text-center" data-package-slug="enterprise-learning-systems" data-package-name="Enterprise Learning Systems" data-package-price="Custom quote after scope review" data-source-cta="enterprise-learning-project" data-lead-intent="enterprise_learning_project">
                        Start an Enterprise Project
                    </button>
                    <a href="/book-free-audit/?project=enterprise-learning&source=enterprise-section" class="bg-white border border-slate-300 text-slate-700 px-6 py-3 rounded-md font-bold hover:bg-slate-50 transition-colors focus-ring text-center">
                        Submit Project Details
                    </a>
                </div>
            </div>

            <!-- Visual Process Diagram Side -->
            <div class="relative lg:pl-10">
                <div class="absolute inset-0 bg-gradient-to-br from-brand-softBg to-transparent rounded-3xl -z-10 transform translate-x-4 translate-y-4"></div>

                <div class="flex flex-col space-y-4 relative">
                    <!-- Vertical connecting line (hidden on very small screens if we wanted, but stack looks good with it) -->
                    <div class="absolute left-6 top-10 bottom-10 w-0.5 bg-brand-primary/20 -z-0"></div>

                    {[
                        { step: '1', title: 'Business Need', desc: 'Identify goals, audience, and constraints.' },
                        { step: '2', title: 'Learning Strategy', desc: 'Map curriculum and learner journey.' },
                        { step: '3', title: 'LMS/Platform Setup', desc: 'Configure system architecture.' },
                        { step: '4', title: 'Course Content', desc: 'Develop SCORM or platform assets.' },
                        { step: '5', title: 'Learner Experience', desc: 'Test onboarding and UI/UX.' },
                        { step: '6', title: 'Reporting & Support', desc: 'Monitor engagement and analytics.' }
                    ].map((item) => (
                        <div class="bg-white border border-slate-100 shadow-sm rounded-xl p-4 flex items-start space-x-4 relative z-10 hover:-translate-y-1 transition-transform">
                            <div class="w-12 h-12 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold flex-shrink-0 shadow-inner">
                                {item.step}
                            </div>
                            <div>
                                <h4 class="font-bold text-brand-navy">{item.title}</h4>
                                <p class="text-sm text-slate-500">{item.desc}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    import { openStartPackageChat } from "../../utils/tawkSales";
    document.addEventListener("DOMContentLoaded", () => {
      const btns = document.querySelectorAll(".tawk-enterprise-btn");
      btns.forEach(btn => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLButtonElement;
          openStartPackageChat({
            packageSlug: target.dataset.packageSlug || "enterprise-learning-systems",
            packageName: target.dataset.packageName || "Enterprise Learning Systems",
            packagePrice: target.dataset.packagePrice || "Custom quote",
            pageUrl: window.location.href,
            pageTitle: document.title,
            sourceCta: target.dataset.sourceCta || "enterprise-learning-project"
          });
        });
      });
    });
</script>
