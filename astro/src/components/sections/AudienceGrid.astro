---
// src/components/sections/AudienceGrid.astro
interface Props {
  audienceSegments?: any[];
}

const { audienceSegments = [] } = Astro.props;

const staticAudiences = [
    { title: "Creators & Coaches", outcome: "Turn your expertise into a structured offer, course, or membership that learners can actually follow." },
    { title: "Consultants", outcome: "Productize your 1:1 frameworks into scalable training assets and premium group programs." },
    { title: "Educators", outcome: "Move from messy files to a clean, professional curriculum designed for student success." },
    { title: "Training Companies", outcome: "Upgrade your learning platform, improve completion rates, and streamline content delivery." },
    { title: "Online Academies", outcome: "Build robust, multi-tier learning experiences with certifications, cohorts, and community." },
    { title: "Businesses & Internal Teams", outcome: "Organize SOPs and scattered training docs into an accessible internal LMS portal." }
];

const displays = audienceSegments.length > 0
    ? audienceSegments.map(s => ({ title: s.title, outcome: s.summary }))
    : staticAudiences;
---
<section class="py-20 md:py-28 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">Built for People and Teams Who Teach Online</h2>
            <p class="text-lg text-brand-textMuted">We help experts and organizations turn scattered knowledge into structured, professional, and impactful learning systems.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            {displays.map(audience => (
                <div class="bg-brand-softBg p-8 rounded-2xl border border-brand-border/40 shadow-sm hover:shadow-md transition-shadow duration-300">
                    <h3 class="text-xl font-bold text-brand-navy mb-3">{audience.title}</h3>
                    <p class="text-brand-textMain leading-relaxed">{audience.outcome}</p>
                </div>
            ))}
        </div>
    </div>
</section>
