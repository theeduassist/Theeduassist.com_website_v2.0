---
const platforms = [
  "Kajabi Builds",
  "LMS Migration",
  "Course Websites",
  "Membership Learning Hubs",
  "Internal Training Portals",
  "Content Libraries",
  "AI-Assisted Workflows",
  "Funnel and Email Systems"
];
---

<section class="py-20 md:py-32 bg-brand-softBg overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-16">

      <div class="lg:w-1/2">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-primary mb-6 leading-tight">
          Built for Kajabi, LMS Platforms, Course Websites, and Training Systems
        </h2>
        <p class="text-lg text-brand-textMuted mb-8 leading-relaxed">
          TheEduAssist can support different course delivery environments. We help you choose, organize, and build around the system that fits your business, content, and learner experience.
        </p>

        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {platforms.map((item) => (
            <li class="flex items-center text-brand-textMain font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-accent mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/platforms/" class="bg-brand-primary text-white font-bold py-3 px-6 rounded-md hover:bg-brand-navy transition-colors shadow-sm focus-ring inline-block">
            View Platforms
          </a>
        </div>
      </div>

      <div class="lg:w-1/2 relative w-full h-[400px]">
        <div class="absolute inset-0 bg-brand-gradient opacity-10 rounded-[3rem] transform rotate-3"></div>
        <div class="absolute inset-0 bg-white border border-brand-border rounded-[3rem] shadow-soft transform -rotate-2 flex items-center justify-center p-8">
            <div class="grid grid-cols-2 gap-6 w-full h-full">
                <!-- Abstract visual representation of platforms -->
                <div class="bg-brand-softBlue rounded-xl w-full h-full flex flex-col items-center justify-center border border-brand-border/50">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-brand-primary mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
                    <span class="text-xs font-bold text-brand-textMuted uppercase tracking-wider">Websites</span>
                </div>
                <div class="bg-brand-softGreen rounded-xl w-full h-full flex flex-col items-center justify-center border border-brand-border/50">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-brand-accent mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
                    <span class="text-xs font-bold text-brand-textMuted uppercase tracking-wider">LMS</span>
                </div>
                <div class="col-span-2 bg-brand-primary text-white rounded-xl w-full h-full flex flex-col items-center justify-center shadow-inner">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                    <span class="text-sm font-bold uppercase tracking-wider">Your Content Ecosystem</span>
                </div>
            </div>
        </div>
      </div>

    </div>
  </div>
</section>
