---
import Button from '../ui/Button.astro';

const trustChips = [
  "Course Creation",
  "Kajabi Setup",
  "LMS Migration",
  "AI Course Support",
  "Content Conversion",
  "Funnels & Automation",
  "Launch Support"
];
---

<section class="relative pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden bg-brand-softBg">
  <!-- Background Accents -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-40">
    <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-brand-softBlue rounded-bl-full blur-3xl transform translate-x-1/4 -translate-y-1/4"></div>
    <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-brand-softGreen rounded-tr-full blur-3xl transform -translate-x-1/4 translate-y-1/4"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10 text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-brand-primary tracking-tight leading-tight mb-6 animate-fade-up">
      E-Learning Services Built Around Your <br class="hidden md:block"/> Complete Course Journey
    </h1>

    <p class="mt-6 text-lg md:text-xl leading-relaxed text-brand-textMuted max-w-4xl mx-auto animate-fade-up" style="animation-delay: 100ms;">
      Whether you need to turn raw content into a course, build a Kajabi system, migrate from an old LMS, organize learning materials, or launch a complete online academy, TheEduAssist helps you structure, build, and improve the full learning experience.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up" style="animation-delay: 200ms;">
      <Button href="/book-free-audit/" variant="primary" size="lg">
        Get 24–48 Hour Review
      </Button>
      <Button href="#service-finder" variant="outline" size="lg">
        Find the Right Service
      </Button>
    </div>

    <!-- Trust Chips -->
    <div class="mt-14 flex flex-wrap justify-center gap-3 animate-fade-up" style="animation-delay: 300ms;">
      {trustChips.map((chip) => (
        <span class="px-4 py-2 bg-white text-sm font-medium text-brand-textMuted rounded-full border border-brand-border shadow-sm">
          {chip}
        </span>
      ))}
    </div>

    <!-- Hero Visual / Pathway Graphic -->
    <div class="mt-20 max-w-5xl mx-auto animate-fade-up" style="animation-delay: 400ms;">
      <div class="bg-white rounded-2xl p-6 md:p-8 border border-brand-border shadow-soft flex flex-col md:flex-row items-center justify-between gap-4 relative">
        <div class="hidden md:block absolute top-1/2 left-8 right-8 h-1 bg-brand-softBlue -translate-y-1/2 z-0"></div>

        {['Idea', 'Structure', 'Build', 'Launch', 'Improve'].map((step, index) => (
          <div class="relative z-10 flex flex-col items-center group w-full md:w-auto">
            <div class="w-14 h-14 rounded-full bg-white border-2 border-brand-softBlue flex items-center justify-center text-brand-primary font-bold shadow-sm transition-colors group-hover:border-brand-accent/30 group-hover:bg-brand-softGreen">
              {index + 1}
            </div>
            <span class="mt-3 text-sm font-semibold text-brand-textMain">{step}</span>
            {index < 4 && (
              <div class="md:hidden w-1 h-6 bg-brand-softBlue my-2"></div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
