---
import Button from '../ui/Button.astro';
---

<section class="py-24 bg-brand-primary relative overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute inset-0 z-0 opacity-20">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-accent rounded-full blur-3xl transform translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-softBlue rounded-full blur-3xl transform -translate-x-1/2 translate-y-1/2"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 lg:px-8 relative z-10 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
      Ready to Find the Right Service for Your Course or Learning System?
    </h2>
    <p class="text-lg md:text-xl text-brand-softBlue mb-10 max-w-2xl mx-auto leading-relaxed">
      Get a 24-48 hour review and we’ll review your content, course idea, platform, or current learning setup and recommend the best next step.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button href="/book-free-audit/?service=general-service-inquiry&source=service-page" variant="primary" size="lg" className="bg-brand-accent text-brand-primary hover:bg-white border-2 border-transparent">
        Get Your Course Reviewed in 24–48 Hours
      </Button>
      <button type="button" data-service-slug="general-service-inquiry" class="tawk-service-btn inline-flex justify-center items-center px-8 py-4 rounded-md bg-transparent text-white font-bold text-lg border-2 border-white/20 hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-[#27496D] focus-visible:ring-white">Start This Service</button>
    </div>
  </div>

<script>
  import { openStartServiceChat } from '../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-service-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget;
        openStartServiceChat({
          serviceSlug: target.dataset.serviceSlug || '',
          pageUrl: window.location.href,
          pageTitle: document.title,
        });
      });
    });
  });
</script>
</section>
