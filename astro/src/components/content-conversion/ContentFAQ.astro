---
// src/components/content-conversion/ContentFAQ.astro
---
<section class="py-20 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Content Conversion FAQ</h2>
    </div>

    <div class="space-y-6">
      {[
        {
          q: "What is content conversion for online courses?",
          a: "Content conversion means turning existing materials such as PDFs, slides, videos, notes, manuals, or documents into structured lessons, summaries, worksheets, quizzes, resources, and platform-ready course assets."
        },
        {
          q: "Can you convert PDFs into course lessons?",
          a: "Yes. We can turn PDFs into lesson summaries, downloadable guides, worksheets, quiz ideas, and module-based course content."
        },
        {
          q: "Can you convert slide decks into online course content?",
          a: "Yes. We can turn slide decks into lesson outlines, video scripts, narration notes, workbook sections, and recap resources."
        },
        {
          q: "Can you convert videos or webinars?",
          a: "Yes. We can help break videos or webinars into lesson topics, key takeaways, action steps, quiz ideas, resource lists, and support content."
        },
        {
          q: "Can you prepare content for Kajabi or an LMS?",
          a: "Yes. We can prepare lesson structures, resources, downloads, quiz ideas, and upload-ready organization for Kajabi, LMS platforms, course websites, or internal training systems."
        },
        {
          q: "Do you use AI for content conversion?",
          a: "We may use AI-assisted workflows to summarize, extract topics, and draft first-pass learning assets, but human review is used to refine clarity, accuracy, learner flow, and platform readiness."
        },
        {
          q: "Do you also build the course platform?",
          a: "Content conversion prepares the assets. If you also need Kajabi, LMS, landing pages, automations, or launch support, that can be added as a separate or combined build."
        },
        {
          q: "What should I prepare before booking a content audit?",
          a: "Bring your PDFs, slides, videos, notes, manuals, folder links, course idea, target audience, platform preference, and launch timeline if available."
        }
      ].map((faq) => (
        <div class="border border-brand-border/60 rounded-xl p-6 bg-brand-softBg hover:shadow-md transition-shadow">
          <h3 class="text-lg font-bold text-brand-navy mb-3 flex items-start">
             <svg class="w-5 h-5 text-brand-accent mr-3 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
             {faq.q}
          </h3>
          <p class="text-brand-textMuted leading-relaxed ml-8">{faq.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>
