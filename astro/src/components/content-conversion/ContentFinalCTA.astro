---
// src/components/content-conversion/ContentFinalCTA.astro
---
<section class="py-24 bg-brand-navy text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 z-0 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:24px_24px] opacity-5"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-brand-accent/20 blur-[100px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <h2 class="text-3xl md:text-5xl font-extrabold mb-8 leading-tight">
            Ready to Turn Your Existing Content Into Course-Ready Assets?
        </h2>
        <p class="text-lg md:text-xl text-gray-300 mb-10 leading-relaxed">
            Get a 24-48 hour review and we’ll review your PDFs, slides, videos, notes, manuals, or current course files to show what needs to be cleaned, structured, converted, and prepared for your learning platform.
        </p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
            <a href="/book-free-audit/?service=content-conversion&source=service-page" class="w-full sm:w-auto bg-brand-accent text-white px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white hover:text-brand-navy shadow-lg text-center">
                Get Your Course Reviewed in 24–48 Hours
            </a>
            <button
                type="button"
                data-service-slug="content-conversion"
                class="tawk-service-btn w-full sm:w-auto bg-white/10 text-white border border-white/20 px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white/20 shadow-sm text-center focus-ring"
            >
                Start This Service
            </button>
        </div>
    </div>

<script>
  import { openStartServiceChat } from '../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-service-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget;
        openStartServiceChat({
          serviceSlug: target.dataset.serviceSlug || '',
          pageUrl: window.location.href,
          pageTitle: document.title,
        });
      });
    });
  });
</script>
</section>
