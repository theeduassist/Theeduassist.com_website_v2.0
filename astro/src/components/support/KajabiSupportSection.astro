---
// src/components/support/KajabiSupportSection.astro
---

<section class="py-20 lg:py-24 bg-white border-y border-brand-border/40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <!-- Content -->
      <div class="lg:w-1/2">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
          Kajabi Support for Course Owners and Training Businesses
        </h2>
        <p class="text-lg text-brand-textMuted mb-8">
          Kajabi is one of TheEduAssist’s strongest specialties. We can help maintain and improve Kajabi websites, course products, landing pages, offers, checkout flows, email campaigns, automations, tags, templates, student onboarding, and launch pages.
        </p>
        <a href="/kajabi-services/" class="inline-flex items-center text-brand-navy font-semibold hover:text-brand-accent transition-colors group">
          View Kajabi Services
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>

      <!-- Capabilities Grid -->
      <div class="lg:w-1/2 w-full grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          "Page updates",
          "Product updates",
          "Offer and checkout review",
          "Email sequence edits",
          "Automation cleanup",
          "Student onboarding fixes",
          "Funnel updates",
          "Launch page preparation",
          "Template improvements",
          "QA checks"
        ].map((item) => (
          <div class="flex items-center p-4 bg-brand-softBg rounded-xl border border-brand-border/40">
             <svg class="w-5 h-5 text-brand-accent mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
             <span class="text-sm font-medium text-brand-navy">{item}</span>
          </div>
        ))}
      </div>
    </div>

    <p class="text-xs text-brand-textMuted mt-12 text-center">
      * Kajabi is a third-party platform. Platform support does not imply official partnership unless stated.
    </p>
  </div>
</section>
