---
// src/components/support/LMSSupportSection.astro
---

<section class="py-20 lg:py-24 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row-reverse items-center gap-12">
      <!-- Content -->
      <div class="lg:w-1/2">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
          LMS and Course Platform Maintenance
        </h2>
        <p class="text-lg text-brand-textMuted mb-8">
          For LMS platforms and course websites, TheEduAssist can help keep training content, modules, lessons, resources, and student pathways organized and updated where supported by the platform.
        </p>
      </div>

      <!-- Capabilities Grid -->
      <div class="lg:w-1/2 w-full grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          "Course content updates",
          "Module and lesson cleanup",
          "Resource organization",
          "Quiz and assessment updates",
          "User access guidance",
          "Completion pathway review",
          "Course library organization",
          "Reporting-ready structure",
          "Learner experience fixes"
        ].map((item) => (
          <div class="flex items-center p-4 bg-white rounded-xl border border-brand-border/60 shadow-sm">
             <svg class="w-5 h-5 text-brand-accent mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
             <span class="text-sm font-medium text-brand-navy">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
