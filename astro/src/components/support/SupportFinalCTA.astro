---
// src/components/support/SupportFinalCTA.astro
---

<section class="py-20 lg:py-24 bg-brand-navy relative overflow-hidden">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 bg-[url('/ui/grid-pattern.svg')] opacity-10 pointer-events-none invert"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
      Ready to Keep Your Course System Clean, Updated, and Launch-Ready?
    </h2>
    <p class="text-xl text-brand-softBg/80 mb-10 max-w-2xl mx-auto">
      Get a 24-48 hour review and we’ll review your course pages, platform, automations, emails, learner journey, and current issues to recommend the right maintenance plan.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/book-free-audit/?service=ongoing-support-maintenance&source=service-page" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-bold text-brand-navy bg-brand-accent hover:bg-green-500 rounded-full shadow-lg transition-all hover:-translate-y-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-navy focus-visible:ring-brand-accent">
        Get Your Course Reviewed in 24–48 Hours
      </a>
      <button
        type="button"
        data-service-slug="ongoing-support-maintenance"
        class="tawk-service-btn w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-transparent border border-white/30 hover:bg-white/10 rounded-full transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-navy focus-visible:ring-white focus-ring"
      >
        Start This Service
      </button>
    </div>
  </div>

<script>
  import { openStartServiceChat } from '../../utils/tawkSales';
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.tawk-service-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget;
        openStartServiceChat({
          serviceSlug: target.dataset.serviceSlug || '',
          pageUrl: window.location.href,
          pageTitle: document.title,
        });
      });
    });
  });
</script>
</section>
