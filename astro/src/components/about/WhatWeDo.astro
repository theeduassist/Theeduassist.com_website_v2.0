---
import SectionHeader from '../ui/SectionHeader.astro';
---

<section class="py-20 lg:py-24 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader
      title="What TheEduAssist Helps You Build"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <a href="/services/" class="group block p-6 bg-white rounded-xl shadow-sm border border-brand-border/50 hover:shadow-md hover:border-brand-primary/30 transition-all focus-ring">
        <h3 class="text-lg font-bold text-brand-primary mb-3 group-hover:text-brand-accent transition-colors">Course Creation & Curriculum Design</h3>
        <p class="text-brand-textMain text-sm mb-4">Turn raw expertise into course maps, modules, lessons, outcomes, worksheets, quizzes, and learning journeys.</p>
        <span class="text-brand-primary font-medium text-sm flex items-center">
            Learn more <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </span>
      </a>

      <a href="/kajabi-services/" class="group block p-6 bg-white rounded-xl shadow-sm border border-brand-border/50 hover:shadow-md hover:border-brand-primary/30 transition-all focus-ring">
        <h3 class="text-lg font-bold text-brand-primary mb-3 group-hover:text-brand-accent transition-colors">Kajabi Websites & Course Setup</h3>
        <p class="text-brand-textMain text-sm mb-4">Build Kajabi websites, landing pages, course products, offers, checkout, emails, automations, and student onboarding.</p>
        <span class="text-brand-primary font-medium text-sm flex items-center">
            Learn more <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </span>
      </a>

      <a href="/services/lms-implementation-migration/" class="group block p-6 bg-white rounded-xl shadow-sm border border-brand-border/50 hover:shadow-md hover:border-brand-primary/30 transition-all focus-ring">
        <h3 class="text-lg font-bold text-brand-primary mb-3 group-hover:text-brand-accent transition-colors">LMS Implementation & Migration</h3>
        <p class="text-brand-textMain text-sm mb-4">Move scattered content from WordPress, Google Drive, PDFs, old LMS platforms, and course files into cleaner learning systems.</p>
        <span class="text-brand-primary font-medium text-sm flex items-center">
            Learn more <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </span>
      </a>

      <a href="/services/ai-assistance/" class="group block p-6 bg-white rounded-xl shadow-sm border border-brand-border/50 hover:shadow-md hover:border-brand-primary/30 transition-all focus-ring">
        <h3 class="text-lg font-bold text-brand-primary mb-3 group-hover:text-brand-accent transition-colors">AI-Powered E-Learning Support</h3>
        <p class="text-brand-textMain text-sm mb-4">Use AI-assisted, human-reviewed workflows to turn ideas and content into course-ready assets faster.</p>
        <span class="text-brand-primary font-medium text-sm flex items-center">
            Learn more <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </span>
      </a>

      <a href="/services/content-conversion/" class="group block p-6 bg-white rounded-xl shadow-sm border border-brand-border/50 hover:shadow-md hover:border-brand-primary/30 transition-all focus-ring">
        <h3 class="text-lg font-bold text-brand-primary mb-3 group-hover:text-brand-accent transition-colors">Content Conversion</h3>
        <p class="text-brand-textMain text-sm mb-4">Convert PDFs, slides, videos, webinars, manuals, SOPs, and notes into lessons, summaries, scripts, worksheets, and quizzes.</p>
        <span class="text-brand-primary font-medium text-sm flex items-center">
            Learn more <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </span>
      </a>

      <a href="/services/funnels-automation/" class="group block p-6 bg-white rounded-xl shadow-sm border border-brand-border/50 hover:shadow-md hover:border-brand-primary/30 transition-all focus-ring">
        <h3 class="text-lg font-bold text-brand-primary mb-3 group-hover:text-brand-accent transition-colors">Funnels & Automation</h3>
        <p class="text-brand-textMain text-sm mb-4">Connect lead capture, landing pages, email follow-up, checkout, course access, and student onboarding.</p>
        <span class="text-brand-primary font-medium text-sm flex items-center">
            Learn more <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </span>
      </a>

      <a href="/services/ongoing-support-maintenance/" class="group block p-6 bg-white rounded-xl shadow-sm border border-brand-border/50 hover:shadow-md hover:border-brand-primary/30 transition-all md:col-span-2 lg:col-span-3 focus-ring">
        <div class="lg:flex lg:items-center lg:justify-between">
            <div class="lg:w-2/3">
                <h3 class="text-lg font-bold text-brand-primary mb-3 group-hover:text-brand-accent transition-colors">Ongoing Support & Maintenance</h3>
                <p class="text-brand-textMain text-sm mb-4 lg:mb-0">Keep your course pages, content, automations, funnels, and learner experience updated after launch.</p>
            </div>
            <div class="lg:w-1/3 lg:text-right">
                <span class="text-brand-primary font-medium text-sm inline-flex items-center">
                    Learn more <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </span>
            </div>
        </div>
      </a>

    </div>
  </div>
</section>
