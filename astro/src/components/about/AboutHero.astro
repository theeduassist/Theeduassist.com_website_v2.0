---
---
<section class="py-20 lg:py-28 bg-white relative overflow-hidden">
  <div class="absolute inset-0 bg-brand-softBg/50 pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <div class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-brand-primary leading-tight tracking-tight mb-6">
          About TheEduAssist
        </h1>
        <p class="text-lg sm:text-xl text-brand-textMain mb-8 leading-relaxed">
          TheEduAssist is an e-learning design and course-building agency helping creators, coaches, educators, consultants, training companies, online academies, and businesses turn knowledge into structured, launch-ready online learning systems.
        </p>
        <div class="flex flex-wrap gap-4 mb-10">
          <a href="/book-free-audit/" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-semibold rounded-md text-white bg-brand-accent hover:bg-brand-primary shadow hover:shadow-md transition-all duration-300 focus-ring">
            Get 24–48 Hour Review
          </a>
          <a href="/services/" class="inline-flex items-center justify-center px-6 py-3 border border-brand-border text-base font-medium rounded-md text-brand-primary bg-white hover:bg-slate-50 transition-all duration-300 focus-ring">
            Explore Services
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {["E-Learning Design Agency", "Course Creation", "Kajabi Specialty", "LMS Migration", "AI E-Learning Support", "Funnels & Automation", "Ongoing Support"].map((chip) => (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-brand-softBlue text-brand-primary border border-brand-primary/10">
              {chip}
            </span>
          ))}
        </div>
      </div>

      <div class="relative w-full max-w-lg mx-auto lg:max-w-none">
        <div class="aspect-square relative flex items-center justify-center bg-slate-50 rounded-2xl border border-brand-border/60 shadow-sm p-4 sm:p-8">
            <div class="absolute inset-0 rounded-2xl bg-grid-slate-100/[0.04] bg-[size:20px_20px]"></div>

            <!-- Nodes Infographic -->
            <div class="relative w-full h-full max-w-[400px] max-h-[400px] flex items-center justify-center">
                <!-- Center Node -->
                <div class="absolute z-20 w-32 h-32 bg-brand-primary rounded-full flex items-center justify-center shadow-lg border-4 border-white">
                    <span class="text-white font-bold text-lg text-center leading-tight">TheEduAssist</span>
                </div>

                <!-- Connectors (SVG) -->
                <svg class="absolute inset-0 w-full h-full z-0 text-brand-border" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" class="opacity-50">
                        <line x1="200" y1="200" x2="200" y2="40" />
                        <line x1="200" y1="200" x2="325" y2="100" />
                        <line x1="200" y1="200" x2="355" y2="245" />
                        <line x1="200" y1="200" x2="265" y2="345" />
                        <line x1="200" y1="200" x2="135" y2="345" />
                        <line x1="200" y1="200" x2="45" y2="245" />
                        <line x1="200" y1="200" x2="75" y2="100" />
                    </g>
                </svg>

                <!-- Orbiting Nodes -->
                {[
                    { label: "Strategy", angle: -90 },
                    { label: "Curriculum", angle: -38.5 },
                    { label: "Content", angle: 13 },
                    { label: "Platform", angle: 64.5 },
                    { label: "Automation", angle: 116 },
                    { label: "Launch", angle: 167.5 },
                    { label: "Support", angle: 219 }
                ].map((node, i) => {
                    // Calculate positions (radius = 160)
                    const r = 160;
                    const rad = node.angle * (Math.PI / 180);
                    const x = Math.cos(rad) * r;
                    const y = Math.sin(rad) * r;
                    return (
                        <div
                            class="absolute z-10 w-24 h-24 bg-white rounded-full flex flex-col items-center justify-center shadow-md border-2 border-brand-accent/30 transition-transform duration-300 hover:scale-105 hover:border-brand-accent/30"
                            style={`transform: translate(${x}px, ${y}px);`}
                        >
                            <span class="text-brand-primary font-semibold text-xs text-center">{node.label}</span>
                        </div>
                    );
                })}
            </div>
        </div>
      </div>
    </div>
  </div>
</section>
